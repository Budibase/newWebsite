---
import bbSymbol from "@assets/BBSymbol.svg";
import bbSymbolWhite from "@assets/BBSymbolWhite.svg";
import { Image } from "astro:assets";
import Button from "@components/Button.astro";
import HeaderDropDown from "@components/HeaderDropDown.astro";

const platformItems = [
  {
    href: "/platform/agents",
    label: "Agents",
    description: "Build agents that plan, act, and work",
  },
  {
    href: "/platform/chat",
    label: "Chat",
    description: "Deploy AI chat for your users",
  },
  {
    href: "/platform/automations",
    label: "Automations",
    description: "Automate and orchestrate workflows",
  },
  {
    href: "/platform/apps",
    label: "Apps",
    description: "Ship internal tools faster",
  },
  {
    href: "/platform/resources",
    label: "Resources",
    description: "Connect your models, data, & tools",
  },
  {
    href: "/platform/enterprise",
    label: "Enterprise",
    description: "Security and control features for Enterprises",
  },
  {
    href: "https://github.com/orgs/Budibase/projects/15/views/11",
    label: "Roadmap",
    description: "Get a glimpse of what's coming up",
    target: "_blank",
  },
];

const resourcesItems = [
  {
    href: "/docs",
    label: "Docs",
    description: "Documentation and guides",
  },
  {
    href: "/tutorials",
    label: "Tutorials",
    description: "Step-by-step learning resources",
  },
  {
    href: "/blog",
    label: "Blog",
    description: "Latest news and updates",
  },
  {
    href: "/changelog",
    label: "Changelog",
    description: "Product updates and releases",
  },
  {
    href: "/company",
    label: "Company",
    description: "About us and our mission",
  },
];
---

<nav
  class="sticky top-0 z-50 bg-primary backdrop-blur-md flex flex-row justify-between items-center container max-w-7xl px-2 lg:px-0 py-3 gap-3 md:gap-0 mx-auto transition-colors duration-150"
>
  <div class="flex items-center gap-3 md:gap-5">
    <a href="/">
      <div class="w-6 mr-2 relative">
        <Image
          src={bbSymbol}
          alt="Budibase symbol"
          class="hover:cursor-pointer dark:hidden"
        />
        <Image
          src={bbSymbolWhite}
          alt="Budibase symbol"
          class="hover:cursor-pointer hidden dark:block"
        />
      </div>
    </a>
    <div class="hidden md:block">
      <HeaderDropDown
        label="Platform"
        items={platformItems}
      />
    </div>
    <a
      target="_blank"
      href="https://discord.com/invite/budibase-733030666647765003"
      class="hidden md:inline-block text-sm px-1 text-stone-800 dark:text-stone-400 hover:text-stone-600 dark:hover:text-stone-100 transition-colors"
    >
      Community
    </a>
    <a
      target="_self"
      href="/pricing"
      class="hidden md:inline-block text-sm px-1 text-stone-800 dark:text-stone-400 hover:text-stone-600 dark:hover:text-stone-100 transition-colors"
      data-astro-prefetch
    >
      Pricing
    </a>
    <div class="hidden md:block">
      <HeaderDropDown
        label="Resources"
        items={resourcesItems}
      />
    </div>
  </div>
  <div class="flex flex-row gap-2 md:gap-3 items-center w-full md:w-auto justify-end">
    <a
      href="https://github.com/budibase/budibase"
      target="_blank"
      class="relative justify-center items-center px-1.5 text-center ease-out duration-150 rounded-sm outline-none transition-all hover:bg-stone-200 dark:hover:bg-stone-800 border-transparent text-xs hidden lg:flex"
      ><span class="truncate"
        ><span
          class="flex text-sm items-center gap-0.5 text-stone-700 hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100"
          ><svg
            class="w-5 h-5"
            viewBox="0 0 17 16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            ><path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M8.5 2.22168C5.23312 2.22168 2.58496 4.87398 2.58496 8.14677C2.58496 10.7642 4.27962 12.9853 6.63026 13.7684C6.92601 13.8228 7.03366 13.6401 7.03366 13.4827C7.03366 13.3425 7.02893 12.9693 7.02597 12.4754C5.38041 12.8333 5.0332 11.681 5.0332 11.681C4.76465 10.996 4.37663 10.8139 4.37663 10.8139C3.83954 10.4471 4.41744 10.4542 4.41744 10.4542C5.01072 10.4956 5.32303 11.0647 5.32303 11.0647C5.85065 11.9697 6.70774 11.7082 7.04431 11.5568C7.09873 11.1741 7.25134 10.9132 7.42051 10.7654C6.10737 10.6157 4.72621 10.107 4.72621 7.83683C4.72621 7.19031 4.95689 6.66092 5.33486 6.24686C5.27394 6.09721 5.07105 5.49447 5.39283 4.67938C5.39283 4.67938 5.88969 4.51967 7.01947 5.28626C7.502 5.15466 7.99985 5.08763 8.5 5.08692C9.00278 5.08929 9.50851 5.15495 9.98113 5.28626C11.1103 4.51967 11.606 4.67879 11.606 4.67879C11.9289 5.49447 11.7255 6.09721 11.6651 6.24686C12.0437 6.66092 12.2732 7.19031 12.2732 7.83683C12.2732 10.1129 10.8897 10.6139 9.5724 10.7606C9.78475 10.9434 9.97344 11.3048 9.97344 11.8579C9.97344 12.6493 9.96634 13.2887 9.96634 13.4827C9.96634 13.6413 10.0728 13.8258 10.3733 13.7678C11.5512 13.3728 12.5751 12.6175 13.3003 11.6089C14.0256 10.6002 14.4155 9.38912 14.415 8.14677C14.415 4.87398 11.7663 2.22168 8.5 2.22168Z"
              fill="currentColor"></path>
          </svg>27.3K</span
        ></span
      ></a
    >
    <Button label="Sign in" url="/" variant="secondary" size="small" />
    <Button label="Get Budibase free" url="/" variant="primary" size="small" />
    <button
      id="mobile-menu-button"
      class="md:hidden p-2 text-stone-800 dark:text-stone-200 hover:bg-stone-200 dark:hover:bg-stone-800 rounded transition-colors"
      aria-label="Toggle mobile menu"
      aria-expanded="false"
    >
      <svg
        id="menu-icon"
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"
        ></path>
      </svg>
      <svg
        id="close-icon"
        class="w-6 h-6 hidden"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"
        ></path>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 bg-stone-50 dark:bg-stone-950 hidden md:hidden"
  aria-hidden="true"
>
  <!-- Main Menu View -->
  <div id="main-menu-view" class="h-full flex flex-col relative">
    <!-- Header with close button -->
    <div class="flex justify-end p-4">
      <button
        id="close-menu-button"
        class="p-2 text-stone-800 dark:text-stone-200 hover:bg-stone-100 dark:hover:bg-stone-800 rounded transition-colors"
        aria-label="Close menu"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"
          ></path>
        </svg>
      </button>
    </div>

    <!-- Navigation Items -->
    <nav class="flex-1 px-4 pt-8">
      <ul class="space-y-6 flex flex-col gap-4">
        <li>
          <button
            id="product-button"
            class="block text-stone-900 dark:text-stone-300 text-3xl hover:text-stone-600 dark:hover:text-stone-300 transition-colors w-full text-left"
          >
            Product
          </button>
        </li>
        <li>
          <a
            href="https://discord.com/invite/budibase-733030666647765003"
            target="_blank"
            class="block text-stone-900 dark:text-stone-300 text-3xl hover:text-stone-600 dark:hover:text-stone-300 transition-colors"
          >
            Community
          </a>
        </li>
        <li>
          <a
            href="/pricing"
            class="block text-stone-900 dark:text-stone-300 text-3xl hover:text-stone-600 dark:hover:text-stone-300 transition-colors"
            data-astro-prefetch
          >
            Pricing
          </a>
        </li>
        <li>
          <button
            id="resources-button"
            class="block text-stone-900 dark:text-stone-300 text-3xl hover:text-stone-600 dark:hover:text-stone-300 transition-colors w-full text-left"
          >
            Resources
          </button>
        </li>
      </ul>
    </nav>

  </div>

  <!-- Product Submenu View -->
  <div id="product-menu-view" class="h-full hidden">
    <!-- Header with back button and close button -->
    <div class="flex justify-between items-center p-4">
      <button
        id="back-product-button"
        class="p-2 text-stone-800 dark:text-stone-300 hover:bg-stone-100 dark:hover:bg-stone-800 rounded transition-colors"
        aria-label="Back to main menu"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"
          ></path>
        </svg>
      </button>
      <button
        id="close-product-button"
        class="p-2 text-stone-800 dark:text-stone-300 hover:bg-stone-100 dark:hover:bg-stone-800 rounded transition-colors"
        aria-label="Close menu"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"
          ></path>
        </svg>
      </button>
    </div>

    <!-- Product Section Title -->
    <div class="px-4 pt-2">
      <p class="text-stone-500 dark:text-stone-500! text-base tracking-wide">Product</p>
    </div>

    <!-- Product Items -->
    <nav class="flex-1 px-4 pt-2">
      <ul class="space-y-4 flex flex-col gap-4">
        {platformItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="block text-stone-900 dark:text-stone-300 text-3xl hover:text-stone-600 dark:hover:text-stone-300 transition-colors"
              data-astro-prefetch
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <!-- Resources Submenu View -->
  <div id="resources-menu-view" class="h-full hidden">
    <!-- Header with back button and close button -->
    <div class="flex justify-between items-center p-4">
      <button
        id="back-button"
        class="p-2 text-stone-800 dark:text-stone-300 hover:bg-stone-100 dark:hover:bg-stone-800 rounded transition-colors"
        aria-label="Back to main menu"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"
          ></path>
        </svg>
      </button>
      <button
        id="close-resources-button"
        class="p-2 text-stone-800 dark:text-stone-300 hover:bg-stone-100 dark:hover:bg-stone-800 rounded transition-colors"
        aria-label="Close menu"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"
          ></path>
        </svg>
      </button>
    </div>

    <!-- Resources Section Title -->
    <div class="px-4 pt-2">
      <p class="text-stone-500 dark:text-stone-500! text-base tracking-wide">Resources</p>
    </div>

    <!-- Resources Items -->
    <nav class="flex-1 px-4 pt-2">
      <ul class="space-y-4 flex flex-col gap-4">
        {resourcesItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="block text-stone-900 dark:text-stone-300 text-3xl hover:text-stone-600 dark:hover:text-stone-300 transition-colors"
              data-astro-prefetch
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</div>

<style>

  #mobile-menu {
    transition: opacity 0.2s ease-in-out, visibility 0.2s ease-in-out;
  }

  #mobile-menu.hidden {
    opacity: 0;
    visibility: hidden;
  }

  #mobile-menu:not(.hidden) {
    opacity: 1;
    visibility: visible;
  }

  #main-menu-view {
    transition: transform 0.3s ease-in-out;
  }

  #product-menu-view {
    position: absolute;
    inset: 0;
    transition: transform 0.3s ease-in-out;
    background: inherit;
    display: flex;
    flex-direction: column;
  }

  #product-menu-view.hidden {
    transform: translateX(100%);
    display: none;
  }

  #product-menu-view:not(.hidden) {
    transform: translateX(0);
  }

  #resources-menu-view {
    position: absolute;
    inset: 0;
    transition: transform 0.3s ease-in-out;
    background: inherit;
    display: flex;
    flex-direction: column;
  }

  #resources-menu-view.hidden {
    transform: translateX(100%);
    display: none;
  }

  #resources-menu-view:not(.hidden) {
    transform: translateX(0);
  }
</style>

<script>
  (function () {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const closeMenuButton = document.getElementById('close-menu-button');
    const closeResourcesButton = document.getElementById('close-resources-button');
    const closeProductButton = document.getElementById('close-product-button');
    const resourcesButton = document.getElementById('resources-button');
    const productButton = document.getElementById('product-button');
    const backButton = document.getElementById('back-button');
    const backProductButton = document.getElementById('back-product-button');
    const mainMenuView = document.getElementById('main-menu-view');
    const resourcesMenuView = document.getElementById('resources-menu-view');
    const productMenuView = document.getElementById('product-menu-view');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    function openMenu() {
      mobileMenu?.classList.remove('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'true');
      menuIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      mobileMenu?.classList.add('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'false');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      document.body.style.overflow = '';
      // Reset to main menu view
      mainMenuView?.classList.remove('hidden');
      resourcesMenuView?.classList.add('hidden');
      productMenuView?.classList.add('hidden');
    }

    function showResourcesMenu() {
      mainMenuView?.classList.add('hidden');
      resourcesMenuView?.classList.remove('hidden');
      productMenuView?.classList.add('hidden');
    }

    function showProductMenu() {
      mainMenuView?.classList.add('hidden');
      productMenuView?.classList.remove('hidden');
      resourcesMenuView?.classList.add('hidden');
    }

    function showMainMenu() {
      mainMenuView?.classList.remove('hidden');
      resourcesMenuView?.classList.add('hidden');
      productMenuView?.classList.add('hidden');
    }

    mobileMenuButton?.addEventListener('click', openMenu);
    closeMenuButton?.addEventListener('click', closeMenu);
    closeResourcesButton?.addEventListener('click', closeMenu);
    closeProductButton?.addEventListener('click', closeMenu);
    resourcesButton?.addEventListener('click', showResourcesMenu);
    productButton?.addEventListener('click', showProductMenu);
    backButton?.addEventListener('click', showMainMenu);
    backProductButton?.addEventListener('click', showMainMenu);

    // Close menu when clicking outside (on the overlay background)
    mobileMenu?.addEventListener('click', (e) => {
      if (e.target === mobileMenu) {
        closeMenu();
      }
    });

    // Close menu on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu?.classList.contains('hidden')) {
        closeMenu();
      }
    });
  })();
</script>
