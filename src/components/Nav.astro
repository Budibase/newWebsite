---
import budibaseLogoBlack from "@assets/BudibaseLogoBlack.svg";
import budibaseLogoWhite from "@assets/BudibaseLogoWhite.svg";
import { Image } from "astro:assets";
import Button from "@components/Button.astro";
import HeaderDropDown from "@components/HeaderDropDown.astro";
import {
  productDropdownItems,
  resourcesDropdownItems,
} from "@components/navDropdownData";
---

<nav
  id="site-nav"
  class="nav-shell sticky top-0 z-50 w-full bg-1 transition-colors duration-150"
  transition:persist
  transition:name="site-chrome"
>
  <div
    class="relative z-10 mx-auto grid h-[var(--site-nav-height)] w-full max-w-7xl grid-cols-[1fr_auto_auto] items-center px-2 md:px-3 lg:grid-cols-[auto_1fr_auto] lg:gap-6 lg:px-0"
  >
    <a href="/" aria-label="Budibase home" class="z-10 shrink-0 flex items-center">
      <div class="relative w-[120px] flex items-center">
        <Image
          src={budibaseLogoBlack}
          alt="Budibase logo"
          class="block hover:cursor-pointer dark:hidden"
        />
        <Image
          src={budibaseLogoWhite}
          alt="Budibase logo"
          class="block hover:cursor-pointer hidden dark:block"
        />
      </div>
    </a>

    <div
      class="z-10 flex items-center gap-2 justify-self-end lg:col-start-3 lg:gap-3"
    >
      <div class="hidden items-center gap-5 whitespace-nowrap lg:flex xl:gap-7">
        <HeaderDropDown label="Product" items={productDropdownItems} />
        <a
          target="_self"
          href="/ops"
          class="text-sm nav-link transition-colors"
          data-astro-prefetch
        >
          Ops
        </a>
        <a
          target="_self"
          href="/pricing"
          class="text-sm nav-link transition-colors"
          data-astro-prefetch
        >
          Pricing
        </a>
        <a
          target="_self"
          href="/blog"
          class="text-sm nav-link transition-colors"
          data-astro-prefetch
        >
          Blog
        </a>
        <a
          href="https://docs.budibase.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm nav-link transition-colors"
        >
          Docs
        </a>
      </div>

      <a
        href="https://discord.com/invite/budibase-733030666647765003"
        target="_blank"
        class="relative justify-center items-center px-1.5 text-center ease-out duration-150 rounded-sm transition-all hover:bg-stone-200 dark:hover:bg-stone-800 border-transparent text-xs hidden xl:flex focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-stone-900"
        ><span class="truncate"
          ><span
            class="flex text-sm items-center gap-0.5 nav-link transition-colors"
            >Community</span
          ></span
        ></a
      >
      <a
        href="https://github.com/budibase/budibase"
        target="_blank"
        class="relative justify-center items-center px-1.5 text-center ease-out duration-150 rounded-sm transition-all hover:bg-stone-200 dark:hover:bg-stone-800 border-transparent text-xs hidden xl:flex focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-stone-900"
        ><span class="truncate"
          ><span
            class="flex text-sm items-center gap-0.5 nav-link transition-colors"
            ><svg
              class="w-5 h-5"
              viewBox="0 0 17 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M8.5 2.22168C5.23312 2.22168 2.58496 4.87398 2.58496 8.14677C2.58496 10.7642 4.27962 12.9853 6.63026 13.7684C6.92601 13.8228 7.03366 13.6401 7.03366 13.4827C7.03366 13.3425 7.02893 12.9693 7.02597 12.4754C5.38041 12.8333 5.0332 11.681 5.0332 11.681C4.76465 10.996 4.37663 10.8139 4.37663 10.8139C3.83954 10.4471 4.41744 10.4542 4.41744 10.4542C5.01072 10.4956 5.32303 11.0647 5.32303 11.0647C5.85065 11.9697 6.70774 11.7082 7.04431 11.5568C7.09873 11.1741 7.25134 10.9132 7.42051 10.7654C6.10737 10.6157 4.72621 10.107 4.72621 7.83683C4.72621 7.19031 4.95689 6.66092 5.33486 6.24686C5.27394 6.09721 5.07105 5.49447 5.39283 4.67938C5.39283 4.67938 5.88969 4.51967 7.01947 5.28626C7.502 5.15466 7.99985 5.08763 8.5 5.08692C9.00278 5.08929 9.50851 5.15495 9.98113 5.28626C11.1103 4.51967 11.606 4.67879 11.606 4.67879C11.9289 5.49447 11.7255 6.09721 11.6651 6.24686C12.0437 6.66092 12.2732 7.19031 12.2732 7.83683C12.2732 10.1129 10.8897 10.6139 9.5724 10.7606C9.78475 10.9434 9.97344 11.3048 9.97344 11.8579C9.97344 12.6493 9.96634 13.2887 9.96634 13.4827C9.96634 13.6413 10.0728 13.8258 10.3733 13.7678C11.5512 13.3728 12.5751 12.6175 13.3003 11.6089C14.0256 10.6002 14.4155 9.38912 14.415 8.14677C14.415 4.87398 11.7663 2.22168 8.5 2.22168Z"
                fill="currentColor"></path>
            </svg>27.5K</span
          ></span
        ></a
      >

      <div class="hidden lg:flex items-center gap-2 lg:gap-3">
        <Button label="Log in" url="/" variant="secondary" size="small" />
        <Button
          label="Try it free"
          url="https://account.budibase.app/register"
          variant="primary"
          size="small"
          target="_blank"
        />
      </div>

      <button
        id="mobile-menu-button"
        class="lg:hidden p-2 text-stone-800 dark:text-stone-200 hover:bg-stone-200 dark:hover:bg-stone-800 rounded transition-colors"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg
          id="menu-icon"
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="close-icon"
          class="w-6 h-6 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>
</nav>

<div
  id="mobile-menu"
  class="fixed inset-0 z-50 bg-stone-50 dark:bg-stone-950 hidden lg:hidden"
  aria-hidden="true"
>
  <div id="main-menu-view" class="h-full flex flex-col relative">
    <div class="flex justify-end p-4">
      <button
        id="close-menu-button"
        class="p-2 text-stone-800 dark:text-stone-200 hover:bg-stone-100 dark:hover:bg-stone-800 rounded transition-colors"
        aria-label="Close menu"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <nav class="flex-1 px-4 pt-8">
      <ul class="space-y-6 flex flex-col gap-4">
        <li>
          <details class="mobile-nav-accordion" data-mobile-nav-accordion>
            <summary class="mobile-nav-accordion-summary">
              <span class="text-3xl nav-link transition-colors">Product</span>
              <svg
                class="mobile-nav-accordion-caret"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6 9l6 6 6-6"
                ></path>
              </svg>
            </summary>
            <ul class="mt-3 flex flex-col gap-2">
              {
                productDropdownItems.map(({ href, label, prefetch, badge, target, rel, disabled }) => (
                  <li>
                    {disabled ? (
                      <span
                        aria-disabled="true"
                        class="mobile-nav-sub-link mobile-nav-sub-link-disabled"
                      >
                        <span>{label}</span>
                        {badge && (
                          <span class="text-sm leading-none font-mono text-[var(--text-secondary)]">
                            {badge}
                          </span>
                        )}
                      </span>
                    ) : (
                      <a
                        href={href}
                        target={target}
                        rel={rel ??
                          (target === "_blank"
                            ? "noopener noreferrer"
                            : undefined)}
                        data-astro-prefetch={prefetch ? "" : undefined}
                        class="mobile-nav-sub-link nav-link transition-colors"
                      >
                        <span>{label}</span>
                        {badge && (
                          <span class="text-sm leading-none font-mono text-[var(--text-secondary)]">
                            {badge}
                          </span>
                        )}
                      </a>
                    )}
                  </li>
                ))
              }
            </ul>
          </details>
        </li>
        <li>
          <a
            href="/ops"
            class="block text-3xl nav-link transition-colors"
            data-astro-prefetch
          >
            Ops
          </a>
        </li>
        <li>
          <a
            href="https://discord.com/invite/budibase-733030666647765003"
            target="_blank"
            class="block text-3xl nav-link transition-colors"
          >
            Community
          </a>
        </li>
        <li>
          <a
            href="/pricing"
            class="block text-3xl nav-link transition-colors"
            data-astro-prefetch
          >
            Pricing
          </a>
        </li>
        <li>
          <details class="mobile-nav-accordion" data-mobile-nav-accordion>
            <summary class="mobile-nav-accordion-summary">
              <span class="text-3xl nav-link transition-colors">Resources</span>
              <svg
                class="mobile-nav-accordion-caret"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6 9l6 6 6-6"
                ></path>
              </svg>
            </summary>
            <ul class="mt-3 flex flex-col gap-2">
              {
                resourcesDropdownItems.map(({ href, label, prefetch, badge, target, rel, disabled }) => (
                  <li>
                    {disabled ? (
                      <span
                        aria-disabled="true"
                        class="mobile-nav-sub-link mobile-nav-sub-link-disabled"
                      >
                        <span>{label}</span>
                        {badge && (
                          <span class="text-sm leading-none font-mono text-[var(--text-secondary)]">
                            {badge}
                          </span>
                        )}
                      </span>
                    ) : (
                      <a
                        href={href}
                        target={target}
                        rel={rel ??
                          (target === "_blank"
                            ? "noopener noreferrer"
                            : undefined)}
                        data-astro-prefetch={prefetch ? "" : undefined}
                        class="mobile-nav-sub-link nav-link transition-colors"
                      >
                        <span>{label}</span>
                        {badge && (
                          <span class="text-sm leading-none font-mono text-[var(--text-secondary)]">
                            {badge}
                          </span>
                        )}
                      </a>
                    )}
                  </li>
                ))
              }
            </ul>
          </details>
        </li>
      </ul>
    </nav>
  </div>
</div>

<style>
  #mobile-menu {
    transition:
      opacity 0.2s ease-in-out,
      visibility 0.2s ease-in-out;
  }

  #mobile-menu.hidden {
    opacity: 0;
    visibility: hidden;
  }

  #mobile-menu:not(.hidden) {
    opacity: 1;
    visibility: visible;
  }

  #main-menu-view {
    transition: transform 0.3s ease-in-out;
  }

  .mobile-nav-accordion {
    border-bottom: 0.5px solid rgb(var(--text) / 0.12);
    padding-bottom: 1rem;
  }

  .mobile-nav-accordion-summary {
    display: flex;
    list-style: none;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    cursor: pointer;
    outline: none;
  }

  .mobile-nav-accordion-summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav-accordion-summary:focus-visible {
    border-radius: 0.375rem;
    box-shadow: 0 0 0 2px rgb(var(--text) / 0.2);
  }

  .mobile-nav-accordion-caret {
    height: 1.5rem;
    width: 1.5rem;
    color: var(--text-primary);
    transition: transform 0.2s ease-in-out;
  }

  .mobile-nav-accordion[open] .mobile-nav-accordion-caret {
    transform: rotate(180deg);
  }

  .mobile-nav-sub-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-left: 0.25rem;
    font-size: 1.5rem;
    line-height: 1.2;
  }

  .mobile-nav-sub-link-disabled {
    color: var(--text-secondary);
    cursor: not-allowed;
  }

  .nav-link {
    color: var(--text-primary);
    font-weight: 500;
  }

  .nav-link:hover {
    color: var(--text-primary) !important;
  }

  .nav-shell :global(header-drop-down summary),
  .nav-shell :global(header-drop-down summary a) {
    color: var(--text-primary) !important;
    font-weight: 500;
  }

  .nav-shell :global(header-drop-down summary:hover),
  .nav-shell :global(header-drop-down summary:focus-visible),
  .nav-shell :global(header-drop-down summary a:hover),
  .nav-shell :global(header-drop-down summary a:focus-visible) {
    color: var(--text-primary) !important;
  }

  .nav-shell {
    background-color: var(--bg-1) !important;
  }
</style>

<script>
  (function () {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const closeMenuButton = document.getElementById("close-menu-button");
    const mainMenuView = document.getElementById("main-menu-view");
    const menuIcon = document.getElementById("menu-icon");
    const closeIcon = document.getElementById("close-icon");

    function openMenu() {
      mobileMenu?.classList.remove("hidden");
      mobileMenuButton?.setAttribute("aria-expanded", "true");
      menuIcon?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      mobileMenu?.classList.add("hidden");
      mobileMenuButton?.setAttribute("aria-expanded", "false");
      menuIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      document.body.style.overflow = "";
      mainMenuView?.classList.remove("hidden");
      mobileMenu
        ?.querySelectorAll("[data-mobile-nav-accordion][open]")
        .forEach((accordion) => accordion.removeAttribute("open"));
    }

    mobileMenuButton?.addEventListener("click", openMenu);
    closeMenuButton?.addEventListener("click", closeMenu);
    mobileMenu?.addEventListener("click", (e) => {
      if (e.target === mobileMenu) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !mobileMenu?.classList.contains("hidden")) {
        closeMenu();
      }
    });
  })();
</script>
