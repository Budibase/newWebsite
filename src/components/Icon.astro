---
import Wrench from "phosphor-astro/Wrench.astro";
import Monitor from "phosphor-astro/Monitor.astro";
import Sun from "phosphor-astro/Sun.astro";
import Moon from "phosphor-astro/Moon.astro";
import ArrowRight from "phosphor-astro/ArrowRight.astro";
import CaretLeft from "phosphor-astro/CaretLeft.astro";
import CaretDown from "phosphor-astro/CaretDown.astro";
import CaretRight from "phosphor-astro/CaretRight.astro";
import ArrowUpRight from "phosphor-astro/ArrowUpRight.astro";
import PlayCircle from "phosphor-astro/PlayCircle.astro";
import PlayFill from "phosphor-astro/PlayFill.astro";
import Check from "phosphor-astro/Check.astro";
import CheckCircle from "phosphor-astro/CheckCircle.astro";
import CheckCircleFill from "phosphor-astro/CheckCircleFill.astro";
import ChatsCircle from "phosphor-astro/ChatsCircle.astro";
import ChatsCircleFill from "phosphor-astro/ChatsCircleFill.astro";
import Cube from "phosphor-astro/Cube.astro";
import Copy from "phosphor-astro/Copy.astro";
import Headset from "phosphor-astro/Headset.astro";
import HeadsetFill from "phosphor-astro/HeadsetFill.astro";
import Plus from "phosphor-astro/Plus.astro";
import X from "phosphor-astro/X.astro";
import Browser from "phosphor-astro/Browser.astro";
import Path from "phosphor-astro/Path.astro";
import Sparkle from "phosphor-astro/Sparkle.astro";
import ChatCircle from "phosphor-astro/ChatCircle.astro";
import UserSwitch from "phosphor-astro/UserSwitch.astro";
import EnvelopeOpen from "phosphor-astro/EnvelopeOpen.astro";
import BrowserFill from "phosphor-astro/BrowserFill.astro";
import PathFill from "phosphor-astro/PathFill.astro";
import SparkleFill from "phosphor-astro/SparkleFill.astro";
import ChatCircleFill from "phosphor-astro/ChatCircleFill.astro";
import UserSwitchFill from "phosphor-astro/UserSwitchFill.astro";
import EnvelopeOpenFill from "phosphor-astro/EnvelopeOpenFill.astro";
import NumberCircleOne from "phosphor-astro/NumberCircleOne.astro";
import NumberCircleTwo from "phosphor-astro/NumberCircleTwo.astro";
import NumberCircleThree from "phosphor-astro/NumberCircleThree.astro";
import NumberCircleFour from "phosphor-astro/NumberCircleFour.astro";
import NumberCircleFive from "phosphor-astro/NumberCircleFive.astro";
import NumberCircleSix from "phosphor-astro/NumberCircleSix.astro";
import NumberCircleSeven from "phosphor-astro/NumberCircleSeven.astro";
import NumberCircleEight from "phosphor-astro/NumberCircleEight.astro";
import NumberCircleNine from "phosphor-astro/NumberCircleNine.astro";
import NumberCircleOneFill from "phosphor-astro/NumberCircleOneFill.astro";
import NumberCircleTwoFill from "phosphor-astro/NumberCircleTwoFill.astro";
import NumberCircleThreeFill from "phosphor-astro/NumberCircleThreeFill.astro";
import NumberCircleFourFill from "phosphor-astro/NumberCircleFourFill.astro";
import NumberCircleFiveFill from "phosphor-astro/NumberCircleFiveFill.astro";
import NumberCircleSixFill from "phosphor-astro/NumberCircleSixFill.astro";
import NumberCircleSevenFill from "phosphor-astro/NumberCircleSevenFill.astro";
import NumberCircleEightFill from "phosphor-astro/NumberCircleEightFill.astro";
import NumberCircleNineFill from "phosphor-astro/NumberCircleNineFill.astro";

// Add more icon imports as needed

const iconMap: Record<string, any> = {
  Wrench: Wrench,
  Monitor: Monitor,
  Sun: Sun,
  Moon: Moon,
  ArrowRight: ArrowRight,
  CaretLeft: CaretLeft,
  CaretDown: CaretDown,
  CaretRight: CaretRight,
  ArrowUpRight: ArrowUpRight,
  PlayCircle: PlayCircle,
  PlayFill: PlayFill,
  Check: Check,
  CheckCircle: CheckCircle,
  ChatsCircle: ChatsCircle,
  Cube: Cube,
  Copy: Copy,
  Headset: Headset,
  Plus: Plus,
  X: X,
  Browser: Browser,
  Path: Path,
  Sparkle: Sparkle,
  ChatCircle: ChatCircle,
  UserSwitch: UserSwitch,
  EnvelopeOpen: EnvelopeOpen,
  NumberCircleOne: NumberCircleOne,
  NumberCircleTwo: NumberCircleTwo,
  NumberCircleThree: NumberCircleThree,
  NumberCircleFour: NumberCircleFour,
  NumberCircleFive: NumberCircleFive,
  NumberCircleSix: NumberCircleSix,
  NumberCircleSeven: NumberCircleSeven,
  NumberCircleEight: NumberCircleEight,
  NumberCircleNine: NumberCircleNine,
  // Add more icon mappings here as needed
};

const iconFillMap: Record<string, any> = {
  CheckCircle: CheckCircleFill,
  ChatsCircle: ChatsCircleFill,
  Browser: BrowserFill,
  Headset: HeadsetFill,
  Path: PathFill,
  Sparkle: SparkleFill,
  ChatCircle: ChatCircleFill,
  UserSwitch: UserSwitchFill,
  EnvelopeOpen: EnvelopeOpenFill,
  NumberCircleOne: NumberCircleOneFill,
  NumberCircleTwo: NumberCircleTwoFill,
  NumberCircleThree: NumberCircleThreeFill,
  NumberCircleFour: NumberCircleFourFill,
  NumberCircleFive: NumberCircleFiveFill,
  NumberCircleSix: NumberCircleSixFill,
  NumberCircleSeven: NumberCircleSevenFill,
  NumberCircleEight: NumberCircleEightFill,
  NumberCircleNine: NumberCircleNineFill,
};

interface Props {
  name: string;
  size?: string;
  class?: string;
  weight?: string;
}

const isFill = Astro.props.weight === "fill";
const IconComponent =
  (isFill && iconFillMap[Astro.props.name]) || iconMap[Astro.props.name];
---

{
  IconComponent && (
    <IconComponent
      class={Astro.props.class}
      weight={!isFill ? Astro.props.weight : undefined}
      style={
        Astro.props.size
          ? `width: ${Astro.props.size}px; height: ${Astro.props.size}px;`
          : undefined
      }
    />
  )
}
