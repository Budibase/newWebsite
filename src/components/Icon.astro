---
import Wrench from "phosphor-astro/Wrench.astro";
import Monitor from "phosphor-astro/Monitor.astro";
import Sun from "phosphor-astro/Sun.astro";
import Moon from "phosphor-astro/Moon.astro";
import ArrowRight from "phosphor-astro/ArrowRight.astro";
import PlayCircle from "phosphor-astro/PlayCircle.astro";
import PlayFill from "phosphor-astro/PlayFill.astro";

// Add more icon imports as needed

const iconMap: Record<string, any> = {
  Wrench: Wrench,
  Monitor: Monitor,
  Sun: Sun,
  Moon: Moon,
  ArrowRight: ArrowRight,
  PlayCircle: PlayCircle,
  PlayFill: PlayFill,
  // Add more icon mappings here as needed
};

interface Props {
  name: string;
  size?: string;
  class?: string;
}

const IconComponent = iconMap[Astro.props.name];
---

{
  IconComponent && (
    <IconComponent
      class={Astro.props.class}
      style={
        Astro.props.size
          ? `width: ${Astro.props.size}px; height: ${Astro.props.size}px;`
          : undefined
      }
    />
  )
}
