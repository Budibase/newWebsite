---
import birdsBackground from "@assets/images/backgrounds/AgentSpace/birds.png";

interface Props {
  title: string;
  outcome: string;
}

const { title, outcome } = Astro.props as Props;
---

<section
  class="agent-detail-hero relative isolate mb-[1.2rem] flex flex-col items-stretch gap-[0.95rem] overflow-visible p-4 md:gap-[1.1rem] md:px-[1.2rem] md:py-5"
  data-agent-detail-hero
  style="--hero-birds-height: 22rem; --agent-detail-title-offset: max(calc(var(--site-nav-height) + 1.1rem), 4.8rem);"
>
  <div
    class="agent-detail-hero-birds pointer-events-none absolute left-1/2 top-0 z-0 h-[var(--hero-birds-height)] w-screen -translate-x-1/2 bg-[image:var(--agent-detail-hero-birds-image)] bg-cover bg-top bg-no-repeat"
    aria-hidden="true"
    style={`--agent-detail-hero-birds-image: url('${birdsBackground.src}')`}
  >
    <div
      class="absolute inset-0 bg-[linear-gradient(180deg,rgb(var(--bg)_/_0.62)_0%,rgb(var(--bg)_/_0.72)_38%,rgb(var(--bg)_/_0.9)_100%)]"
    ></div>
  </div>

  <div
    class="agent-detail-hero-main relative z-[1] mx-auto mt-[var(--agent-detail-title-offset)] grid max-w-[min(100%,46rem)] justify-items-center gap-[0.8rem] text-center md:mt-[clamp(5.6rem,8vw,7.2rem)]"
  >
    <h1 class="hero-title mb-2 text-[clamp(2rem,1.5rem+2vw,3.4rem)]! sm:!text-[70px] leading-[0.9]!">
      {title}
    </h1>
    <p class="m-0 max-w-[56ch] text-[rgb(var(--text-primary)_/_0.84)]">{outcome}</p>
  </div>
  <div class="agent-detail-hero-prompt relative z-[1] mx-auto flex w-[min(100%,72rem)] items-center justify-center [&>*]:w-full">
    <slot />
  </div>
</section>

<script is:inline>
  (() => {
    const syncHeroBirdsHeight = () => {
      const heroes = Array.from(
        document.querySelectorAll("[data-agent-detail-hero]"),
      );

      heroes.forEach((hero) => {
        if (!(hero instanceof HTMLElement)) return;
        const prompt = hero.querySelector(".agent-detail-hero-prompt");
        if (!(prompt instanceof HTMLElement)) return;

        const heroRect = hero.getBoundingClientRect();
        const promptRect = prompt.getBoundingClientRect();
        const promptOffsetTop = promptRect.top - heroRect.top;
        const targetHeight = Math.round(
          Math.max(0, promptOffsetTop + promptRect.height / 2),
        );

        hero.style.setProperty("--hero-birds-height", `${targetHeight}px`);
      });
    };

    const onReady = () => {
      syncHeroBirdsHeight();
      window.addEventListener("resize", syncHeroBirdsHeight, {
        passive: true,
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", onReady, { once: true });
    } else {
      onReady();
    }

    document.addEventListener("astro:after-swap", () => {
      requestAnimationFrame(syncHeroBirdsHeight);
    });
  })();
</script>
