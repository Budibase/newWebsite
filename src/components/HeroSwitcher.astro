---
import { Image } from "astro:assets";
import Tag from "@components/Tag.astro";

export interface SwitchItem {
  label: string;
  product: ImageMetadata;
  alt?: string;
  icon?: astroHTML.JSX.Element | any;
  tagLabel?: string;
  tagVariant?: string;
}

interface Props {
  id?: string;
  items: SwitchItem[];
  class?: string;
}

const {
  id = `hero-switcher-${Math.random().toString(36).slice(2, 8)}`,
  items,
  class: className,
} = Astro.props as Props;
---

<div id={id} class={`hero-switcher ${className ?? ""}`.trim()}>
  <div class="tabs-row">
    <div class="tabs" role="tablist" aria-label="Product switcher">
      {
        items.map((item, idx) => {
          const tabId = `${id}-tab-${idx}`;
          const baseClasses = [
            "appearance-none",
            "bg-transparent",
            "border-0",
            "px-2",
            "py-1",
            "text-sm",
            "md:text-base",
            "text-muted",
            "border-b",
            "border-transparent",
            "whitespace-nowrap",
            "cursor-pointer",
            "inline-flex",
            "items-center",
            "gap-1.5",
            "transition-colors",
            "duration-150",
            "hover:text",
            "shrink-0",
    "focus-visible:outline-none",
    "focus-visible:ring-2",
    "focus-visible:ring-stone-500",
    "focus-visible:ring-offset-2",
    "focus-visible:ring-offset-white",
            "focus-visible:ring-2",
            "focus-visible:ring-ring",
            "focus-visible:ring-offset-2",
            "focus-visible:ring-offset-bg",
            "rounded-lg",
          ];
          const activeClasses = idx === 0
            ? [
                "is-active",
                "bg-2",
                "text",
              ]
            : [];
          return (
            <button
              id={tabId}
              role="tab"
              aria-selected={idx === 0 ? "true" : "false"}
              aria-controls={`${id}-panel-${idx}`}
              class={[...baseClasses, ...activeClasses].join(" ")}
              data-index={idx}
              data-label={item.label}
              type="button"
              tabindex={idx === 0 ? 0 : -1}
            >
              {item.icon && <item.icon class="w-4 h-4" />}
              <span class="tab-label text-sm">{item.label}</span>
              {item.tagLabel && (
                <Tag
                  label={item.tagLabel}
                  variant={item.tagVariant as any ?? "primary"}
                  size="extra-small"
                  class="ml-1"
                />
              )}
            </button>
          );
        })
      }
    </div>
    <div class="tabs-addon">
      <slot name="addon" />
    </div>
  </div>

  <div class="media" role="region" aria-label="Product preview">
    {
      items.map((item, idx) => (
        <div
          id={`${id}-panel-${idx}`}
          role="tabpanel"
          aria-labelledby={`${id}-tab-${idx}`}
          aria-hidden={idx === 0 ? "false" : "true"}
          class={`product ${idx === 0 ? "is-active" : ""}`.trim()}
          data-index={idx}
          data-label={item.label}
        >
          <Image
            class="product-img"
            src={item.product}
            alt={item.alt ?? `${item.label} screenshot`}
            loading="lazy"
          />
        </div>
      ))
    }
  </div>
</div>

<style>
  .hero-switcher {
    width: 100%;
  }

  .tabs {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    position: relative;
    z-index: 3;
  }

  .tabs-row {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 12px;
  }

  .tabs-addon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .tabs::-webkit-scrollbar {
    display: none;
  }

  .media {
    position: relative;
    width: 100%;
    border-radius: 8px;
    overflow: visible;
    margin-top: 10px;
  }

  .product {
    position: relative;
    display: none;
    align-items: center;
    justify-content: center;
    min-height: 0;
    min-width: 0;
    overflow: visible;
    border-radius: 8px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 150ms ease-out;
    pointer-events: none;
    z-index: 1;
    box-sizing: border-box;
    width: 100%;
  }

  .product.is-active {
    display: flex;
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
  }

  .product-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
    object-fit: contain;
  }

  @media (max-width: 720px) {
    .tabs-row {
      flex-wrap: wrap;
      justify-content: center;
    }

    .tabs {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script define:vars={{ id }}>
  (() => {
    function init(rootId) {
      const root = document.getElementById(rootId);
      if (!root) return;
      const tabs = Array.from(root.querySelectorAll('[role="tab"]'));
      const products = Array.from(root.querySelectorAll('.product'));

      function updateTabClasses(tab, isActive) {
        if (isActive) {
          tab.classList.add('is-active', 'bg-2', 'text-text', 'rounded-lg');
          tab.classList.remove('bg-transparent', 'text-text-muted');
        } else {
          tab.classList.remove('is-active', 'bg-2', 'bg-secondary', 'text-text', 'rounded-lg');
          tab.classList.add('bg-transparent', 'text-text-muted');
        }
      }

      function setActive(index) {
        tabs.forEach((t, i) => {
          const active = i === index;
          t.setAttribute('aria-selected', active ? 'true' : 'false');
          t.setAttribute('tabindex', active ? '0' : '-1');
          t.classList.toggle('is-active', active);
          updateTabClasses(t, active);
        });
        products.forEach((p, i) => {
          const active = i === index;
          p.classList.toggle('is-active', active);
          p.setAttribute('aria-hidden', active ? 'false' : 'true');
        });
      }

      root.__bbSetActive = setActive;

      root.addEventListener('click', (e) => {
        const btn = e.target && e.target.closest ? e.target.closest('button[role="tab"]') : null;
        if (btn && root.contains(btn)) {
          const idx = tabs.indexOf(btn);
          if (idx >= 0) setActive(idx);
        }
      });

      root.addEventListener('keydown', (e) => {
        const activeIdx = tabs.findIndex((t) => t.classList.contains('is-active'));
        if (tabs.length === 0) return;
        if (e.key === 'ArrowRight') {
          e.preventDefault();
          setActive((activeIdx + 1) % tabs.length);
        }
        if (e.key === 'ArrowLeft') {
          e.preventDefault();
          setActive((activeIdx - 1 + tabs.length) % tabs.length);
        }
      });

      setActive(0);
    }

    window.__bbHeroSwitcherSetActive = function (rootId, index) {
      const root = document.getElementById(rootId);
      const setActive = root && root.__bbSetActive;
      if (typeof setActive === 'function') setActive(index);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => init(id));
    } else {
      init(id);
    }
  })();
</script>
