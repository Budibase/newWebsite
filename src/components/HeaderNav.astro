---
import bbSymbol from "../assets/logos/bbSymbol.svg";
import { Image } from "astro:assets";
---

<div
  class="flex flex-col sm:flex-row justify-between items-start sm:items-center pt-6 md:pt-14 px-2 flex-wrap gap-3 sm:gap-2 container max-w-xl mx-auto"
>
  <div class="flex items-center">
    <a href="/" aria-label="Budibase home">
      <div class="w-8 h-8">
        <Image
          src={bbSymbol}
          alt="Budibase symbol"
          class="hover:cursor-pointer"
        />
      </div>
    </a>
  </div>
  <div class="flex flex-col sm:flex-row flex-wrap gap-2 w-full sm:w-auto">
    <div class="flex flex-wrap rounded-full p-1 transition-all gap-1">
      <a target="_self" href="/ops" data-astro-prefetch>
        <div
          class="py-1 pl-2 pr-2 rounded-full transition-all text-sm font-medium bg-transparent text-stone-700"
        >
          Ops
        </div>
      </a>
      <a target="_self" href="/pricing" data-astro-prefetch>
        <div
          class="py-1 pl-2 pr-2 rounded-full transition-all text-sm font-medium bg-transparent text-stone-700"
        >
          Pricing
        </div>
      </a>
      <a target="_self" href="/blog" data-astro-prefetch>
        <div
          class="py-1 pl-2 pr-2 rounded-full transition-all text-sm font-medium bg-transparent text-stone-700"
        >
          Blog
        </div>
      </a>
    </div>
    <div class="flex p-1 gap-2">
      <a target="_self" href="/talk-to-our-team">
        <button class="secondary"> Sign in </button>
      </a>
      <a href="/talk-to-our-team">
        <button class="primary"> Try for free </button>
      </a>
    </div>
  </div>
</div>
