---
import Button from "@components/Button.astro";

---
<div class="gap-4 lg:gap-5 mx-auto px-4 md:px-6 mt-20 md:mt-40 lg:mt-50 grid-cols-1 lg:grid-cols-6 max-w-homepage lg:px-0 lg:mx-auto box-content flex items-center my-0! py-12 md:py-25 lg:py-35">
        <div class="w-full col-span-1 lg:col-span-6 flex flex-col items-center text-center">
                <h2 class="text-2xl md:text-3xl lg:text-5xl! text-primary mb-4 max-w-lg px-2">Ready to talk?</h2>
                <p class="text-stone-700  text-base md:text-lg lg:text-xl! mb-6 md:mb-8! text-center max-w-lg px-2">Save weeks building agents, chat, automations, and apps with your models, your tools and data. </p>
                <Button label="Contact sales" url="/contact/" variant="large" size="large" />
        </div>
</div>
