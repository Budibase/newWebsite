---
import Button from "@components/Button.astro";

---
<div class="gap-4 lg:gap-5 mx-auto px-6 mt-40 lg:mt-50 grid-cols-1 lg:grid-cols-6 max-w-homepage lg:px-[200px] lg:mx-auto box-content flex items-center my-0! py-25 lg:py-35">
        <div class="w-full col-span-1 lg:col-span-6 flex flex-col items-center text-center">
                <h2 class="text-5xl! text-primary mb-4 max-w-lg">Sign up today.</h2>
                <p class="text-stone-700 dark:text-stone-200! text-xl! mb-8! text-center max-w-lg">Save weeks building agents, chat, automations, and apps with your models, your tools and data. </p>
                <Button label="Get Budibase free" url="/" variant="cta" size="large" />
        </div>
</div>
