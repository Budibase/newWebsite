---
import { Image } from "astro:assets";
import TeamsLogo from "@assets/logos/microsoft-teams.svg";
import BambooHrLogo from "@assets/logos/bamboohr.svg";
import ClockFill from "phosphor-astro/ClockFill.astro";
import RowsPlusBottomFill from "phosphor-astro/RowsPlusBottomFill.astro";
import PaperPlaneTiltFill from "phosphor-astro/PaperPlaneTiltFill.astro";
import SparkleFill from "phosphor-astro/SparkleFill.astro";
import CheckCircleFill from "phosphor-astro/CheckCircleFill.astro";
import SectionBlock from "@components/SectionBlock.astro";

interface FrameNode {
  title: string;
  description?: string;
  iconKind: "sparkle" | "clock" | "rowsPlusBottom" | "paperPlaneTilt" | "teams" | "bamboohr";
  iconTone: "trigger" | "agent" | "integration" | "alert";
  badgeLabel?: "Trigger" | "Operation";
  badgeTone?: "trigger" | "operation";
}

interface FrameScenario {
  id: "teams-alert" | "whos-out" | "release-notes" | "offboard";
  nodes: FrameNode[];
}

const id = `automation-trigger-outcome-${Math.random().toString(36).slice(2, 8)}`;

const frames: FrameScenario[] = [
  {
    id: "teams-alert",
    nodes: [
      {
        badgeLabel: "Trigger",
        badgeTone: "trigger",
        title: "Agent trigger",
        description: "This automation is triggered by agents",
        iconKind: "sparkle",
        iconTone: "trigger",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Microsoft Teams",
        description: "Send alert message to #ITOps channel",
        iconKind: "teams",
        iconTone: "integration",
      },
    ],
  },
  {
    id: "whos-out",
    nodes: [
      {
        badgeLabel: "Trigger",
        badgeTone: "trigger",
        title: "Schedule",
        description: "Everyday at 8am",
        iconKind: "clock",
        iconTone: "trigger",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "API connector",
        description: "Check who is on annual leave",
        iconKind: "bamboohr",
        iconTone: "integration",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Broadcast Agent",
        description: "Fetch who is on annual leave and send a message to Slack",
        iconKind: "sparkle",
        iconTone: "agent",
      },
    ],
  },
  {
    id: "release-notes",
    nodes: [
      {
        badgeLabel: "Trigger",
        badgeTone: "trigger",
        title: "Schedule",
        description: "Everyday at 8am",
        iconKind: "clock",
        iconTone: "trigger",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Github Agent",
        description: "Fetch releases",
        iconKind: "sparkle",
        iconTone: "agent",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Broadcast Agent",
        description: "Create release notes and send a message to Slack",
        iconKind: "sparkle",
        iconTone: "agent",
      },
    ],
  },
  {
    id: "offboard",
    nodes: [
      {
        badgeLabel: "Trigger",
        badgeTone: "trigger",
        title: "Submission",
        description: "Offboarding_Table",
        iconKind: "rowsPlusBottom",
        iconTone: "trigger",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Offboard Agent",
        description: "Revoke permissions from Slack, Okta, and Jira",
        iconKind: "sparkle",
        iconTone: "agent",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Alert manager",
        description: "Send confirmation email to manager",
        iconKind: "paperPlaneTilt",
        iconTone: "alert",
      },
    ],
  },
];
---

<section id={id}>
  <div class="grid grid-cols-1 gap-8 lg:grid-cols-[minmax(0,1.02fr)_minmax(0,0.98fr)] lg:items-center lg:gap-20">
    <div>
      <div class="automation-trigger-outcome-canvas rounded-xl px-4 py-5 sm:px-5 sm:py-6">
        <div data-flow-content class="automation-trigger-outcome-flow-content">
          {
            frames.map((frame, frameIndex) => (
              <ul
                class:list={[
                  "automation-trigger-outcome-node-list",
                  frame.id === "teams-alert" && "is-frame-teams-alert",
                  frameIndex === 0 && "is-active",
                ]}
                data-frame-list
                data-frame-id={frame.id}
                data-frame-index={frameIndex}
                aria-hidden={frameIndex === 0 ? "false" : "true"}
              >
                {
                  frame.nodes.map((node) => (
                    <li class="automation-trigger-outcome-node-wrap">
                      {node.badgeLabel && (
                        <span
                          class:list={[
                            "automation-trigger-outcome-node-badge",
                            node.badgeTone === "operation"
                              ? "is-operation"
                              : "is-trigger",
                          ]}
                        >
                          {node.badgeLabel}
                        </span>
                      )}

                      <div class="automation-trigger-outcome-node">
                        <span
                          class:list={[
                            "automation-trigger-outcome-node-icon",
                            `is-${node.iconTone}`,
                          ]}
                          aria-hidden="true"
                        >
                          {node.iconKind === "sparkle" && <SparkleFill class="h-[18px] w-[18px]" />}
                          {node.iconKind === "clock" && <ClockFill class="h-[18px] w-[18px]" />}
                          {node.iconKind === "rowsPlusBottom" && (
                            <RowsPlusBottomFill class="h-[18px] w-[18px]" />
                          )}
                          {node.iconKind === "paperPlaneTilt" && (
                            <PaperPlaneTiltFill class="h-[18px] w-[18px]" />
                          )}
                          {node.iconKind === "teams" && (
                            <Image src={TeamsLogo} alt="Microsoft Teams" class="h-[18px] w-[18px]" />
                          )}
                          {node.iconKind === "bamboohr" && (
                            <Image src={BambooHrLogo} alt="BambooHR" class="h-[18px] w-[18px]" />
                          )}
                        </span>

                        <div class="automation-trigger-outcome-node-copy">
                          <div class="automation-trigger-outcome-node-title">{node.title}</div>
                          {node.description && <p class="automation-trigger-outcome-node-description">{node.description}</p>}
                        </div>
                      </div>
                    </li>
                  ))
                }
              </ul>
            ))
          }
        </div>
      </div>
    </div>

    <SectionBlock
      titleColorMode="split-secondary-primary"
      titleLines={[
        { text: "More powerful triggers." },
        { text: "More agent-driven execution." },
      ]}
      description="Automations can start from agents, schedules, emails, apps, or data changes - then orchestrate decisions and system actions automatically across your business."
      maxWidth="xl"
      spacing="default"
      contentClass="pt-1"
    >
      <div class="flex flex-col gap-[var(--section-gap-sm)]">
        <h3 class="m-0 !text-lg text-[var(--text-primary)]">With Budibase, you can:</h3>
        <ul class="flex flex-col gap-4">
          <li class="flex items-start gap-3">
            <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
            <div class="space-y-1.5">
              <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
                Trigger workflows from agents and real operational events
              </div>
              <p class="m-0 text-[14px] leading-6 text-[var(--text-secondary)]">
                Agents, schedules, emails, data updates, and webhooks can all start a controlled workflow.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
            <div class="space-y-1.5">
              <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
                Execute real system actions with full control
              </div>
              <p class="m-0 text-[14px] leading-6 text-[var(--text-secondary)]">
                Combine Agent steps, API requests, database updates, email notifications, and logic - with logs, testing,
                and full data visibility.
              </p>
            </div>
          </li>
        </ul>
      </div>
    </SectionBlock>
  </div>
</section>

<style>
  .automation-trigger-outcome-canvas {
    --automation-trigger-outcome-grid-dot: rgb(var(--border) / 0.45);
    --automation-trigger-outcome-connector: rgb(var(--ring) / 0.72);
    --automation-trigger-outcome-node-bg: var(--bg-3);
    --automation-trigger-outcome-node-integration-bg: var(--bb-gray-800);
    --automation-trigger-outcome-trigger-bg: var(--bb-orange-700);
    --automation-trigger-outcome-operation-bg: var(--bb-purple-800);
    --automation-trigger-outcome-agent-bg: var(--bb-blue-800);
    --automation-trigger-outcome-node-title: var(--text-primary);
    --automation-trigger-outcome-node-description: var(--text-secondary);
    --automation-trigger-outcome-node-icon-fg: var(--bb-white);
    --automation-trigger-outcome-badge-fg: rgb(var(--text));
    background:
      radial-gradient(circle at center, var(--automation-trigger-outcome-grid-dot) 1px, transparent 1px) 0 0 / 20px
        20px,
      var(--bg-2);
  }

  .automation-trigger-outcome-flow-content {
    position: relative;
    width: 100%;
    max-width: 380px;
    height: 512px;
    margin: 0 auto;
    transition:
      opacity 180ms ease,
      transform 220ms ease;
  }

  .automation-trigger-outcome-flow-content.is-swapping {
    opacity: 0;
    transform: translateY(5px);
  }

  .automation-trigger-outcome-node-list {
    --node-width: 380px;
    --node-row-gap: 60px;
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--node-row-gap);
    justify-content: center;
    width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .automation-trigger-outcome-node-list.is-frame-teams-alert {
    --node-width: 380px;
  }

  .automation-trigger-outcome-node-list.is-active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .automation-trigger-outcome-node-wrap {
    position: relative;
    width: var(--node-width);
  }

  .automation-trigger-outcome-node-wrap:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 50%;
    top: calc(100% + 8px);
    width: 1px;
    height: calc(var(--node-row-gap) - 16px);
    transform: translateX(-50%);
    background-image: linear-gradient(to bottom, var(--automation-trigger-outcome-connector) 45%, transparent 45%);
    background-size: 1px 8px;
    background-repeat: repeat-y;
    animation: automation-trigger-outcome-march 700ms linear infinite;
  }

  .automation-trigger-outcome-node-badge {
    position: absolute;
    left: 0;
    bottom: calc(100% + 8px);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    color: var(--bb-white);
    padding: 2px 4px;
    font-size: 14px;
    font-weight: 500;
    line-height: 17px;
  }

  .automation-trigger-outcome-node-badge.is-trigger {
    background: var(--automation-trigger-outcome-trigger-bg);
  }

  .automation-trigger-outcome-node-badge.is-operation {
    background: var(--automation-trigger-outcome-operation-bg);
  }

  .automation-trigger-outcome-node {
    position: relative;
    display: flex;
    width: 100%;
    min-height: 48px;
    align-items: flex-start;
    gap: 10px;
    border-radius: 6px;
    border: none;
    background: var(--automation-trigger-outcome-node-bg);
    padding: 8px 12px;
  }

  .automation-trigger-outcome-node-icon {
    display: inline-flex;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    color: var(--automation-trigger-outcome-node-icon-fg);
  }

  .automation-trigger-outcome-node-icon.is-trigger {
    background: var(--automation-trigger-outcome-trigger-bg);
  }

  .automation-trigger-outcome-node-icon.is-agent {
    background: var(--automation-trigger-outcome-agent-bg);
  }

  .automation-trigger-outcome-node-icon.is-integration {
    background: var(--automation-trigger-outcome-node-integration-bg);
  }

  .automation-trigger-outcome-node-icon.is-alert {
    background: var(--automation-trigger-outcome-operation-bg);
  }

  .automation-trigger-outcome-node-copy {
    min-width: 0;
    flex: 1;
  }

  .automation-trigger-outcome-node-title {
    margin: 0;
    color: var(--text-primary);
    font-size: 16px;
    font-weight: 500;
    line-height: 22px;
  }

  .automation-trigger-outcome-node-description {
    margin: 0;
    color: var(--automation-trigger-outcome-node-description);
    font-size: 16px;
    font-weight: 400;
    line-height: 22px;
  }

  @keyframes automation-trigger-outcome-march {
    from {
      background-position-y: 0;
    }
    to {
      background-position-y: 8px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .automation-trigger-outcome-flow-content {
      transition: none;
    }

    .automation-trigger-outcome-node-wrap:not(:last-child)::after {
      animation: none;
    }
  }

  @media (max-width: 767px) {
    .automation-trigger-outcome-canvas {
      padding: 16px;
    }

    .automation-trigger-outcome-flow-content {
      height: 512px;
    }

    .automation-trigger-outcome-node-list {
      width: 100%;
    }

    .automation-trigger-outcome-node-wrap,
    .automation-trigger-outcome-node-list.is-frame-teams-alert .automation-trigger-outcome-node-wrap {
      width: min(100%, var(--node-width));
    }

    .automation-trigger-outcome-node {
      width: 100%;
      min-height: 46px;
    }
  }
</style>

<script define:vars={{ id }}>
  (() => {
    const root = document.getElementById(id);
    if (!root) return;

    const flowContent = root.querySelector("[data-flow-content]");
    const frameLists = Array.from(root.querySelectorAll("[data-frame-list]"));
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    if (frameLists.length === 0) return;

    const FRAME_INTERVAL_MS = 5000;
    const SWAP_DURATION_MS = 180;

    let activeIndex = 0;
    let loopTimer = null;
    let swapTimer = null;

    function setActiveFrame(index) {
      const normalizedIndex = ((index % frameLists.length) + frameLists.length) % frameLists.length;

      frameLists.forEach((frame, frameIndex) => {
        const isActive = frameIndex === normalizedIndex;
        frame.classList.toggle("is-active", isActive);
        frame.setAttribute("aria-hidden", isActive ? "false" : "true");
      });

      activeIndex = normalizedIndex;
    }

    function stopLoop() {
      if (loopTimer) {
        window.clearInterval(loopTimer);
        loopTimer = null;
      }
      if (swapTimer) {
        window.clearTimeout(swapTimer);
        swapTimer = null;
      }
    }

    function swapToFrame(index, options = { animate: true }) {
      const { animate } = options;

      if (!animate || prefersReducedMotion.matches) {
        flowContent?.classList.remove("is-swapping");
        setActiveFrame(index);
        return;
      }

      flowContent?.classList.add("is-swapping");

      if (swapTimer) {
        window.clearTimeout(swapTimer);
      }

      swapTimer = window.setTimeout(() => {
        setActiveFrame(index);
        flowContent?.classList.remove("is-swapping");
      }, SWAP_DURATION_MS);
    }

    function startLoop() {
      stopLoop();
      loopTimer = window.setInterval(() => {
        swapToFrame(activeIndex + 1, { animate: true });
      }, FRAME_INTERVAL_MS);
    }

    function handleMotionChange() {
      if (prefersReducedMotion.matches) {
        stopLoop();
        flowContent?.classList.remove("is-swapping");
        setActiveFrame(0);
        return;
      }

      startLoop();
    }

    if (typeof prefersReducedMotion.addEventListener === "function") {
      prefersReducedMotion.addEventListener("change", handleMotionChange);
    } else if (typeof prefersReducedMotion.addListener === "function") {
      prefersReducedMotion.addListener(handleMotionChange);
    }

    setActiveFrame(0);

    if (!prefersReducedMotion.matches) {
      startLoop();
    }
  })();
</script>
