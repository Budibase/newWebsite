---
import OnePlatformAppBg from "@assets/images/homepage/onePlatform/OnePlatformApp.png?url";
import CaretDownIcon from "@assets/images/demos/app-demo/481b5637386cfa51221252c07d627de130d801d4.svg?url";
---

<div
  class="one-platform-app"
  role="img"
  aria-label="App preview showing a request access form with system, request, and manager fields"
>
  <img
    src={OnePlatformAppBg}
    alt=""
    class="one-platform-app__bg"
    aria-hidden="true"
    loading="lazy"
    decoding="async"
  />
  <div class="one-platform-app__surface" aria-hidden="true">
    <div class="one-platform-app__panel">
      <p class="one-platform-app__title">Request Access Form</p>

      <div class="one-platform-app__fields">
        <label class="one-platform-app__field">
          <span class="one-platform-app__label">System</span>
          <span class="one-platform-app__input one-platform-app__input--select">
            <span>Salesforce</span>
            <img src={CaretDownIcon} alt="" class="one-platform-app__caret" />
          </span>
        </label>

        <label class="one-platform-app__field">
          <span class="one-platform-app__label">Request</span>
          <span
            class="one-platform-app__input one-platform-app__input--textarea"
          >
            Need access for sales reporting
          </span>
        </label>

        <label class="one-platform-app__field">
          <span class="one-platform-app__label">Manager</span>
          <span class="one-platform-app__input one-platform-app__input--select">
            <span>Peter Gibbons</span>
            <img src={CaretDownIcon} alt="" class="one-platform-app__caret" />
          </span>
        </label>

        <div class="one-platform-app__actions">
          <span class="one-platform-app__submit">Submit request</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .one-platform-app {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 40px 0 0 20px;
    display: flex;
    justify-content: flex-end;
    align-items: stretch;
    background: var(--bb-gray-50);
  }

  .one-platform-app::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--bb-background-base) 64%, transparent) 0%,
      color-mix(in srgb, var(--bb-background-base) 34%, transparent) 38%,
      color-mix(in srgb, var(--bb-background-base) 10%, transparent) 100%
    );
  }

  .one-platform-app__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .one-platform-app__surface {
    flex: 1 1 auto;
    min-height: 0;
    background: white;
    padding: 12px;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    position: relative;
    z-index: 2;
  }

  .one-platform-app__panel {
    width: 100%;
  }

  .one-platform-app__title {
    margin: 0;
    color: var(--bb-gray-800) !important;
    font-size: 14px;
    line-height: 20px;
    font-weight: 500;
  }

  .one-platform-app__fields {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    padding-top: 20px;
    padding-bottom: 20px;
  }

  .one-platform-app__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 100%;
  }

  .one-platform-app__label {
    color: var(--bb-gray-700);
    font-size: 13px;
    line-height: 1;
    font-weight: 400;
  }

  .one-platform-app__input {
    width: 100%;
    border: 1px solid var(--bb-gray-100);
    border-radius: 4px;
    background: var(--bb-gray-75);
    color: var(--bb-gray-900);
    font-size: 13px;
    font-weight: 400;
    box-sizing: border-box;
  }

  .one-platform-app__input--select {
    min-height: 38px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 8px 12px;
    line-height: 1;
  }

  .one-platform-app__input--textarea {
    min-height: 64px;
    display: block;
    padding: 8px 12px;
    line-height: 17px;
  }

  .one-platform-app__caret {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    opacity: 0.72;
  }

  .one-platform-app__actions {
    display: flex;
    align-items: center;
    padding-top: 6px;
  }

  .one-platform-app__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    padding: 8px 10px;
    border-radius: 999px;
    background: var(--bb-blue-800);
    color: var(--bb-gray-50);
    font-size: 13px;
    line-height: 1;
    font-weight: 500;
    text-align: center;
  }

  @media (max-width: 420px) {
    .one-platform-app {
      padding-top: 32px;
      padding-left: 14px;
    }
  }
</style>
