---
import type { Page } from 'astro';
import type { HTMLAttributes } from 'astro/types';
import { ensureTrailingSlash } from '../helpers/path.ts';

export type Props = Omit<HTMLAttributes<'nav'>, 'slot'> & {
	page: Page<unknown>;
	allPages: string[];
	restRoute?: boolean;
};

const {
	page,
	allPages,
	restRoute = false,
	'aria-label': ariaLabel = 'Pagination',
	...attrs
} = Astro.props;

---

<nav aria-label={ariaLabel} class="pagination" {...attrs}>
	<div class="pagination-cards">
		{
			page.url.prev && (
				<a
					href={ensureTrailingSlash(page.url.prev)}
					data-astro-prefetch
					data-astro-transition="none"
					class="pagination-card pagination-prev"
				>
					<span class="pagination-kicker">← Previous</span>
					<span class="pagination-title">Newer posts</span>
					<span class="sr-only">
						Go to page {page.currentPage - 1} of {page.lastPage}
					</span>
				</a>
			)
		}
		{
			page.url.next && (
				<a
					href={ensureTrailingSlash(page.url.next)}
					data-astro-prefetch
					data-astro-transition="none"
					class="pagination-card pagination-next"
				>
					<span class="pagination-kicker">Next →</span>
					<span class="pagination-title">Older posts</span>
					<span class="sr-only">
						Go to page {page.currentPage + 1} of {page.lastPage}
					</span>
				</a>
			)
		}
	</div>
</nav>

<style>
	.pagination {
		color: rgb(var(--text));
	}

	.pagination-cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
		width: 100%;
	}

	.pagination-card {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		width: 100%;
		padding: 0.9rem 1rem;
		border-radius: 6px;
		background: rgb(var(--surface));
		border: none;
		text-decoration: none;
		color: inherit;
		transition: transform 120ms ease, background 120ms ease;
	}

	.pagination-card:hover {
		transform: translateY(-1px);
		background: rgb(var(--surface-2));
	}

	.pagination-kicker {
		font-size: 0.85rem;
		color: var(--bb-gray-600);
	}

	.pagination-title {
		font-size: 0.95rem;
		color: rgb(var(--text));
	}

	.pagination-next {
		text-align: right;
		align-items: flex-end;
	}
</style>
