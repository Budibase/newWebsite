---
// Simple anchor link component
// Props:
// - label: string (text content)
// - url: string (href)
// - target?: string (e.g. '_blank')
// - variant?: 'primary' | 'secondary' | 'cta' (default 'primary')
// - size?: 'small' | 'medium' | 'large' (default 'medium')
// - class?: string (extra classes)
// - underline?: boolean (adds underline decoration when true)

type Variant = "primary" | "secondary" | "cta";
type Size = "small" | "medium" | "large";

interface Props {
  label: string;
  url: string;
  target?: string;
  variant?: Variant;
  size?: Size;
  class?: string;
  ariaLabel?: string;
  rel?: string;
  underline?: boolean;
}

const {
  label,
  url,
  target = "_self",
  variant = "primary",
  size = "medium",
  class: className = "",
  ariaLabel,
  rel,
  underline = false,
} = Astro.props as Props;

const sizeClass = size !== "medium" ? size : "";
const variantClass = variant;
const underlineClass = underline ? "underline" : "";

// Build Tailwind classes for variants with dark mode support
const variantColorClasses = {
  primary: "text-stone-900 dark:text-stone-50",
  secondary: "text-stone-500 dark:text-stone-400",
  cta: "text-sky-700 dark:text-sky-200",
};

const hoverColorClasses = {
  primary: "hover:text-stone-700 dark:hover:text-stone-100",
  secondary: "hover:text-stone-700 dark:hover:text-stone-300",
  cta: "hover:text-sky-600 dark:hover:text-sky-100",
};

const classes = [
  "alink",
  sizeClass,
  variantClass,
  underlineClass,
  variantColorClasses[variant],
  hoverColorClasses[variant],
  className,
]
  .filter(Boolean)
  .join(" ");

const computedRel =
  rel ?? (target === "_blank" ? "noopener noreferrer" : undefined);
---

<a
  href={url}
  target={target}
  rel={computedRel}
  class={classes}
  aria-label={ariaLabel}
>
  {label}
  <slot />
  <!-- allow optional icon/content -->
</a>

<style>
  .alink {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    transition: color 150ms ease-out;
  }

  /* Sizes */
  .alink.small {
    font-size: 14px;
  }
  .alink.medium {
    font-size: 16px;
  }
  .alink.large {
    font-size: 18px;
  }

  /* Hover opacity - colors are handled via Tailwind dark mode classes */
  .alink:hover {
    opacity: 0.9;
  }

  /* Underline styling */
  .alink.underline {
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 0.5px;
    text-decoration-color: currentColor;
  }
</style>
