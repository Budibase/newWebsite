---
import CTA from "@components/CTA.astro";
import TitleBlock from "@components/TitleBlock.astro";
import Button from "@components/Button.astro";

interface Props {
  title: string;
  description?: string;
  heroHeader?: boolean;
}

const { title, description = "", heroHeader = false } = Astro.props as Props;
const currentPath = Astro.url.pathname;
const hasHeaderSlot = Astro.slots.has("header");

function normalizePath(path: string): string {
  if (path.length > 1 && path.endsWith("/")) {
    return path.slice(0, -1);
  }
  return path;
}

const normalizedCurrentPath = normalizePath(currentPath);
const isAutomationsPage = normalizedCurrentPath === "/product/automations";
const isAppsPage = normalizedCurrentPath === "/product/apps";
const useHeroHeaderLayout = heroHeader || isAppsPage;
const homepageStylePaths = new Set([
  "/product/agents",
  "/product/automations",
  "/product/apps",
  "/product/data",
  "/product/connections",
  "/product/apis",
]);
const useHomepageHeaderStyles = homepageStylePaths.has(normalizedCurrentPath);
const shouldUseHeroTitle =
  normalizedCurrentPath.startsWith("/product") ||
  normalizedCurrentPath === "/enterprise";
const isProductPage = normalizedCurrentPath.startsWith("/product");
const homepageTitleClass = isAutomationsPage
  ? "hero-title-small mb-2 leading-[0.9]! tracking-[-0.02em]! text-[var(--text-primary)]"
  : "hero-title mb-2 leading-[0.9]! tracking-[-0.02em]! text-[var(--text-primary)]";
const titleClass = useHomepageHeaderStyles
  ? homepageTitleClass
  : isProductPage
    ? "hero-title mb-2"
    : shouldUseHeroTitle
      ? "hero-title mb-2 text-5xl! sm:!text-[70px]"
      : "mb-2 text-5xl!";
const descriptionClass = useHomepageHeaderStyles
  ? "!mb-4 !text-xl text-secondary"
  : "text-stone-500! ";
const descriptionWidthClass = isProductPage ? "mx-auto max-w-xl" : "";
const headerClass = useHeroHeaderLayout
  ? "platform-page-header platform-page-header--hero text-center"
  : isProductPage
    ? "platform-page-header mt-10 text-center md:mt-14 lg:mt-20"
    : "platform-page-header text-center";
const titleWidthClass =
  normalizedCurrentPath === "/product/automations"
    ? "mx-auto w-full max-w-2xl"
    : "";
const showDescription = description.trim().length > 0;
const appsTitleLines = isAppsPage
  ? title
      .split("\n")
      .map((text) => text.trim())
      .filter(Boolean)
      .map((text) => ({ text }))
  : [];
const layoutContainerClass = useHeroHeaderLayout
  ? "mx-auto w-full max-w-[var(--site-container-max)] px-2 pb-12 md:px-3 lg:px-0"
  : "mx-auto w-full max-w-[var(--site-container-max)] space-y-12 px-2 pb-12 pt-6 md:px-3 lg:px-0";
const mainClass = useHeroHeaderLayout
  ? "platform-main platform-main--hero"
  : "platform-main";
---

<div class="platform-layout">
  <div class={layoutContainerClass}>
    <section class={headerClass}>
      {
        hasHeaderSlot ? (
          <slot name="header" />
        ) : (
          <>
            {isAppsPage ? (
              <TitleBlock
                variant="hero"
                title={title}
                titleLines={appsTitleLines.length > 1 ? appsTitleLines : []}
                titleColorMode="split-primary-secondary"
                titleClass="mb-4 w-full leading-[0.9]! tracking-[-0.02em]!"
                containerClass={titleWidthClass}
              />
            ) : (
              <h1 class:list={[titleClass, titleWidthClass]}>{title}</h1>
            )}
            {showDescription && (
              <p class:list={[descriptionClass, descriptionWidthClass]}>
                {description}
              </p>
            )}
            {isAppsPage && (
              <div class="platform-page-header-cta">
                <Button
                  label="Try for free"
                  url="https://account.budibase.app/register"
                  variant="primary"
                  size="large"
                  target="_blank"
                />
                <Button
                  label="Contact sales"
                  url="/contact/"
                  variant="secondary"
                  size="large"
                  class="px-6 py-3 text-xl md:px-7 md:py-3.5 md:text-xl ml-5"
                  target="_blank"
                />
              </div>
            )}
          </>
        )
      }
    </section>
    <main class={mainClass}>
      <slot />
    </main>
    <CTA />
  </div>
</div>

<style>
  .platform-layout {
    width: 100%;
  }

  .platform-page-header {
    margin-bottom: 2rem;
  }

  .platform-page-header--hero {
    background: var(--bg-1);
    margin-bottom: 0;
    padding-top: max(calc(var(--site-nav-height) + 1.2rem), 4.8rem);
    padding-bottom: 3rem;
  }

  .platform-main--hero {
    padding-top: 1.5rem;
  }

  .platform-page-header-cta {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 767px) {
    .platform-page-header--hero {
      padding-bottom: 2rem;
    }
  }

  .platform-main {
    flex: 1;
    min-width: 0;
  }
</style>
