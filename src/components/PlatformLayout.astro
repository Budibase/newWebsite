---
import CTA from "@components/CTA.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "" } = Astro.props as Props;
const currentPath = Astro.url.pathname;

function normalizePath(path: string): string {
  if (path.length > 1 && path.endsWith("/")) {
    return path.slice(0, -1);
  }
  return path;
}

const normalizedCurrentPath = normalizePath(currentPath);
const isAutomationsPage = normalizedCurrentPath === "/product/automations";
const homepageStylePaths = new Set([
  "/product/agents",
  "/product/automations",
  "/product/apps",
  "/product/data",
  "/product/connections",
  "/product/apis",
]);
const useHomepageHeaderStyles = homepageStylePaths.has(normalizedCurrentPath);
const shouldUseHeroTitle =
  normalizedCurrentPath.startsWith("/product") ||
  normalizedCurrentPath === "/enterprise";
const isProductPage = normalizedCurrentPath.startsWith("/product");
const homepageTitleClass = isAutomationsPage
  ? "hero-title-small mb-2 leading-[0.9]! tracking-[-0.02em]! text-[var(--text-primary)]"
  : "hero-title mb-2 leading-[0.9]! tracking-[-0.02em]! text-[var(--text-primary)]";
const titleClass = useHomepageHeaderStyles
  ? homepageTitleClass
  : isProductPage
    ? "hero-title mb-2"
    : shouldUseHeroTitle
      ? "hero-title mb-2 text-5xl!"
    : "mb-2 text-5xl!";
const descriptionClass = useHomepageHeaderStyles
  ? "!mb-4 !text-xl text-secondary"
  : "text-stone-500! dark:text-stone-400!";
const descriptionWidthClass = isProductPage
  ? "mx-auto max-w-sm sm:max-w-md md:max-w-lg lg:max-w-xl"
  : "";
const headerClass = isProductPage
  ? "platform-page-header mt-10 text-center md:mt-14 lg:mt-20"
  : "platform-page-header text-center";
const titleWidthClass =
  normalizedCurrentPath === "/product/automations"
    ? "mx-auto w-full max-w-2xl"
    : "";
const showDescription = description.trim().length > 0;
---

<div class="platform-layout">
  <div
    class="mx-auto w-full max-w-7xl space-y-12 px-2 pb-12 pt-6 md:px-3 lg:px-0"
  >
    <section class={headerClass}>
      <h1 class:list={[titleClass, titleWidthClass]}>{title}</h1>
      {
        showDescription && (
          <p class:list={[descriptionClass, descriptionWidthClass]}>{description}</p>
        )
      }
    </section>
    <main class="platform-main">
      <slot />
    </main>
    <CTA />
  </div>
</div>

<style>
  .platform-layout {
    width: 100%;
  }

  .platform-page-header {
    margin-bottom: 2rem;
  }

  .platform-main {
    flex: 1;
    min-width: 0;
  }
</style>
