---
import CTA from "@components/CTA.astro";

interface NavItem {
  text: string;
  link: string;
  sectionId: string;
  icon?: any;
  pageTitle?: string;
  pageDescription?: string;
}

interface NavGroup {
  header?: string;
  items: NavItem[];
}

interface Props {
  title: string;
  description: string;
  navItems: NavItem[] | NavGroup[];
  mainContentWidth?: "default" | "narrow";
}

const {
  title,
  description,
  navItems,
  mainContentWidth = "default",
} = Astro.props as Props;
const currentPath = Astro.url.pathname;

function normalizePath(path: string): string {
  if (path.length > 1 && path.endsWith("/")) {
    return path.slice(0, -1);
  }
  return path;
}

const normalizedCurrentPath = normalizePath(currentPath);
const isGrouped = navItems.length > 0 && "items" in navItems[0];
const flattenedNavItems = isGrouped
  ? (navItems as NavGroup[]).flatMap((group) => group.items)
  : (navItems as NavItem[]);
const activeNavItem = flattenedNavItems.find(
  (item) => normalizePath(item.link) === normalizedCurrentPath,
);
const resolvedTitle = activeNavItem?.pageTitle ?? title;
const resolvedDescription = activeNavItem?.pageDescription ?? description;
const mainInnerClass =
  mainContentWidth === "narrow"
    ? "side-rail-main-inner side-rail-main-inner--narrow"
    : "side-rail-main-inner";
const homepageStylePaths = new Set([
  "/product/agents",
  "/product/automations",
  "/product/apps",
  "/product/data",
  "/product/connections",
  "/product/apis",
]);
const useHomepageHeaderStyles = homepageStylePaths.has(normalizedCurrentPath);
const titleClass = useHomepageHeaderStyles
  ? "hero-title mb-2 w-full max-w-3xl text-[50px]! leading-[1.02]! tracking-[-0.02em]! text-[var(--text-primary)] sm:text-[50px]! sm:leading-[1.02]!"
  : "mb-2 text-5xl!";
const descriptionClass = useHomepageHeaderStyles
  ? "mx-auto max-w-3xl !mb-4 !text-xl text-secondary"
  : "text-stone-500! dark:text-stone-400!";
---

<div class="platform-layout">
  <div class={`${mainInnerClass} space-y-12`}>
    <section class="side-rail-page-header mx-auto max-w-3xl text-center">
      <h1 class={titleClass}>{resolvedTitle}</h1>
      <p class={descriptionClass}>{resolvedDescription}</p>
    </section>
    <main class="platform-main">
      <slot />
    </main>
    <CTA />
  </div>
</div>

<style>
  .platform-layout {
    width: 100%;
  }

  .platform-main {
    flex: 1;
    min-width: 0;
  }
</style>
