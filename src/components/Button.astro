---
import Icon from "@components/Icon.astro";

// Reusable Button component
// Props:
// - label: string (required)
// - url?: string (if provided, renders an anchor)
// - variant?: 'primary' | 'secondary' | 'cta' (defaults to 'primary')
// - type?: 'button' | 'submit' | 'reset' (button only)
// - class?: string (additional classes)
// - size?: 'small' | 'medium' | 'large' (defaults to 'medium')
// - icon?: string (optional icon name to display before the label)
// - iconSize?: string (optional icon size in pixels, overrides default size-based calculation)

type Variant = "primary" | "secondary" | "cta";
type Size = "small" | "medium" | "large" | "sm";

interface Props {
  label: string;
  url?: string;
  variant?: Variant;
  type?: "button" | "submit" | "reset";
  class?: string;
  ariaLabel?: string;
  size?: Size;
  icon?: string;
  iconSize?: string;
  target?: string;
  rel?: string;
}

const {
  label,
  url,
  variant = "primary",
  type = "button",
  class: className = "",
  ariaLabel,
  size = "medium",
  icon,
  iconSize: providedIconSize,
  target,
  rel,
} = Astro.props as Props;

// Map button size to icon size (in pixels)
const iconSizes: Record<"small" | "medium" | "large", string> = {
  small: "16",
  medium: "18",
  large: "20",
};

const normalizedSize = size === "sm" ? "small" : size;

// Use provided iconSize if available, otherwise calculate based on button size
const iconSize = icon ? (providedIconSize ?? iconSizes[normalizedSize]) : undefined;

// Build Tailwind classes based on variant and size
const variantClasses = {
  // Primary: system action (semantic)
  primary: "bg-grey-900 text-grey-50 hover:bg-grey-800 dark:bg-grey-100 dark:text-grey-900 dark:hover:bg-grey-200",

  // Secondary: subtle surface + border
  secondary: "bg-secondary text hover:bg-surface-2",

  // CTA: brand-forward emphasis (explicit blue scale)
  cta: "bg-blue-500 text-white hover:bg-blue-800 active:bg-blue-900 dark:bg-blue-600 dark:text-blue-100 dark:hover:bg-blue-500 dark:active:bg-blue-400",
};

const sizeClasses = {
  small: "px-2.5 py-[4.5px] text-sm",
  medium: "px-3 py-1.5 text-base",
  large: "px-4 py-2 text-lg",
};

// Gap classes based on size (4px small, 6px medium, 8px large)
const gapClasses = {
  small: "gap-1", // 4px
  medium: "gap-1.5", // 6px
  large: "gap-2", // 8px
};

const baseClasses =
  "inline-flex items-center justify-center rounded-full !font-medium transition-colors duration-150 active:scale-[0.98] no-underline cursor-pointer font-sans focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-bg";

const paddingClasses = sizeClasses[normalizedSize];
const gapClass = gapClasses[normalizedSize];

const classes = [baseClasses, variantClasses[variant], paddingClasses, gapClass, className]
  .filter(Boolean)
  .join(" ");

const computedRel = rel ?? (target === "_blank" ? "noopener noreferrer" : undefined);
---

{
  url ? (
    <a
      href={url}
      class={classes}
      aria-label={ariaLabel}
      role="button"
      target={target}
      rel={computedRel}
    >
      {icon && iconSize && <Icon name={icon} size={iconSize} />}
      {label}
    </a>
  ) : (
    <button type={type} class={classes} aria-label={ariaLabel}>
      {icon && iconSize && <Icon name={icon} size={iconSize} />}
      {label}
    </button>
  )
}
