---
import Icon from "@components/Icon.astro";

// Reusable Button component
// Props:
// - label: string (required)
// - url?: string (if provided, renders an anchor)
// - variant?: 'primary' | 'secondary' | 'cta' (defaults to 'primary')
// - type?: 'button' | 'submit' | 'reset' (button only)
// - class?: string (additional classes)
// - size?: 'small' | 'medium' | 'large' (defaults to 'medium')
// - icon?: string (optional icon name to display before the label)
// - iconSize?: string (optional icon size in pixels, overrides default size-based calculation)

type Variant = "primary" | "secondary" | "cta";

interface Props {
  label: string;
  url?: string;
  variant?: Variant;
  type?: "button" | "submit" | "reset";
  class?: string;
  ariaLabel?: string;
  size?: "small" | "medium" | "large";
  icon?: string;
  iconSize?: string;
  target?: string;
  rel?: string;
}

const {
  label,
  url,
  variant = "primary",
  type = "button",
  class: className = "",
  ariaLabel,
  size = "medium",
  icon,
  iconSize: providedIconSize,
  target,
  rel,
} = Astro.props as Props;

// Map button size to icon size (in pixels)
const iconSizes: Record<"small" | "medium" | "large", string> = {
  small: "16",
  medium: "18",
  large: "20",
};

// Use provided iconSize if available, otherwise calculate based on button size
const iconSize = icon ? (providedIconSize ?? iconSizes[size]) : undefined;

// Build Tailwind classes based on variant and size
const variantClasses = {
  primary: "bg-stone-900 dark:bg-stone-100 text-stone-50 dark:text-stone-900 hover:bg-stone-700 dark:hover:bg-stone-200",
  secondary: "bg-stone-100 dark:bg-stone-800 text-stone-900 dark:text-stone-100 border border-stone-300 dark:border-stone-700 hover:bg-stone-100 dark:hover:bg-stone-700",
  cta: "bg-sky-700 dark:bg-sky-800 text-stone-50 hover:bg-sky-900 dark:hover:bg-sky-600",
};

const sizeClasses = {
  small: "px-2.5 py-[4.5px] text-sm",
  medium: "px-3 py-1.5 text-base",
  large: "px-4 py-2 text-lg",
};

// CTA variant has different padding
const ctaSizeClasses = {
  small: "px-3 py-[3px] text-sm",
  medium: "px-3 py-[3px] text-base",
  large: "px-3 py-[3px] text-lg",
};

// Gap classes based on size (4px small, 6px medium, 8px large)
const gapClasses = {
  small: "gap-1", // 4px
  medium: "gap-1.5", // 6px
  large: "gap-2", // 8px
};

const baseClasses = "inline-flex items-center justify-center rounded-full font-normal transition-all duration-150 active:scale-[0.98] no-underline border-none cursor-pointer font-sans";

// Use special padding for CTA variant
const paddingClasses = sizeClasses[size];
const gapClass = gapClasses[size];

const classes = [
  baseClasses,
  variantClasses[variant],
  paddingClasses,
  gapClass,
  className,
]
  .filter(Boolean)
  .join(" ");

const computedRel =
  rel ?? (target === "_blank" ? "noopener noreferrer" : undefined);
---

{
  url ? (
    <a
      href={url}
      class={classes}
      aria-label={ariaLabel}
      role="button"
      target={target}
      rel={computedRel}
    >
      {icon && iconSize && <Icon name={icon} size={iconSize} />}
      {label}
    </a>
  ) : (
    <button type={type} class={classes} aria-label={ariaLabel}>
      {icon && iconSize && <Icon name={icon} size={iconSize} />}
      {label}
    </button>
  )
}
