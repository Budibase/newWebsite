---
import Icon from "@components/Icon.astro";
import {
  getButtonClasses,
  getButtonIconSize,
  getButtonRel,
} from "../lib/button-classes.js";

// Reusable Button component
// Props:
// - label: string (required)
// - url?: string (if provided, renders an anchor)
// - variant?: 'primary' | 'secondary' | 'cta' | 'cta-on-base' | 'large' (defaults to 'primary')
// - type?: 'button' | 'submit' | 'reset' (button only)
// - class?: string (additional classes)
// - size?: 'small' | 'medium' | 'large' (defaults to 'medium')
// - icon?: string (optional icon name to display before the label)
// - iconSize?: string (optional icon size in pixels, overrides default size-based calculation)

type Variant = "primary" | "secondary" | "cta" | "cta-on-base" | "large";
type Size = "small" | "medium" | "large" | "sm";

interface Props {
  label: string;
  url?: string;
  variant?: Variant;
  type?: "button" | "submit" | "reset";
  class?: string;
  ariaLabel?: string;
  size?: Size;
  icon?: string;
  iconSize?: string;
  target?: string;
  rel?: string;
}

const {
  label,
  url,
  variant = "primary",
  type = "button",
  class: className = "",
  ariaLabel,
  size = "medium",
  icon,
  iconSize: providedIconSize,
  target,
  rel,
} = Astro.props as Props;
const iconSize = icon
  ? (providedIconSize ?? getButtonIconSize(size))
  : undefined;
const classes = getButtonClasses({ variant, size, className });
const computedRel = getButtonRel({ target, rel });
---

{
  url ? (
    <a
      href={url}
      class={classes}
      aria-label={ariaLabel}
      role="button"
      target={target}
      rel={computedRel}
    >
      {icon && iconSize && <Icon name={icon} size={iconSize} />}
      {label}
    </a>
  ) : (
    <button type={type} class={classes} aria-label={ariaLabel}>
      {icon && iconSize && <Icon name={icon} size={iconSize} />}
      {label}
    </button>
  )
}
