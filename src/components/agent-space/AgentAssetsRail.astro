---
export interface AssetGroup {
  label: string;
  items: string[];
}

interface Props {
  groups: AssetGroup[];
}

const { groups } = Astro.props as Props;
const visibleGroups = groups.filter((group) => group.items.length > 0);
---

{
  visibleGroups.length > 0 && (
    <aside class="agent-assets-rail" aria-label="Assets used">
      <div class="agent-assets-card">
        <h2 class="agent-assets-title">Assets used</h2>
        {visibleGroups.map((group) => (
          <section class="agent-assets-group">
            <h3 class="agent-assets-group-title">{group.label}</h3>
            <ul class="agent-assets-list">
              {group.items.map((item) => (
                <li class="agent-assets-item">
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </aside>
  )
}

<style>
  .agent-assets-rail {
    min-width: 0;
  }

  .agent-assets-card {
    border: 0.5px solid var(--border-color);
    border-radius: 0.8rem;
    background: var(--bg-2);
    padding: 0.9rem;
    display: grid;
    gap: 0.85rem;
  }

  .agent-assets-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.1;
    color: var(--text-primary);
  }

  .agent-assets-group {
    display: grid;
    gap: 0.45rem;
  }

  .agent-assets-group-title {
    margin: 0;
    font-size: 0.82rem;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-secondary);
    font-weight: 600;
  }

  .agent-assets-list {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .agent-assets-item {
    margin: 0 !important;
    list-style: none !important;
  }

  .agent-assets-item span {
    display: inline-flex;
    align-items: center;
    min-height: 1.7rem;
    border: 0.5px solid var(--border-color);
    border-radius: 999px;
    padding: 0 0.6rem;
    font-size: 0.82rem;
    line-height: 1.2;
    color: var(--text-primary);
    background: color-mix(in srgb, var(--bg-1) 70%, var(--bg-2) 30%);
  }

  @media (min-width: 1024px) {
    .agent-assets-card {
      position: sticky;
      top: calc(var(--site-nav-height) + 1rem);
      max-height: calc(100dvh - var(--site-nav-height) - 2rem);
      overflow-y: auto;
      scrollbar-width: thin;
    }
  }
</style>
