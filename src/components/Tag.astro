---
// Reusable Tag component
// Props:
// - label: string (required)
// - variant?: 'primary' | 'secondary' | 'cta' | 'orange' (defaults to 'primary')
// - size?: 'small' | 'medium' | 'large' (defaults to 'medium')
// - class?: string (additional classes)

type Variant = "primary" | "secondary" | "cta" | "orange";

interface Props {
  label: string;
  variant?: Variant;
  size?: "extra-small" | "small" | "medium" | "large";
  class?: string;
  ariaLabel?: string;
}

const {
  label,
  variant = "primary",
  size = "medium",
  class: className = "",
  ariaLabel,
} = Astro.props as Props;

// Build Tailwind classes based on variant and size
const variantClasses = {
  primary: "bg-stone-800 dark:bg-stone-100 text-stone-50 dark:text-stone-900 hover:bg-stone-200 dark:hover:bg-stone-200",
  secondary: "bg-stone-200 dark:bg-stone-800 text-stone-900 dark:text-stone-100 hover:bg-stone-300 dark:hover:bg-stone-700",
  cta: "bg-sky-700 dark:bg-sky-800 text-white dark:text-stone-50 hover:bg-sky-900 dark:hover:bg-sky-500",
  orange: "bg-orange-600 dark:bg-orange-500 text-white hover:bg-orange-700 dark:hover:bg-orange-400",
};

const sizeClasses = {
  "extra-small": "px-1 py-0.5 text-[10px]",
  small: "px-1.5 py-0.5 text-xs",
  medium: "px-2 py-1 text-sm",
  large: "px-2.5 py-1.5 text-lg",
};

const baseClasses = "inline-flex items-center justify-center gap-2 rounded font-mono font-medium transition-all duration-150 cursor-default whitespace-nowrap";

// Secondary variant has different border-radius
const radiusClass = variant === "secondary" ? "rounded-md" : "rounded";

const classes = [
  baseClasses,
  radiusClass,
  variantClasses[variant],
  sizeClasses[size],
  className,
]
  .filter(Boolean)
  .join(" ");
---

<span class={classes} aria-label={ariaLabel}>
  {label}
  <slot />
  <!-- Slot allows optional inline icon/content -->
</span>
