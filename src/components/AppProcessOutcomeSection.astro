---
import CheckCircleFill from "phosphor-astro/CheckCircleFill.astro";
import FormDemo from "@components/FormDemo.astro";
import SectionBlock from "@components/SectionBlock.astro";
---

<section>
  <div class="grid grid-cols-1 gap-8 lg:grid-cols-[minmax(0,1.02fr)_minmax(0,0.98fr)] lg:items-center lg:gap-20">
    <div>
      <FormDemo />
    </div>

    <SectionBlock
      titleColorMode="split-secondary-primary"
      titleLines={[
        { text: "Turn messy processes" },
        { text: "into simple apps" },
      ]}
      description="Growing businesses run on requests, approvals, and internal processes but too often those live in spreadsheets, inboxes, or Slack threads. Within Budibase, you can turn those processes into simple internal apps your team can rely on."
      maxWidth="xl"
      spacing="default"
      contentClass="pt-1"
    >
      <ul class="m-0 flex flex-col gap-4">
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
            Collect requests with forms
          </div>
        </li>
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
            Track work in structured workflows
          </div>
        </li>
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
            Give teams one place to manage operations - no engineering required.
          </div>
        </li>
      </ul>
    </SectionBlock>
  </div>
</section>
