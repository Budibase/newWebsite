---
import { cx } from "../../lib/ui-classes";

type Variant = "primary" | "secondary" | "outline" | "ghost" | "danger";
type Size = "sm" | "md" | "lg" | "icon";

interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: Variant;
  size?: Size;
  class?: string;
  target?: string;
  rel?: string;
  disabled?: boolean;
  ariaLabel?: string;
  [key: string]: unknown;
}

const {
  href,
  type = "button",
  variant = "primary",
  size = "md",
  class: className,
  target,
  rel,
  disabled = false,
  ariaLabel,
  ...rest
} = Astro.props as Props;

const base =
  "inline-flex shrink-0 items-center justify-center gap-2 whitespace-nowrap rounded-xs border font-sans font-medium no-underline outline-none transition-all duration-150 ease-out select-none focus-visible:ring-3 focus-visible:ring-ring/35 disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 active:scale-[0.98] [&_svg]:pointer-events-none [&_svg]:shrink-0";

const variants: Record<Variant, string> = {
  primary:
    "border-transparent bg-brand text-on-brand hover:bg-brand-hover active:bg-brand-hover",
  secondary:
    "border-transparent bg-surface text-text hover:bg-surface-2 active:bg-surface-2",
  outline:
    "border-border bg-bg text-text hover:bg-surface hover:text-text active:bg-surface-2",
  ghost:
    "border-transparent bg-transparent text-text hover:bg-surface hover:text-text active:bg-surface-2",
  danger:
    "border-transparent bg-danger text-on-brand hover:bg-red-600 active:bg-red-600",
};

const sizes: Record<Size, string> = {
  sm: "h-8 px-3 text-sm",
  md: "h-9 px-3.5 text-sm",
  lg: "h-10 px-4 text-base",
  icon: "size-9 p-0",
};

const classes = cx(base, variants[variant], sizes[size], className);
const computedRel =
  rel ?? (target === "_blank" ? "noopener noreferrer" : undefined);
---

{
  href ? (
    <a
      href={href}
      class={classes}
      target={target}
      rel={computedRel}
      aria-label={ariaLabel}
      aria-disabled={disabled ? "true" : undefined}
      data-slot="button"
      data-variant={variant}
      data-size={size}
      {...rest}
    >
      <slot />
    </a>
  ) : (
    <button
      type={type}
      class={classes}
      disabled={disabled}
      aria-label={ariaLabel}
      data-slot="button"
      data-variant={variant}
      data-size={size}
      {...rest}
    >
      <slot />
    </button>
  )
}
