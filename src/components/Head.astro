---
import Favicon from "./Favicon.astro";
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import "../styles/fonts.css";
import SEO from "./SEO.astro";

export type Props = {
  title?: string;
  rawTitle?: string;
  description?: string;
  image?: { src: string; alt: string };
  canonicalURL?: URL | null;
  pageType?: "website" | "article";
};

const twitterHandle = "budibase";

const siteInfo = {
  name: "Budibase",
  description:
    "Build AI agents, chat and automate internal workflows instantly. The fastest way to automate internal business processes.",
  image: {
    src: "/og.png",
    alt: "Budibase - Make work flow",
  },
};

const {
  rawTitle,
  description = siteInfo.description,
  image = siteInfo.image,
  canonicalURL = new URL(Astro.request.url, Astro.site),
  pageType = "website",
} = Astro.props;

const title =
  rawTitle ?? [Astro.props.title, siteInfo.name].filter(Boolean).join(" | ");
const resolvedImage = {
  src: new URL(image.src, Astro.site).toString(),
  alt: image.alt,
};

// Simple smartypants-like function for typographic quotes and dashes
function smartypants(text: string, _mode?: number): string {
  return text
    .replace(/'/g, "&#8217;") // apostrophe
    .replace(/'/g, "&#8216;") // opening single quote
    .replace(/"/g, "&#8221;") // closing double quote
    .replace(/"/g, "&#8220;") // opening double quote
    .replace(/--/g, "&#8212;") // em dash
    .replace(/-/g, "&#8211;"); // en dash
}
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />
<title set:html={smartypants(title, 1)} />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#8D46E7" />
<script is:inline>
  // Prevent flash of unstyled content by applying theme immediately
  // Solution based on: https://medium.com/@maiowebdesign/astro-dark-mode-flickering-62da94d08ce6
  (function () {
    function getEffectiveTheme() {
      try {
        const stored = localStorage.getItem("theme");
        if (stored === "dark" || stored === "light") {
          return stored;
        }
      } catch (e) {
        // localStorage might not be available
      }
      // System preference
      return window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    }

    function applyTheme(skipTransitions = false) {
      if (skipTransitions) {
        document.documentElement.classList.add("no-transitions");
      }

      const effectiveTheme = getEffectiveTheme();
      if (effectiveTheme === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }

      if (skipTransitions) {
        // Force reflow to ensure the class is applied
        void document.documentElement.offsetHeight;
        document.documentElement.classList.remove("no-transitions");
      }
    }

    // Apply theme immediately before any rendering
    applyTheme();

    // Re-apply theme on Astro view transitions (client-side navigation)
    // Use astro:after-swap and skip transitions to prevent flicker
    document.addEventListener("astro:after-swap", () => {
      applyTheme(true);
    });

    // Also listen for storage changes (for syncing across tabs)
    window.addEventListener("storage", (e) => {
      if (e.key === "theme") {
        applyTheme(true);
      }
    });
  })();
</script>
<style is:inline>
  /* Disable transitions during theme switch to prevent flicker */
  .no-transitions,
  .no-transitions *,
  .no-transitions *::before,
  .no-transitions *::after {
    transition: none !important;
    animation: none !important;
  }
</style>

<!-- Font preloads, omit MDIO to improve initial load -->
<link
  rel="preload"
  href="/fonts/InterDisplay-Regular.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/Inter-Regular.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/Inter-Medium.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>

<!-- Low Priority Global Metadata -->
<Favicon />
<link rel="mask-icon" href="/favicon.svg" color="#8D46E7" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" href="/rss.xml" title="RSS" />

<!-- SEO construct -->
<SEO
  name={siteInfo.name}
  title={title}
  description={description}
  image={resolvedImage}
  twitter={{ handle: twitterHandle }}
  og={{ type: pageType }}
  canonicalURL={canonicalURL}
/>
<ClientRouter />
<style>
  body {
    font-family: var(--font-sans);
  }
</style>
