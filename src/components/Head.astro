---
import { Font } from "astro:assets";
import Favicon from "./Favicon.astro";
import SEO from './SEO.astro';
import { resolveImageReference } from "../lib/imageReference";

export type Props = {
	title?: string;
	rawTitle?: string;
	description?: string;
	image?: { src: string; alt: string };
	canonicalURL?: URL | null;
	robots?: string;
	pageType?: 'website' | 'article';
	schema?: Record<string, unknown> | Array<Record<string, unknown>>;
};

const twitterHandle = 'budibase';
const genericProductDescription =
  "Enterprise-grade security and governance built for deploying AI into real business operations.";

const siteInfo = {
	name: 'Budibase',
	description: 'Build AI agents, chat and automate internal workflows instantly. The fastest way to automate internal business processes.',
	image: {
		src: '/og.png',
		alt: 'Budibase - Make work flow',
	},
};

const routeSeoFallbacks = {
  "/pricing": {
    title: "Pricing Plans",
    description:
      "Compare Budibase pricing for AI agents, automations, internal apps, and enterprise operations.",
  },
  "/product/agents": {
    title: "AI Agents",
  },
  "/product/apps": {
    title: "Internal Apps",
  },
  "/product/automations": {
    title: "Workflow Automations",
  },
  "/product/resources": {
    title: "Operational Resources",
    description:
      "Give teams reusable operational resources, templates, and building blocks for AI-powered work.",
  },
  "/product/enterprise": {
    title: "Enterprise Control and Security",
    description:
      "Control security, governance, support, and deployment options for enterprise AI operations with Budibase.",
  },
} as const;

type RouteSeoFallback = {
  title: string;
  description?: string;
};

const genericTitleCandidates = new Set([
  "Agents",
  "Apps",
  "Automations",
  "Blog",
  "Product",
]);

function normalizePath(path: string): string {
  if (path.length > 1 && path.endsWith("/")) {
    return path.slice(0, -1);
  }
  return path;
}

function getRouteSeoFallback(pathname: string) {
  if (pathname === "/blog" || /^\/blog\/\d+$/.test(pathname)) {
    return {
      title: "Blog and Resources",
    } satisfies RouteSeoFallback;
  }

  return routeSeoFallbacks[
    pathname as keyof typeof routeSeoFallbacks
  ] as RouteSeoFallback | undefined;
}

function resolvePageTitle(
  pathname: string,
  title?: string,
): string | undefined {
  const trimmedTitle = title?.trim();
  const routeFallback = getRouteSeoFallback(pathname);

  if (routeFallback?.title && (!trimmedTitle || genericTitleCandidates.has(trimmedTitle))) {
    return routeFallback.title;
  }

  return trimmedTitle;
}

function buildTitle(title?: string, rawTitle?: string): string {
  if (rawTitle) {
    return rawTitle;
  }

  if (!title) {
    return siteInfo.name;
  }

  if (/\bBudibase\b/i.test(title)) {
    return title;
  }

  return `${title} | ${siteInfo.name}`;
}

function resolvePageDescription(
  pathname: string,
  description?: string,
): string {
  const trimmedDescription = description?.trim();
  const routeFallback = getRouteSeoFallback(pathname);

  if (!routeFallback?.description) {
    return trimmedDescription || siteInfo.description;
  }

  if (!trimmedDescription) {
    return routeFallback.description;
  }

  if (
    (pathname === "/product/resources" || pathname === "/product/enterprise") &&
    trimmedDescription === genericProductDescription
  ) {
    return routeFallback.description;
  }

  return trimmedDescription;
}

const {
	title: providedTitle,
	rawTitle,
	description: providedDescription,
	image = siteInfo.image,
	canonicalURL = new URL(Astro.request.url, Astro.site),
	robots,
	pageType = 'website',
	schema,
} = Astro.props;

const normalizedPath = normalizePath(Astro.url.pathname);
const pageTitle = resolvePageTitle(normalizedPath, providedTitle);
const title = buildTitle(pageTitle, rawTitle);
const description = resolvePageDescription(normalizedPath, providedDescription);
const resolvedImageReference = resolveImageReference(image.src) ?? siteInfo.image.src;
const resolvedImage = {
	src: new URL(resolvedImageReference, Astro.site).toString(),
	alt: image.alt || siteInfo.image.alt,
};
const defaultSchema =
	normalizedPath === "/"
		? {
				"@context": "https://schema.org",
				"@type": "WebSite",
				url: "https://budibase.com/",
				description,
				license: "This work is licensed and owned by Budibase",
				name: title,
				publisher: {
					"@type": "Organization",
					name: "Budibase",
					url: "https://budibase.com/",
					sameAs: [
						"https://www.wikidata.org/wiki/Q131328403",
						"https://x.com/budibase",
						"https://www.linkedin.com/company/budibase/",
						"https://github.com/budibase/budibase",
					],
				},
			}
		: undefined;
const resolvedSchema = schema ?? defaultSchema;

// Simple smartypants-like function for typographic quotes and dashes
function smartypants(text: string, _mode?: number): string {
	return text
		.replace(/'/g, '&#8217;') // apostrophe
		.replace(/'/g, '&#8216;') // opening single quote
		.replace(/"/g, '&#8221;') // closing double quote
		.replace(/"/g, '&#8220;') // opening double quote
		.replace(/--/g, '&#8212;') // em dash
		.replace(/-/g, '&#8211;'); // en dash
}
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />
<title set:html={smartypants(title, 1)} />
<meta name="generator" content={Astro.generator} />
<meta name="color-scheme" content="light dark" />
<meta name="theme-color" content="#faf9f5" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#141413" media="(prefers-color-scheme: dark)" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="mobile-web-app-capable" content="yes" />
<link rel="manifest" href="/manifest.webmanifest" />
<script
  src="https://cdn.kukie.io/s/35056df5-a65d-4cb3-be6d-e29000e4b2da/c.js"
  async
></script>
<script is:inline>
  // Prevent flash of unstyled content by applying theme immediately
  // Solution based on: https://medium.com/@maiowebdesign/astro-dark-mode-flickering-62da94d08ce6
  (function() {
    function getCodeTheme(theme) {
      return theme === 'dark' ? 'github-dark' : 'github-light';
    }

    function getEffectiveTheme() {
      try {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || stored === 'light') {
          return stored;
        }
      } catch (e) {
        // localStorage might not be available
      }
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    function applyTheme() {
      const effectiveTheme = getEffectiveTheme();
      document.documentElement.classList.toggle('dark', effectiveTheme === 'dark');
      document.documentElement.dataset.theme = getCodeTheme(effectiveTheme);
    }

    // Apply theme immediately before any rendering
    applyTheme();

    // Only react to explicit theme changes (avoids flicker on navigation)
    window.addEventListener('storage', (e) => {
      if (e.key === 'theme') {
        applyTheme();
      }
    });
  })();
</script>
<script is:inline>
  if ("serviceWorker" in navigator) {
    window.addEventListener(
      "load",
      () => {
        navigator.serviceWorker.register("/sw.js").catch(() => {});
      },
      { once: true },
    );
  }
</script>
<script is:inline>
  (() => {
    const GTM_ID = "GTM-TW89LL3";
    const PROD_HOSTS = new Set(["budibase.com", "www.budibase.com"]);

    function shouldLoadGtm() {
      return PROD_HOSTS.has(window.location.hostname);
    }

    function injectGtm() {
      if (!shouldLoadGtm() || document.getElementById("gtm-loader")) return;

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        "gtm.start": Date.now(),
        event: "gtm.js",
      });

      const script = document.createElement("script");
      script.id = "gtm-loader";
      script.async = true;
      script.src = `https://www.googletagmanager.com/gtm.js?id=${GTM_ID}`;
      document.head.appendChild(script);
    }

    window.addEventListener(
      "load",
      () => {
        if ("requestIdleCallback" in window) {
          window.requestIdleCallback(injectGtm, { timeout: 3000 });
        } else {
          window.setTimeout(injectGtm, 1500);
        }
      },
      { once: true },
    );
  })();
</script>
<style is:inline>
  /* Intentionally left blank */
</style>


<Font cssVariable="--font-inter" preload={[{ weight: 400 }]} />
<Font cssVariable="--font-fraunces" />
<Font cssVariable="--font-ia-writer-mono" />


<!-- Low Priority Global Metadata -->
<Favicon />
<link rel="mask-icon" href="/favicon.svg" color="#8D46E7" />
<link rel="sitemap" href="/sitemap.xml" />
<link rel="alternate" type="application/rss+xml" href="/rss.xml" title="RSS" />

<!-- SEO construct -->
<SEO
	name={siteInfo.name}
	title={title}
	description={description}
	image={resolvedImage}
	twitter={{ handle: twitterHandle }}
	og={{ type: pageType }}
	canonicalURL={canonicalURL}
	robots={robots}
	schema={resolvedSchema}
/>
<style>
  body {
    font-family: var(--font-sans);
  }
</style>
