---
import Icon from "@components/Icon.astro";

interface Props {
  href: string;
  title: string;
  role: string;
  copies: number;
  tags: string[];
}

const { href, title, role, copies, tags } = Astro.props as Props;

const iconMap: Record<string, { name: string; className: string }> = {
  Apps: { name: "Browser", className: "text-orange-400" },
  Automations: { name: "Path", className: "text-blue-400" },
  Agents: { name: "Sparkle", className: "text-purple-400" },
  Agent: { name: "Sparkle", className: "text-purple-400" },
  Chat: { name: "ChatCircle", className: "text-green-400" },
  "Human-in-the-loop": { name: "UserSwitch", className: "text-red-400" },
  HITL: { name: "UserSwitch", className: "text-red-400" },
};
---

<a
  href={href}
  class="group grid grid-cols-[1fr_180px_140px] gap-4 items-start py-3 border-b border-stone-200/70 dark:border-stone-800/70 hover:bg-stone-100/60 dark:hover:bg-stone-900/60 transition-colors px-2"
  data-astro-prefetch
>
  <div class="flex flex-col gap-2">
    <div>
      <div class="flex items-center flex-wrap gap-3">
        <h3 class="!text-base font-medium text-[color:rgb(var(--text))]">
          {title}
        </h3>
        <div class="flex items-center gap-1">
          {tags
            .map((tag) => iconMap[tag])
            .filter(Boolean)
            .map((icon) => (
              <span class="w-6 h-6 rounded-sm bg-[color:var(--bg-2)] flex items-center justify-center">
                <Icon name={icon.name} weight="fill" class={`w-4 h-4 ${icon.className}`} />
              </span>
            ))}
        </div>
      </div>
    </div>
  </div>
  <span class="!text-base text-stone-600 dark:text-stone-400">{role}</span>
  <span class="!text-base font-normal text-stone-600 dark:text-stone-400">{copies}</span>
</a>
