---
import Tag from "@components/Tag.astro";
import Link from "@components/Link.astro";

interface NavItem {
	text: string;
	link: string;
	sectionId: string;
	icon?: any;
	linkVariant?: "primary" | "secondary" | "cta";
	disabled?: boolean;
	tag?: {
		label: string;
		variant: "primary" | "secondary" | "cta" | "orange";
	};
}

interface NavGroup {
	header?: string;
	headerStyle?: "default" | "label";
	items: NavItem[];
}

interface Props {
	navItems: NavItem[] | NavGroup[];
}

const { navItems } = Astro.props;
const currentPath = Astro.url.pathname;

// Check if navItems is grouped or flat
const isGrouped = navItems.length > 0 && "items" in navItems[0];
const groupedNavItems = isGrouped ? (navItems as NavGroup[]) : null;
const flatNavItems = isGrouped ? null : (navItems as NavItem[]);

function isActive(link: string): boolean {
	return currentPath === link || (link === "/product" && currentPath === "/product/");
}
---

<aside class="platform-sidebar">
	<nav>
		<ul>
			{isGrouped ? (
				groupedNavItems!.map((group, groupIndex) => (
					<>
						{group.header && (
							<li class:list={["nav-group-header", groupIndex > 0 && "nav-group-header-spaced"]}>
								<span class:list={[
									group.headerStyle === "label"
										? "px-3 text-sm text-secondary"
										: "text-xs text-stone-600  uppercase tracking-wider px-3 py-2",
								]}>
									{group.header}
								</span>
							</li>
						)}
						{group.items.map((item, itemIndex) => {
							return (
								<li>
									{item.disabled ? (
										<div
											class="nav-link nav-link-disabled flex flex-row items-center h-8 px-3 rounded-md text-sm text-text-subtle cursor-default select-none"
											aria-disabled="true"
										>
											<span>{item.text}</span>
										</div>
									) : item.linkVariant === "cta" ? (
										<Link
											label={item.text}
											url={item.link}
											variant="cta"
											dataSection={item.sectionId}
											class={[
												"nav-link flex flex-row items-center h-8 px-3 rounded-md text-sm w-full !text-primary  hover:!text-primary  [&.active]:!text-sky-700  [&.active:hover]:!text-sky-600 ",
												"hover:bg-stone-100 ",
												isActive(item.link) && "active [&.active]:bg-stone-200 ",
											]
												.filter(Boolean)
												.join(" ")}
										/>
									) : (
										<a href={item.link} class:list={[
											"nav-link flex flex-row items-center h-8 px-3 rounded-md text-primary  hover:text-primary  [&.active]:text-sky-700  [&.active:hover]:text-sky-600  [&.active]:bg-stone-200  text-sm",
											isActive(item.link) && "active"
										]} data-section={item.sectionId}>
											<span>{item.text}</span>
											{item.tag && (
												<Tag
													label={item.tag.label}
													variant={item.tag.variant}
													size="extra-small"
													class="ml-auto"
												/>
											)}
										</a>
									)}
								</li>
							);
						})}
						{groupIndex < groupedNavItems!.length - 1 && (
							<li class="nav-group-divider">
								<hr
									class:list={[
										"nav-hr border-t-[0.5px] chrome-border mb-2",
										groupedNavItems![groupIndex + 1]?.headerStyle === "label" ? "mt-5" : "mt-2",
									]}
								/>
							</li>
						)}
					</>
				))
			) : (
				flatNavItems!.map((item, index) => {
					return (
						<li>
							{item.disabled ? (
								<div
									class="nav-link nav-link-disabled flex flex-row items-center h-8 px-3 rounded-md text-sm text-text-subtle cursor-default select-none"
									aria-disabled="true"
								>
									<span>{item.text}</span>
								</div>
							) : item.linkVariant === "cta" ? (
								<Link
									label={item.text}
									url={item.link}
									variant="cta"
									dataSection={item.sectionId}
									class={[
										"nav-link flex flex-row items-center h-8 px-3 rounded-md text-sm w-full !text-primary  hover:!text-primary  [&.active]:!text-sky-700  [&.active:hover]:!text-sky-600 ",
										"hover:bg-stone-100 ",
										isActive(item.link) && "active [&.active]:bg-stone-100 ",
									]
										.filter(Boolean)
										.join(" ")}
								/>
							) : (
								<a href={item.link} class:list={[
									"nav-link flex flex-row items-center h-8 px-3 rounded-md text-primary  hover:text-primary  [&.active]:text-sky-700  [&.active:hover]:text-sky-600  [&.active]:bg-stone-100  text-sm",
									isActive(item.link) && "active"
								]} data-section={item.sectionId}>
										<span>{item.text}</span>
										{item.tag && (
											<Tag
												label={item.tag.label}
												variant={item.tag.variant}
												size="extra-small"
												class="ml-auto"
											/>
										)}
									</a>
							)}

						</li>
					);
				})
			)}
		</ul>
	</nav>
</aside>

<style>
	.platform-sidebar {
		width: 100%;
	}

	.nav-group-header {
		margin-bottom: 0.5rem !important;
	}

	.nav-group-header-spaced {
		margin-top: 0.5rem !important;
	}
</style>
