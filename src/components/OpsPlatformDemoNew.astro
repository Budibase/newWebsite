---
import { Image } from "astro:assets";
import BudibaseSymbol from "@assets/BBSymbolWhite.svg";
import JessAvatarImage from "@assets/images/avatars/Avatar.png";
import SarahAvatarImage from "@assets/images/avatars/Ellipse-1.png";
import PlatformBgImage from "@assets/images/homepage/platform/bg4.png";
import PaperPlaneTiltFill from "phosphor-astro/PaperPlaneTiltFill.astro";

const bgImage = PlatformBgImage.src;
const jessAvatar = JessAvatarImage.src;
const sarahAvatar = SarahAvatarImage.src;

const requestRows = [
  {
    request: "Access to Salesforce",
    category: "Access",
    priority: "Medium",
    priorityTone: "medium",
    status: "Pending",
    statusTone: "pending",
  },
  {
    request: "VPN not connecting",
    category: "Network",
    priority: "High",
    priorityTone: "high",
    status: "Approved",
    statusTone: "approved",
  },
  {
    request: "Additional Figma seat",
    category: "Software",
    priority: "Low",
    priorityTone: "low",
    status: "In progress",
    statusTone: "progress",
  },
  {
    request: "Replace faulty monitor",
    category: "Hardware",
    priority: "Medium",
    priorityTone: "medium",
    status: "Pending",
    statusTone: "pending",
  },
  {
    request: "Create shared inbox for support",
    category: "Operations",
    priority: "Medium",
    priorityTone: "medium",
    status: "In progress",
    statusTone: "progress",
  },
  {
    request: "Password reset for finance system",
    category: "Access",
    priority: "High",
    priorityTone: "high",
    status: "Completed",
    statusTone: "completed",
  },
  {
    request: "Setup Slack channel for new project",
    category: "Collaboration",
    priority: "Low",
    priorityTone: "low",
    status: "In progress",
    statusTone: "progress",
  },
  {
    request: "Company car request for sales manager",
    category: "Operations",
    priority: "Low",
    priorityTone: "low",
    status: "Rejected",
    statusTone: "rejected",
  },
  {
    request: "Printer not working in office",
    category: "Hardware",
    priority: "High",
    priorityTone: "high",
    status: "Approved",
    statusTone: "approved",
  },
];

const id = `ops-platform-demo-new-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  id={id}
  class="ops-platform-demo-new"
  data-state="idle"
  data-analysis-step="0"
  data-panel-active="false"
  data-ops-platform-demo-new
>
  <Image
    src={PlatformBgImage}
    alt=""
    class="ops-platform-demo-new__bg"
    aria-hidden="true"
    format="webp"
    quality={72}
    loading="lazy"
    decoding="async"
  />

  <div class="ops-platform-demo-new__layout">
    <article class="ops-platform-demo-new__chat-card">
      <header class="ops-platform-demo-new__chat-header">
        <p class="ops-platform-demo-new__chat-title">Chat</p>
      </header>

      <div class="ops-platform-demo-new__chat-thread">
        <div class="ops-platform-demo-new__message">
          <img
            src={jessAvatar}
            alt="Jess Mitchell"
            class="ops-platform-demo-new__avatar"
            loading="lazy"
          />
          <div class="ops-platform-demo-new__message-body">
            <div class="ops-platform-demo-new__message-meta">
              <p class="ops-platform-demo-new__message-author">Jess Mitchell</p>
              <p class="ops-platform-demo-new__message-time">12 mins</p>
            </div>
            <p class="ops-platform-demo-new__message-copy">
              Sarah, James has accepted his offer and will start on Monday 1st of June.
            </p>
          </div>
        </div>

        <div class="ops-platform-demo-new__message">
          <img
            src={sarahAvatar}
            alt="Sarah Harvey"
            class="ops-platform-demo-new__avatar"
            loading="lazy"
          />
          <div class="ops-platform-demo-new__message-body">
            <div class="ops-platform-demo-new__message-meta">
              <p class="ops-platform-demo-new__message-author">Sarah Harvey</p>
              <p class="ops-platform-demo-new__message-time">12 mins</p>
            </div>
            <p class="ops-platform-demo-new__message-copy">
              That's great news. He'll be a super addition to the team.
            </p>
          </div>
        </div>

        <div class="ops-platform-demo-new__message ops-platform-demo-new__message--request">
          <img
            src={sarahAvatar}
            alt="Sarah Harvey"
            class="ops-platform-demo-new__avatar"
            loading="lazy"
          />
          <div class="ops-platform-demo-new__message-body">
            <div class="ops-platform-demo-new__message-meta">
              <p class="ops-platform-demo-new__message-author">Sarah Harvey</p>
              <p class="ops-platform-demo-new__message-time">12 mins</p>
            </div>
            <p class="ops-platform-demo-new__message-copy">
              <span class="ops-platform-demo-new__mention">@Ops Assistant</span>
              <span>{` I need approval for a new laptop for a marketing hire?`}</span>
            </p>
          </div>
        </div>

        <div class="ops-platform-demo-new__message ops-platform-demo-new__message--assistant">
          <div class="ops-platform-demo-new__assistant-avatar">
            <Image src={BudibaseSymbol} alt="" class="ops-platform-demo-new__assistant-avatar-icon" />
          </div>
          <div class="ops-platform-demo-new__message-body">
            <div class="ops-platform-demo-new__message-meta">
              <p class="ops-platform-demo-new__message-author">Ops Assistant</p>
              <p class="ops-platform-demo-new__message-time">12 mins</p>
            </div>
            <div class="ops-platform-demo-new__assistant-body ops-platform-demo-new__assistant-body--analysis">
              <p class="ops-platform-demo-new__message-copy ops-platform-demo-new__analysis-line">
                Analyzing request...
              </p>
              <p class="ops-platform-demo-new__message-copy ops-platform-demo-new__analysis-line ops-platform-demo-new__analysis-line--step" data-analysis-line="1">
                ✓ Extracting details
              </p>
              <p class="ops-platform-demo-new__message-copy ops-platform-demo-new__analysis-line ops-platform-demo-new__analysis-line--step" data-analysis-line="2">
                ✓ Checking policy
              </p>
              <p class="ops-platform-demo-new__message-copy ops-platform-demo-new__analysis-line ops-platform-demo-new__analysis-line--step" data-analysis-line="3">
                ✓ Selecting workflow
              </p>
            </div>
            <div class="ops-platform-demo-new__assistant-body ops-platform-demo-new__assistant-body--final">
              <p class="ops-platform-demo-new__message-copy">
                Got it - creating a laptop purchase request.
              </p>
              <div class="ops-platform-demo-new__assistant-panel">
                <p class="ops-platform-demo-new__message-copy">• Team: Marketing</p>
                <p class="ops-platform-demo-new__message-copy">• Item: Laptop for new hire</p>
                <p class="ops-platform-demo-new__message-copy">• Budget: £700–£900</p>
              </div>
              <p class="ops-platform-demo-new__message-copy">
                Submitted to Ops for review.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="ops-platform-demo-new__composer">
        <div class="ops-platform-demo-new__composer-active">
          <p class="ops-platform-demo-new__composer-copy">
            <span class="ops-platform-demo-new__mention">@Ops Assistant</span>
            <span>{` I need approval for a new laptop for a marketing hire?`}</span>
          </p>
          <div class="ops-platform-demo-new__composer-actions">
            <button
              type="button"
              class="ops-platform-demo-new__send-button"
              data-ops-send
              aria-label="Send request"
            >
              <PaperPlaneTiltFill class="ops-platform-demo-new__send-icon" aria-hidden="true" />
              <span>Send</span>
            </button>
          </div>
        </div>

        <div class="ops-platform-demo-new__composer-inactive" aria-hidden="true">
          <div class="ops-platform-demo-new__composer-actions">
            <button
              type="button"
              class="ops-platform-demo-new__send-button ops-platform-demo-new__send-button--inactive"
              tabindex="-1"
            >
              <PaperPlaneTiltFill class="ops-platform-demo-new__send-icon" aria-hidden="true" />
              <span>Send</span>
            </button>
          </div>
        </div>
      </div>
    </article>

    <section class="ops-platform-demo-new__requests-panel" aria-label="Requests">
      <div class="ops-platform-demo-new__requests-heading">
        <p class="ops-platform-demo-new__requests-title">Requests</p>
      </div>

      <div class="ops-platform-demo-new__filters" aria-hidden="true">
        <span class="ops-platform-demo-new__filter ops-platform-demo-new__filter--active">
          All requests
        </span>
        <span class="ops-platform-demo-new__filter">By status</span>
        <span class="ops-platform-demo-new__filter">By priority</span>
      </div>

      <div class="ops-platform-demo-new__table" role="table" aria-label="Requests table">
        <div class="ops-platform-demo-new__table-row ops-platform-demo-new__table-row--header" role="row">
          <div class="ops-platform-demo-new__table-cell" role="columnheader">Request</div>
          <div
            class="ops-platform-demo-new__table-cell ops-platform-demo-new__table-cell--category"
            role="columnheader"
          >
            Category
          </div>
          <div class="ops-platform-demo-new__table-cell" role="columnheader">Priority</div>
          <div class="ops-platform-demo-new__table-cell" role="columnheader">Status</div>
        </div>

        <div class="ops-platform-demo-new__table-row ops-platform-demo-new__table-row--new" role="row">
          <div class="ops-platform-demo-new__table-cell ops-platform-demo-new__table-cell--request" role="cell">
            <span>Laptop for new marketing hire</span>
            <span class="ops-platform-demo-new__new-badge">New</span>
          </div>
          <div
            class="ops-platform-demo-new__table-cell ops-platform-demo-new__table-cell--category"
            role="cell"
          >
            Hardware
          </div>
          <div class="ops-platform-demo-new__table-cell" role="cell">
            <span class="ops-platform-demo-new__priority">
              <span class="ops-platform-demo-new__priority-dot ops-platform-demo-new__priority-dot--high"></span>
              <span>High</span>
            </span>
          </div>
          <div class="ops-platform-demo-new__table-cell" role="cell">
            <span class="ops-platform-demo-new__status ops-platform-demo-new__status--pending">
              Pending
            </span>
          </div>
        </div>

        {requestRows.map((row) => (
          <div class="ops-platform-demo-new__table-row" role="row">
            <div class="ops-platform-demo-new__table-cell" role="cell">{row.request}</div>
            <div
              class="ops-platform-demo-new__table-cell ops-platform-demo-new__table-cell--category"
              role="cell"
            >
              {row.category}
            </div>
            <div class="ops-platform-demo-new__table-cell" role="cell">
              <span class="ops-platform-demo-new__priority">
                <span class={`ops-platform-demo-new__priority-dot ops-platform-demo-new__priority-dot--${row.priorityTone}`}></span>
                <span>{row.priority}</span>
              </span>
            </div>
            <div class="ops-platform-demo-new__table-cell" role="cell">
              <span class={`ops-platform-demo-new__status ops-platform-demo-new__status--${row.statusTone}`}>
                {row.status}
              </span>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</div>

<style>
  .ops-platform-demo-new {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    background: #f0eee6;
    padding: 40px;
  }

  .ops-platform-demo-new__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
    pointer-events: none;
  }

  .ops-platform-demo-new__layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 401px minmax(0, 839px);
    align-items: center;
    gap: 40px;
  }

  .ops-platform-demo-new__chat-card {
    overflow: hidden;
    border-radius: 8px;
    background: #ffffff;
  }

  .ops-platform-demo-new__chat-header {
    border-bottom: 1px solid #ececec;
    padding: 10px 18px;
  }

  .ops-platform-demo-new__chat-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 500;
    line-height: 20px;
    color: #191919;
  }

  .ops-platform-demo-new__chat-thread {
    display: flex;
    height: 406px;
    flex-direction: column;
    overflow: hidden;
    padding: 20px 12px 12px;
  }

  .ops-platform-demo-new__message + .ops-platform-demo-new__message {
    margin-top: 30px;
  }

  .ops-platform-demo-new__message {
    display: flex;
    align-items: flex-start;
    gap: 6px;
  }

  .ops-platform-demo-new__message--request,
  .ops-platform-demo-new__message--assistant {
    max-height: 0;
    margin-top: 0;
    opacity: 0;
    overflow: hidden;
    transform: translateY(10px);
    transition:
      opacity 280ms ease,
      transform 280ms ease,
      max-height 280ms ease,
      margin-top 280ms ease;
  }

  .ops-platform-demo-new[data-state="request-visible"] .ops-platform-demo-new__message--request,
  .ops-platform-demo-new[data-state="typing"] .ops-platform-demo-new__message--request,
  .ops-platform-demo-new[data-state="row-inserted"] .ops-platform-demo-new__message--request,
  .ops-platform-demo-new[data-state="response-visible"] .ops-platform-demo-new__message--request,
  .ops-platform-demo-new[data-state="hold"] .ops-platform-demo-new__message--request {
    max-height: 120px;
    margin-top: 30px;
    opacity: 1;
    transform: translateY(0);
  }

  .ops-platform-demo-new[data-state="typing"] .ops-platform-demo-new__message--assistant,
  .ops-platform-demo-new[data-state="row-inserted"] .ops-platform-demo-new__message--assistant,
  .ops-platform-demo-new[data-state="response-visible"] .ops-platform-demo-new__message--assistant,
  .ops-platform-demo-new[data-state="hold"] .ops-platform-demo-new__message--assistant {
    max-height: 240px;
    margin-top: 30px;
    opacity: 1;
    transform: translateY(0);
  }

  .ops-platform-demo-new__avatar,
  .ops-platform-demo-new__assistant-avatar {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    border-radius: 999px;
  }

  .ops-platform-demo-new__avatar {
    display: block;
  }

  .ops-platform-demo-new__assistant-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #467db4;
    padding: 4px;
  }

  .ops-platform-demo-new__assistant-avatar-icon {
    width: 16px;
    height: 16px;
    display: block;
  }

  .ops-platform-demo-new__message-body {
    display: flex;
    min-width: 0;
    flex: 1;
    flex-direction: column;
    gap: 10px;
  }

  .ops-platform-demo-new__message-meta {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ops-platform-demo-new__message-author,
  .ops-platform-demo-new__message-time,
  .ops-platform-demo-new__message-copy,
  .ops-platform-demo-new__composer-copy,
  .ops-platform-demo-new__requests-title,
  .ops-platform-demo-new__filter,
  .ops-platform-demo-new__table-cell,
  .ops-platform-demo-new__status,
  .ops-platform-demo-new__new-badge,
  .ops-platform-demo-new__chat-title {
    margin: 0;
    font-family: var(--font-sans);
  }

  .ops-platform-demo-new__message-author {
    font-size: 13px;
    font-weight: 400;
    line-height: 1;
    color: #202020;
  }

  .ops-platform-demo-new__message-time {
    font-size: 13px;
    font-weight: 400;
    line-height: 1;
    color: #666663;
  }

  .ops-platform-demo-new__message-copy {
    font-size: 13px;
    font-weight: 400;
    line-height: normal;
    color: #3f3f3f;
  }

  .ops-platform-demo-new__assistant-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ops-platform-demo-new__assistant-body--analysis {
    gap: 4px;
  }

  .ops-platform-demo-new__assistant-body--final {
    display: none;
  }

  .ops-platform-demo-new[data-state="typing"] .ops-platform-demo-new__assistant-body--analysis,
  .ops-platform-demo-new[data-state="row-inserted"] .ops-platform-demo-new__assistant-body--analysis {
    display: flex;
  }

  .ops-platform-demo-new[data-state="response-visible"] .ops-platform-demo-new__assistant-body--analysis,
  .ops-platform-demo-new[data-state="hold"] .ops-platform-demo-new__assistant-body--analysis {
    display: none;
  }

  .ops-platform-demo-new[data-state="response-visible"] .ops-platform-demo-new__assistant-body--final,
  .ops-platform-demo-new[data-state="hold"] .ops-platform-demo-new__assistant-body--final {
    display: flex;
  }

  .ops-platform-demo-new__analysis-line--step {
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 220ms ease, transform 220ms ease;
  }

  .ops-platform-demo-new[data-analysis-step="1"] [data-analysis-line="1"],
  .ops-platform-demo-new[data-analysis-step="2"] [data-analysis-line="1"],
  .ops-platform-demo-new[data-analysis-step="3"] [data-analysis-line="1"],
  .ops-platform-demo-new[data-analysis-step="2"] [data-analysis-line="2"],
  .ops-platform-demo-new[data-analysis-step="3"] [data-analysis-line="2"],
  .ops-platform-demo-new[data-analysis-step="3"] [data-analysis-line="3"],
  .ops-platform-demo-new[data-state="row-inserted"] .ops-platform-demo-new__analysis-line--step,
  .ops-platform-demo-new[data-state="response-visible"] .ops-platform-demo-new__analysis-line--step,
  .ops-platform-demo-new[data-state="hold"] .ops-platform-demo-new__analysis-line--step {
    opacity: 1;
    transform: translateY(0);
  }

  .ops-platform-demo-new__assistant-panel {
    display: flex;
    width: 100%;
    flex-direction: column;
    gap: 0;
    border-radius: 2px;
    background: #f0eee6;
    padding: 6px;
  }

  .ops-platform-demo-new__mention {
    color: #386cf4;
  }

  .ops-platform-demo-new__composer {
    padding: 0 12px 20px;
  }

  .ops-platform-demo-new__composer-active,
  .ops-platform-demo-new__composer-inactive {
    display: flex;
    height: 80px;
    flex-direction: column;
    justify-content: flex-start;
    border: 1px solid #e5e4df;
    border-radius: 6px;
    background: #fafaf7;
    padding: 16px 12px;
  }

  .ops-platform-demo-new__composer-inactive {
    display: none;
  }

  .ops-platform-demo-new[data-state="request-visible"] .ops-platform-demo-new__composer-active,
  .ops-platform-demo-new[data-state="typing"] .ops-platform-demo-new__composer-active,
  .ops-platform-demo-new[data-state="row-inserted"] .ops-platform-demo-new__composer-active,
  .ops-platform-demo-new[data-state="response-visible"] .ops-platform-demo-new__composer-active,
  .ops-platform-demo-new[data-state="hold"] .ops-platform-demo-new__composer-active {
    display: none;
  }

  .ops-platform-demo-new[data-state="request-visible"] .ops-platform-demo-new__composer-inactive,
  .ops-platform-demo-new[data-state="typing"] .ops-platform-demo-new__composer-inactive,
  .ops-platform-demo-new[data-state="row-inserted"] .ops-platform-demo-new__composer-inactive,
  .ops-platform-demo-new[data-state="response-visible"] .ops-platform-demo-new__composer-inactive,
  .ops-platform-demo-new[data-state="hold"] .ops-platform-demo-new__composer-inactive {
    display: flex;
  }

  .ops-platform-demo-new__composer-copy {
    font-size: 13px;
    font-weight: 400;
    line-height: normal;
    color: #3f3f3f;
  }

  .ops-platform-demo-new__composer-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: auto;
  }

  .ops-platform-demo-new__send-button {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 0;
    border-radius: 5px;
    background: #386cf4;
    padding: 5px 6px;
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    line-height: normal;
    color: #ffffff;
    cursor: pointer;
    transition:
      transform 160ms ease,
      filter 160ms ease,
      background-color 160ms ease;
  }

  .ops-platform-demo-new__send-button:hover {
    filter: brightness(0.96);
  }

  .ops-platform-demo-new__send-button:focus-visible {
    outline: 2px solid #386cf4;
    outline-offset: 2px;
  }

  .ops-platform-demo-new[data-state="send-pressed"] .ops-platform-demo-new__send-button {
    transform: scale(0.96);
    filter: brightness(0.92);
  }

  .ops-platform-demo-new__send-button--inactive {
    background: #bfbfba;
    cursor: default;
    pointer-events: none;
  }

  .ops-platform-demo-new__send-icon {
    width: 11.603px;
    height: 12.996px;
    display: block;
    color: currentColor;
  }

  .ops-platform-demo-new__requests-panel {
    border-radius: 6px;
    background: rgb(255 255 255 / 0.9);
    padding: 20px;
    opacity: 0.8;
    transition: opacity 320ms ease;
  }

  .ops-platform-demo-new[data-panel-active="true"] .ops-platform-demo-new__requests-panel {
    opacity: 1;
  }

  .ops-platform-demo-new__requests-heading {
    margin-bottom: 16px;
  }

  .ops-platform-demo-new__requests-title {
    font-size: 16px;
    font-weight: 500;
    line-height: 20px;
    color: #191919;
  }

  .ops-platform-demo-new__filters {
    display: flex;
    gap: 16px;
    margin-bottom: 16px;
  }

  .ops-platform-demo-new__filter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 20px;
    padding: 6px 0;
    font-size: 13px;
    font-weight: 400;
    line-height: 20px;
    color: #191919;
  }

  .ops-platform-demo-new__filter--active {
    background: #e5e4df;
    padding: 6px 12px;
  }

  .ops-platform-demo-new__table {
    overflow: hidden;
    border: 1px solid #e5e4df;
    border-radius: 6px;
    background: #fafaf7;
  }

  .ops-platform-demo-new__table-row {
    display: grid;
    grid-template-columns: minmax(0, 320px) minmax(0, 1fr) 130px 130px;
    align-items: center;
    min-height: 37px;
    border-top: 0.5px solid #e5e4df;
  }

  .ops-platform-demo-new__table-row--header {
    min-height: 35px;
    border-top: 0;
  }

  .ops-platform-demo-new__table-row--new {
    min-height: 0;
    max-height: 0;
    border-top: 0;
    background: #f0eee6;
