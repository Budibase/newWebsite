<script define:vars={{ id }}>
  (() => {
    const root = document.getElementById(id);
    if (!root) return;

    const sendButton = root.querySelector("[data-ops-send]");
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let timers = [];
    let isRunning = false;
    let hasAutoPlayed = false;
    let observer;

    function clearTimers() {
      timers.forEach((timer) => window.clearTimeout(timer));
      timers = [];
    }

    function queue(fn, delay) {
      const timer = window.setTimeout(fn, delay);
      timers.push(timer);
    }

    function setState(state) {
      root.dataset.state = state;
    }

    function setAnalysisStep(step) {
      root.dataset.analysisStep = String(step);
    }

    function setPanelActive(isActive) {
      root.dataset.panelActive = String(isActive);
    }

    function resetToIdle() {
      setState("idle");
      setAnalysisStep(0);
      setPanelActive(false);
      isRunning = false;
    }

    function showFinalState() {
      clearTimers();
      setState("hold");
      setAnalysisStep(3);
      setPanelActive(true);
      isRunning = false;
    }

    function startSequence() {
      if (prefersReducedMotion.matches || isRunning) return;

      clearTimers();
      isRunning = true;
      setState("send-pressed");
      setAnalysisStep(0);
      setPanelActive(false);

      queue(() => setState("request-visible"), 1000);
      queue(() => setState("typing"), 2000);
      queue(() => setAnalysisStep(1), 2500);
      queue(() => setAnalysisStep(2), 3000);
      queue(() => setPanelActive(true), 3000);
      queue(() => setAnalysisStep(3), 3500);
      queue(() => setState("row-inserted"), 4000);
      queue(() => setState("response-visible"), 4420);
      queue(() => setState("hold"), 4700);
      queue(resetToIdle, 12700);
    }

    sendButton?.addEventListener("click", () => {
      if (prefersReducedMotion.matches || isRunning) return;
      startSequence();
    });

    observer = new IntersectionObserver(
      (entries) => {
        const entry = entries[0];
        if (!entry?.isIntersecting || hasAutoPlayed) return;

        hasAutoPlayed = true;
        observer?.disconnect();

        if (prefersReducedMotion.matches) {
          showFinalState();
          return;
        }

        queue(startSequence, 500);
      },
      { threshold: 0.35 },
    );

    observer.observe(root);

    prefersReducedMotion.addEventListener?.("change", (event) => {
      if (event.matches) {
        showFinalState();
      } else {
        resetToIdle();
      }
    });
  })();
</script>
