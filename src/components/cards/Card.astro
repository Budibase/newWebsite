---
import Link from "@components/Link.astro";
import Tag from "@components/Tag.astro";
import ArrowUpRight from "phosphor-astro/ArrowUpRight.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  label: string;
  description: string;
  linkUrl?: string;
  tag?: string;
  imageSrc?: ImageMetadata;
  imageAlt?: string;
  imagePlaceholderColor?: string;
}

const {
  label,
  description,
  linkUrl,
  tag,
  imageSrc,
  imageAlt = label,
  imagePlaceholderColor,
} = Astro.props as Props;

const hasImageOverlay = Astro.slots.has("image-overlay");
---

{linkUrl ? (
  <Link url={linkUrl} label="" ariaLabel={label} class="card-link" target="_blank">
    <div class="card bg-secondary ease-in-out duration-50 hover:bg-stone-200! dark:hover:bg-stone-800! p-4 rounded-md">
      <div class="card-content">
        {tag && <Tag label={tag} variant="secondary" size="small" class="w-fit mb-2" />}
        <h3 class="text-lg! card-title">
          {label}
          {linkUrl && (
            <ArrowUpRight class="card-icon text-stone-600 dark:text-stone-400" />
          )}
        </h3>
        <p class="text-stone-500! dark:text-stone-400!">{description}</p>
        {(imageSrc || imagePlaceholderColor || hasImageOverlay) && (
          <div class="card-image-wrap">
            {imageSrc && (
              <Image
                src={imageSrc}
                alt={imageAlt}
                class="card-image rounded-sm"
                loading="lazy"
              />
            )}
            {!imageSrc && imagePlaceholderColor && (
              <div
                class="card-image rounded-sm"
                role="img"
                aria-label={imageAlt}
                style={`background-color: ${imagePlaceholderColor};`}
              ></div>
            )}
            <slot name="image-overlay" />
          </div>
        )}
      </div>
    </div>
  </Link>
) : (
  <div class="card bg-secondary ease-in-out duration-50 p-4 rounded-md">
    <div class="card-content">
      {tag && <Tag label={tag} variant="secondary" size="small" class="w-fit mb-2" />}
      <h3 class="text-lg!">{label}</h3>
      <p class="text-stone-500! dark:text-stone-400! text-sm!">{description}</p>
      {(imageSrc || imagePlaceholderColor || hasImageOverlay) && (
        <div class="card-image-wrap">
          {imageSrc && (
            <Image
              src={imageSrc}
              alt={imageAlt}
              class="card-image rounded-sm"
              loading="lazy"
            />
          )}
          {!imageSrc && imagePlaceholderColor && (
            <div
              class="card-image rounded-sm"
              role="img"
              aria-label={imageAlt}
              style={`background-color: ${imagePlaceholderColor};`}
            ></div>
          )}
          <slot name="image-overlay" />
        </div>
      )}
    </div>
  </div>
)}

<style>
  .card {
    border: 1px solid var(--border);
  }

  .card-link {
    display: block !important;
    text-decoration: none;
    width: 100%;
  }

  .card-link :global(.alink) {
    display: block !important;
    width: 100%;
    font-size: 0;
  }


  .card-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .card-content h3 {
    line-height: 1.2;
  }

  .card-title {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .card-icon {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  .card-icon :global(*) {
    color: inherit;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-image-wrap {
    width: 100%;
    height: 300px;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    overflow: hidden;
    position: relative;
  }

</style>
