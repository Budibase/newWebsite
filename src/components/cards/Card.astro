---
import Link from "@components/Link.astro";
import Tag from "@components/Tag.astro";
import ArrowUpRight from "phosphor-astro/ArrowUpRight.astro";
import type { ImageMetadata } from "astro";

interface Props {
  label: string;
  description?: string;
  class?: string;
  cardContentClass?: string;
  cardTitleClass?: string;
  linkUrl?: string;
  openInNewTab?: boolean;
  showLinkIcon?: boolean;
  truncateDescription?: boolean;
  tagPosition?: "top" | "bottom";
  tagNoPadding?: boolean;
  tag?: string;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
  imagePlaceholderColor?: string;
}

const {
  label,
  description = "",
  class: className = "",
  cardContentClass = "",
  cardTitleClass = "",
  linkUrl,
  openInNewTab = true,
  showLinkIcon = true,
  truncateDescription = false,
  tagPosition = "top",
  tagNoPadding = false,
  tag,
  imageSrc,
  imageAlt = label,
  imagePlaceholderColor,
} = Astro.props as Props;

const hasImageOverlay = Astro.slots.has("image-overlay");
const showTagAtTop = Boolean(tag) && tagPosition === "top";
const showTagAtBottom = Boolean(tag) && tagPosition === "bottom";
const tagClass = tagNoPadding ? "w-fit !px-0 !py-0" : "w-fit";
const descriptionStyle = truncateDescription
  ? "white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
  : undefined;
const resolvedImageSrc =
  typeof imageSrc === "string" ? imageSrc : imageSrc?.src;
---

{
  linkUrl ? (
    <Link
      url={linkUrl}
      label=""
      ariaLabel={label}
      class="card-link"
      target={openInNewTab ? "_blank" : "_self"}
    >
      <div
        class={`card w-full max-w-full min-w-0 bg-secondary ease-in-out duration-50 hover:bg-stone-200!  p-4 rounded-md ${className}`}
      >
        <div class={`card-content ${cardContentClass}`}>
          {showTagAtTop && (
            <Tag
              label={tag!}
              variant="secondary"
              size="small"
              class={`${tagClass} mb-2`}
            />
          )}
          <h3 class={`text-lg! card-title ${cardTitleClass}`}>
            {label}
            {linkUrl && showLinkIcon && (
              <ArrowUpRight class="card-icon text-stone-600 " />
            )}
          </h3>
          {description && (
            <p class="w-full min-w-0 text-stone-500! " style={descriptionStyle}>
              {description}
            </p>
          )}
          <slot />
          {showTagAtBottom && (
            <Tag
              label={tag!}
              variant="secondary"
              size="small"
              class={tagClass}
            />
          )}
          {(imageSrc || imagePlaceholderColor || hasImageOverlay) && (
            <div class="card-image-wrap">
              {resolvedImageSrc && (
                <img
                  src={resolvedImageSrc}
                  alt={imageAlt}
                  class="card-image rounded-sm"
                  loading="lazy"
                />
              )}
              {!resolvedImageSrc && imagePlaceholderColor && (
                <div
                  class="card-image rounded-sm"
                  role="img"
                  aria-label={imageAlt}
                  style={`background-color: ${imagePlaceholderColor};`}
                />
              )}
              <slot name="image-overlay" />
            </div>
          )}
        </div>
      </div>
    </Link>
  ) : (
    <div
      class={`card w-full max-w-full min-w-0 bg-secondary ease-in-out duration-50 p-4 rounded-md ${className}`}
    >
      <div class={`card-content ${cardContentClass}`}>
        {showTagAtTop && (
          <Tag
            label={tag!}
            variant="secondary"
            size="small"
            class={`${tagClass} mb-2`}
          />
        )}
        <h3 class={`text-lg! card-title ${cardTitleClass}`}>{label}</h3>
        {description && (
          <p
            class="w-full min-w-0 text-stone-500!  text-sm!"
            style={descriptionStyle}
          >
            {description}
          </p>
        )}
        <slot />
        {showTagAtBottom && (
          <Tag label={tag!} variant="secondary" size="small" class={tagClass} />
        )}
        {(imageSrc || imagePlaceholderColor || hasImageOverlay) && (
          <div class="card-image-wrap">
            {resolvedImageSrc && (
              <img
                src={resolvedImageSrc}
                alt={imageAlt}
                class="card-image rounded-sm"
                loading="lazy"
              />
            )}
            {!resolvedImageSrc && imagePlaceholderColor && (
              <div
                class="card-image rounded-sm"
                role="img"
                aria-label={imageAlt}
                style={`background-color: ${imagePlaceholderColor};`}
              />
            )}
            <slot name="image-overlay" />
          </div>
        )}
      </div>
    </div>
  )
}

<style>
  .card {
    border: 1px solid var(--border);
    min-width: 0;
    overflow: hidden;
  }

  .card-link {
    display: block !important;
    text-decoration: none;
    width: 100% !important;
    min-width: 0;
  }

  .card-link:global(.alink),
  :global(a.card-link.alink) {
    display: block !important;
    width: 100% !important;
    min-width: 0;
  }

  .card-link > .card {
    width: 100%;
    min-width: 0;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .card-content h3 {
    line-height: 1.2;
    min-width: 0;
    max-width: 100%;
  }

  .card-content p {
    min-width: 0;
    max-width: 100%;
  }

  .card-title {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .card-icon {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  .card-icon :global(*) {
    color: inherit;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    margin: auto;
  }

  .card-image-wrap {
    height: 100%;
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    overflow: hidden;
    position: relative;
  }
</style>
