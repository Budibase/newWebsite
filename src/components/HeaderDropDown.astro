---
interface Props {
  label: string;
  labelHref?: string;
  items: Array<{
    href: string;
    label: string;
    prefetch?: boolean;
    badge?: string;
    description?: string;
    target?: string;
    rel?: string;
    disabled?: boolean;
  }>;
}

const useTwoColumns = Astro.props.items.length > 4;
---

<header-drop-down>
  <details class="group relative">
    <summary class="accordion cursor-pointer link flex items-center gap-2 text-sm px-1 text-primary hover:text-primary group-open:text-primary transition-colors">
      {Astro.props.labelHref ? (
        <a
          href={Astro.props.labelHref}
          class="flex items-center gap-2"
          data-astro-prefetch
          onclick="event.stopPropagation()"
        >
          {Astro.props.label}
        </a>
      ) : (
        Astro.props.label
      )}
    </summary>
    <ul
      class:list={[
        useTwoColumns
          ? "grid grid-cols-[repeat(2,auto)] gap-y-[6px] gap-x-[6px]"
          : "flex flex-col gap-[6px]",
        "absolute left-0 top-full translate-y-2",
        "w-fit max-w-[calc(100vw-2rem)] bg-secondary pt-2 px-[15px] pb-3 text-base shadow-xl ring-1 ring-stone-200/60 dark:ring-stone-800/60",
        "invisible group-open:visible group-hover:visible",
        "origin-top scale-95 group-open:scale-100 group-hover:scale-100",
        "opacity-0 group-open:opacity-100 group-hover:opacity-100",
        "transition-all duration-300",
      ]}
    >
      {
        Astro.props.items.map(
          ({
            href,
            label,
            prefetch,
            badge,
            target,
            rel,
            disabled,
          }) => (
            <li class="min-w-[7.5rem]">
              {disabled ? (
                <span
                  aria-disabled="true"
                  class="nav__sub-nav__link inline-flex cursor-not-allowed items-center gap-2 py-[2px] text-sm font-medium text-primary"
                >
                  <span>{label}</span>
                  {badge && (
                    <span class="text-xs leading-none font-mono text-primary">
                      {badge}
                    </span>
                  )}
                </span>
              ) : (
                <a
                  href={href}
                  target={target}
                  rel={rel ??
                    (target === "_blank" ? "noopener noreferrer" : undefined)}
                  data-astro-prefetch={prefetch ? "" : undefined}
                  class="nav__sub-nav__link inline-flex items-center gap-2 py-[2px] text-sm font-medium transition-colors text-primary hover:text-primary"
                >
                  <span>{label}</span>
                  {badge && (
                    <span class="text-xs leading-none font-mono text-primary">
                      {badge}
                    </span>
                  )}
                </a>
              )}
            </li>
          ),
        )
      }
    </ul>
  </details>
</header-drop-down>

<script>
  if (!customElements.get("header-drop-down")) {
    customElements.define(
      "header-drop-down",
      class HeaderDropDown extends HTMLElement {
        connectedCallback() {
          const menu = this.querySelector("details");
          if (!menu) return;

          let hoverTimeout;

          this.addEventListener("mouseenter", () => {
            clearTimeout(hoverTimeout);
            menu.open = true;
          });

          this.addEventListener("mouseleave", () => {
            hoverTimeout = setTimeout(() => {
              if (!menu.matches(":focus-within")) {
                menu.open = false;
              }
            }, 200);
          });

          menu.addEventListener("focusout", () => {
            if (!menu.matches(":focus-within")) {
              setTimeout(() => {
                menu.open = false;
              }, 200);
            }
          });
        }
      },
    );
  }
</script>
