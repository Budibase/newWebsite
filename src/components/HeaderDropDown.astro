---
import CaretDown from "phosphor-astro/CaretDown.astro";
import Icon from "@components/Icon.astro";


interface Props {
	label: string;
	items: Array<{
		href: string;
		label: string;
		prefetch?: boolean;
		badge?: string;
	}>;
}
---

<header-drop-down>
	<details class="group relative">
		<summary class="accordion cursor-pointer link flex items-center gap-2 text-sm px-1 text-stone-900 dark:text-stone-400 hover:text-stone-700 dark:hover:text-stone-200 transition-colors">
			{Astro.props.label}
		</summary>
		<ul
			class:list={[
				// grid
				'grid grid-cols-2 gap-x-3',

				// positioning
				'absolute left-0 top-full translate-y-2',

				// panel styling
				'min-w-80 rounded-lg bg-secondary p-1 text-stone-900 dark:text-stone-100 text-sm',

				// transitioning
				'invisible group-open:visible group-hover:visible',
				'origin-top scale-95 group-open:scale-100 group-hover:scale-100',
				'opacity-0 group-open:opacity-100 group-hover:opacity-100',
				'transition-all duration-300',
			]}
		>
			<slot />
			{
				Astro.props.items.map(({ href, label, prefetch, badge }) => (
					<li>
						<a
							{href}
							data-astro-prefetch={prefetch ? '' : undefined}
							class="flex items-center gap-2 rounded-md p-3 leading-none transition-colors text-stone-900 dark:text-stone-100 hover:bg-stone-200 dark:hover:bg-stone-800 hover:text-stone-900 dark:hover:text-stone-50"
						>
							{label}
							{badge && (
								<span class="text-xs leading-none font-mono py-1 px-1.5 rounded text-stone-600 dark:text-stone-400">
									{badge}
								</span>
							)}
						</a>
					</li>
				))
			}
		</ul>
	</details>
</header-drop-down>

<script>
	customElements.define(
		'header-drop-down',
		class HeaderDropDown extends HTMLElement {
			connectedCallback() {
				const menu = this.querySelector('details');
				if (menu) {
					// Handle hover to open/close dropdown
					let hoverTimeout: NodeJS.Timeout;
					
					this.addEventListener('mouseenter', () => {
						clearTimeout(hoverTimeout);
						menu.open = true;
					});
					
					this.addEventListener('mouseleave', () => {
						hoverTimeout = setTimeout(() => {
							if (!menu.matches(':focus-within')) {
								menu.open = false;
							}
						}, 200);
					});
					
					// Handle focusout for keyboard navigation
					menu.addEventListener('focusout', () => {
						if (!menu.matches(':focus-within')) {
							// delay the transition on focusout so the menu doesn't immediately disappear
							setTimeout(() => {
								menu.open = false;
							}, 200);
						}
					});
				}
			}
		},
	);
</script>