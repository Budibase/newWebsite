---
// Theme toggle component with three options: system, light, and dark
// Follows Tailwind CSS dark mode pattern: https://tailwindcss.com/docs/dark-mode
import Icon from "@components/Icon.astro";
---

<div
  class="flex bg-stone-100 dark:bg-stone-900 rounded-lg p-0.5 gap-0.5"
  role="group"
  aria-label="Theme selection"
>
  <!-- Hidden element to ensure Tailwind includes dynamically added classes -->
  <div class="hidden bg-stone-700 dark:bg-stone-600 text-stone-50 dark:text-stone-50"></div>
  
  <button
    type="button"
    class="theme-button flex items-center justify-center w-8 h-8 p-0 border-none bg-transparent rounded-md cursor-pointer transition-all duration-150 text-stone-600 dark:text-stone-400 hover:bg-stone-200 dark:hover:bg-stone-800 hover:text-stone-800 dark:hover:text-stone-200"
    data-theme="system"
    aria-label="System theme"
    title="Use system theme"
  >
    <Icon name="Monitor" size="16" class="w-4 h-4" />
  </button>
  <button
    type="button"
    class="theme-button flex items-center justify-center w-8 h-8 p-0 border-none bg-transparent rounded-md cursor-pointer transition-all duration-150 text-stone-600 dark:text-stone-400 hover:bg-stone-200 dark:hover:bg-stone-800 hover:text-stone-800 dark:hover:text-stone-200"
    data-theme="light"
    aria-label="Light theme"
    title="Light theme"
  >
    <Icon name="Sun" size="16" class="w-4 h-4" />
  </button>
  <button
    type="button"
    class="theme-button flex items-center justify-center w-8 h-8 p-0 border-none bg-transparent rounded-md cursor-pointer transition-all duration-150 text-stone-600 dark:text-stone-400 hover:bg-stone-200 dark:hover:bg-stone-800 hover:text-stone-800 dark:hover:text-stone-200"
    data-theme="dark"
    aria-label="Dark theme"
    title="Dark theme"
  >
    <Icon name="Moon" size="16" class="w-4 h-4" />
  </button>
</div>

<script>
  // @ts-nocheck
  (function () {
    // Get effective theme (resolves system preference)
    function getEffectiveTheme() {
      const stored = localStorage.getItem("theme");
      if (stored === "dark" || stored === "light") {
        return stored;
      }
      // System preference
      return window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    }

    // Apply theme to document (without transitions to prevent flicker)
    function applyTheme(skipTransitions = false) {
      if (skipTransitions) {
        document.documentElement.classList.add("no-transitions");
      }
      
      const effectiveTheme = getEffectiveTheme();
      if (effectiveTheme === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
      
      if (skipTransitions) {
        // Force reflow to ensure the class is applied
        void document.documentElement.offsetHeight;
        document.documentElement.classList.remove("no-transitions");
      }
      
      updateActiveButton();
    }

    // Update which button is active
    function updateActiveButton() {
      const themeSwitcher = document.querySelector('[role="group"][aria-label="Theme selection"]');
      if (!themeSwitcher) return;
      
      const buttons = themeSwitcher.querySelectorAll(".theme-button");
      const stored = localStorage.getItem("theme") || "system";
      
      buttons.forEach((button) => {
        const theme = button.getAttribute("data-theme");
        if (theme === stored) {
          // Active state: darker in light mode, lighter in dark mode
          button.classList.add("bg-stone-200", "dark:bg-stone-800", "text-stone-950", "dark:text-stone-50");
          button.classList.remove("text-stone-600", "dark:text-stone-400", "bg-transparent");
        } else {
          button.classList.remove("bg-stone-700", "dark:bg-stone-600", "text-stone-50", "dark:text-stone-50");
          button.classList.add("text-stone-600", "dark:text-stone-400", "bg-transparent");
        }
      });
    }

    // Set theme preference
    /**
     * @param {string} theme
     */
    function setTheme(theme) {
      if (theme === "system") {
        localStorage.removeItem("theme");
      } else {
        localStorage.setItem("theme", theme);
      }
      // Skip transitions when manually switching to prevent flicker
      applyTheme(true);
    }

    // Initialize theme and button state
    function init() {
      const themeSwitcher = document.querySelector('[role="group"][aria-label="Theme selection"]');
      if (!themeSwitcher) return;

      const buttons = themeSwitcher.querySelectorAll(".theme-button");
      
      // Apply theme
      applyTheme();

      // Handle button clicks
      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const theme = button.getAttribute("data-theme");
          if (theme) {
            setTheme(theme);
          }
        });
      });
    }

    // Initialize on load
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }

    // Re-apply theme on Astro view transitions (client-side navigation)
    // Use astro:after-swap instead of astro:page-load to prevent flicker
    // Solution based on: https://medium.com/@maiowebdesign/astro-dark-mode-flickering-62da94d08ce6
    document.addEventListener("astro:after-swap", () => {
      // Apply theme immediately after DOM swap (before rendering)
      applyTheme(true);
      // Re-initialize button listeners in case DOM was replaced
      setTimeout(init, 0);
    });

    // Listen for system theme changes (only if system theme is selected)
    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", () => {
        // Only update if system theme is selected
        if (!localStorage.getItem("theme")) {
          applyTheme();
        }
      });
  })();
</script>

<style>
  /* Disable transitions during theme switch to prevent flicker */
  .no-transitions,
  .no-transitions *,
  .no-transitions *::before,
  .no-transitions *::after {
    transition: none !important;
    animation: none !important;
  }
</style>

