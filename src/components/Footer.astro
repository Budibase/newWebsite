---
import Link from "@components/Link.astro";
import Check from "phosphor-astro/CheckCircle.astro";
import GlobeSimple from "phosphor-astro/GlobeSimple.astro";
import Certificate from "phosphor-astro/Certificate.astro";

interface FooterLink {
  label: string;
  url: string;
  target?: string;
}

interface FooterColumn {
  title: string;
  links: FooterLink[];
}

const footerColumns: FooterColumn[] = [
  {
    title: "Product",
    links: [
      { label: "Agents", url: "/product/agents/" },
      { label: "Automations", url: "/product/automations/" },
      { label: "Apps", url: "/product/apps/" },
      { label: "Pricing", url: "/pricing/" },
      { label: "Use cases", url: "/ops/" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Blog", url: "/blog/" },
      { label: "Changelog", url: "/changelog/" },
      { label: "Customers", url: "/customers/" },
      { label: "Docs", url: "https://docs.budibase.com", target: "_blank" },
      { label: "Security", url: "/security/" },
      { label: "IT Teams", url: "/it/" },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Support Policy", url: "/support/" },
      { label: "Terms of Service", url: "/terms/" },
      { label: "Privacy Policy", url: "/privacy/" },
    ],
  },
  {
    title: "Connect",
    links: [
      {
        label: "Discord",
        url: "https://discord.com/invite/budibase-733030666647765003",
        target: "_blank",
      },
      {
        label: "LinkedIn",
        url: "https://linkedin.com/company/budibase",
        target: "_blank",
      },
      {
        label: "YouTube",
        url: "https://youtube.com/@budibase",
        target: "_blank",
      },
      {
        label: "Partners",
        url: "/partners/"
      },
    ],
  },
];
---

<footer
  class="footer bg-1 border-t-[0.5px] chrome-border"
  transition:persist
  transition:name="site-footer"
>
  <div class="footer-container mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0">
    <!-- Upper section: Navigation columns -->
    <div class="footer-nav">
      {
        footerColumns.map((column) => (
          <div class="footer-column">
            <p>{column.title}</p>
            <ul class="text-stone-500! flex flex-col gap-1.5! sm:gap-0.5!">
              {column.links.map((link) => (
                <li>
                  <Link
                    label={link.label}
                    url={link.url}
                    target={link.target}
                    variant="secondary"
                    size="small"
                    class="footer-link min-h-12 py-1.5 sm:min-h-0 sm:py-0"
                  />
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Lower section: Copyright and controls -->
    <div class="footer-bottom">
      <div class="footer-copyright">
        <span>© 2025 Budibase, Inc.</span>
        <span class="footer-certification">
          <Certificate class="footer-check-icon" />
          <span>ISO 27001 Certified</span>
        </span>
        <span class="footer-certification">
          <Check class="footer-check-icon" />
          <span>GDPR Compliant</span>
        </span>
        <span class="footer-certification">
          <GlobeSimple class="footer-check-icon" />
          <span>Made in Europe</span>
        </span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 2rem 0 1.5rem;
    margin-top: auto;
  }

  @media (min-width: 640px) {
    .footer {
      padding: 3rem 0 1.5rem;
    }
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .footer-nav {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 2.5rem;
      margin-bottom: 3rem;
    }
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding-top: 1.5rem;
  }

  .footer-copyright {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 12px;
    color: var(--text-primary);
  }

  @media (min-width: 640px) {
    .footer-copyright {
      gap: 1rem;
      font-size: 14px;
    }
  }

  .footer-certification {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .footer-check-icon {
    width: 16px;
    height: 16px;
    color: var(--text-secondary);
  }

  .footer-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .footer-controls {
      width: 100%;
      justify-content: flex-start;
    }
  }

</style>
