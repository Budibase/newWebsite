---
import bbSymbol from "../assets/logos/bbSymbol.svg";
import { Image } from 'astro:assets';
---

<div class="flex justify-between items-center pt-8 md:pt-14 px-2 flex-wrap gap-2 container max-w-3xl mx-auto ">
    <div class="relative">
        <div class="flex items-center">
            <a href="/">
                <div class="w-8 h-8">
                    <Image src={bbSymbol} alt="Budibase symbol" class="hover:cursor-pointer">
                </div>
            </a>
        </div>
    </div>
    <div class="flex flex-wrap gap-0 md:gap-2">
        <div class="flex rounded-full p-1 transition-all">
            <a target="_self" href="/pricing" data-astro-prefetch>
                <div class="py-1 pl-1 md:pl-2 pr-1 md:pr-2 rounded-full transition-all font-medium bg-transparent text-stone-700">
                    Workflows
                </div>
            </a>
            <a target="_self" href="/pricing" data-astro-prefetch>
                <div class="py-1 pl-1 md:pl-2 pr-1 md:pr-2 rounded-full transition-all font-medium bg-transparent text-stone-700">
                    Pricing
                </div>
            </a>
            <a target="_self" href="/blog" data-astro-prefetch>
                <div class="py-1 pl-1 md:pl-2 pr-1 md:pr-2 rounded-full transition-all font-medium bg-transparent text-stone-700 ">
                    Resources +
                </div>
            </a>
        </div>
        <div class="flex p-1 gap-2">
            <a target="_self" href="/talk-to-our-team">
                <button class="secondary">
                    Sign in
                </button>
            </a>
            <a href="/talk-to-our-team">
                <button class="primary">
                    Try for free
                </button>
            </a>
        </div>
    </div>
</div>
