---
import { Image } from "astro:assets";
import Icon from "@components/Icon.astro";
import BudibaseSymbol from "@assets/BBSymbolWhite.svg";
import DiscordLogo from "@assets/logos/discord.svg";
import SlackLogo from "@assets/logos/Slack.svg";
import TeamsLogo from "@assets/logos/microsoft-teams.svg";

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props as Props;

---

<div class={`agent-channels-overlay${className ? ` ${className}` : ""}`} data-node-id="2943:15268">
  <div class="agent-channels-overlay-panel">
    <div class="agent-channels-overlay-row">
      <div class="agent-channels-overlay-row-main">
        <Image src={BudibaseSymbol} alt="" class="agent-channels-overlay-icon agent-channels-overlay-icon-chat" />
        <span class="agent-channels-overlay-label">Budibase Chat</span>
      </div>
      <div class="agent-channels-overlay-row-actions">
        <Icon name="Wrench" size="16" class="agent-channels-overlay-gear" />
        <div class="agent-channels-overlay-chip">Enable chat</div>
      </div>
    </div>

    <div class="agent-channels-overlay-row">
      <div class="agent-channels-overlay-row-main">
        <Image src={SlackLogo} alt="" class="agent-channels-overlay-icon agent-channels-overlay-icon-slack" />
        <span class="agent-channels-overlay-label">Slack</span>
      </div>
      <div class="agent-channels-overlay-row-actions">
        <div class="agent-channels-overlay-chip">Connect</div>
      </div>
    </div>

    <div class="agent-channels-overlay-row">
      <div class="agent-channels-overlay-row-main">
        <Image src={TeamsLogo} alt="" class="agent-channels-overlay-icon agent-channels-overlay-icon-teams" />
        <span class="agent-channels-overlay-label">Microsoft Teams</span>
      </div>
      <div class="agent-channels-overlay-row-actions">
        <div class="agent-channels-overlay-chip">Connect</div>
      </div>
    </div>

    <div class="agent-channels-overlay-row">
      <div class="agent-channels-overlay-row-main">
        <Image src={DiscordLogo} alt="" class="agent-channels-overlay-icon agent-channels-overlay-icon-discord" />
        <span class="agent-channels-overlay-label">Discord</span>
      </div>
      <div class="agent-channels-overlay-row-actions">
        <Icon name="Wrench" size="16" class="agent-channels-overlay-gear" />
        <span class="agent-channels-overlay-toggle" aria-hidden="true">
          <span class="agent-channels-overlay-toggle-knob"></span>
        </span>
      </div>
    </div>
  </div>
</div>

<style>
  .agent-channels-overlay {
    width: min(100%, 348px);
    pointer-events: none;
  }

  .agent-channels-overlay-panel {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 6px;
    background: var(--bb-gray-900);
    border: 1px solid var(--bb-gray-800);
    box-shadow: 0 10px 24px var(--bb-transparent-black-300);
  }

  .agent-channels-overlay-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 39px;
    border-top: 1px solid var(--bb-gray-800);
    background: var(--bb-gray-900);
  }

  .agent-channels-overlay-row:first-child {
    border-top: 0;
  }

  .agent-channels-overlay-row-main {
    display: flex;
    min-width: 0;
    flex: 1 1 auto;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
  }

  .agent-channels-overlay-row-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 16px;
    padding: 8px 12px;
    flex-shrink: 0;
    min-width: 96px;
  }

  .agent-channels-overlay-label {
    color: var(--bb-silver-200) !important;
    font-size: 13px;
    font-weight: 400;
    line-height: 17px;
    letter-spacing: 0;
    white-space: nowrap;
  }

  .agent-channels-overlay-icon,
  .agent-channels-overlay-gear,
  .agent-channels-overlay-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .agent-channels-overlay-icon-chat {
    width: 15.91px;
    height: 16.05px;
  }

  .agent-channels-overlay-icon-teams {
    width: 15px;
    height: 16px;
    object-fit: contain;
  }

  .agent-channels-overlay-icon-slack {
    width: 15px;
    height: 15px;
    object-fit: contain;
  }

  .agent-channels-overlay-icon-discord {
    width: 16px;
    height: 12px;
  }

  .agent-channels-overlay-gear {
    width: 16px;
    height: 16px;
    color: var(--bb-gray-400);
  }

  .agent-channels-overlay-toggle {
    width: 27px;
    height: 14px;
    border-radius: 999px;
    background: var(--bb-green-600);
    padding: 2px;
    justify-content: flex-end;
  }

  .agent-channels-overlay-toggle-knob {
    width: 10px;
    height: 10px;
    display: block;
    border-radius: 999px;
    background: var(--bb-white);
  }

  .agent-channels-overlay-chip {
    border: 1px solid var(--bb-gray-800);
    border-radius: 6px;
    padding: 4px 8px;
    color: var(--bb-gray-400) !important;
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0;
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .agent-channels-overlay {
      width: min(100%, 320px);
    }

    .agent-channels-overlay-row-actions {
      min-width: 84px;
      gap: 12px;
    }
  }
</style>
