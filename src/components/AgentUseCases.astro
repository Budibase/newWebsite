---
import AvatarImage from "@assets/images/avatars/Avatar.png?url";
import SupportAvatarImage from "@assets/images/avatars/Ellipse-1.png?url";
import BudibaseSymbol from "@assets/BBSymbolWhite.svg?url";
import GmailLogo from "@assets/logos/Gmail.svg?url";
import TeamsLogo from "@assets/logos/microsoft-teams.svg?url";
import BambooHrLogo from "@assets/logos/bamboohr.svg?url";
import RowsPlusBottomFill from "phosphor-astro/RowsPlusBottomFill.astro";
import PaperPlaneTiltFill from "phosphor-astro/PaperPlaneTiltFill.astro";
import SparkleFill from "phosphor-astro/SparkleFill.astro";
import CheckCircleFill from "phosphor-astro/CheckCircleFill.astro";
import Icon from "@components/Icon.astro";
import SectionBlock from "@components/SectionBlock.astro";
import Tabs from "@components/Tabs.astro";

interface FrameNode {
  title: string;
  description?: string;
  iconKind:
    | "sparkle"
    | "clock"
    | "rowsPlusBottom"
    | "paperPlaneTilt"
    | "teams"
    | "bamboohr";
  iconTone: "trigger" | "agent" | "integration" | "alert";
  badgeLabel?: "Trigger" | "Operation";
  badgeTone?: "trigger" | "operation";
}

interface FrameScenario {
  id: "employee-self-service" | "approval-requests" | "internal-support";
  nodes: FrameNode[];
}

const id = `agent-use-cases-${Math.random().toString(36).slice(2, 8)}`;

const frames: FrameScenario[] = [
  {
    id: "employee-self-service",
    nodes: [
      {
        badgeLabel: "Trigger",
        badgeTone: "trigger",
        title: "Employee request",
        description: "A teammate asks a question in chat",
        iconKind: "sparkle",
        iconTone: "trigger",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Knowledge agent",
        description: "Find the right policy or answer instantly",
        iconKind: "teams",
        iconTone: "integration",
      },
    ],
  },
  {
    id: "approval-requests",
    nodes: [
      {
        badgeLabel: "Trigger",
        badgeTone: "trigger",
        title: "Approval request",
        description: "A new request is submitted for review",
        iconKind: "rowsPlusBottom",
        iconTone: "trigger",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Approval agent",
        description: "Collect context and prepare the workflow",
        iconKind: "bamboohr",
        iconTone: "integration",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Decision routing",
        description: "Send the request to the right approver",
        iconKind: "sparkle",
        iconTone: "agent",
      },
    ],
  },
  {
    id: "internal-support",
    nodes: [
      {
        badgeLabel: "Trigger",
        badgeTone: "trigger",
        title: "Support request",
        description: "A request comes in from an employee",
        iconKind: "paperPlaneTilt",
        iconTone: "trigger",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Support agent",
        description: "Understand the issue and gather details",
        iconKind: "sparkle",
        iconTone: "agent",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Team handoff",
        description: "Route the request to the right team in Slack",
        iconKind: "teams",
        iconTone: "integration",
      },
    ],
  },
];

const tabs = [
  {
    key: "employee-self-service",
    label: "Employee self-service",
    icon: "ChatsCircle",
    iconWeight: "fill",
  },
  {
    key: "approval-requests",
    label: "Approval requests",
    icon: "CheckCircle",
    iconWeight: "fill",
  },
  {
    key: "internal-support",
    label: "Internal support",
    icon: "Headset",
    iconWeight: "fill",
  },
];
---

<section id={id}>
  <div
    class="grid grid-cols-1 gap-8 lg:grid-cols-[minmax(0,1.02fr)_minmax(0,0.98fr)] lg:items-center lg:gap-20"
  >
    <div>
      <Tabs
        tabs={tabs}
        defaultKey="employee-self-service"
        label="Agent use case scenarios"
        class="agent-use-cases-tabs"
      >
        {
          frames.map((frame) => (
            <div data-tab-panel={frame.id}>
              {frame.id === "employee-self-service" ? (
                <div class="agent-use-cases-thread-stage">
                  <div class="agent-use-cases-thread-card">
                    <div class="agent-use-cases-thread-header">
                      <button
                        type="button"
                        class="agent-use-cases-thread-back"
                        aria-label="Back"
                      >
                        <Icon
                          name="CaretLeft"
                          size="20"
                          class="agent-use-cases-thread-back-icon"
                        />
                      </button>
                      <h3 class="agent-use-cases-thread-title">Threads</h3>
                    </div>

                    <div class="agent-use-cases-thread-body">
                      <div class="agent-use-cases-thread-message">
                        <img
                          src={AvatarImage}
                          alt="John Smyth"
                          class="agent-use-cases-thread-avatar"
                        />
                        <div class="agent-use-cases-thread-copy">
                          <div class="agent-use-cases-thread-meta">
                            <p class="agent-use-cases-thread-name">
                              John Smyth
                            </p>
                            <p class="agent-use-cases-thread-time">13 mins</p>
                          </div>
                          <p class="agent-use-cases-thread-text">
                            <span class="agent-use-cases-thread-link">
                              @Ops Assistant
                            </span>
                            <span> Who’s out of office tomorrow?</span>
                          </p>
                        </div>
                      </div>

                      <div class="agent-use-cases-thread-message">
                        <div
                          class="agent-use-cases-thread-badge"
                          aria-hidden="true"
                        >
                          <img
                            src={BudibaseSymbol}
                            alt=""
                            class="agent-use-cases-thread-badge-symbol"
                          />
                        </div>
                        <div class="agent-use-cases-thread-copy">
                          <div class="agent-use-cases-thread-meta">
                            <p class="agent-use-cases-thread-name">
                              Ops Assistant
                            </p>
                            <p class="agent-use-cases-thread-time">12 mins</p>
                          </div>
                          <div class="agent-use-cases-thread-response">
                            <p>Here’s who’s out tomorrow</p>
                            <ul>
                              <li>Sarah (Marketing)</li>
                              <li>David (Sales)</li>
                              <li>Priya (Engineering)</li>
                            </ul>
                            <p>
                              Want me to post this in
                              <span class="agent-use-cases-thread-link">
                                {" "}
                                #team-updates
                              </span>
                              ?
                            </p>
                          </div>
                        </div>
                      </div>
                    </div>

                    <div class="agent-use-cases-thread-input">
                      <div class="agent-use-cases-thread-input-row">
                        <div
                          class="agent-use-cases-thread-input-icon-wrap"
                          aria-hidden="true"
                        >
                          <Icon
                            name="Plus"
                            size="16"
                            class="agent-use-cases-thread-input-icon"
                          />
                        </div>
                        <p class="agent-use-cases-thread-input-text">
                          Add a reply
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              ) : frame.id === "approval-requests" ? (
                <div class="agent-use-cases-approval-stage">
                  <div class="agent-use-cases-approval-form-card">
                    <RowsPlusBottomFill
                      class="agent-use-cases-approval-form-icon"
                      aria-hidden="true"
                    />
                    <h3 class="agent-use-cases-approval-form-title">
                      Access request form
                    </h3>
                    <p class="agent-use-cases-approval-form-label">
                      What would you like access to?
                    </p>
                    <div
                      class="agent-use-cases-approval-select"
                      aria-hidden="true"
                    >
                      <span class="agent-use-cases-approval-select-value">
                        Product data
                      </span>
                      <Icon
                        name="CaretRight"
                        size="18"
                        class="agent-use-cases-approval-select-caret rotate-90"
                      />
                    </div>
                    <div class="agent-use-cases-approval-submit">Submit</div>
                  </div>

                  <div
                    class="agent-use-cases-approval-connector"
                    aria-hidden="true"
                  />

                  <div class="agent-use-cases-approval-info-card">
                    <div
                      class="agent-use-cases-approval-info-icon is-agent"
                      aria-hidden="true"
                    >
                      <SparkleFill class="agent-use-cases-approval-info-icon-image" />
                    </div>
                    <div class="agent-use-cases-approval-info-copy">
                      <p class="agent-use-cases-approval-info-title">
                        Access Agent
                      </p>
                      <p class="agent-use-cases-approval-info-text">
                        Handle employee access requests and approvals
                        automatically.
                      </p>
                    </div>
                  </div>

                  <div
                    class="agent-use-cases-approval-connector"
                    aria-hidden="true"
                  />

                  <div class="agent-use-cases-approval-info-card">
                    <div
                      class="agent-use-cases-approval-info-icon is-gmail"
                      aria-hidden="true"
                    >
                      <img
                        src={GmailLogo}
                        alt=""
                        class="agent-use-cases-approval-gmail-icon"
                      />
                    </div>
                    <div class="agent-use-cases-approval-info-copy">
                      <p class="agent-use-cases-approval-info-title">
                        Gmail notification
                      </p>
                      <p class="agent-use-cases-approval-info-text">
                        The Access Agent has granted you access to Product data.
                      </p>
                    </div>
                  </div>
                </div>
              ) : frame.id === "internal-support" ? (
                <div class="agent-use-cases-thread-stage">
                  <div class="agent-use-cases-thread-card agent-use-cases-support-card">
                    <div class="agent-use-cases-support-header">
                      <img
                        src={TeamsLogo}
                        alt=""
                        class="agent-use-cases-support-header-logo"
                      />
                      <h3 class="agent-use-cases-support-header-title">
                        Microsoft Teams
                      </h3>
                    </div>

                    <div class="agent-use-cases-thread-body agent-use-cases-support-body">
                      <div class="agent-use-cases-thread-message">
                        <img
                          src={SupportAvatarImage}
                          alt="Jess Mitchell"
                          class="agent-use-cases-thread-avatar agent-use-cases-support-avatar"
                        />
                        <div class="agent-use-cases-thread-copy">
                          <div class="agent-use-cases-thread-meta">
                            <p class="agent-use-cases-thread-name">
                              Jess Mitchell
                            </p>
                            <p class="agent-use-cases-thread-time">2 mins</p>
                          </div>
                          <p class="agent-use-cases-thread-text">
                            <span class="agent-use-cases-thread-link">
                              @Ops Assistant
                            </span>
                            <span> my VPN isn’t working</span>
                          </p>
                        </div>
                      </div>

                      <div class="agent-use-cases-thread-message">
                        <div
                          class="agent-use-cases-thread-badge agent-use-cases-support-badge"
                          aria-hidden="true"
                        >
                          <img
                            src={BudibaseSymbol}
                            alt=""
                            class="agent-use-cases-thread-badge-symbol"
                          />
                        </div>
                        <div class="agent-use-cases-thread-copy">
                          <div class="agent-use-cases-thread-meta">
                            <p class="agent-use-cases-thread-name">
                              Ops Assistant
                            </p>
                            <p class="agent-use-cases-thread-time">2 mins</p>
                          </div>
                          <div class="agent-use-cases-support-response">
                            <p>Sounds like a VPN access issue.</p>
                            <p>Support ticket created</p>
                            <ul>
                              <li>Category: Network &amp; Connectivity</li>
                              <li>Issue: VPN access</li>
                              <li>Priority: Medium</li>
                            </ul>
                            <p>Assigned to IT. They'll follow up shortly.</p>
                          </div>
                        </div>
                      </div>
                    </div>

                    <div class="agent-use-cases-thread-input">
                      <div class="agent-use-cases-thread-input-row">
                        <div
                          class="agent-use-cases-thread-input-icon-wrap"
                          aria-hidden="true"
                        >
                          <Icon
                            name="Plus"
                            size="24"
                            class="agent-use-cases-support-input-icon"
                          />
                        </div>
                        <p class="agent-use-cases-thread-input-text">
                          Add a reply
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              ) : (
                <div class="agent-use-cases-canvas rounded-xl px-4 py-5 sm:px-5 sm:py-6">
                  <div class="agent-use-cases-flow-content">
                    <ul class="agent-use-cases-node-list">
                      {frame.nodes.map((node) => (
                        <li class="agent-use-cases-node-wrap">
                          {node.badgeLabel && (
                            <span
                              class:list={[
                                "agent-use-cases-node-badge",
                                node.badgeTone === "operation"
                                  ? "is-operation"
                                  : "is-trigger",
                              ]}
                            >
                              {node.badgeLabel}
                            </span>
                          )}

                          <div class="agent-use-cases-node">
                            <span
                              class:list={[
                                "agent-use-cases-node-icon",
                                `is-${node.iconTone}`,
                              ]}
                              aria-hidden="true"
                            >
                              {node.iconKind === "sparkle" && (
                                <SparkleFill class="h-[18px] w-[18px]" />
                              )}
                              {node.iconKind === "rowsPlusBottom" && (
                                <RowsPlusBottomFill class="h-[18px] w-[18px]" />
                              )}
                              {node.iconKind === "paperPlaneTilt" && (
                                <PaperPlaneTiltFill class="h-[18px] w-[18px]" />
                              )}
                              {node.iconKind === "teams" && (
                                <img
                                  src={TeamsLogo}
                                  alt="Microsoft Teams"
                                  class="h-[18px] w-[18px]"
                                />
                              )}
                              {node.iconKind === "bamboohr" && (
                                <img
                                  src={BambooHrLogo}
                                  alt="BambooHR"
                                  class="h-[18px] w-[18px]"
                                />
                              )}
                            </span>

                            <div class="agent-use-cases-node-copy">
                              <div class="agent-use-cases-node-title">
                                {node.title}
                              </div>
                              {node.description && (
                                <p class="agent-use-cases-node-description">
                                  {node.description}
                                </p>
                              )}
                            </div>
                          </div>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              )}
            </div>
          ))
        }
      </Tabs>
    </div>

    <SectionBlock
      titleColorMode="split-secondary-primary"
      titleLines={[
        { text: "Agents that handle" },
        { text: "everyday requests" },
      ]}
      description="Budibase agents help teams handle routine operational work automatically. They can understand requests, gather information, and take action across your systems."
      maxWidth="xl"
      spacing="default"
      contentClass="pt-1"
    >
      <ul class="flex flex-col gap-4">
        <li class="flex items-start gap-3">
          <CheckCircleFill
            class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]"
            aria-hidden="true"
          />
          <div class="space-y-1.5">
            <div
              class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]"
            >
              Employee self-service
            </div>
            <p class="m-0 text-[14px] leading-6 text-[var(--text-secondary)]">
              Employees ask questions and get instant answers.
            </p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <CheckCircleFill
            class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]"
            aria-hidden="true"
          />
          <div class="space-y-1.5">
            <div
              class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]"
            >
              Approval requests
            </div>
            <p class="m-0 text-[14px] leading-6 text-[var(--text-secondary)]">
              Agents can collect information and run approval workflows.
            </p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <CheckCircleFill
            class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]"
            aria-hidden="true"
          />
          <div class="space-y-1.5">
            <div
              class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]"
            >
              Support triage
            </div>
            <p class="m-0 text-[14px] leading-6 text-[var(--text-secondary)]">
              Agents can manage incoming requests and route them to the right
              team.
            </p>
          </div>
        </li>
      </ul>
    </SectionBlock>
  </div>
</section>

<style>
  .agent-use-cases-tabs :global(.tabs-list) {
    width: 100%;
  }

  .agent-use-cases-canvas {
    --agent-use-cases-grid-dot: rgb(var(--border) / 0.45);
    --agent-use-cases-connector: rgb(var(--ring) / 0.72);
    --agent-use-cases-node-bg: var(--bg-3);
    --agent-use-cases-node-integration-bg: var(--bb-gray-800);
    --agent-use-cases-trigger-bg: var(--bb-orange-700);
    --agent-use-cases-operation-bg: var(--bb-purple-800);
    --agent-use-cases-agent-bg: var(--bb-blue-800);
    --agent-use-cases-node-description: var(--text-secondary);
    --agent-use-cases-node-icon-fg: var(--bb-white);
    background:
      radial-gradient(
          circle at center,
          var(--agent-use-cases-grid-dot) 1px,
          transparent 1px
        )
        0 0 / 20px 20px,
      var(--bg-2);
  }

  .agent-use-cases-flow-content {
    position: relative;
    width: 100%;
    max-width: 380px;
    height: 420px;
    margin: 0 auto;
  }

  .agent-use-cases-node-list {
    --node-width: 380px;
    --node-row-gap: 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--node-row-gap);
    width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .agent-use-cases-node-list.is-frame-employee-self-service {
    --node-width: 380px;
  }

  .agent-use-cases-node-wrap {
    position: relative;
    width: var(--node-width);
  }

  .agent-use-cases-node-wrap:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 50%;
    top: calc(100% + 8px);
    width: 1px;
    height: calc(var(--node-row-gap) - 16px);
    transform: translateX(-50%);
    background-image: linear-gradient(
      to bottom,
      var(--agent-use-cases-connector) 45%,
      transparent 45%
    );
    background-size: 1px 8px;
    background-repeat: repeat-y;
    animation: agent-use-cases-march 700ms linear infinite;
  }

  .agent-use-cases-node-badge {
    position: absolute;
    left: 0;
    bottom: calc(100% + 8px);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    color: var(--bb-white);
    padding: 2px 4px;
    font-size: 14px;
    font-weight: 500;
    line-height: 17px;
  }

  .agent-use-cases-node-badge.is-trigger {
    background: var(--agent-use-cases-trigger-bg);
  }

  .agent-use-cases-node-badge.is-operation {
    background: var(--agent-use-cases-operation-bg);
  }

  .agent-use-cases-node {
    position: relative;
    display: flex;
    width: 100%;
    min-height: 48px;
    align-items: flex-start;
    gap: 10px;
    border-radius: 6px;
    border: none;
    background: var(--agent-use-cases-node-bg);
    padding: 8px 12px;
  }

  .agent-use-cases-node-icon {
    display: inline-flex;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    color: var(--agent-use-cases-node-icon-fg);
  }

  .agent-use-cases-node-icon.is-trigger {
    background: var(--agent-use-cases-trigger-bg);
  }

  .agent-use-cases-node-icon.is-agent {
    background: var(--agent-use-cases-agent-bg);
  }

  .agent-use-cases-node-icon.is-integration {
    background: var(--agent-use-cases-node-integration-bg);
  }

  .agent-use-cases-node-icon.is-alert {
    background: var(--agent-use-cases-operation-bg);
  }

  .agent-use-cases-node-copy {
    min-width: 0;
    flex: 1;
  }

  .agent-use-cases-node-title {
    margin: 0;
    color: var(--text-primary);
    font-size: 16px;
    font-weight: 500;
    line-height: 22px;
  }

  .agent-use-cases-node-description {
    margin: 0;
    color: var(--agent-use-cases-node-description);
    font-size: 16px;
    font-weight: 400;
    line-height: 22px;
  }

  .agent-use-cases-thread-stage {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 612px;
    min-height: 600px;
    margin: 0 auto;
    padding: 81px 86px;
    border-radius: 12px;
    background: var(--bg-2);
  }

  .agent-use-cases-thread-card {
    width: 100%;
    max-width: 440px;
    overflow: hidden;
    border-radius: 12px;
    background: var(--bb-white);
    padding-bottom: 20px;
    font-family: var(--font-display);
  }

  .agent-use-cases-thread-header {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 10px 18px;
    border-bottom: 1px solid var(--bb-gray-100);
  }

  .agent-use-cases-thread-back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--bb-gray-500);
    cursor: default;
  }

  .agent-use-cases-thread-back-icon {
    color: currentColor;
  }

  .agent-use-cases-thread-title {
    margin: 0;
    color: var(--bb-text-base);
    font-size: 18px;
    font-weight: 500;
    line-height: 1;
  }

  .agent-use-cases-thread-body {
    display: flex;
    flex-direction: column;
    gap: 30px;
    padding: 20px 18px 0;
  }

  .agent-use-cases-thread-message {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    width: 100%;
  }

  .agent-use-cases-thread-avatar {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 8px;
    object-fit: cover;
  }

  .agent-use-cases-thread-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 8px;
    background: var(--bb-brand);
    padding: 8px;
  }

  .agent-use-cases-thread-badge-symbol {
    width: 24px;
    height: 24px;
    display: block;
  }

  .agent-use-cases-thread-copy {
    width: 350px;
    max-width: calc(100% - 54px);
  }

  .agent-use-cases-thread-meta {
    display: flex;
    align-items: center;
    gap: 6px;
