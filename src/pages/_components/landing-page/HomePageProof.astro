---
import SectionBlock from "@components/SectionBlock.astro";
import Button from "@components/Button.astro";
import Card from "@components/cards/Card.astro";

const customerCards = [
  {
    label: "Pays Basque",
    description: "Basque Country water network digitized critical operations.",
    linkUrl: "/blog/pays-basque/",
  },
  {
    label: "Knights Brown",
    description: "Accelerating internal tool development with low-code.",
    linkUrl: "/blog/knights-brown/",
  },
  {
    label: "Ströer-x",
    description: "Operational workflows transformed with custom applications.",
    linkUrl: "/blog/stroer-x/",
  },
  {
    label: "Reworld",
    description: "Projected savings through streamlined enterprise workflows.",
    linkUrl: "/blog/reworld/",
  },
  {
    label: "Schnellecke",
    description: "Delivery time cut from days to under an hour.",
    linkUrl: "/blog/schnellecke/",
  },
  {
    label: "Bulgarian Government",
    description: "Mission-critical refugee response delivered at national scale.",
    linkUrl: "/blog/bulgarian-government/",
  },
];
---

<section class="container max-w-7xl mx-auto mt-12 md:mt-24 px-2 lg:px-0">
  <SectionBlock
    title="Trusted for real-world operations"
    description="Established governments to industry leaders use Budibase to transform workflows and build faster businesses."
    align="center"
    maxWidth="3xl"
  >
    <div class="benefits-grid">
      <div class="benefits-grid-featured bg-base-18">
        <div class="featured-wrapper">
          <div class="featured-content">
            <p class="detail text-center text-white featured-eyebrow">
              Proud to be
            </p>

            <h3 class="h1 mb-3 font-weight-bold text-white">Open source</h3>

            <p class="text-center text-white">
              Budibase is open source, allowing you to transform operations
              within the security of your own infrastructure.
            </p>
          </div>

          <div class="platform-hero__cta">
            <Button
              label="Contact sales"
              url="/contact/"
              variant="primary"
              size="large"
              class="px-6 py-3 text-xl md:px-7 md:py-3.5 md:text-xl"
            />
          </div>
        </div>
      </div>

      <div class="customer-cards-area">
        <div class="customer-cards-grid">
          {
            customerCards.map((card) => (
              <div class="customer-card-item">
                <Card
                  tag="/Customers"
                  label={card.label}
                  description={card.description}
                  linkUrl={card.linkUrl}
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </SectionBlock>
</section>

<style>
  .benefits-grid {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) minmax(0, 2fr);
    min-height: 544px;
    gap: 24px;
    align-items: stretch;
  }

  .benefits-grid-featured {
    background: var(--bb-black);
    color: var(--bb-white);
    border-radius: 12px;
    padding: 32px;
    overflow: hidden;
  }

  .featured-wrapper {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .featured-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 280px;
  }

  .benefits-grid-featured p,
  .benefits-grid-featured h3 {
    color: var(--bb-white);
    opacity: 1;
  }

  .benefits-grid-featured .featured-eyebrow {
    opacity: 0.75;
  }

  .platform-hero__cta {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
  }

  .customer-cards-area {
    min-width: 0;
    height: 100%;
  }

  .customer-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: repeat(2, minmax(0, 1fr));
    gap: 24px;
    height: 100%;
    min-height: 544px;
  }

  .customer-card-item {
    min-width: 0;
    min-height: 0;
    height: 100%;
  }

  .customer-card-item :global(a) {
    display: flex;
    height: 100%;
    width: 100%;
    color: inherit;
    text-decoration: none;
  }

  .customer-card-item :global(article),
  .customer-card-item :global(.card),
  .customer-card-item :global(.card-inner) {
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
  }

  @media (max-width: 768px) {
    .benefits-grid {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    .benefits-grid-featured {
      min-height: 360px;
    }

    .customer-cards-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      min-height: unset;
    }
  }
</style>
