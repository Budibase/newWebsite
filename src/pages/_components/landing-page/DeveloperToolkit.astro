---
import Button from "@components/Button.astro";
---

<div class="bg-secondary block-section mt-12 md:mt-24">
  <div class="container relative max-w-7xl mx-auto">
    <div class="px-2 lg:px-0 pb-0 md:pb-0 pt-0">
      <div class="blocks">
        <div class="block-el block-el-Developer Toolkit block-in-view">
          <div class="relative mx-auto flex max-w-[700px] flex-col items-center justify-center lg:max-w-full">
            <!-- Header Section -->
            <div class="flex w-full h-fit items-center justify-center border-x border-stone-300 dark:border-stone-700 px-4 md:px-16 pb-16 md:pb-[240px] pt-20 md:pt-[320px] text-center">
              <h3 class="h3 max-w-2xl text-stone-900 dark:text-stone-100">
                Complete developer toolkit for effortlessly deploying customized, interactive Agents in minutes
              </h3>
            </div>

            <!-- Grid Section -->
            <div class="relative flex w-full grid-cols-[1fr_480px_1fr] grid-rows-2 flex-col gap-0 border-x border-stone-300 dark:border-stone-700 sm:grid-cols-[1fr_320px_1fr] md:grid-cols-[1fr_380px_1fr] lg:grid xl:grid-cols-[1fr_480px_1fr]">
              <!-- Top Left: Public API -->
              <div class="col-span-1 row-span-1 flex flex-col items-start justify-start px-5 md:px-12 lg:px-20 py-5 md:py-10 lg:py-20 xl:px-[60px] xl:pt-12 col-start-1 row-start-1 border-b border-t border-stone-300 dark:border-stone-700">
                <h3 class="h4 mb-2 md:mb-8 text-stone-900 dark:text-stone-100">Public API</h3>
                <div class="text-base text-stone-500 dark:text-stone-400">
                  Use our SDKs for JavaScript, Python, Swift, and more to embed voice agents into your apps, sites, or systems. Stream audio, manage sessions, and control behavior with minimal setup.
                </div>
              </div>

              <!-- Top Right: Low latency -->
              <div class="col-span-1 row-span-1 flex flex-col items-start justify-start px-5 md:px-12 lg:px-20 py-5 md:py-10 lg:py-20 xl:px-[60px] xl:pt-12 col-start-3 row-start-1 border-b border-t border-stone-300 dark:border-stone-700">
                <h3 class="h4 mb-2 md:mb-8 text-stone-900 dark:text-stone-100">Low latency</h3>
                <div class="text-base text-stone-500 dark:text-stone-400">
                  Responses are generated and delivered in real time, even during high-concurrency traffic. Our system is optimized for sub-second turnaround across speech, reasoning, and voice synthesis.
                </div>
              </div>

              <!-- Center Canvas Area -->
              <div class="relative col-start-2 row-span-2 row-start-1 flex min-h-full w-full items-center justify-center border border-stone-300 dark:border-stone-700" style="aspect-ratio: 16 / 17;">
                <!-- Corner SVG Decorations -->
                <svg class="absolute -left-px -top-px" fill="none" height="31" viewBox="0 0 31 31" width="31" xmlns="http://www.w3.org/2000/svg">
                  <path d="M30.5 0.5H0.5V30.5" stroke="currentColor" stroke-opacity="0.4" class="text-stone-400 dark:text-stone-500"></path>
                </svg>
                <svg class="absolute -right-px -top-px rotate-90" fill="none" height="31" viewBox="0 0 31 31" width="31" xmlns="http://www.w3.org/2000/svg">
                  <path d="M30.5 0.5H0.5V30.5" stroke="currentColor" stroke-opacity="0.4" class="text-stone-400 dark:text-stone-500"></path>
                </svg>
                <svg class="absolute -bottom-px -right-px rotate-180" fill="none" height="31" viewBox="0 0 31 31" width="31" xmlns="http://www.w3.org/2000/svg">
                  <path d="M30.5 0.5H0.5V30.5" stroke="currentColor" stroke-opacity="0.4" class="text-stone-400 dark:text-stone-500"></path>
                </svg>
                <svg class="absolute -bottom-px -left-px -rotate-90" fill="none" height="31" viewBox="0 0 31 31" width="31" xmlns="http://www.w3.org/2000/svg">
                  <path d="M30.5 0.5H0.5V30.5" stroke="currentColor" stroke-opacity="0.4" class="text-stone-400 dark:text-stone-500"></path>
                </svg>

                <!-- Grid Pattern Background -->
                <div class="absolute left-0 top-0 h-full w-full overflow-hidden opacity-20" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 15px, currentColor 15px, currentColor 16px), repeating-linear-gradient(90deg, transparent, transparent 15px, currentColor 15px, currentColor 16px); background-size: 16px 16px;" aria-hidden="true"></div>

                <!-- Canvas Container -->
                <div class="relative z-10 flex h-full w-full items-center justify-center">
                  <div class="h-full w-[65%]">
                    <canvas style="vertical-align: top; width: 100%; height: 100%;" width="622" height="1016"></canvas>
                  </div>
                </div>
              </div>

              <!-- Bottom Left: Bring any LLM -->
              <div class="col-span-1 row-span-1 flex flex-col items-start justify-start px-5 md:px-12 lg:px-20 py-5 md:py-10 lg:py-20 xl:px-[60px] xl:pt-12 col-start-1 row-start-2 border-b border-stone-300 dark:border-stone-700">
                <h3 class="h4 mb-2 md:mb-8 text-stone-900 dark:text-stone-100">Bring any LLM</h3>
                <div class="text-base text-stone-500 dark:text-stone-400">
                  Connect any leading model — GPT-4, Claude, Gemini, or your own — with a few lines of config. Swap models at any time to match your performance, privacy, or cost needs.
                </div>
              </div>

              <!-- Bottom Right: RAG -->
              <div class="col-span-1 row-span-1 flex flex-col items-start justify-start px-5 md:px-12 lg:px-20 py-5 md:py-10 lg:py-20 xl:px-[60px] xl:pt-12 col-start-3 row-start-2 border-b border-stone-300 dark:border-stone-700">
                <h3 class="h4 mb-2 md:mb-8 text-stone-900 dark:text-stone-100">RAG</h3>
                <div class="text-base text-stone-500 dark:text-stone-400">
                  Use Retrieval-Augmented Generation to pull from your own documents and sources. Index files and URLs instantly and get grounded, up-to-date answers with minimal latency.
                </div>
              </div>
            </div>

            <!-- Bottom Buttons Section -->
            <div class="flex w-full h-fit flex-col items-center justify-center border-x border-stone-300 dark:border-stone-700 px-4 md:px-16 py-10 md:py-[160px] lg:py-[200px]">
              <div class="flex flex-wrap justify-center gap-3 md:gap-12">
                <Button
                  label="Documentation"
                  url="https://docs.budibase.com"
                  variant="secondary"
                  class="border-stone-300 dark:border-stone-700 text-stone-900 dark:text-stone-100 hover:text-stone-700 dark:hover:text-stone-50 hover:border-stone-400 dark:hover:border-stone-600 bg-transparent"
                />
                <Button
                  label="API Reference"
                  url="https://docs.budibase.com/docs/public-api"
                  variant="secondary"
                  class="border-stone-300 dark:border-stone-700 text-stone-900 dark:text-stone-100 hover:text-stone-700 dark:hover:text-stone-50 hover:border-stone-400 dark:hover:border-stone-600 bg-transparent"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
