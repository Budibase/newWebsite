---
import SectionBlock from "@components/SectionBlock.astro";
import Card from "@components/cards/Card.astro";
import WorkplaceRequestDemo from "./WorkplaceRequestDemo.astro";
import UseCase1 from "@assets/images/homepage/use cases/1.png?url";
import UseCase2 from "@assets/images/homepage/use cases/2.png?url";
import UseCase3 from "@assets/images/homepage/use cases/3.png?url";
import AvatarImage from "@assets/images/avatars/Avatar.png?url";
import EllipseImage from "@assets/images/avatars/Ellipse.png?url";
import EllipseImageAlt from "@assets/images/avatars/Ellipse-1.png?url";
import SlackLogo from "@assets/logos/Slack.svg?url";
import DiscordLogo from "@assets/logos/discord.svg?url";
import TeamsLogo from "@assets/logos/microsoft-teams.svg?url";

const cards = [
  {
    label: "Employee requests",
    description: "Answer everyday workplace questions",
    imageSrc: UseCase1,
    imageAlt: "Employee requests scenic background",
    demo: {
      channel: "Slack",
      channelLogo: SlackLogo,
      employeeName: "John Smyth",
      employeeAvatarImage: AvatarImage,
      employeeAvatarShape: "square" as const,
      timeLabel: "13 mins",
      promptText: "Who’s out of office tomorrow?",
      assistantIntro: "Here’s who’s out tomorrow",
      bulletItems: [
        "Sarah (Marketing)",
        "David (Sales)",
        "Priya (Engineering)",
      ],
      footerSegments: [
        { text: "Want me to post this in " },
        { text: "#team-updates", highlight: true },
        { text: "?" },
      ],
    },
  },
  {
    label: "Approval workflows",
    description: "Create and route approval requests",
    imageSrc: UseCase2,
    imageAlt: "Approval workflows scenic background",
    demo: {
      channel: "Discord",
      channelLogo: DiscordLogo,
      employeeName: "Sarah Harvey",
      employeeAvatarImage: EllipseImage,
      employeeAvatarShape: "circle" as const,
      timeLabel: "12 mins",
      promptText: "I need approval for a new laptop for a marketing hire?",
      assistantIntro: "Laptop purchase request created:",
      bulletItems: [
        "Team: Marketing",
        "Item: Laptop for new hire",
        "Budget: £700–£900",
      ],
      footerSegments: [{ text: "Sent to IT for review." }],
    },
  },
  {
    label: "Support triage",
    description: "Categorize and route support issues",
    imageSrc: UseCase3,
    imageAlt: "Support triage scenic background",
    demo: {
      channel: "Microsoft Teams",
      channelLogo: TeamsLogo,
      employeeName: "Jess Mitchell",
      employeeAvatarImage: EllipseImageAlt,
      employeeAvatarShape: "circle" as const,
      timeLabel: "2 mins",
      promptText: "my VPN isn’t working. please help!",
      assistantIntro: "Sounds like a VPN access issue. Support ticket created:",
      bulletItems: [
        "Category: Network",
        "Issue: VPN access",
        "Priority: Medium",
      ],
      footerSegments: [{ text: "Assigned to IT. They'll follow up shortly." }],
    },
  },
] as const;
---

<section
  class="container max-w-[var(--site-container-max)] mx-auto mt-12 md:mt-24 px-2 lg:px-0"
>
  <SectionBlock
    title="Operations your team can run with AI agents"
    description="Employees ask questions, request approvals, and report issues every day. Budibase agents understand these requests and handle the work automatically."
    align="center"
    maxWidth="3xl"
  >
    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
      {
        cards.map((card) => (
          <div class="workplace-requests__card">
            <Card
              label={card.label}
              description={card.description}
              imageSrc={card.imageSrc}
              imageAlt={card.imageAlt}
            >
              <div
                slot="image-overlay"
                class="workplace-requests__overlay"
                aria-hidden="true"
              >
                <WorkplaceRequestDemo {...card.demo} />
              </div>
            </Card>
          </div>
        ))
      }
    </div>
  </SectionBlock>
</section>

<style>
  .workplace-requests__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 12px;
  }

  .workplace-requests__card :global(.card-image) {
    opacity: 0.75;
  }

  .workplace-requests__card :global(.card-image-wrap) {
    height: 520px;
  }
</style>
