---
import CheckCircleFill from "phosphor-astro/CheckCircleFill.astro";
import SecurityDemoTwo from "@components/SecurityDemoTwo.astro";
import SectionBlock from "@components/SectionBlock.astro";
import Button from "@components/Button.astro";
---

<section>
  <div class="grid grid-cols-1 gap-8 lg:grid-cols-[minmax(0,1.02fr)_minmax(0,0.98fr)] lg:items-center lg:gap-20">

     <div>
      <SecurityDemoTwo />
    </div>

    <SectionBlock
      titleColorMode="split-secondary-primary"
      titleLines={[
        { text: "Deploy in the cloud or" },
        { text: "Your own secure environment" },
      ]}
      description="Choose Budibase Cloud for a ready-to-use, secure platform to deploy workflow tools, without the infrastructure overhead, or self-host for maximum control"
      maxWidth="xl"
      spacing="default"
      contentClass="pt-1"
    >
      <ul class="m-0 flex flex-col gap-4">
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
            Budibase servers are hosted within the EU (Ireland) in data centers certified by SOC 1/2 and ISO 27001.
          </div>
        </li>
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
            Mandatory HTTPS connections and data encrpytion in-transit and at-rest.
          </div>
        </li>
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
             Self-hosting via Docker, Kubernetes, and more.
          </div>
        </li>
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
             Air-gapped deployments.
          </div>
        </li>
      </ul>
     <div class="mt-16">
        <Button
          label="Get started"
          url="https://account.budibase.app/register"
          variant="primary"
          size="large"
          class="px-6 py-3 text-xl md:px-7 md:py-3.5 md:text-xl"
          target="_blank"
        />
      </div>
    </SectionBlock>
  </div>
</section>
