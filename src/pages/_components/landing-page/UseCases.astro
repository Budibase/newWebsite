---
import ProductSection from "@components/cards/ProductSection.astro";
import HeroBackground from "@assets/images/homepage/HeroBackground.png";
---

<ProductSection
  tagLabel="/Chat"
  title="Incident triage"
  description="Help analysts process, classify, and respond to incidents faster - without sending data outside their network."
  productImage={HeroBackground}
  linkLabel="Build an agent"
  linkUrl="/blog"
  features={[
    "Trigger: A new alert or incident record appears (from Budibase form, Splunk, Sentinel, or ServiceNow)",
    "Agent: Summarizes the incident in plain English",
    "Agent: Extracts key entities (user, IP, hostname, file)",
    "Agent: Correlates with threat-intel feeds (VirusTotal, AbuseIPDB",
    "Agent: Assesses severity and likely cause.",
    "Output: Structured triage summary, tags the record, and suggests next steps.",
    "Automation: Creates or updates a ServiceNow/Jira ticket, notifies Slack/Teams, logs the action",
  ]}
/>
