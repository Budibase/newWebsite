---
import Customers from "@components/Customers.astro";
import Button from "@components/Button.astro";
import Curl from "@components/Curl.astro";
import HeroSwitcher from "@components/HeroSwitcher.astro";
import AgentInstructions2 from "@assets/images/platform/AgentInstructions2.png";
import AgentInChat from "@assets/images/platform/AgentInChat.png";
import AgentInAutomations from "@assets/images/platform/AgentInAutomations.png";
import ValleyImage from "@assets/images/homepage/valley.png";
import ClarenceImage from "@assets/images/homepage/ClarencePortrait.png";
import Sparkle from "phosphor-astro/Sparkle.astro";
import ChatCircle from "phosphor-astro/ChatCircle.astro";
import Path from "phosphor-astro/PathFill.astro";
import Browsers from "phosphor-astro/Browsers.astro";
import Database from "phosphor-astro/GridNine.astro";
import Webhooks from "phosphor-astro/WebhooksLogo.astro";
import Users from "phosphor-astro/HardDrives.astro";
import Certificate from "phosphor-astro/Certificate.astro";
import Check from "phosphor-astro/CheckCircle.astro";
import GlobeSimple from "phosphor-astro/GlobeSimple.astro";
import Cube from "phosphor-astro/Cube.astro";
import { Image } from "astro:assets";
---

<section class="container max-w-7xl mx-auto px-2 lg:px-0 flex flex-col mt-8 md:mt-8">

  <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
    <div class="flex-1 flex flex-col items-center text-center">
      <Image
        src={ClarenceImage}
        alt="Clarence"
        width={100}
        height={100}
        class="mb-3 shrink-0"
      />
      <h1 class="max-w-md h2 text-stone-950 dark:text-stone-50 mb-5 font-medium!">
          Budibase is the open-source platform for AI agents. Built for real workflows.
      </h1>
      <div class="flex flex-row">
        <Button
          label="Try Budibase Cloud"
          url="https://account.budibase.app/register"
          variant="cta"
          target="_blank"
        />
      </div>
      <div class="mt-2 md:mt-4 w-fit">
        <Curl />
      </div>
    </div>
  </div>

  <div class="mt-6 md:mt-10">
    <HeroSwitcher
      items={[
        {
          label: "Agents",
          product: AgentInstructions2,
          alt: "Budibase agents",
          icon: Sparkle,
          tagLabel: "Beta",
          tagVariant: "cta",
        },
        {
          label: "Chat",
          product: AgentInChat,
          alt: "Budibase chat",
          icon: ChatCircle,
          tagLabel: "Alpha",
          tagVariant: "secondary",
        },
        {
          label: "Workflows",
          product: AgentInAutomations,
          alt: "Budibase automations",
          icon: Path,
        },
        {
          label: "Apps",
          product: ValleyImage,
          alt: "Budibase apps",
          icon: Browsers,
        },
        {
          label: "Tables",
          product: ValleyImage,
          alt: "Budibase tables",
          icon: Database,
        },
        {
          label: "API explorer",
          product: ValleyImage,
          alt: "Budibase API explorer",
          icon: GlobeSimple,
        },
        {
          label: "10K operations",
          product: ValleyImage,
          alt: "10K operations",
          icon: Cube,
        },
      ]}
    />
  </div>
</section>
