---
import Customers from "@components/Customers.astro";
import Button from "@components/Button.astro";
import AgentDemo from "@components/AgentDemo.astro";
---

<section class="container max-w-6xl mx-auto px-2 lg:px-0 flex flex-col mt-8 md:mt-8">

  <div class="flex flex-col md:flex-row items-start gap-8 md:gap-12">
    <div class="flex-1 flex flex-col items-start text-left">
      <h1 class="hero-title mt-12 mb-2 w-full max-w-2xl text-[50px]! leading-[1.02]! tracking-[-0.02em]! text-[var(--text-primary)] sm:text-[50px]! sm:leading-[1.02]!">
        <span class="block">
          Open-source AI agents for real work
        </span>
      </h1>
      <div class="max-w-3xl !mb-4 !text-xl text-primary">
        Connect your tools. Define the rules. Let agents handle the work.
      </div>
      <div class="flex flex-row">
        <Button
          label="Try Budibase Cloud"
          url="https://account.budibase.app/register"
          variant="primary"
          size="large"
          target="_blank"
        />
      </div>
    </div>
  </div>

  <div class="mt-6 md:mt-10">
    <AgentDemo />
  </div>

</section>
