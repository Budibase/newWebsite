---
import Button from "@components/Button.astro";
import AgentDemo from "@components/AgentDemo.astro";
---

<section
  class="container max-w-7xl mx-auto px-2 lg:px-0 flex flex-col mt-8 md:mt-8"
>
  <div class="flex flex-col md:flex-row gap-8 md:gap-12 max-w-4xl mx-auto">
    <div class="flex-1 flex flex-col">
      <h1 class="hero-title mx-auto mt-12 mb-5 block w-full text-pretty">
        The open source platform for running AI operations.
        <span class="text-text-muted"
          >Apps, automations, and AI agents for modern Enterprise Ops teams -
          from everyday requests to mission critical operations.</span
        >
      </h1>
      <div class="flex flex-row gap-4">
        <Button
          label="Book a demo"
          url="https://account.budibase.app/register"
          variant="cta"
          size="large"
          target="_blank"
        />
        <Button
          label="Get started"
          url="https://account.budibase.app/register"
          variant="secondary"
          size="large"
          target="_blank"
        />
      </div>
    </div>
  </div>
  <div class="mt-6 md:mt-10">
    <AgentDemo />
  </div>
</section>
