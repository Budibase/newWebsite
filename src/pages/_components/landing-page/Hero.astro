---
import Customers from "@components/Customers.astro";
import Button from "@components/Button.astro";
import HeroSwitcher from "@components/HeroSwitcher.astro";
import AgentPreview from "@assets/images/platform/AgentPreview.png";
import agents from "@assets/images/platform/agents.png";
import AgentInAutomations from "@assets/images/platform/AgentInAutomations.png";
import AgentTools from "@assets/images/platform/AgentTools.png";
import Users from "phosphor-astro/HardDrives.astro";
import Certificate from "phosphor-astro/Certificate.astro";
import Check from "phosphor-astro/CheckCircle.astro";
import GlobeHemisphereWest from "phosphor-astro/GlobeHemisphereWest.astro";
---

<section class="container max-w-7xl mx-auto px-2 lg:px-0 flex flex-col mt-8 md:mt-20">
  <h1 class="max-w-xl h2 text-stone-500! dark:text-stone-400! mb-5">
    Budibase is a free and open AI workflow platform. 
    <span class="text-stone-950 dark:text-stone-50"
      >Build AI Agents, Chat, Automations, and
       Apps, and join 300K users transforming workflows with AI.</span
    >
  </h1>
  <div class="flex flex-row">
    <Button label="Get Budibase free" url="/" variant="cta" />
  </div>
  <div class="flex flex-wrap items-center gap-3 md:gap-4 text-xs text-stone-500 dark:text-stone-400 mt-5">
    <span class="flex items-center gap-1">
      <Users class="w-4 h-4" />
      <span>Self-host</span>
    </span>
    <span class="flex items-center gap-1">
      <Certificate class="w-4 h-4" />
      <span>ISO 27001 Certified</span>
    </span>
    <span class="flex items-center gap-1">
      <Check class="w-4 h-4" />
      <span>GDPR Compliant</span>
    </span>
    <span class="flex items-center gap-1">
      <GlobeHemisphereWest class="w-4 h-4" />
      <span>Made in Europe</span>
    </span>
  </div>

  <div class="mt-6 md:mt-10">
    <HeroSwitcher
      items={[
        {
          label: "Chat",
          product: AgentPreview,
          alt: "Budibase chat",
        },
        {
          label: "Agents",
          product: agents,
          alt: "Budibase agents",
        },
        {
          label: "Automations",
          product: AgentInAutomations,
          alt: "Budibase automations",
        },
        {
          label: "Apps",
          product: AgentTools,
          alt: "Budibase apps",
        },
        {
          label: "Tables",
          product: AgentTools,
          alt: "Budibase tables",
        },
      ]}
    />
  </div>
</section>
