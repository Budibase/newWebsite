---
import AnthropicLogo from "@assets/logos/anthropic.avif?url";
import AzureOpenAILogo from "@assets/logos/azure-openai.svg?url";
import GoogleLogo from "@assets/logos/Google.svg?url";
import GroqLogo from "@assets/logos/groq.png?url";
import MistralLogo from "@assets/logos/Mistral.svg?url";
import OpenAILogo from "@assets/logos/openai.avif?url";
import OpenRouterLogo from "@assets/logos/openrouter.svg?url";

import AmazonS3Logo from "@assets/logos/amazon-s3.svg?url";
import DynamoDBLogo from "@assets/logos/amazon-dynamodb.svg?url";
import ElasticsearchLogo from "@assets/logos/elastic.svg?url";
import FirestoreLogo from "@assets/logos/firestore.svg?url";
import MongoDBLogo from "@assets/logos/mongodb.svg?url";
import MySQLLogo from "@assets/logos/MYSQL.svg?url";
import PostgresLogo from "@assets/logos/Postgres.svg?url";
import SupabaseLogo from "@assets/logos/supbase.png?url";

import GithubLogoSvg from "@assets/logos/github.svg?url";
import GithubLogoWhite from "@assets/logos/githubWhite.png?url";
import JiraLogo from "@assets/logos/Jira.svg?url";
import OpenApiLogo from "@assets/logos/openapi.svg?url";
import ServiceNowLogo from "@assets/logos/servicenow.svg?url";
import SlackLogo from "@assets/logos/Slack.svg?url";
import StripeSvgLogo from "@assets/logos/stripe.svg?url";
import TwilioLogo from "@assets/logos/twilio.svg?url";
import ZendeskLogo from "@assets/logos/zendesk.svg?url";

import AnsibleLogo from "@assets/logos/ansible.svg?url";
import BrevoLogo from "@assets/logos/brevo.svg?url";
import ExaLogo from "@assets/logos/exa.png?url";
import PagerDutyLogo from "@assets/logos/pagerduty.jpeg?url";
import ResendLogo from "@assets/logos/resend.svg?url";
import SmtpLogo from "@assets/logos/smtp.svg?url";
import VirusTotalLogo from "@assets/logos/virustotal.svg?url";
import WorkableLogo from "@assets/logos/workable.svg?url";

const modelLogos = [
  { src: AnthropicLogo, alt: "Anthropic" },
  { src: AzureOpenAILogo, alt: "Azure OpenAI" },
  { src: GoogleLogo, alt: "Google" },
  { src: GroqLogo, alt: "Groq" },
  { src: MistralLogo, alt: "Mistral" },
  { src: OpenAILogo, alt: "OpenAI" },
  { src: OpenRouterLogo, alt: "OpenRouter" },
];

const dataLogos = [
  { src: AmazonS3Logo, alt: "Amazon S3" },
  { src: DynamoDBLogo, alt: "DynamoDB" },
  { src: ElasticsearchLogo, alt: "Elasticsearch" },
  { src: FirestoreLogo, alt: "Firestore" },
  { src: MongoDBLogo, alt: "MongoDB" },
  { src: MySQLLogo, alt: "MySQL" },
  { src: PostgresLogo, alt: "PostgreSQL" },
  { src: SupabaseLogo, alt: "Supabase" },
];

const apiLogos = [
  { src: GithubLogoSvg, alt: "GitHub" },
  { src: JiraLogo, alt: "Jira" },
  { src: OpenApiLogo, alt: "OpenAPI" },
  { src: ServiceNowLogo, alt: "ServiceNow" },
  { src: SlackLogo, alt: "Slack" },
  { src: StripeSvgLogo, alt: "Stripe" },
  { src: TwilioLogo, alt: "Twilio" },
  { src: ZendeskLogo, alt: "Zendesk" },
];

const operationsLogos = [
  { src: AnsibleLogo, alt: "Ansible" },
  { src: BrevoLogo, alt: "Brevo" },
  { src: ExaLogo, alt: "Exa" },
  { src: PagerDutyLogo, alt: "PagerDuty" },
  { src: ResendLogo, alt: "Resend" },
  { src: SmtpLogo, alt: "SMTP" },
  { src: VirusTotalLogo, alt: "VirusTotal" },
  { src: WorkableLogo, alt: "Workable" },
];
---

<section
  class="container max-w-[var(--site-container-max)] mx-auto mt-12 md:mt-24 px-2 lg:px-0"
>
  <div
    class="connections-shell rounded-3xl border border-[var(--border)] p-5 md:p-7"
  >
    <div
      class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.2fr)_minmax(0,1fr)] lg:grid-rows-2 lg:items-center"
    >
      <div class="lg:col-start-1 lg:row-start-1">
        <div
          class="relative flex min-h-[220px] items-center justify-center rounded-2xl border border-stone-200/60 bg-white/70 p-4 lg:min-h-[260px]"
        >
          <div
            class="grid w-full grid-cols-3 gap-2 justify-items-center sm:grid-cols-4"
          >
            {
              modelLogos.map((logo) => (
                <div class="flex h-[42px] w-[42px] items-center justify-center rounded-[10px] border border-dashed border-stone-300/70 bg-white p-[6px]  ">
                  <img
                    src={logo.src}
                    alt={logo.alt}
                    class="h-full w-full object-contain"
                    width={26}
                    height={26}
                  />
                </div>
              ))
            }
          </div>
          <div
            class="mt-4 flex w-full max-w-[220px] flex-col items-center rounded-2xl border border-[var(--border)] bg-white px-4 py-3 text-center shadow-lg lg:absolute lg:left-1/2 lg:top-1/2 lg:mt-0 lg:w-auto lg:max-w-none lg:-translate-x-1/2 lg:-translate-y-1/2"
          >
            <p class="text-[0.7rem] uppercase tracking-[0.2em] text-stone-500">
              AI models
            </p>
            <p class="text-2xl font-semibold text-stone-800">182</p>
          </div>
        </div>
      </div>

      <div
        class="flex items-center justify-center lg:col-start-2 lg:row-start-1 lg:row-span-2"
      >
        <div
          class="connections-card-title max-w-lg rounded-2xl border border-[var(--border)] bg-white px-6 py-8 text-center shadow-xl"
        >
          <h2 class="section-title m-0 w-full text-center">
            <span class="block text-[var(--text-primary)]"
              >Your models, your tools,</span
            >
            <span class="block text-[var(--text-secondary)]"
              >your data, your privacy.</span
            >
          </h2>
        </div>
      </div>

      <div class="lg:col-start-3 lg:row-start-1">
        <div
          class="relative flex min-h-[220px] items-center justify-center rounded-2xl border border-stone-200/60 bg-white/70 p-4 lg:min-h-[260px]"
        >
          <div
            class="grid w-full grid-cols-3 gap-2 justify-items-center sm:grid-cols-4"
          >
            {
              apiLogos.map((logo) => (
                <div class="flex h-[42px] w-[42px] items-center justify-center rounded-[10px] border border-dashed border-stone-300/70 bg-white p-[6px]  ">
                  {logo.alt === "GitHub" ? (
                    <>
                      <img
                        src={GithubLogoSvg}
                        alt="GitHub"
                        class="h-full w-full object-contain "
                        width={26}
                        height={26}
                      />
                      <img
                        src={GithubLogoWhite}
                        alt="GitHub"
                        class="hidden h-full w-full object-contain "
                        width={26}
                        height={26}
                      />
                    </>
                  ) : (
                    <img
                      src={logo.src}
                      alt={logo.alt}
                      class="h-full w-full object-contain"
                      width={26}
                      height={26}
                    />
                  )}
                </div>
              ))
            }
          </div>
          <div
            class="mt-4 flex w-full max-w-[220px] flex-col items-center rounded-2xl border border-[var(--border)] bg-white px-4 py-3 text-center shadow-lg lg:absolute lg:left-1/2 lg:top-1/2 lg:mt-0 lg:w-auto lg:max-w-none lg:-translate-x-1/2 lg:-translate-y-1/2"
          >
            <p class="text-[0.7rem] uppercase tracking-[0.2em] text-stone-500">
              APIs
            </p>
            <p class="text-2xl font-semibold text-stone-800">92</p>
          </div>
        </div>
      </div>

      <div class="lg:col-start-1 lg:row-start-2">
        <div
          class="relative flex min-h-[220px] items-center justify-center rounded-2xl border border-stone-200/60 bg-white/70 p-4 lg:min-h-[260px]"
        >
          <div
            class="grid w-full grid-cols-3 gap-2 justify-items-center sm:grid-cols-4"
          >
            {
              dataLogos.map((logo) => (
                <div class="flex h-[42px] w-[42px] items-center justify-center rounded-[10px] border border-dashed border-stone-300/70 bg-white p-[6px]  ">
                  <img
                    src={logo.src}
                    alt={logo.alt}
                    class="h-full w-full object-contain"
                    width={26}
                    height={26}
                  />
                </div>
              ))
            }
          </div>
          <div
            class="mt-4 flex w-full max-w-[220px] flex-col items-center rounded-2xl border border-[var(--border)] bg-white px-4 py-3 text-center shadow-lg lg:absolute lg:left-1/2 lg:top-1/2 lg:mt-0 lg:w-auto lg:max-w-none lg:-translate-x-1/2 lg:-translate-y-1/2"
          >
            <p class="text-[0.7rem] uppercase tracking-[0.2em] text-stone-500">
              Data sources
            </p>
            <p class="text-2xl font-semibold text-stone-800">17</p>
          </div>
        </div>
      </div>

      <div class="lg:col-start-3 lg:row-start-2">
        <div
          class="relative flex min-h-[220px] items-center justify-center rounded-2xl border border-stone-200/60 bg-white/70 p-4 lg:min-h-[260px]"
        >
          <div
            class="grid w-full grid-cols-3 gap-2 justify-items-center sm:grid-cols-4"
          >
            {
              operationsLogos.map((logo) => (
                <div class="flex h-[42px] w-[42px] items-center justify-center rounded-[10px] border border-dashed border-stone-300/70 bg-white p-[6px]  ">
                  <img
                    src={logo.src}
                    alt={logo.alt}
                    class="h-full w-full object-contain"
                    width={26}
                    height={26}
                  />
                </div>
              ))
            }
          </div>
          <div
            class="mt-4 flex w-full max-w-[220px] flex-col items-center rounded-2xl border border-[var(--border)] bg-white px-4 py-3 text-center shadow-lg lg:absolute lg:left-1/2 lg:top-1/2 lg:mt-0 lg:w-auto lg:max-w-none lg:-translate-x-1/2 lg:-translate-y-1/2"
          >
            <p class="text-[0.7rem] uppercase tracking-[0.2em] text-stone-500">
              Operations
            </p>
            <p class="text-2xl font-semibold text-stone-800">15,642</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .connections-shell {
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--bb-gray-800) 5%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        color-mix(in srgb, var(--bb-gray-800) 5%, transparent) 1px,
        transparent 1px
      );
    background-size: 28px 28px;
  }
</style>
