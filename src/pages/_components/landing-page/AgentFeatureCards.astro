---
import Card from "@components/cards/Card.astro";
import InstructionsEditor from "@components/InstructionsEditor.astro";
import AgentInstructionsContent from "@components/AgentInstructionsContent.astro";
import AgentModelSelectorOverlay from "@components/AgentModelSelectorOverlay.astro";
import Sky1 from "@assets/images/backgrounds/sky/1.png";
import Sky2 from "@assets/images/backgrounds/sky/2.png";
import Sky3 from "@assets/images/backgrounds/sky/3.png";
---

<section class="container max-w-7xl mx-auto mt-12 md:mt-24 px-2 lg:px-0">
  <h2 class="text-primary text-center mb-4">
    Automate complex work without losing control.
  </h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 md:gap-2">
    <Card
      label="Build agents like writing a list"
      description="Define controlled agent behavior with structured instructions and reusable guidance."
      imageSrc={Sky1}
    >
      <div slot="image-overlay" class="agents-card-overlay" aria-hidden="true">
        <InstructionsEditor
          variant="agent-demo"
          class="agents-card-overlay-editor"
          background="var(--bg-1)"
          border="0.5px solid var(--border-color)"
        >
          <AgentInstructionsContent />
        </InstructionsEditor>
      </div>
    </Card>
    <Card
      label="Choose between 100s of AI models"
      description="Run agents with OpenAI, Anthropic, Mistral, or custom model providers."
      imageSrc={Sky2}
    >
      <div
        slot="image-overlay"
        class="agents-card-overlay agents-card-overlay-interactive agents-card-overlay-center-top"
      >
        <AgentModelSelectorOverlay class="agents-card-overlay-selector" />
      </div>
    </Card>
    <Card
      label="Deploy where work happens"
      description="Run agents inside Automations, Budibase Chat, Discord, and soon Teams and Slack."
      imageSrc={Sky3}
    />
    <Card
      label="Multi-step reasoning with tool usage"
      description="Plan and execute multi-step tasks by combining reasoning with connected tools."
    />
    <Card
      label="Connect 100s of tools"
      description="Give your agent access to over 10,000 operations across 100s of tools."
    />
    <Card
      label="Structured instruction builder"
      description="Define controlled agent behavior with structured instructions and reusable guidance."
    />
    <Card
      label="Knowledge retrieval (RAG)"
      description="Ground responses with retrieval workflows, including pgvector support."
    />
    <Card
      label="Data and API access"
      description="Access internal data tables and external APIs to execute operational tasks."
    />
    <Card
      label="Multi-channel deployment"
      description="Deploy to Automations, Budibase Chat, Discord, and upcoming Teams and Slack."
    />
  </div>
</section>

<style>
  .agents-card-overlay {
    position: absolute;
    inset: 0;
    padding-top: 20px;
    padding-left: 20px;
    padding-right: 20px;
    padding-bottom: 20px;
    pointer-events: none;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
  }

  .agents-card-overlay-editor {
    width: min(100%, 420px);
    max-height: 100%;
    overflow: auto;
    border-radius: 10px;
  }

  .agents-card-overlay-selector {
    max-height: 100%;
    overflow: auto;
  }

  .agents-card-overlay-interactive {
    pointer-events: auto;
  }

  .agents-card-overlay-center-top {
    align-items: flex-start;
    justify-content: center;
  }
</style>
