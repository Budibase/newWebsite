<script>
  const productTabs = Array.from(
    document.querySelectorAll('#product-tabs [role="tab"]'),
  );
  const productPanels = {
    chatMedia: document.getElementById("chatMedia"),
    formsMedia: document.getElementById("formsMedia"),
    appsMedia: document.getElementById("appsMedia"),
    tablesMedia: document.getElementById("tablesMedia"),
  };

  function activateProductTab(targetId) {
    productTabs.forEach((tab) => {
      const isActive = tab.dataset.target === targetId;
      tab.classList.toggle("is-active", isActive);
      tab.setAttribute("aria-selected", String(isActive));
      tab.setAttribute("tabindex", isActive ? "0" : "-1");
    });

    Object.entries(productPanels).forEach(([id, panel]) => {
      if (!panel) return;
      const shouldShow = id === targetId;
      panel.classList.toggle("is-visible", shouldShow);
      panel.hidden = !shouldShow;
    });
  }

  function moveProductFocus(delta) {
    const currentIndex = productTabs.findIndex(
      (tab) => tab.getAttribute("aria-selected") === "true",
    );
    const nextIndex =
      (currentIndex + delta + productTabs.length) % productTabs.length;
    productTabs[nextIndex]?.focus();
  }

  productTabs.forEach((tab) => {
    tab.addEventListener("click", () => activateProductTab(tab.dataset.target));
    tab.addEventListener("keydown", (event) => {
      switch (event.key) {
        case "ArrowRight":
        case "ArrowDown":
          event.preventDefault();
          moveProductFocus(1);
          break;
        case "ArrowLeft":
        case "ArrowUp":
          event.preventDefault();
          moveProductFocus(-1);
          break;
        case "Home":
          event.preventDefault();
          productTabs[0]?.focus();
          break;
        case "End":
          event.preventDefault();
          productTabs[productTabs.length - 1]?.focus();
          break;
        case "Enter":
        case " ":
          event.preventDefault();
          activateProductTab(tab.dataset.target);
          break;
      }
    });
  });

  activateProductTab("chatMedia");
</script>
