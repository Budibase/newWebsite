---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Plus from "phosphor-astro/Plus.astro";
import BBSymbolWhite from "@assets/logos/BBSymbolWhite.svg";

interface FooterSegment {
  text: string;
  highlight?: boolean;
}

interface Props {
  channel: string;
  channelLogo: ImageMetadata;
  employeeName: string;
  employeeAvatarImage: ImageMetadata;
  employeeAvatarShape?: "square" | "circle";
  timeLabel: string;
  promptText: string;
  assistantIntro: string;
  bulletItems: readonly string[];
  footerSegments: readonly FooterSegment[];
}

const {
  channel,
  channelLogo,
  employeeName,
  employeeAvatarImage,
  employeeAvatarShape = "circle",
  timeLabel,
  promptText,
  assistantIntro,
  bulletItems,
  footerSegments,
} = Astro.props as Props;
---

<div class="workplace-request-demo">
  <div class="workplace-request-demo__header">
    <span class="workplace-request-demo__channel-logo">
      <Image src={channelLogo} alt={channel} class="workplace-request-demo__channel-logo-image" />
    </span>
    <span class="workplace-request-demo__channel-name">{channel}</span>
  </div>

  <div class="workplace-request-demo__messages">
    <div class="workplace-request-demo__message">
      <div
        class:list={[
          "workplace-request-demo__avatar",
          employeeAvatarShape === "square" ? "is-square" : "is-circle",
        ]}
      >
        <Image
          src={employeeAvatarImage}
          alt={employeeName}
          class="workplace-request-demo__avatar-image"
        />
      </div>

      <div class="workplace-request-demo__message-content">
        <div class="workplace-request-demo__meta">
          <span class="workplace-request-demo__author">{employeeName}</span>
          <span class="workplace-request-demo__time">{timeLabel}</span>
        </div>
        <p class="workplace-request-demo__text">
          <span class="workplace-request-demo__mention">@Ops Assistant</span>
          <span>{` ${promptText}`}</span>
        </p>
      </div>
    </div>

    <div class="workplace-request-demo__message">
      <div class="workplace-request-demo__assistant-avatar">
        <Image src={BBSymbolWhite} alt="Budibase" class="workplace-request-demo__assistant-avatar-image" />
      </div>

      <div class="workplace-request-demo__message-content">
        <div class="workplace-request-demo__meta">
          <span class="workplace-request-demo__author">Ops Assistant</span>
          <span class="workplace-request-demo__time">{timeLabel}</span>
        </div>
        <p class="workplace-request-demo__text">{assistantIntro}</p>
        <div class="workplace-request-demo__details">
          <ul>
            {bulletItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <p class="workplace-request-demo__text">
          {
            footerSegments.map((segment) => (
              <span class:list={[segment.highlight && "workplace-request-demo__highlight"]}>
                {segment.text}
              </span>
            ))
          }
        </p>
      </div>
    </div>
  </div>

  <div class="workplace-request-demo__input">
    <span class="workplace-request-demo__input-icon">
      <Plus />
    </span>
    <span>Add a reply</span>
  </div>
</div>

<style>
  .workplace-request-demo {
    width: min(100%, 320px);
    border: 1px solid #ececec;
    border-radius: 10px;
    background: #ffffff;
    box-shadow: 0 18px 35px rgb(15 23 42 / 0.14);
    overflow: hidden;
  }

  .workplace-request-demo__header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid #ececec;
    background: #ffffff;
  }

  .workplace-request-demo__channel-logo {
    display: inline-flex;
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
  }

  .workplace-request-demo__channel-logo-image,
  .workplace-request-demo__avatar-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .workplace-request-demo__channel-name,
  .workplace-request-demo__author {
    font-family: var(--font-sans);
    font-weight: 500;
    color: #202020;
  }

  .workplace-request-demo__channel-name {
    font-size: 14px;
    line-height: 1.1;
  }

  .workplace-request-demo__messages {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 14px 12px 18px;
  }

  .workplace-request-demo__message {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .workplace-request-demo__avatar,
  .workplace-request-demo__assistant-avatar {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
  }

  .workplace-request-demo__avatar {
    width: 36px;
    height: 36px;
    overflow: hidden;
  }

  .workplace-request-demo__avatar.is-circle {
    border-radius: 999px;
  }

  .workplace-request-demo__avatar.is-square {
    border-radius: 999px;
  }

  .workplace-request-demo__avatar-image {
    object-fit: cover;
  }

  .workplace-request-demo__assistant-avatar {
    width: 36px;
    height: 36px;
    padding: 6px;
    border-radius: 999px;
    background: #386cf4;
  }

  .workplace-request-demo__assistant-avatar-image {
    width: calc(100% - 5px);
    height: calc(100% - 5px);
    object-fit: contain;
    display: block;
  }

  .workplace-request-demo__message-content {
    min-width: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .workplace-request-demo__meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .workplace-request-demo__time {
    font-size: 10px;
    line-height: 1;
    color: #7e7e7e;
  }

  .workplace-request-demo__text {
    margin: 0;
    font-size: 13px;
    line-height: 1.35;
    color: #202020 !important;
    text-wrap: balance;
  }

  .workplace-request-demo__mention,
  .workplace-request-demo__highlight {
    color: #386cf4;
  }

  .workplace-request-demo__details {
    border-radius: 3px;
    background: #f0eee6;
    padding: 8px 10px;
  }

  .workplace-request-demo__details ul {
    margin: 0 !important;
    padding-left: 18px;
    font-size: 13px;
    line-height: 1.35;
    color: #202020 !important;
    list-style: disc !important;
    list-style-position: outside;
  }

  .workplace-request-demo__details li {
    color: #202020 !important;
    list-style: disc !important;
  }

  .workplace-request-demo__details li::marker {
    color: #202020;
  }

  :global(.dark) .workplace-request-demo__text,
  :global(.dark) .workplace-request-demo__details ul,
  :global(.dark) .workplace-request-demo__details li,
  :global(.dark) .workplace-request-demo__details li::marker {
    color: #202020 !important;
  }

  .workplace-request-demo__input {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 12px 12px;
    padding: 10px 12px;
    border: 1px solid #ececec;
    border-radius: 14px;
    background: #ffffff;
    font-size: 13px;
    line-height: 1.1;
    color: #7e7e7e;
  }

  .workplace-request-demo__input-icon {
    display: inline-flex;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #ececec;
    color: #7e7e7e;
  }

  .workplace-request-demo__input-icon :global(svg) {
    width: 14px;
    height: 14px;
  }
</style>
