---
import EriLogo from "@assets/logos/ERI_horizontal_RGB.svg?url";
import AmericanExpressLogo from "@assets/logos/AmericanExpress.svg?url";
import SaabLogo from "@assets/logos/saab.svg?url";
import OctopusWordmark from "@assets/logos/octopus-logo.svg?url";
import ArmLogo from "@assets/logos/arm.svg?url";
import ForbesLogo from "@assets/logos/Forbes_idMGYiEOgb_0.svg?url";
---

<section class="container max-w-7xl mx-auto px-2 lg:px-0 mt-12 md:mt-24">
  <h2 class="SectionTitle text-secondary">Join 300K modern teams</h2>

  <div class="customerstatic-scroll mt-6 overflow-x-auto">
    <div class="mx-auto w-fit">
      <div
        class="inline-flex min-w-max items-stretch justify-center gap-3 md:gap-4"
      >
        <div class="customerstatic-card bg-secondary">
          <img
            src={AmericanExpressLogo}
            alt="American Express logo"
            class="logo-mark amex-logo logo-gray-100"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="customerstatic-card bg-secondary">
          <img
            src={EriLogo}
            alt="ERI logo"
            class="logo-mark logo-gray-100"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="customerstatic-card bg-secondary">
          <img
            src={SaabLogo}
            alt="Saab logo"
            class="logo-mark logo-gray-100-darkmark"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="customerstatic-card bg-secondary">
          <img
            src={ArmLogo}
            alt="ARM logo"
            class="logo-mark logo-gray-100-darkmark"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="customerstatic-card bg-secondary">
          <img
            src={ForbesLogo}
            alt="Forbes logo"
            class="logo-mark logo-gray-100"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="customerstatic-card bg-secondary">
          <img
            src={OctopusWordmark}
            alt="Octopus logo"
            class="logo-gray-100-darkmark octopus-wordmark"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .customerstatic-scroll {
    scrollbar-width: none;
  }

  .customerstatic-scroll::-webkit-scrollbar {
    display: none;
  }

  .customerstatic-card {
    display: flex;
    height: 92px;
    width: 168px;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    padding: 18px 20px;
  }

  .logo-mark {
    max-width: 110px;
    max-height: 28px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .amex-logo {
    width: 120px;
    max-width: 120px;
  }

  .octopus-wordmark {
    max-width: 110px;
    max-height: 28px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .logo-gray-100 {
    filter: grayscale(1) brightness(1.85) contrast(0.92);
  }

  .logo-gray-100-darkmark {
    filter: grayscale(1) invert(1) brightness(1.35) contrast(0.92);
  }
</style>
