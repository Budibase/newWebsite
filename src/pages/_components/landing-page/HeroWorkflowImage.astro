<style>
  #canvas {
    background-image: radial-gradient(
      circle at 1px 1px,
      rgba(148, 163, 184, 0.25) 1px,
      transparent 0
    );
    background-size: 16px 16px; /* dot spacing */
  }
</style>

<script>
  // Simple tab switcher: shows the selected section and hides others
  // @ts-check
  /** @type {HTMLButtonElement[]} */
  const tabButtons = Array.from(
    /** @type {NodeListOf<HTMLButtonElement>} */ (
      document.querySelectorAll("[data-target]")
    ),
  );
  /** @type {HTMLElement[]} */
  const sections = Array.from(
    /** @type {NodeListOf<HTMLElement>} */ (
      document.querySelectorAll("#canvas .tab-section")
    ),
  );

  /**
   * @param {string} targetId
   */
  function activate(targetId) {
    // Toggle section visibility
    sections.forEach((el) => {
      el.id === targetId
        ? el.classList.remove("hidden")
        : el.classList.add("hidden");
    });
    // Toggle button active state
    tabButtons.forEach((btn) => {
      const isActive = btn.getAttribute("data-target") === targetId;
      btn.classList.toggle("active", isActive);
      btn.classList.toggle("inactive", !isActive);
      btn.setAttribute("aria-selected", String(isActive));
    });
  }

  // Attach listeners
  tabButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-target");
      if (id) activate(id);
    });
  });

  // Initialize to current active (default "workflows")
  const initiallyActive =
    tabButtons
      .find((b) => b.classList.contains("active"))
      ?.getAttribute("data-target") || "workflows";
  activate(initiallyActive);

  // Note: auto-rotation removed per request. Tabs switch only on click.

  // Minimal chat behavior for Agents tab
  /** @type {HTMLFormElement | null} */
  const chatForm = /** @type {HTMLFormElement | null} */ (
    document.getElementById("agent-chat-form")
  );
  /** @type {HTMLInputElement | null} */
  const chatInput = /** @type {HTMLInputElement | null} */ (
    document.getElementById("agent-chat-input")
  );
  /** @type {HTMLElement | null} */
  const chatMessages = /** @type {HTMLElement | null} */ (
    document.getElementById("agent-chat-messages")
  );

  /**
   * @param {'user'|'assistant'} role
   * @param {string} text
   */
  function appendMessage(role, text) {
    if (!chatMessages) return;
    const wrapper = document.createElement("div");
    wrapper.className = "flex items-start gap-2";
    if (role === "user") wrapper.classList.add("justify-end");

    if (role === "assistant") {
      const avatar = document.createElement("div");
      avatar.className =
        "shrink-0 bg-lavendar-dark text-white h-6 w-6 rounded-md grid place-items-center text-[10px]";
      avatar.textContent = "A";
      wrapper.appendChild(avatar);
    }

    const bubble = document.createElement("div");
    bubble.className =
      role === "user"
        ? "bg-sky-medium text-white rounded-lg px-3 py-2 text-sm max-w-[80%]"
        : "bg-ivory-medium text-gray-900 rounded-lg px-3 py-2 text-sm max-w-[80%]";
    bubble.textContent = text;
    wrapper.appendChild(bubble);
    chatMessages.appendChild(wrapper);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  if (chatForm && chatInput) {
    chatForm.addEventListener("submit", (e) => {
      e.preventDefault();
      const text = chatInput.value.trim();
      if (!text) return;
      appendMessage("user", text);
      chatInput.value = "";
      // Simulated assistant reply
      setTimeout(() => {
        appendMessage(
          "assistant",
          `Got it — drafting offboarding steps for "${text}" (suspend accounts, revoke access, notify manager).`,
        );
      }, 500);
    });
  }
</script>
