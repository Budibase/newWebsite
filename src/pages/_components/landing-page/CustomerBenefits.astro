      src="https://res.cloudinary.com/daog6scxm/image/upload/v1757690227/NewWebsite/images/afcec39e-e401-4c1b-a5e4-57efee935274.webp"
    />
    <img
      alt="switzerland flag"
      loading="lazy"
      width="172"
      height="60"
      decoding="async"
      data-nimg="1"
      class="size-full object-contain nth-[n+11]:hidden h-13 max-md:nth-8:hidden max-md:nth-9:hidden max-xl:nth-8:block max-xl:nth-9:block max-xl:h-11"
