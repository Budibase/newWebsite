---
import CustomerQuotes from "./CustomerQuotes.astro";
---

<section class="max-w-xl mx-auto">
  <h1 class="!text-2xl">
    Chosen by 200,000 teams from the world's top Governments and organizations
  </h1>
  <div
    class="mt-4 grid align-middle items-center grid-cols-10 gap-x-5 gap-y-4.5 max-xl:grid-cols-8 max-xl:gap-y-5 max-lg:gap-x-5 max-lg:gap-y-3 max-md:grid-cols-8 max-md:gap-x-4 max-md:gap-y-2 max-md:[&>*:nth-child(1n+11)]:hidden"
  >
    <img
      alt=""
      loading="lazy"
      width="172"
      height="60"
      decoding="async"
      data-nimg="1"
      class="size-full object-contain nth-[n+11]:hidden h-13 max-md:nth-8:hidden max-md:nth-9:hidden max-xl:nth-8:block max-xl:nth-9:block max-xl:h-11"
      style="color:transparent"
      src="https://res.cloudinary.com/daog6scxm/image/upload/v1757690484/NewWebsite/images/24d8742e-0b7c-447e-a7dd-7aad9c9c77b6.webp"
    />
