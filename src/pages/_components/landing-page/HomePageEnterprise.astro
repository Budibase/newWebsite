---
import SectionBlock from "@components/SectionBlock.astro";
import Card from "@components/cards/Card.astro";

import BackgroundImage from "@assets/images/homepage/use cases/1.png?url";

const cards = [
  {
    label: "Open-source and self-hosting",
    description:
      "Budibase is open-source. Self-host or let us manage everything via Budibase Cloud.",
    imageUrl:
      "https://res.cloudinary.com/daog6scxm/image/upload/v1698944959/cms/home/enterprise/Deploy_itdcgr.webp",
    imageAlt: "Budibase Public API",
  },
  {
    label: "Enterprise-grade security",
    description:
      "Budibase is ISO 27001 certified and fully committed to ongoing compliance.",
    imageUrl:
      "https://res.cloudinary.com/daog6scxm/image/upload/v1698942060/cms/home/enterprise/security_joe3dh.webp",
    imageAlt: "Privacy checklist",
  },
  {
    label: "Built to scale",
    description:
      "Custom RBAC, SSO, SAML, backups, audit logs, and a public API allow you to scale with confidence.",
    imageUrl:
      "https://res.cloudinary.com/daog6scxm/image/upload/v1698937918/cms/home/enterprise/built-to-scale_foaoqi.webp",
    imageAlt: "Budibase auth illustration",
  },
] as const;
---

<section
  class="container max-w-[var(--site-container-max)] mx-auto mt-12 md:mt-24 px-2 lg:px-0"
>
  <SectionBlock
    title="Scale with Confidence"
    description="Whether you’re automating workflows, removing data silos, or building agents — Budibase works for you."
    align="center"
    maxWidth="3xl"
  >
    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
      {
        cards.map((card) => (
          <div
            class="home-enterprise__card"
            style={`--enterprise-bg: url("${BackgroundImage}")`}
          >
            <Card
              label={card.label}
              description={card.description}
              imageSrc={BackgroundImage}
              imageAlt={card.imageAlt}
            >
              <div
                slot="image-overlay"
                class="home-enterprise__overlay"
                aria-hidden="true"
              >
                <img
                  class="home-enterprise__overlay-image"
                  src={card.imageUrl}
                  alt={card.imageAlt}
                  loading="lazy"
                />
              </div>
            </Card>
          </div>
        ))
      }
    </div>
  </SectionBlock>
</section>

<style>
  .home-enterprise__card :global(.card-image-wrap) {
    position: relative;
    height: 360px;
    background-image: var(--enterprise-bg);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    overflow: hidden;
  }

  .home-enterprise__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 12px;
    background-image: var(--enterprise-bg);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    border-radius: inherit;
    pointer-events: none;
  }

  .home-enterprise__overlay-image {
    width: 100%;
    max-width: 360px;
    height: auto;
    border-radius: 0.5rem;
  }

  .home-enterprise__card :global(.card-image) {
    opacity: 0;
  }
</style>
