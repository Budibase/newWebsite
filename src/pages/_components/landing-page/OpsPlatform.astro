---
import SectionBlock from "@components/SectionBlock.astro";
import OpsPlatformDemoNew from "@components/OpsPlatformDemoNew.astro";
---

<section
  class="container max-w-[var(--site-container-max)] mx-auto mt-12 md:mt-24 px-2 lg:px-0"
>
  <SectionBlock
    title="Agents that take action"
    description="Budibase agents don’t just answer questions. They run workflows across your business - creating records, routing approvals, updating apps, and notifying teams automatically."
    align="center"
    maxWidth="3xl"
  >
    <div class="ops-platform__demo">
      <OpsPlatformDemoNew />
    </div>
  </SectionBlock>
</section>

<style>
  .ops-platform__demo {
    width: 100%;
  }
</style>
