                  style="background-size: 6px 100%; opacity: 1;"
                ></div>
                <div
                  aria-hidden="true"
                  class="decorative-border absolute top-0 right-0 h-full w-0.5"
                  style="background-size: 100% 6px; opacity: 1;"
                ></div>
                <img
                  alt="Vonage"
