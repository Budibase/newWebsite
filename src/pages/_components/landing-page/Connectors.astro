                />
              </div>
            </div>

            <!-- Bottom Decorative Border -->
            <div class="relative h-12 w-full">
              <div
                aria-hidden="true"
                class="decorative-border absolute top-0 right-0 h-full w-0.5"
                style="background-size: 100% 6px; opacity: 1; mask-image: linear-gradient(black 0%, black 20%, transparent 100%);"
              ></div>
              <div
                aria-hidden="true"
                class="decorative-border absolute top-0 left-0 h-full w-0.5"
                style="background-size: 100% 6px; opacity: 1; mask-image: linear-gradient(black 0%, black 20%, transparent 100%);"
              ></div>
            </div>

            <!-- Footer Section -->
            <div class="mb-12 mt-3 text-center text-base text-stone-500  lg:mb-16 lg:mt-8">
              And hundreds more via APIs or MCPs.
            </div>

            <Button
              label="View all Integrations"
              url="/product/connections"
              variant="secondary"
              class="border-stone-300  text-stone-900  hover:text-stone-700  hover:border-stone-400  bg-transparent"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
