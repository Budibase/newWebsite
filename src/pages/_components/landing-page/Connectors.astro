---
import Button from "@components/Button.astro";
import PlaceholderIcon from "@assets/logos/bbSymbol.svg";
---

<style>
  .decorative-border {
    background-image: repeating-radial-gradient(
      circle,
      var(--bb-transparent-black-400) 0px,
      var(--bb-transparent-black-400) 1px,
      transparent 1px,
      transparent 6px
    );
  }
</style>

<div class="bg-secondary block-section mt-12 md:mt-24">
  <div class="container relative max-w-7xl mx-auto">
    <div class="px-2 lg:px-0 pb-0 md:pb-0 pt-0">
      <div class="blocks">
        <div class="block-el block-el-convai-integrations-table block-in-view">
          <div class="flex flex-col items-center justify-center">
            <!-- Header Section -->
            <div class="mb-10 flex w-full max-w-3xl flex-col items-center text-center lg:mb-16">
              <h3 class="h3 mb-4 max-w-2xl text-stone-900 ">
                Integrate seamlessly with your tech stack and the tools you already use
              </h3>
              <div class="text-base max-w-xl text-pretty text-stone-500 ">
                Connect agents to your CRM, support desk, calendar, payment system, or telephony provider. Whether it's Salesforce, Stripe, Zendesk, or Twilio, integrations work out of the box with minimal setup
              </div>
            </div>

            <!-- Top Decorative Border -->
            <div class="relative h-12 w-full">
              <div
                aria-hidden="true"
                class="decorative-border absolute top-0 right-0 h-full w-0.5"
                style="background-size: 100% 6px; opacity: 1; mask-image: linear-gradient(to top, black 0%, black 20%, transparent 100%);"
              ></div>
              <div
                aria-hidden="true"
                class="decorative-border absolute top-0 left-0 h-full w-0.5"
                style="background-size: 100% 6px; opacity: 1; mask-image: linear-gradient(to top, black 0%, black 20%, transparent 100%);"
              ></div>
            </div>

            <!-- Logo Grid -->
            <div class="grid w-full max-w-xl grid-cols-3 grid-rows-3 border border-stone-300 ">
              <!-- Row 1 -->
              <div class="relative flex items-center justify-center p-5 lg:px-[60px] lg:py-8">
                <div
                  aria-hidden="true"
                  class="decorative-border absolute bottom-0 left-0 h-0.5 w-full"
                  style="background-size: 6px 100%; opacity: 1;"
                ></div>
                <div
                  aria-hidden="true"
                  class="decorative-border absolute top-0 right-0 h-full w-0.5"
                  style="background-size: 100% 6px; opacity: 1;"
                ></div>
                <img
                  alt="Aston Martin"
                  loading="lazy"
                  width="120"
                  height="40"
                  decoding="async"
                  class="h-[30px] w-[90px] transform-gpu object-contain transition-all duration-700 ease-out-slow lg:h-10 lg:w-30"
                  src={PlaceholderIcon.src}
                  style="color: transparent;"
                />
              </div>

              <div class="relative flex items-center justify-center p-5 lg:px-[60px] lg:py-8">
                <div
                  aria-hidden="true"
                  class="decorative-border absolute bottom-0 left-0 h-0.5 w-full"
                  style="background-size: 6px 100%; opacity: 1;"
                ></div>
                <div
                  aria-hidden="true"
                  class="decorative-border absolute top-0 right-0 h-full w-0.5"
                  style="background-size: 100% 6px; opacity: 1;"
                ></div>
                <img
                  alt="Stripe"
                  loading="lazy"
                  width="120"
                  height="40"
                  decoding="async"
                  class="h-[30px] w-[90px] transform-gpu object-contain transition-all duration-700 ease-out-slow lg:h-10 lg:w-30"
                  src={PlaceholderIcon.src}
                  style="color: transparent;"
                />
              </div>

              <div class="relative flex items-center justify-center p-5 lg:px-[60px] lg:py-8">
                <div
                  aria-hidden="true"
                  class="decorative-border absolute bottom-0 left-0 h-0.5 w-full"
                  style="background-size: 6px 100%; opacity: 1;"
                ></div>
                <img
                  alt="Cal.com"
                  loading="lazy"
                  width="120"
                  height="40"
                  decoding="async"
                  class="h-[30px] w-[90px] transform-gpu object-contain transition-all duration-700 ease-out-slow lg:h-10 lg:w-30"
                  src={PlaceholderIcon.src}
                  style="color: transparent;"
                />
              </div>

              <!-- Row 2 -->
              <div class="relative flex items-center justify-center p-5 lg:px-[60px] lg:py-8">
                <div
