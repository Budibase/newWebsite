---
import SupportAvatarImage from "@assets/images/avatars/Ellipse-1.png?url";
import BudibaseSymbol from "@assets/BBSymbolWhite.svg?url";
import TeamsLogo from "@assets/logos/microsoft-teams.svg?url";
import CheckCircleFill from "phosphor-astro/CheckCircleFill.astro";
import Icon from "@components/Icon.astro";
import SectionBlock from "@components/SectionBlock.astro";

interface FrameNode {
  title: string;
  description?: string;
  iconKind:
    | "sparkle"
    | "clock"
    | "rowsPlusBottom"
    | "paperPlaneTilt"
    | "teams"
    | "bamboohr";
  iconTone: "trigger" | "agent" | "integration" | "alert";
  badgeLabel?: "Trigger" | "Operation";
  badgeTone?: "trigger" | "operation";
}

interface FrameScenario {
  id: "employee-self-service" | "approval-requests" | "internal-support";
  nodes: FrameNode[];
}

const id = `agent-use-cases-${Math.random().toString(36).slice(2, 8)}`;

const frames: FrameScenario[] = [
  {
    id: "internal-support",
    nodes: [
      {
        badgeLabel: "Trigger",
        badgeTone: "trigger",
        title: "Support request",
        description: "A request comes in from an employee",
        iconKind: "paperPlaneTilt",
        iconTone: "trigger",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Support agent",
        description: "Understand the issue and gather details",
        iconKind: "sparkle",
        iconTone: "agent",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Team handoff",
        description: "Route the request to the right team in Slack",
        iconKind: "teams",
        iconTone: "integration",
      },
    ],
  },
];

const tabs = [
  {
    key: "internal-support",
    label: "Internal support",
    icon: "Headset",
    iconWeight: "fill",
  },
];
---

<section>
  <div
    class="grid grid-cols-1 gap-8 lg:grid-cols-[minmax(0,1.02fr)_minmax(0,0.98fr)] lg:items-center lg:gap-20"
  >
    <SectionBlock
      titleColorMode="split-secondary-primary"
      titleLines={[
        { text: "Handle requests where" },
        { text: "Work really happens" },
      ]}
      description="Budibase agents help teams handle routine operational work automatically, via existing messaging tools. They can understand requests, gather information, and take action across your systems."
      maxWidth="xl"
      spacing="default"
      contentClass="pt-1"
    >
      <ul class="flex flex-col gap-4">
        <li class="flex items-start gap-3">
          <CheckCircleFill
            class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]"
            aria-hidden="true"
          />
          <div class="space-y-1.5">
            <div
              class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]"
            >
              Employee self-service
            </div>
            <p class="m-0 text-[14px] leading-6 text-[var(--text-secondary)]">
              Employees ask questions and get instant answers.
            </p>
          </div>
        </li>

        <li class="flex items-start gap-3">
          <CheckCircleFill
            class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]"
            aria-hidden="true"
          />
          <div class="space-y-1.5">
            <div
              class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]"
            >
              Approval requests
            </div>
            <p class="m-0 text-[14px] leading-6 text-[var(--text-secondary)]">
              Agents can collect information and run approval workflows.
            </p>
          </div>
        </li>

        <li class="flex items-start gap-3">
          <CheckCircleFill
            class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]"
            aria-hidden="true"
          />
          <div class="space-y-1.5">
            <div
              class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]"
            >
              Support triage
            </div>
            <p class="m-0 text-[14px] leading-6 text-[var(--text-secondary)]">
              Agents can manage incoming requests and route them to the right
              team.
            </p>
          </div>
        </li>
      </ul>
    </SectionBlock>

    <div>
      <div class="agent-use-cases-thread-stage">
        <div class="agent-use-cases-thread-card agent-use-cases-support-card">
          <div class="agent-use-cases-support-header">
            <img
              src={TeamsLogo}
              alt=""
              class="agent-use-cases-support-header-logo"
            />
            <h3 class="agent-use-cases-support-header-title">
              Microsoft Teams
            </h3>
          </div>

          <div class="agent-use-cases-thread-body agent-use-cases-support-body">
            <div class="agent-use-cases-thread-message">
              <img
                src={SupportAvatarImage}
                alt="Jess Mitchell"
                class="agent-use-cases-thread-avatar agent-use-cases-support-avatar"
              />
              <div class="agent-use-cases-thread-copy">
                <div class="agent-use-cases-thread-meta">
                  <p class="agent-use-cases-thread-name">Jess Mitchell</p>
                  <p class="agent-use-cases-thread-time">2 mins</p>
                </div>
                <p class="agent-use-cases-thread-text">
                  <span class="agent-use-cases-thread-link">@Ops Assistant</span
                  >
                  <span> my VPN isn’t working</span>
                </p>
              </div>
            </div>

            <div class="agent-use-cases-thread-message">
              <div
                class="agent-use-cases-thread-badge agent-use-cases-support-badge"
                aria-hidden="true"
              >
                <img
                  src={BudibaseSymbol}
                  alt=""
                  class="agent-use-cases-thread-badge-symbol"
                />
              </div>
              <div class="agent-use-cases-thread-copy">
                <div class="agent-use-cases-thread-meta">
                  <p class="agent-use-cases-thread-name">Ops Assistant</p>
                  <p class="agent-use-cases-thread-time">2 mins</p>
                </div>
                <div class="agent-use-cases-support-response">
                  <p>Sounds like a VPN access issue.</p>
                  <p>Support ticket created</p>
                  <ul>
                    <li>Category: Network &amp; Connectivity</li>
                    <li>Issue: VPN access</li>
                    <li>Priority: Medium</li>
                  </ul>
                  <p>Assigned to IT. They'll follow up shortly.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="agent-use-cases-thread-input">
            <div class="agent-use-cases-thread-input-row">
              <div
                class="agent-use-cases-thread-input-icon-wrap"
                aria-hidden="true"
              >
                <Icon
                  name="Plus"
                  size="24"
                  class="agent-use-cases-support-input-icon"
                />
              </div>
              <p class="agent-use-cases-thread-input-text">Add a reply</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .agent-use-cases-thread-stage {
    --form-demo-grid-dot: rgb(var(--text) / 0.12);

    display: flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    max-width: 100%;
    margin: 0 auto;
    padding: 64px;
    box-sizing: border-box;
    border: 1px solid rgb(var(--border) / 0.45);
    border-radius: 12px;
    background:
      radial-gradient(
          circle at center,
          var(--form-demo-grid-dot) 1.3px,
          transparent 1.3px
        )
        0 0 / 20px 20px,
      var(--bg-2);
    animation: form-demo-dot-drift 14s linear infinite;
  }

  .agent-use-cases-thread-card {
    width: 600px;
    max-width: 100%;
    overflow: hidden;
    border-radius: 12px;
    background: var(--bb-white);
    padding-bottom: 20px;
    font-family: var(--font-display);
    text-align: left;
  }

  .agent-use-cases-support-card {
    border-radius: 10px;
  }

  .agent-use-cases-support-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-bottom: 1px solid var(--bb-gray-100);
    text-align: left;
  }

  .agent-use-cases-support-header-logo {
    width: 22px;
    height: 23px;
    display: block;
    object-fit: contain;
    flex-shrink: 0;
  }

  .agent-use-cases-support-header-title {
    margin: 0;
    color: var(--bb-text-base) !important;
    font-size: 18px;
    font-weight: 500;
    line-height: 1;
    text-align: left;
  }

  .agent-use-cases-thread-body {
    display: flex;
    flex-direction: column;
    gap: 30px;
    padding: 20px 18px 0;
    text-align: left;
  }

  .agent-use-cases-support-body {
    min-height: 300px;
  }

  .agent-use-cases-thread-message {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 14px;
    width: 100%;
    text-align: left;
  }

  .agent-use-cases-thread-avatar {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 8px;
    object-fit: cover;
  }

  .agent-use-cases-support-avatar,
  .agent-use-cases-support-badge {
    border-radius: 999px;
  }

  .agent-use-cases-thread-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 8px;
    background: var(--bb-brand);
    padding: 8px;
  }

  .agent-use-cases-thread-badge-symbol {
    width: 24px;
    height: 24px;
    display: block;
  }

  .agent-use-cases-thread-copy {
    width: 350px;
    max-width: calc(100% - 54px);
    text-align: left;
  }

  .agent-use-cases-thread-meta {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 6px;
    margin-bottom: 10px;
    text-align: left;
  }

  .agent-use-cases-thread-name,
  .agent-use-cases-thread-time,
  .agent-use-cases-thread-text,
  .agent-use-cases-thread-input-text,
  .agent-use-cases-support-response p,
  .agent-use-cases-support-response li {
    margin: 0;
    letter-spacing: 0;
    text-align: left;
  }

  .agent-use-cases-thread-name {
    color: var(--bb-text-base) !important;
    font-size: 18px;
    font-weight: 500;
    line-height: 1;
  }

  .agent-use-cases-thread-time {
    color: var(--bb-gray-600) !important;
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
  }

  .agent-use-cases-thread-text,
  .agent-use-cases-support-response {
    color: var(--bb-gray-700) !important;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.5;
    text-align: left;
  }

  .agent-use-cases-thread-link {
    color: var(--bb-brand) !important;
  }

  .agent-use-cases-support-response p {
    color: var(--bb-gray-700) !important;
  }

  .agent-use-cases-support-response p + p {
    margin-top: 18px;
  }

  .agent-use-cases-support-response ul {
    margin: 0;
    padding-left: 0;
    text-align: left;
  }

  .agent-use-cases-support-response li {
    position: relative;
    padding-left: 18px;
    color: var(--bb-gray-700) !important;
  }

  .agent-use-cases-support-response li::before {
    content: "•";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--bb-gray-700);
  }

  .agent-use-cases-thread-input {
    width: 404px;
    max-width: calc(100% - 36px);
    height: 57px;
    margin: 30px auto 0;
    border: 1px solid var(--bb-gray-100);
    border-radius: 16px;
    display: flex;
    align-items: center;
    padding: 10px 20px;
    text-align: left;
  }

  .agent-use-cases-thread-input-row {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 12px;
    text-align: left;
  }

  .agent-use-cases-thread-input-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 37px;
    height: 37px;
    border-radius: 999px;
    background: var(--bb-gray-100);
    color: var(--bb-gray-600);
    flex-shrink: 0;
  }

  .agent-use-cases-thread-input-text {
    color: var(--bb-gray-600);
    font-size: 16px;
    font-weight: 400;
    line-height: 1;
  }

  .agent-use-cases-support-input-icon {
    width: 24px;
    height: 24px;
    display: block;
    color: currentColor;
  }

  @keyframes form-demo-dot-drift {
    from {
      background-position:
        0 0,
        0 0;
    }

    to {
      background-position:
        20px 20px,
        0 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .agent-use-cases-thread-stage {
      animation: none;
    }
  }

  @media (max-width: 767px) {
    .agent-use-cases-thread-stage {
      width: 100%;
      padding: 24px 16px;
    }

    .agent-use-cases-thread-card {
      width: 100%;
    }

    .agent-use-cases-thread-copy {
      width: auto;
      max-width: calc(100% - 54px);
    }

    .agent-use-cases-thread-input {
      width: calc(100% - 36px);
      max-width: none;
    }
  }
</style>
