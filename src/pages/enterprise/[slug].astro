---
import Layout from "../../layouts/MainLayout.astro";
import PlatformLayout from "@components/PlatformLayout.astro";
import { enterpriseNavItemsData } from "./_navItems";
import { getCollection, render } from "astro:content";
import Buildings from "phosphor-astro/Buildings.astro";
import ShieldCheck from "phosphor-astro/ShieldCheck.astro";
import Sliders from "phosphor-astro/Sliders.astro";
import Headset from "phosphor-astro/Headset.astro";
import MapPin from "phosphor-astro/MapPin.astro";
import HardHat from "phosphor-astro/HardHat.astro";
import Broadcast from "phosphor-astro/Broadcast.astro";
import Recycle from "phosphor-astro/Recycle.astro";
import Truck from "phosphor-astro/Truck.astro";
import Bank from "phosphor-astro/Bank.astro";
import Gear from "phosphor-astro/Gear.astro";
import Package from "phosphor-astro/Package.astro";
import ChartBar from "phosphor-astro/ChartBar.astro";
import EnvelopeSimple from "phosphor-astro/EnvelopeSimple.astro";
import DefaultCover from "@assets/images/homepage/valley.png";
import { Image } from "astro:assets";

const iconMap: Record<string, any> = {
	Buildings,
	ShieldCheck,
	Sliders,
	Headset,
	MapPin,
	HardHat,
	Broadcast,
	Recycle,
	Truck,
	Bank,
	Gear,
	Package,
	ChartBar,
	EnvelopeSimple,
};

const navItems = enterpriseNavItemsData.map(group => ({
	...group,
	items: group.items.map(item => ({
		...item,
		icon: iconMap[item.iconName],
	})),
}));

// Load all case study images
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/case-studies/*.*');

// Generate static paths for all case studies
export async function getStaticPaths() {
	const caseStudies = await getCollection("caseStudies");
	return caseStudies.map(study => ({
		params: { slug: study.id },
		props: { study },
	}));
}

const { study } = Astro.props;
const { Content } = await render(study);
const { title, quote, employees, industry, coverImage, author } = study.data;

// Get the cover image - use custom if specified, otherwise default
let coverSrc = DefaultCover;
if (coverImage && images[coverImage]) {
	const imageModule = await images[coverImage]();
	coverSrc = imageModule.default;
}
---

<Layout>
	<PlatformLayout
		title="Enterprise"
		description="Enterprise-grade security, control, & support for mission-critical workflows."
		{navItems}
	>
		<div class="mb-8">
			<div class="bg-stone-100 dark:bg-stone-900 rounded-md p-4 mb-4">
				<h2 class="text-lg! text-stone-900 dark:text-stone-100">
					{title}
				</h2>
				{(employees || industry) && (
					<p class="text-sm! text-stone-500! dark:text-stone-500! mb-4!">
						{[employees, industry].filter(Boolean).join(" · ")}
					</p>
				)}

				<Image
					src={coverSrc}
					alt={`${title} case study`}
					class="w-full h-96 object-cover rounded-md mb-6"
				/>

				<article class="article">
					<Content />
					
					{author && (
						<p class="mt-8 font-semibold">
							{author.name}<br />
							<span class="font-normal text-stone-500 dark:text-stone-400">{author.role}</span>
						</p>
					)}
				</article>
			</div>
		</div>
	</PlatformLayout>
</Layout>
