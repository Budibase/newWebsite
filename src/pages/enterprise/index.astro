---
import Layout from "../../layouts/MainLayout.astro";
import PlatformLayout from "@components/PlatformLayout.astro";
import HeroBg from "@assets/images/homepage/valley.png";
import { Image } from "astro:assets";
import Card from "@components/cards/Card.astro";
import type { ImageInputFormat } from "node_modules/astro/dist/assets/types";
import Button from "@components/Button.astro";
import BookACallButton from "../../components/BookACallButton.astro";

const pageTitle = "Enterprise";
const pageDescription =
  "Budibase Enterprise delivers the security, control, and dedicated support that large organizations need.";

const navItems = [
  {
    text: "Overview",
    link: "/enterprise",
    sectionId: "overview",
    pageTitle,
    pageDescription,
  },
];

const headlineFeatureCards = [
