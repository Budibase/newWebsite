const headlineImageMetadata = (src:string, format:ImageInputFormat) : ImageMetadata => ({
  src:src, 
  format:format,
  height: 100,
  width: 100,
});

---

<Layout title={pageTitle} description={pageDescription}>
  <PlatformLayout title={pageTitle} description={pageDescription}>
    <div class="mb-10">
      
      <div class="mb-4 flex justify-center">
          <Button label="Book a demo" size="large" url="/contact/"/>
      </div>

      <div class="bg-stone-100  rounded-md p-4 mb-4">
        

        <Image
          src={HeroBg}
          alt="Enterprise overview"
          class="w-full h-96 object-cover rounded-md"
        />

        
      </div>


      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-2 headline-features-container">
        {
          headlineFeatureCards.map((card) => (
            <Card label={card.label} description={card.description} imageSrc={headlineImageMetadata(card.img_src, card.img_format)}/>
          ))
        }
      </div>

      

      {
        featureCardCategories.map((category) => (
          <section class="mb-8">
            <h2 class="mb-6 text-xl md:text-2xl lg:text-3xl text-secondary text-center">
              {category.title}
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-2">
              {
                category.cards.map((card) => (
                  <Card label={card.label} description={card.description} />
                ))
              }
            </div>
          </section>
        ))
      }
    </div>

    <section class="mb-8 m-16">
      <h1 class="mb-6 text-xl md:text-2xl lg:text-3xl text-secondary text-center">
        Contact us
      </h1>
      <p class="text-center">
        Let's explore how Budibase can work for you.
      </p>
      <div class="mb-4 flex justify-center margin-xl m-5">
            <Button label="Book a demo" size="large" url="/contact/" variant="cta"/>
      </div>
    </section>

    <section class="mb-8 m-16">
      <h2 class="mb-6 text-xl md:text-2xl lg:text-3xl text-secondary text-center">
        Enterprise customers
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-2">
        {
          customerCards.map((card) => (
            <Card
              tag="/Customers"
              label={card.label}
              description={card.description}
              linkUrl={card.linkUrl}
            />
          ))
        }
      </div>
    </section>
  </PlatformLayout>
</Layout>

<style>

.headline-features-container {
  margin-bottom: 32px;
  margin-top: 32px;
}

:global(.enterprise-contact) {
  margin: 3rem auto 0;
  max-width: 52rem;
  width: 100%;
}

:global(.enterprise-contact__cta) {
  display: flex;
  justify-content: center;
  width: 100%;
}

:global(.enterprise-contact__copy) {
  margin: 1.5rem 0 2rem;
  text-align: center;
  color: rgb(var(--text));
  font-size: 1.05rem;
  line-height: 1.5;
}

:global(.enterprise-contact__form-wrap) {
  margin: 0 auto;
  max-width: 42rem;
  width: 100%;
}

:global(.enterprise-contact .contact-form) {
  margin-top: 0;
  width: 100%;
}

:global(.enterprise-contact .contact-form__honeypot) {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

:global(.enterprise-contact .contact-field) {
  display: grid;
  gap: 0.65rem;
  margin: 0;
  text-align: left;
}

:global(.enterprise-contact .contact-field + .contact-field) {
  margin-top: 1.55rem;
}

:global(.enterprise-contact .contact-field span) {
  color: rgb(var(--text));
  font-size: 0.98rem;
  font-weight: 700;
  line-height: 1.2;
}

:global(.enterprise-contact .contact-field input),
:global(.enterprise-contact .contact-field textarea) {
  width: 100%;
  border: 1px solid rgb(var(--border) / 0.92);
  border-radius: 0.55rem;
  background: transparent;
  color: rgb(var(--text));
  font: inherit;
  transition:
    border-color 150ms ease,
    box-shadow 150ms ease,
    background-color 150ms ease;
}

:global(.enterprise-contact .contact-field input) {
  min-height: 3.1rem;
  padding: 0 0.95rem;
}

:global(.enterprise-contact .contact-field textarea) {
  min-height: 10.6rem;
  resize: vertical;
  padding: 0.9rem 0.95rem;
}

:global(.enterprise-contact .contact-field input:hover),
:global(.enterprise-contact .contact-field textarea:hover) {
  border-color: rgb(var(--border-strong) / 0.9);
}

:global(.enterprise-contact .contact-field input::placeholder),
:global(.enterprise-contact .contact-field textarea::placeholder) {
  color: rgb(var(--text-subtle));
}

:global(.enterprise-contact .contact-field input:focus-visible),
:global(.enterprise-contact .contact-field textarea:focus-visible),
:global(.enterprise-contact .contact-submit:focus-visible) {
  outline: 2px solid rgb(var(--ring));
  outline-offset: 3px;
}

:global(.enterprise-contact .contact-submit) {
  display: block;
  margin-top: 2.2rem;
  margin-left: auto;
  margin-right: auto;
  border: 0;
  border-radius: 999px;
  background: rgb(var(--text));
  color: rgb(var(--bg));
  min-height: 3.35rem;
  padding: 0 1.45rem;
  font: inherit;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition:
    transform 150ms ease,
    opacity 150ms ease;
}

:global(.enterprise-contact .contact-submit:hover) {
  transform: translateY(-1px);
  opacity: 0.94;
}

  .headline-features-container :global(img) {
    max-width: 100px;
    height: auto;
    object-fit: contain;
  }

</style>
