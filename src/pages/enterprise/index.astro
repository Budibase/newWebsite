    img_format: "svg" as ImageInputFormat
  },
  {
    label: "Open-source",
    description: "Deploy on your own infrastructure with complete data sovereignty.",
    img_src:"https://res.cloudinary.com/daog6scxm/image/upload/e_grayscale/v1778075353/icons/open-source-logo-blueish_v4vexu.png",
    img_format: "svg" as ImageInputFormat
  },
  {
    label: "Priority response",
