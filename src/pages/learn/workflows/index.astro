---
import Layout from "../../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import PlaybookRow from "@components/workflows/PlaybookRow.astro";
import CategoriesSidebar from "../../blog/_components/CategoriesSidebar.astro";
import { learnLinks } from "../_learnLinks";

const workflows = await getCollection("workflows");
const orderedSlugs = [
  "incident-triage",
  "access-request",
  "change-management",
  "password-reset",
  "employee-onboarding",
  "holiday-approval",
  "invoice-approval",
  "support-ticket-triage",
];
const orderedWorkflows = orderedSlugs
  .map((slug) =>
    workflows.find((entry) => entry.data.slug === slug || entry.id === slug),
  )
  .filter(Boolean) as typeof workflows;
const workflowRows = orderedWorkflows.length ? orderedWorkflows : workflows;
const activeLearnLink = learnLinks.find(link => link.href === "/learn/workflows");
const pageTitle = activeLearnLink?.pageTitle ?? "Workflows";
const pageDescription =
  activeLearnLink?.pageDescription ?? "Proven workflow playbooks for real-world use cases.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
>
  <div class="side-rail-shell">
    <aside class="side-rail-left chrome-border" aria-label="Learn navigation">
      <div class="side-rail-left-scroll">
        <div class="px-3 mb-3 text-sm text-secondary">Learn</div>
        <CategoriesSidebar
          showHeader={false}
          links={learnLinks}
          activeHref="/learn/workflows"
        />
      </div>
    </aside>

    <div class="side-rail-main">
      <div class="side-rail-main-inner">
        <section class="side-rail-page-header max-w-3xl">
          <h1 class="mb-2 text-5xl!">{pageTitle}</h1>
          <p class="text-stone-500! dark:text-stone-400!">
            {pageDescription}
          </p>
        </section>

        <main class="blog-main">
          <section class="pb-12">
            <div class="grid grid-cols-[1fr_180px_140px] gap-4 !text-base tracking-wide text-stone-500 dark:text-stone-400 border-b border-stone-200/70 dark:border-stone-800/70 pb-2 px-2">
              <span>Workflow</span>
              <span>Role</span>
              <span>Copies</span>
            </div>
            <div>
              {workflowRows.map((entry, index) => (
                (() => {
                  const entrySlug = entry.data.slug ?? entry.id;
                  return (
                <PlaybookRow
                  href={`/learn/workflows/${entrySlug}`}
                  title={entry.data.title}
                  role={entry.data.role}
                  tags={entry.data.tags}
                  copies={Math.floor(Math.random() * (5000 - 200 + 1)) + 200}
                />
                  );
                })()
              ))}
            </div>
          </section>
        </main>
      </div>
    </div>
  </div>
</Layout>

<style>
	.blog-main {
		flex: 1;
		min-width: 0;
		min-height: 60vh;
	}
</style>
