---
import Layout from "../../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import PlaybookRow from "@components/workflows/PlaybookRow.astro";
import CategoriesSidebar from "../../blog/_components/CategoriesSidebar.astro";
import { learnLinks } from "../_learnLinks";

const workflows = await getCollection("workflows");
const orderedSlugs = [
  "incident-triage",
  "access-request",
  "change-management",
  "password-reset",
  "employee-onboarding",
  "holiday-approval",
  "invoice-approval",
  "support-ticket-triage",
];
const orderedWorkflows = orderedSlugs
  .map((slug) =>
    workflows.find((entry) => entry.data.slug === slug || entry.id === slug),
  )
  .filter(Boolean) as typeof workflows;
const workflowRows = orderedWorkflows.length ? orderedWorkflows : workflows;
---

<Layout
  title="Workflow Library"
  description="Proven workflows for how real work gets done."
>
  <div class="mt-24 container max-w-7xl mx-auto learn-index">
    <div class="blog-layout">
      <aside class="blog-sidebar">
        <CategoriesSidebar
          title="Learn"
          description="Guides, workflows, and updates to help you build real AI workflows with Budibase."
          links={learnLinks}
          activeHref="/learn/workflows"
        />
      </aside>

      <main class="blog-main">
        <section class="pb-5">
          <div class="max-w-3xl">
            <h1 class="mb-2 text-xl!">
              Workflow Library
            </h1>
          </div>
        </section>

        <section class="pb-12">
          <div class="grid grid-cols-[1fr_180px_140px] gap-4 !text-base tracking-wide text-stone-500 dark:text-stone-400 border-b border-stone-200/70 dark:border-stone-800/70 pb-2 px-2">
            <span>Workflow</span>
            <span>Role</span>
            <span>Copies</span>
          </div>
          <div>
            {workflowRows.map((entry, index) => (
              (() => {
                const entrySlug = entry.data.slug ?? entry.id;
                return (
              <PlaybookRow
                href={`/learn/workflows/${entrySlug}`}
                title={entry.data.title}
                role={entry.data.role}
                tags={entry.data.tags}
                copies={Math.floor(Math.random() * (5000 - 200 + 1)) + 200}
              />
                );
              })()
            ))}
          </div>
        </section>

      </main>
    </div>
  </div>
</Layout>

<style>
	.blog-container {
		min-height: calc(100vh - 200px);
		padding: 2rem 1rem;
	}

	.blog-layout {
		margin: 0 auto;
		display: grid;
		grid-template-columns: minmax(220px, 280px) minmax(0, 1fr);
		grid-template-areas: "sidebar main";
		gap: 4rem;
		align-items: start;
	}

	.blog-sidebar {
		grid-area: sidebar;
		position: sticky;
		top: 2rem;
	}

	.blog-main {
		grid-area: main;
		flex: 1;
		min-width: 0;
		min-height: 60vh;
	}

	@media (max-width: 1024px) {
		.blog-layout {
			gap: 4rem;
		}
	}

	@media (max-width: 768px) {
		.blog-layout {
			grid-template-columns: 1fr;
			gap: 2rem;
			grid-template-areas:
				"sidebar"
				"main";
		}

		.blog-sidebar {
			position: static;
		}

		.blog-container {
			padding: 1.5rem 1rem;
		}
	}
</style>
