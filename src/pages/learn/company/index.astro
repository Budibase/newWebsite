---
import Layout from "../../../layouts/MainLayout.astro";
import CategoriesSidebar from "../../blog/_components/CategoriesSidebar.astro";
import { learnLinks } from "../_learnLinks";
const activeLearnLink = learnLinks.find(link => link.href === "/learn/company");
const pageTitle = activeLearnLink?.pageTitle ?? "Company";
const pageDescription = activeLearnLink?.pageDescription ?? "Who we are and what we build.";
---

<Layout title={pageTitle} description={pageDescription}>
  <div class="side-rail-shell">
    <aside class="side-rail-left chrome-border" aria-label="Learn navigation">
      <div class="side-rail-left-scroll">
        <div class="px-3 mb-3 text-sm text-secondary">Learn</div>
        <CategoriesSidebar
          showHeader={false}
          links={learnLinks}
          activeHref="/learn/company"
        />
      </div>
    </aside>

    <div class="side-rail-main">
      <div class="side-rail-main-inner">
        <section class="side-rail-page-header max-w-3xl">
          <h1 class="mb-2 text-5xl!">{pageTitle}</h1>
          <p class="text-stone-500! dark:text-stone-400!">
            {pageDescription}
          </p>
        </section>

        <main class="blog-main">
          <section class="rounded-2xl border border-stone-200/70 dark:border-stone-800/70 bg-secondary p-6 md:p-8">
            <p class="text-sm md:text-base text-stone-600 dark:text-stone-400 mt-2">
              Coming soon.
            </p>
          </section>
        </main>
      </div>
    </div>
  </div>
</Layout>

<style>
	.blog-main {
		flex: 1;
		min-width: 0;
		min-height: 60vh;
	}
</style>
