---
import Layout from "../../../layouts/MainLayout.astro";
import PlatformLayout from "@components/PlatformLayout.astro";
import { platformNavItemsData } from "../_navItems";
import Circles from "phosphor-astro/Nut.astro";
import Memory from "phosphor-astro/Memory.astro";
import ChatCircle from "phosphor-astro/ChatCircle.astro";
import Path from "phosphor-astro/PathFill.astro";
import Browsers from "phosphor-astro/Browsers.astro";
import Link from "phosphor-astro/Cube.astro";
import Webhooks from "phosphor-astro/WebhooksLogo.astro";
import Database from "phosphor-astro/GridNine.astro";
import Sparkle from "phosphor-astro/Sparkle.astro";
import Cloud from "phosphor-astro/Cloud.astro";
import HeroBg from "@assets/images/homepage/valley.png";
import { Image } from "astro:assets";
import Card from "@components/cards/Card.astro";

const iconMap: Record<string, any> = {
	Circles,
	Memory,
	ChatCircle,
	Path,
	Browsers,
	Link,
	Webhooks,
	Database,
	Sparkle,
	Cloud,
};

const navItems = platformNavItemsData.map(group => ({
	...group,
	items: group.items.map(item => ({
		...item,
		icon: iconMap[item.iconName],
	})),
}));
---

<Layout>
	<PlatformLayout
		title="APIs"
		description="Connect to external and internal APIs to fetch data, perform actions, and integrate with third-party services."
		{navItems}
	>
		<div class="mb-8">
			<div class="bg-stone-100 dark:bg-stone-900 rounded-md p-4 mb-4">
				<h2 class="text-lg! text-stone-900 dark:text-stone-100">
					API editor
				</h2>
				<p
					class="text-base! text-stone-600! dark:text-stone-400! mb-4! lg:max-w-lg"
				>
					Connect to external and internal APIs to fetch data, perform actions, and integrate with third-party services.
				</p>

				<Image
					src={HeroBg}
					alt="APIs integration"
					class="w-full h-96 object-cover rounded-md"
				/>
			</div>

			<div
				class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 md:gap-2"
			>
				<Card
					label="REST APIs"
					description="Connect to RESTful APIs with support for GET, POST, PUT, DELETE, and custom methods."
				/>
				<Card
					label="Authentication"
					description="Secure your API connections with OAuth, API keys, bearer tokens, and custom auth methods."
				/>
				<Card
					label="Request/Response handling"
					description="Transform request payloads and parse response data with built-in JSON, XML, and form data support."
				/>
				<Card
					label="Agent integration"
					description="Allow agents to call external and internal APIs to fetch data or perform actions."
				/>
				<Card
					label="Automation triggers"
					description="Trigger automations from webhooks and API endpoints."
				/>
				<Card
					label="Error handling"
					description="Configure retry logic and error handling for API calls."
				/>
			</div>
		</div>
	</PlatformLayout>
</Layout>

