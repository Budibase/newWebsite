---
import Layout from "../../../layouts/MainLayout.astro";
import PlatformLayout from "@components/PlatformLayout.astro";
import { pricingNavItemsData } from "../_navItems";
import Buildings from "phosphor-astro/Buildings.astro";
import ShieldCheck from "phosphor-astro/ShieldCheck.astro";
import Sliders from "phosphor-astro/Sliders.astro";
import Headset from "phosphor-astro/Headset.astro";
import MapPin from "phosphor-astro/MapPin.astro";
import HardHat from "phosphor-astro/HardHat.astro";
import Broadcast from "phosphor-astro/Broadcast.astro";
import Recycle from "phosphor-astro/Recycle.astro";
import Truck from "phosphor-astro/Truck.astro";
import Bank from "phosphor-astro/Bank.astro";
import Gear from "phosphor-astro/Gear.astro";
import Package from "phosphor-astro/Package.astro";
import ChartBar from "phosphor-astro/ChartBar.astro";
import HeroBg from "@assets/images/homepage/valley.png";
import { Image } from "astro:assets";
import Card from "@components/cards/Card.astro";

const iconMap: Record<string, any> = {
  Buildings,
  ShieldCheck,
  Sliders,
  Headset,
  MapPin,
  HardHat,
  Broadcast,
  Recycle,
  Truck,
  Bank,
  Gear,
  Package,
  ChartBar,
};

const navItems = pricingNavItemsData.map((group) => ({
  ...group,
  items: group.items.map((item) => ({
    ...item,
    icon: iconMap[item.iconName],
  })),
}));
---

<Layout>
  <PlatformLayout
    title="Commerical"
    description="Choose the plan that fits your team and scale with confidence."
    {navItems}
  >
    <div class="mb-8">
      <div class="bg-stone-100 dark:bg-stone-900 rounded-md p-4 mb-4">
        <h2 class="text-lg! text-stone-900 dark:text-stone-100">Control</h2>
        <p
          class="text-base! text-stone-600! dark:text-stone-400! mb-4! lg:max-w-lg"
        >
          Full control over your deployment, infrastructure, and data. Self-host
          on your own servers or use our managed cloud with complete
          sovereignty.
        </p>

        <Image
          src={HeroBg}
          alt="Control features"
          class="w-full h-96 object-cover rounded-md"
        />
      </div>

      <div
        class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 md:gap-2"
      >
        <Card
          label="Self-hosted deployment"
          description="Deploy on your own infrastructure with Docker, Kubernetes, or bare metal."
        />
        <Card
          label="Air-gapped support"
          description="Run completely offline in secure, isolated environments."
        />
        <Card
          label="Multi-tenancy"
          description="Isolate teams and departments with separate workspaces and data."
        />
        <Card
          label="Custom branding"
          description="White-label the platform with your own logos, colors, and domain."
        />
        <Card
          label="SCIM provisioning"
          description="Automated user lifecycle management with your identity provider."
        />
        <Card
          label="Environment controls"
          description="Manage development, staging, and production environments separately."
        />
      </div>
    </div>
  </PlatformLayout>
</Layout>
