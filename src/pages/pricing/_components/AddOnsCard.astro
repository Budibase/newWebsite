---
// Add-ons list row component
// Design: simple row with label on the left and price on the right,
// separated by a subtle divider (see provided reference image).
// Props:
// - label: string
// - price: string (custom display e.g., "$199/mo", "Contact us")

interface Props {
  label: string;
  price: string;
}

const { label, price } = Astro.props as Props;
---

<div class="addon-row">
  <div class="text-base md:text-lg text-stone-900 dark:text-stone-100">{label}</div>
  <div class="text-base md:text-lg text-stone-900 dark:text-stone-100 whitespace-nowrap">{price}</div>
</div>

<style>
  .addon-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 0;
    border-top: 1px solid var(--color-stone-200);
  }

  :global(.dark) .addon-row {
    border-color: var(--color-stone-800);
  }

  .label {
    font-size: 22px;
    color: var(--text-primary);
  }
  .price {
    font-size: 22px;
    color: var(--color-stone-900);
    white-space: nowrap;
  }

  :global(.dark) .price {
    color: var(--color-stone-100);
  }
</style>
