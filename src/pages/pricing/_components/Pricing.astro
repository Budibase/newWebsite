---
/* removed self-host switcher imports */
import PricingCard from "./PricingCard.astro";
import AddOnsCard from "./AddOnsCard.astro";
import Link from "@components/Link.astro";
---

<section class="container max-w-7xl mx-auto flex flex-col mt-12 md:mt-24 px-2 lg:px-0">
  <!--Title section -->
  <h1 class="max-w-2xl text-2xl md:text-3xl lg:text-4xl mb-4 text-stone-950 dark:text-stone-100">
    Pricing
  </h1>
  <div class="mb-6 text-sm md:text-base text-secondary">
    You can also choose to <span>
      <Link
        url="https://github.com/Budibase/budibase"
        label="self-host our open-source community plan."
        variant="primary"
        underline={false}
      />
    </span>
  </div>
  <div class="container flex flex-col gap-2">
    <div class="flex flex-row gap-2 mb-4">
      <ul class="inline-flex flex-row bg-secondary rounded-[20px] p-1">
        <li>
          <button
            id="Annual button"
            data-billing="annual"
            aria-pressed="true"
            class="bg-white dark:bg-stone-800 rounded-[19px] py-2 px-2 md:px-4 flex flex-row text-xs md:text-sm text-stone-900 dark:text-stone-100"
          >
            Yearly
          </button>
        </li>
        <li>
          <button
            id="Monthly button"
            data-billing="monthly"
            aria-pressed="false"
            class="bg-transparent rounded-[19px] py-2 px-2 md:px-4 flex flex-row text-xs md:text-sm text-stone-600 dark:text-stone-400"
          >
            Monthly
          </button>
        </li>
      </ul>
    </div>

    <section class="mb-12 md:mb-20">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-3">
        <PricingCard
          title="Pro"
          description="Includes:"
          creatorPrice={10}
          userPrice={2}
          billingPlan="pro"
          creatorUnit="/ month"
          userUnit="/ month"
          creatorLabel="per creator"
          userLabel="per end user"
          recommended={false}
          buttonLabel="Start 14 day free trial"
          buttonVariant="primary"
          buttonUrl="/signup-plus"
          features={[
            "1 Workspace",
            "10k Automation runs",
            "Custom RBAC",
            "Custom branding",
            "SSO",
          ]}
        />
        <PricingCard
          title="Premium"
          description="Everything in Pro, plus:"
          creatorPrice={50}
          userPrice={5}
          billingPlan="premium"
          creatorUnit="/ month"
          userUnit="/ month"
          creatorLabel="per creator"
          userLabel="per end user"
          recommended={true}
          buttonLabel="Start 14 day free trial"
          buttonVariant="cta"
          buttonUrl="/signup-plus"
          features={[
            "Multiple workspaces",
            "100k Automation runs",
            "User groups",
            "Synchronous automations",
            "Backups",
          ]}
        />
        <PricingCard
          title="Enterprise"
          description="Everything in Premium, plus:"
          creatorPrice="From $7,500"
          creatorUnit="/ year"
          creatorLabel=""
          recommended={false}
          buttonLabel="Contact sales"
          buttonVariant="primary"
          buttonUrl="/signup-plus"
          features={[
            "Bulk discounts",
            "Enforced SSO",
            "On-premise / Cloud",
            "Active directory / SCIM",
            "Env variables",
            "Dedicated Support",
            "Audit Logs",
          ]}
        />
      </div>
    </section>
    <section class="my-8">
      <p class="text-xl md:text-2xl! pb-6 text-stone-900 dark:text-stone-100">Add-ons</p>
      <AddOnsCard label="Airgapped deployment" price="$10,000 per year" />
      <AddOnsCard label="1 business day SLA" price="$20,000 per year" />
      <AddOnsCard label="Professional services" price="$500 per day" />
    </section>
  </div>
</section>

<script>
  const toggleButtons = document.querySelectorAll("[data-billing]");
  const cards = document.querySelectorAll("[data-billing-plan]");

  const activeClasses = [
    "bg-white",
    "dark:bg-stone-800",
    "text-stone-900",
    "dark:text-stone-100",
  ];
  const inactiveClasses = [
    "bg-transparent",
    "text-stone-600",
    "dark:text-stone-400",
  ];

  const formatPrice = (value) =>
    Number.isInteger(value) ? value.toString() : value.toFixed(2);

  const applyBilling = (billing) => {
    toggleButtons.forEach((button) => {
      const isActive = button.dataset.billing === billing;
      button.setAttribute("aria-pressed", isActive ? "true" : "false");
      activeClasses.forEach((className) => button.classList.toggle(className, isActive));
      inactiveClasses.forEach((className) => button.classList.toggle(className, !isActive));
    });

    cards.forEach((card) => {
      card.querySelectorAll(".amount[data-base-price]").forEach((amountEl) => {
        const basePrice = Number(amountEl.dataset.basePrice);
        const multiplier = billing === "monthly" ? 1.2 : 1;
        const updatedPrice = basePrice * multiplier;
        amountEl.textContent = `$${formatPrice(updatedPrice)}`;
      });
    });
  };

  toggleButtons.forEach((button) => {
    button.addEventListener("click", () => {
      applyBilling(button.dataset.billing || "annual");
    });
  });

  applyBilling("annual");
</script>
