---
import StarFour from "phosphor-astro/StarFour.astro";
import Sparkle from "phosphor-astro/Sparkle.astro";
import PlusCircle from "phosphor-astro/PlusCircleFill.astro";
import Cloud from "phosphor-astro/Cloud.astro";
import { Image } from "astro:assets";
import Arm from "../../../assets/logos/arm.svg";
import Amex from "../../../assets/logos/amex.png";
---

<section class="mt-8 container max-w-6xl mx-auto">
  <div class="grid grid-cols-3 gap-4">
    <div id="pricing-card">
      <div class="p-1 border bg-white rounded-lg">
        <div class="rounded-md border !border-dashed px-8 py-6">
          <div class="flex-col items-center gap-2 mb-2">
            <div class="flex items-center gap-2">
              <div class="bg-sky-dark w-8 h-8 rounded-xl p-1">
                <Cloud class="fill-white" />
              </div>
              <div>
                <h2 class="!text-2xl m-0">Starter</h2>
              </div>
            </div>
            <div class="mt-8">
              <p class="font-semibold !text-4xl">$19</p>
              <p class="font-medium text-cloud-dark text-sm">
                per month with annual subscription discount; $1188 billed up
                front. $150 if billed monthly.
              </p>
              <button class="w-full primary large my-4"
                >Try 14-day free trial</button
              >
              <ul class="mt-4">
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  1 creator
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  1 workspace
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  20 interface users
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  1,000 actions
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  100,000 BB AI tokens
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  Custom branding
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  SSO
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div id="pricing-card">
      <div class="p-1 border bg-white rounded-4xl">
        <div class="rounded-[1.8rem] border !border-dashed px-8 py-6">
          <div class="flex-col items-center gap-2 mb-2">
            <div class="flex items-center gap-2">
              <div class="bg-sky-dark w-8 h-8 rounded-xl p-1">
                <Cloud class="fill-white" />
              </div>
              <div>
                <h2 class="!text-2xl m-0">Premium</h2>
              </div>
            </div>
            <div class="mt-8">
              <p class="font-semibold !text-4xl">$199</p>
              <p class="font-medium text-cloud-dark text-sm">
                per month with annual subscription discount; $1188 billed up
                front. $150 if billed monthly.
              </p>
              <button class="w-full primary large my-4"
                >Try 14-day free trial</button
              >
              <ul class="mt-4">
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  Everything in starter
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  3 creators
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  5 workspaces
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  100 interface users
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  50,000 actions
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  1,000,000 BB AI tokens
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  Synchronous automations
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div id="pricing-card">
      <div class="p-1 border bg-white rounded-4xl">
        <div class="border rounded-[1.8rem] !border-dashed px-8 py-6">
          <div class="flex-col gap-2">
            <div class="flex items-center gap-2">
              <div class="bg-sky-dark w-8 h-8 rounded-xl p-1">
                <Sparkle class="fill-white" />
              </div>
              <div>
                <h2 class="!text-2xl m-0">Enterprise</h2>
              </div>
            </div>
            <!--
                        <div class="flex mt-4 items-center gap-3">
                            <Image src={Arm} alt="Arm logo" class="h-4 w-auto" />
                            <Image src={Amex} alt="Amex logo" class="h-8 w-auto"/>
                        </div>
                        -->
            <div class="mt-8">
              <p class="font-semibold !text-4xl">Contact us</p>
              <p class="font-medium text-cloud-dark text-sm">
                Pricing starts at $10,000, billed annually. Monthly billing not
                available.
              </p>
              <button class="w-full primary large my-4">Contact sales</button>
              <ul class="mt-4">
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  Higher limits
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  Priority support
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  Audit logs
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  AD / SCIM
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  Enhanced SSO
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  Custom roles
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  Custom BB AI tokens
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  Environment variables
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span>
                    <PlusCircle class="fill-black w-6" />
                  </span>
                  Air-gapped deployment
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
