---
import PricingCard from "./PricingCard.astro";
import PlanComparison from "./PlanComparison.astro";
import Plus from "phosphor-astro/Plus.astro";

type FaqItem = {
  question: string;
  paragraphs: string[];
  bullets?: string[];
};

const openSourcePlanFeatures = [
  "1 Workspace",
  "Unlimited apps",
  "Unlimited automations",
  "Unlimited agents",
  "Unlimited users",
  "Community support",
  "SSO",
];

const selfHostedEnterprisePlanFeatures = [
  "Everything in open source",
  "Custom branding",
  "Backups and restore",
  "Environment variables",
  "Enforced SSO",
  "User groups",
  "Active directory/SCIM",
  "365 days logs",
  "Audit logs",
  "Priorty support/SLAs",
];

const faqItems: FaqItem[] = [
  {
    question: 'What are "actions"?',
    paragraphs: [
      "Actions represent the total work your agents, apps and automations perform.",
      "If your agent takes an action or your workflow runs a step, that counts as an action.",
      "If a user creates, updates or deletes a row in the Budibase DB or a SQL DB - that counts as one action.",
      "Custom SQL queries and API requests are not included as actions.",
    ],
    bullets: [
      "AI agent tool calls",
      "Automation node executions",
      "Save row",
      "Delete row",
    ],
  },
  {
    question: "Why do you price by actions?",
    paragraphs: [
      "Actions directly reflect the amount of useful work Budibase is doing. This aligns pricing with real business value, not just seats or arbitrary limits.",
    ],
  },
  {
    question: "Are actions soft limits or hard limits?",
    paragraphs: [
      "Actions are hard monthly limits based on your selected plan tier. When you reach your limit, you'll need to move to a higher tier or plan to continue running agents and automations.",
      "This ensures:",
    ],
    bullets: [
      "Predictable infrastructure performance",
      "Clear cost control",
      "Transparent scaling as your action volume grows",
    ],
  },
  {
    question: "Why use hard limits instead of overage billing?",
    paragraphs: [
      "Hard limits keep costs predictable for SMEs. You always know exactly what you're paying each month with no surprise overages.",
    ],
  },
  {
    question: "Can I add more users?",
    paragraphs: [
      "Yes. Pro, Premium, and Business include an End users add-on.",
      "End users are $5/user/mo on yearly billing. Monthly billing follows the same +20% pricing logic shown on the page.",
    ],
  },
  {
    question: "Can I add more creators (builders)?",
    paragraphs: [
      "Yes. Premium and Business include a Creators add-on.",
      "Creators are $50/creator/mo on yearly billing. Monthly billing follows the same +20% pricing logic shown on the page.",
    ],
  },
  {
    question: "Do add-on prices change with yearly vs monthly billing?",
    paragraphs: [
      "Yes. Add-ons follow the same yearly/monthly toggle as plan pricing.",
      "Monthly values are calculated as yearly price +20%.",
    ],
  },
  {
    question: "Does Budibase offer a free open-source plan?",
    paragraphs: [
      "Yes. Budibase offers a fully open-source self-hosted plan that is free to use indefinitely.",
      "You can build and run apps, agents, and automations on your own infrastructure without software licensing fees.",
    ],
  },
  {
    question: "When should I choose cloud instead of self-hosting?",
    paragraphs: [
      "Cloud is best if you want managed infrastructure, built-in scalability, collaboration tools, AI credits, and support.",
      "Self-hosting is ideal if you require full control over your infrastructure and deployment.",
    ],
  },
];
---

<section class="container max-w-7xl mx-auto flex flex-col mt-8 px-2 lg:px-0">
  <div class="flex flex-col items-center text-center">
    <h1
      class="hero-title max-w-2xl !text-5xl sm:!text-[70px] mb-4 mt-6 text-center md:mt-10 lg:mt-16 text-stone-950 dark:text-stone-100"
    >
      Pricing
    </h1>
  </div>
  <div class="w-full flex flex-col gap-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-5 mb-2 items-center">
      <div class="hidden md:block" aria-hidden="true"></div>

      <div class="flex flex-row gap-2 justify-center md:col-start-2">
        <ul
          role="group"
          aria-label="Hosting option"
          class="inline-flex flex-row bg-secondary rounded-[20px] p-1"
          id="hosting-toggle"
        >
          <li>
            <button
              id="cloud-hosting-button"
              data-hosting-option="cloud"
              aria-pressed="true"
              class="bg-white dark:bg-stone-800 rounded-[19px] py-3 px-3 md:px-4 flex flex-row text-xs md:text-sm text-stone-900 dark:text-stone-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-stone-400 focus-visible:ring-offset-2 min-h-[44px]"
            >
              Budibase cloud
            </button>
          </li>
          <li>
            <button
              id="self-hosting-button"
              data-hosting-option="self-host"
              aria-pressed="false"
              class="bg-transparent rounded-[19px] py-3 px-3 md:px-4 flex flex-row text-xs md:text-sm text-stone-600 dark:text-stone-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-offset-2 min-h-[44px]"
            >
              Self-host
            </button>
          </li>
        </ul>
      </div>

      <div
        class="flex flex-row gap-2 justify-center md:justify-end md:col-start-3"
        data-billing-toggle-wrap
      >
        <ul
          role="group"
          aria-label="Billing period"
          class="inline-flex flex-row bg-secondary rounded-[20px] p-1"
          id="billing-toggle"
        >
          <li>
            <button
              id="annual-button"
              data-billing="annual"
              aria-pressed="true"
              class="bg-white dark:bg-stone-800 rounded-[19px] py-3 px-3 md:px-4 flex flex-row text-xs md:text-sm text-stone-900 dark:text-stone-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-stone-400 focus-visible:ring-offset-2 min-h-[44px]"
            >
              Yearly
            </button>
          </li>
          <li>
            <button
              id="monthly-button"
              data-billing="monthly"
              aria-pressed="false"
              class="bg-transparent rounded-[19px] py-3 px-3 md:px-4 flex flex-row text-xs md:text-sm text-stone-600 dark:text-stone-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-stone-400 focus-visible:ring-offset-2 min-h-[44px]"
            >
              Monthly
            </button>
          </li>
        </ul>
      </div>
    </div>

    <section class="mb-5 md:mb-5">
      <div class="pricing-cards-stage">
        <div
          data-hosting-panel="cloud"
          class="pricing-cards-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3 justify-center items-stretch"
        >
          <PricingCard
            title="Pro"
            description="Includes:"
            creatorPrice={19}
            billingPlan="pro"
            creatorUnit="/ month"
            creatorLabel=""
            recommended={false}
            buttonLabel="Start 14 day free trial"
            buttonVariant="cta"
            buttonUrl="https://account.budibase.app/register"
            operationTiers={[
              { operations: "5K", yearlyPrice: 19, aiCredits: "2K" },
              { operations: "10K", yearlyPrice: 29, aiCredits: "2K" },
            ]}
            defaultTierIndex={0}
            features={[
              "1 creator",
              "2 end users",
              "1 day logs",
              "1 workspace",
              "Unlimited agents",
              "Synchronous automations",
            ]}
            hostingItems={["Budibase Cloud"]}
          />
          <PricingCard
            title="Premium"
            description="Everything in Pro, plus:"
            creatorPrice={49}
            billingPlan="premium"
            creatorUnit="/ month"
            creatorLabel=""
            recommended={false}
            buttonLabel="Start 14 day free trial"
            buttonVariant="cta"
            buttonUrl="https://account.budibase.app/register"
            operationTiers={[
              { operations: "20K", yearlyPrice: 49, aiCredits: "10K" },
              { operations: "50K", yearlyPrice: 79, aiCredits: "10K" },
            ]}
            defaultTierIndex={0}
            features={[
              "1 creator",
              "10 end users",
              "7 days logs",
              "10 workspaces",
              "Custom branding",
              "Backups and restore",
              "SSO",
            ]}
            hostingItems={["Budibase Cloud"]}
          />
          <PricingCard
            title="Business"
            tagLabel="Best value"
            description="Everything in Premium, plus:"
            creatorPrice={299}
            billingPlan="business"
            creatorUnit="/ month"
            creatorLabel=""
            recommended={false}
            buttonLabel="Start 14 day free trial"
            buttonVariant="cta"
            buttonUrl="https://account.budibase.app/register"
            operationTiers={[
              { operations: "250K", yearlyPrice: 299, aiCredits: "50K" },
            ]}
            defaultTierIndex={0}
            features={[
              "3 creators",
              "30 end users",
              "30 days logs",
              "Unlimited workspaces",
              "Environment variables",
              "Enforced SSO",
              "User groups",
              "Email support",
            ]}
            hostingItems={["Budibase Cloud"]}
          />
          <PricingCard
            title="Enterprise"
            description="Everything in Business, plus:"
            creatorPrice="Custom"
            billingPlan="enterprise"
            creatorUnit=""
            creatorLabel=""
            additionalPriceText="Custom actions"
            additionalPriceTone="primary"
            recommended={false}
            buttonLabel="Contact sales"
            buttonVariant="primary"
            buttonUrl="/contact"
            addonItems={["Air-gapped deployment", "Onboarding and training"]}
            features={[
              "Active directory/SCIM",
              "365 days logs",
              "Audit logs",
              "Priorty support/SLAs",
            ]}
            hostingItems={["Budibase Cloud", "Self-host / on-premise"]}
          />
        </div>
        <div
          data-hosting-panel="self-host"
          class="pricing-cards-grid hidden grid grid-cols-1 md:grid-cols-2 gap-3 justify-center items-stretch max-w-3xl mx-auto"
          aria-hidden="true"
        >
          <PricingCard
            title="Open source"
            description="Includes:"
            creatorPrice="Free"
            billingPlan="open-source"
            creatorUnit=""
            creatorLabel=""
            additionalPriceText="Unlimited actions"
            additionalPriceTone="primary"
            recommended={false}
            buttonLabel="Visit the docs"
            buttonVariant="primary"
            buttonUrl="https://docs.budibase.com"
            buttonTarget="_blank"
            addonItems={[]}
            features={openSourcePlanFeatures}
            hostingItems={["Self-host / on-premise"]}
          />
          <PricingCard
            title="Enterprise"
            description="Includes:"
            creatorPrice="Custom pricing"
            billingPlan="self-host-enterprise"
            creatorUnit=""
            creatorLabel=""
            additionalPriceText="Unlimited actions"
            additionalPriceTone="primary"
            recommended={false}
            buttonLabel="Contact sales"
            buttonVariant="cta"
            buttonUrl="/contact"
            addonItems={["Air-gapped deployment", "Onboarding and training"]}
            features={selfHostedEnterprisePlanFeatures}
            hostingItems={["Budibase Cloud", "Self-host / on-premise"]}
          />
        </div>
      </div>
    </section>

    <PlanComparison />

    <section class="mb-12 md:mb-20" aria-labelledby="pricing-faqs-heading">
      <h2
        id="pricing-faqs-heading"
        class="text-3xl font-semibold text-stone-900 dark:text-stone-100 mb-6 md:mb-8"
      >
        FAQs
      </h2>
      <div
        data-faq-accordion
        class="border-t border-dotted border-stone-300/80 dark:border-stone-700/80"
      >
        {
          faqItems.map((item) => (
            <details
              data-faq-item
              class="group border-b border-dotted border-stone-300/80 dark:border-stone-700/80"
            >
              <summary class="list-none [&::-webkit-details-marker]:hidden min-h-[64px] py-4 md:py-5 cursor-pointer flex items-center justify-between gap-4 text-left text-stone-900 dark:text-stone-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-stone-400 focus-visible:ring-offset-2">
                <h3 class="m-0 text-lg md:text-xl text-stone-900 dark:text-stone-100">
                  {item.question}
                </h3>
                <span class="shrink-0">
                  <Plus
                    class="w-5 h-5 md:w-6 md:h-6 text-stone-900 dark:text-stone-100 transition-transform duration-200 ease-out group-open:rotate-45"
                    aria-hidden="true"
                  />
                </span>
              </summary>
              <div class="faq-answer text-base md:text-lg text-stone-600 dark:text-stone-300 pb-5 md:pb-6 pr-1 md:pr-12">
                {item.paragraphs.map((paragraph) => (
                  <p class="mb-3">{paragraph}</p>
                ))}
                {item.bullets && item.bullets.length > 0 && (
                  <ul class="mb-3">
                    {item.bullets.map((bullet) => (
                      <li class="mb-1">{bullet}</li>
                    ))}
                  </ul>
                )}
              </div>
            </details>
          ))
        }
      </div>
    </section>
  </div>
</section>

<style>
  .pricing-cards-grid {
    position: relative;
  }

  .faq-answer {
    font: inherit;
  }

  .faq-answer p,
  .faq-answer ul,
  .faq-answer li {
    color: inherit !important;
    font: inherit;
  }

  .faq-answer ul {
    list-style: disc !important;
    list-style-position: outside;
    padding-left: 1.5rem !important;
    margin: 0 0 0.75rem !important;
  }

  .faq-answer li {
    display: list-item;
    list-style: disc !important;
  }

  .faq-answer li::marker {
    color: inherit !important;
  }
</style>

<script>
  const activeClasses = [
    "bg-white",
    "dark:bg-stone-800",
    "text-stone-900",
    "dark:text-stone-100",
  ];
  const inactiveClasses = [
    "bg-transparent",
    "text-stone-600",
    "dark:text-stone-400",
  ];

  const setToggleButtonState = (
    buttons: NodeListOf<Element>,
    dataKey: string,
    value: string,
  ) => {
    buttons.forEach((button) => {
      const htmlButton = button as HTMLButtonElement;
      const isActive = htmlButton.dataset[dataKey] === value;
      htmlButton.setAttribute("aria-pressed", isActive ? "true" : "false");
      activeClasses.forEach((className) =>
        htmlButton.classList.toggle(className, isActive),
      );
      inactiveClasses.forEach((className) =>
        htmlButton.classList.toggle(className, !isActive),
      );
    });
  };

  // Hosting toggle (cloud/self-host)
  const hostingButtons = document.querySelectorAll("[data-hosting-option]");
  const hostingPanels = document.querySelectorAll("[data-hosting-panel]");
  const billingToggleWrap = document.querySelector(
    "[data-billing-toggle-wrap]",
  );

  const applyHosting = (hostingOption: string) => {
    setToggleButtonState(hostingButtons, "hostingOption", hostingOption);

    hostingPanels.forEach((panel) => {
      const htmlPanel = panel as HTMLElement;
      const isActive = htmlPanel.dataset.hostingPanel === hostingOption;
      htmlPanel.classList.toggle("hidden", !isActive);
      htmlPanel.setAttribute("aria-hidden", isActive ? "false" : "true");
    });

    if (billingToggleWrap) {
      const hideBillingToggle = hostingOption === "self-host";
      billingToggleWrap.classList.toggle("invisible", hideBillingToggle);
      billingToggleWrap.classList.toggle(
        "pointer-events-none",
        hideBillingToggle,
      );
      billingToggleWrap.setAttribute(
        "aria-hidden",
        hideBillingToggle ? "true" : "false",
      );
    }
  };

  // Billing toggle (yearly/monthly)
  const toggleButtons = document.querySelectorAll("[data-billing]");
  const cards = document.querySelectorAll("[data-billing-plan]");

  const formatPrice = (value: number) => Math.round(value).toString();
  let currentBilling = "annual";

  const syncCardTierSelection = (card: Element) => {
    const operationsSelect = card.querySelector(
      "[data-operations-select]",
    ) as HTMLSelectElement | null;
    if (!operationsSelect || !operationsSelect.selectedOptions.length) {
      return;
    }

    const selectedOption = operationsSelect
      .selectedOptions[0] as HTMLOptionElement;
    const tierIndex = selectedOption.dataset.tierIndex;
    const tierPrice = selectedOption.dataset.tierPrice;
    const tierAi = selectedOption.dataset.tierAi;

    if (tierIndex !== undefined) {
      (card as HTMLElement).dataset.tierIndex = tierIndex;
    }

    if (tierPrice !== undefined && tierPrice !== "") {
      const basePrice = Number(tierPrice);
      if (!Number.isNaN(basePrice)) {
        card
          .querySelectorAll(".amount[data-base-price]")
          .forEach((amountEl) => {
            (amountEl as HTMLElement).dataset.basePrice = String(basePrice);
          });
      }
    }

    if (tierAi) {
      const aiValueEl = card.querySelector("[data-tier-ai-value]");
      if (aiValueEl) {
        (aiValueEl as HTMLElement).textContent = tierAi;
      }
      const aiRow = card.querySelector("[data-tier-ai]");
      if (aiRow) {
        (aiRow as HTMLElement).dataset.tierAi = tierAi;
      }
    }
  };

  const applyBilling = (billing: string) => {
    currentBilling = billing;
    setToggleButtonState(toggleButtons, "billing", billing);

    const multiplier = billing === "monthly" ? 1.2 : 1;

    cards.forEach((card) => {
      syncCardTierSelection(card);

      card.querySelectorAll(".amount[data-base-price]").forEach((amountEl) => {
        const htmlEl = amountEl as HTMLElement;
        const basePrice = Number(htmlEl.dataset.basePrice);
        const updatedPrice = basePrice * multiplier;
        htmlEl.textContent = `$${formatPrice(updatedPrice)}`;
      });

      card
        .querySelectorAll("[data-overage-kind][data-base-overage]")
        .forEach((popoverEl) => {
          const htmlEl = popoverEl as HTMLElement;
          const baseOverage = Number(htmlEl.dataset.baseOverage);
          const kind = htmlEl.dataset.overageKind;
          const updatedOverage = Math.round(baseOverage * multiplier);

          if (kind === "creators") {
            htmlEl.textContent = `Add more creators for $${updatedOverage} per creator per month`;
            return;
          }

          if (kind === "end-users") {
            htmlEl.textContent = `Add more end users for $${updatedOverage} per end user per month`;
          }
        });

      card
        .querySelectorAll(
          "[data-addon-base][data-addon-prefix][data-addon-suffix]",
        )
        .forEach((addonEl) => {
          const htmlEl = addonEl as HTMLElement;
          const baseAddon = Number(htmlEl.dataset.addonBase);
          if (Number.isNaN(baseAddon)) {
            return;
          }

          const prefix = htmlEl.dataset.addonPrefix || "";
          const suffix = htmlEl.dataset.addonSuffix || "";
          const updatedAddonValue = formatPrice(baseAddon * multiplier);
          const updatedAddonText = `${prefix}$${updatedAddonValue}${suffix}`;
          const addonTextEl = htmlEl.querySelector("[data-addon-text]");

          if (addonTextEl) {
            (addonTextEl as HTMLElement).textContent = updatedAddonText;
          }
        });
    });
  };

  cards.forEach((card) => {
    const operationsSelect = card.querySelector(
      "[data-operations-select]",
    ) as HTMLSelectElement | null;
    if (!operationsSelect || operationsSelect.dataset.tierBound === "true") {
      return;
    }

    operationsSelect.dataset.tierBound = "true";
    operationsSelect.addEventListener("change", () => {
      applyBilling(currentBilling);
    });
  });

  toggleButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const htmlButton = button as HTMLButtonElement;
      applyBilling(htmlButton.dataset.billing || "annual");
    });
  });

  hostingButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const htmlButton = button as HTMLButtonElement;
      applyHosting(htmlButton.dataset.hostingOption || "cloud");
    });
  });

  applyHosting("cloud");
  applyBilling("annual");

  const faqDetails = Array.from(
    document.querySelectorAll("[data-faq-item]"),
  ) as HTMLDetailsElement[];

  faqDetails.forEach((detail) => {
    if (detail.dataset.faqBound === "true") {
      return;
    }

    detail.dataset.faqBound = "true";

    detail.addEventListener("toggle", () => {
      if (!detail.open) {
        return;
      }

      faqDetails.forEach((otherDetail) => {
        if (otherDetail !== detail) {
          otherDetail.open = false;
        }
      });
    });
  });
</script>
