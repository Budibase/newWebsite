---
/* removed self-host switcher imports */
import PricingCard from "./PricingCard.astro";

const addOns = [
  "$2 per user",
  "$10 per 1000 automation runs",
  "$10 per 10m BB AI tokens",
];
---

<section class="container max-w-7xl mx-auto flex flex-col mt-8 px-2 lg:px-0">
  <!--Title section -->
  <div class="flex flex-col items-center text-center">
    <h1 class="max-w-2xl !text-5xl mb-4 text-stone-950 dark:text-stone-100">
      Pricing
    </h1>
  </div>
  <div class="w-full flex flex-col gap-2">
    <div class="flex flex-row gap-2 mb-4 justify-center">
      <!-- Deployment Type Switcher -->
      <ul role="group" aria-label="Deployment type" class="inline-flex flex-row bg-secondary rounded-[20px] p-1" id="deployment-switcher">
        <li>
          <button
            id="self-hosted-button"
            data-deployment="self-hosted"
            aria-pressed="true"
            class="bg-white dark:bg-stone-800 rounded-[19px] py-3 px-3 md:px-4 flex flex-row text-xs md:text-sm text-stone-900 dark:text-stone-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-stone-400 focus-visible:ring-offset-2 min-h-[44px]"
          >
            Self-hosted
          </button>
        </li>
        <li>
          <button
            id="budibase-hosted-button"
            data-deployment="cloud"
            aria-pressed="false"
            class="bg-transparent rounded-[19px] py-3 px-3 md:px-4 flex flex-row text-xs md:text-sm text-stone-600 dark:text-stone-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-stone-400 focus-visible:ring-offset-2 min-h-[44px]"
          >
            Budibase Hosted
          </button>
        </li>
      </ul>
      <!-- Yearly/Monthly Toggle (hidden by default, shown only for cloud) -->
      <ul role="group" aria-label="Billing period" class="inline-flex flex-row bg-secondary rounded-[20px] p-1 hidden" id="billing-toggle">
        <li>
          <button
            id="annual-button"
            data-billing="annual"
            aria-pressed="true"
            class="bg-white dark:bg-stone-800 rounded-[19px] py-3 px-3 md:px-4 flex flex-row text-xs md:text-sm text-stone-900 dark:text-stone-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-stone-400 focus-visible:ring-offset-2 min-h-[44px]"
          >
            Yearly
          </button>
        </li>
        <li>
          <button
            id="monthly-button"
            data-billing="monthly"
            aria-pressed="false"
            class="bg-transparent rounded-[19px] py-3 px-3 md:px-4 flex flex-row text-xs md:text-sm text-stone-600 dark:text-stone-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-stone-400 focus-visible:ring-offset-2 min-h-[44px]"
          >
            Monthly
          </button>
        </li>
      </ul>
    </div>

    <!-- Self-Hosted Plans -->
    <section class="mb-12 md:mb-20" id="self-hosted-plans" aria-hidden="false">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 justify-center items-stretch">
        <div class="min-w-[420px] h-full">
          <PricingCard
            title="Community"
            description="Includes:"
            creatorPrice="Free"
            creatorUnit=""
            creatorLabel=""
            recommended={false}
            buttonLabel="Install on-prem"
            buttonVariant="cta"
            buttonUrl="https://docs.budibase.com/docs/docker"
            buttonTarget="_blank"
            addOns={addOns}
            features={[
              "Unlimited users",
              "SSO",
              "Custom RBAC",
              "Unlimited automation runs",
            ]}
          />
        </div>
        <div class="min-w-[420px] h-full">
          <PricingCard
            title="Business"
            description="Everything in Community, plus:"
            creatorPrice="From $600"
            creatorUnit="/ month, billed yearly"
            creatorLabel=""
            recommended={false}
            buttonLabel="Contact sales"
            buttonVariant="primary"
            buttonUrl="/signup-plus"
            addOns={addOns}
            features={[
              "Workspaces",
              "Enforced SSO",
              "Environment variables",
              "User groups",
              "Custom branding",
              "1 year automation logs",
              "1 year backups",
              "Email support",
            ]}
          />
        </div>
        <div class="min-w-[420px] h-full">
          <PricingCard
            title="Enterprise"
            description="Everything in Business, plus:"
            creatorPrice="From $1250"
            creatorUnit="/ month, billed yearly"
            creatorLabel=""
            recommended={false}
            buttonLabel="Contact sales"
            buttonVariant="primary"
            buttonUrl="/signup-plus"
            addOns={addOns}
            features={[
              "Bulk discounts",
              "Active directory / SCIM",
              "Audit Logs",
              "Import / Export API",
              "SLAs",
              "Unlimited automation logs",
              "Unlimited backups",
              "Dedicated support",
              { text: "Airgapped deployment", icon: "plus" },
              { text: "Professional services", icon: "plus" },
            ]}
          />
        </div>
      </div>
    </section>

    <!-- Cloud Plans -->
    <section class="mb-12 md:mb-20 hidden" id="cloud-plans" aria-hidden="true">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3 justify-center items-stretch">
        <PricingCard
          title="Pro"
          description="Includes:"
          creatorPrice={10}
          userPrice={2}
          billingPlan="pro"
          creatorUnit="/ month"
          userUnit="/ month"
          creatorLabel="per creator"
          userLabel="per end user"
          recommended={false}
          buttonLabel="Start 14 day free trial"
          buttonVariant="cta"
          buttonUrl="/signup-plus"
          addOns={addOns}
          features={[
            "1K automation runs",
            "Custom RBAC",
            "SSO",
            "Synchronous automations",
          ]}
        />
        <PricingCard
          title="Premium"
          description="Everything in Pro, plus:"
          creatorPrice={50}
          userPrice={5}
          billingPlan="premium"
          creatorUnit="/ month"
          userUnit="/ month"
          creatorLabel="per creator"
          userLabel="per end user"
          recommended={true}
          buttonLabel="Start 14 day free trial"
          buttonVariant="cta"
          buttonUrl="/signup-plus"
          addOns={addOns}
          features={[
            "10K automation runs",
            "1 year automation logs",
            "1 year backups",
            "Workspaces",
            "Custom branding",
          ]}
        />
        <PricingCard
          title="Business"
          description="Everything in Premium, plus:"
          creatorPrice="From $600"
          creatorUnit="/ month, billed yearly"
          creatorLabel=""
          additionalPriceText="Incl 2 creators & 80 end-users"
          recommended={false}
          buttonLabel="Contact sales"
          buttonVariant="primary"
          buttonUrl="/signup-plus"
          addOns={addOns}
          features={[
            "50K automation runs",
            "1 year automation logs",
            "1 year backups",
            "Enforced SSO",
            "User groups",
            "Env variables",
            "Email support",
          ]}
        />
        <PricingCard
          title="Enterprise"
          description="Everything in Business, plus:"
          creatorPrice="From $1250"
          creatorUnit="/ month, billed yearly"
          creatorLabel=""
          additionalPriceText="Incl 2 creators & 100 end-users"
          recommended={false}
          buttonLabel="Contact sales"
          buttonVariant="primary"
          buttonUrl="/signup-plus"
          addOns={addOns}
          features={[
            "Custom automation runs",
            "Unlimited automation logs",
            "Unlimited backups",
            "Flexible pricing",
            "Active directory / SCIM",
            "Audit Logs",
            "Import / Export API",
            "SLAs",
            "Dedicated Support",
            { text: "Airgapped deployment", icon: "plus" },
            { text: "Professional services", icon: "plus" },
          ]}
        />
      </div>
    </section>
  </div>
</section>

<script>
  // Deployment type switching
  const deploymentButtons = document.querySelectorAll("[data-deployment]");
  const billingToggle = document.getElementById("billing-toggle");
  const selfHostedPlans = document.getElementById("self-hosted-plans");
  const cloudPlans = document.getElementById("cloud-plans");

  const activeClasses = [
    "bg-white",
    "dark:bg-stone-800",
    "text-stone-900",
    "dark:text-stone-100",
  ];
  const inactiveClasses = [
    "bg-transparent",
    "text-stone-600",
    "dark:text-stone-400",
  ];

  const applyDeploymentType = (deploymentType: string) => {
    deploymentButtons.forEach((button) => {
      const htmlButton = button as HTMLButtonElement;
      const isActive = htmlButton.dataset.deployment === deploymentType;
      htmlButton.setAttribute("aria-pressed", isActive ? "true" : "false");
      activeClasses.forEach((className) => htmlButton.classList.toggle(className, isActive));
      inactiveClasses.forEach((className) => htmlButton.classList.toggle(className, !isActive));
    });

    if (deploymentType === "self-hosted") {
      // Show self-hosted plans, hide cloud plans and billing toggle
      selfHostedPlans?.classList.remove("hidden");
      selfHostedPlans?.setAttribute("aria-hidden", "false");
      cloudPlans?.classList.add("hidden");
      cloudPlans?.setAttribute("aria-hidden", "true");
      billingToggle?.classList.add("hidden");
      billingToggle?.setAttribute("aria-hidden", "true");
      billingToggle?.classList.remove("inline-flex");
    } else {
      // Show cloud plans and billing toggle, hide self-hosted plans
      selfHostedPlans?.classList.add("hidden");
      selfHostedPlans?.setAttribute("aria-hidden", "true");
      cloudPlans?.classList.remove("hidden");
      cloudPlans?.setAttribute("aria-hidden", "false");
      billingToggle?.classList.remove("hidden");
      billingToggle?.setAttribute("aria-hidden", "false");
      billingToggle?.classList.add("inline-flex");
    }
  };

  deploymentButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const htmlButton = button as HTMLButtonElement;
      applyDeploymentType(htmlButton.dataset.deployment || "self-hosted");
    });
  });

  // Billing toggle (yearly/monthly) - only for cloud plans
  const toggleButtons = document.querySelectorAll("[data-billing]");
  const cards = document.querySelectorAll("[data-billing-plan]");

  const formatPrice = (value: number) =>
    Number.isInteger(value) ? value.toString() : value.toFixed(2);

  const applyBilling = (billing: string) => {
    toggleButtons.forEach((button) => {
      const htmlButton = button as HTMLButtonElement;
      const isActive = htmlButton.dataset.billing === billing;
      htmlButton.setAttribute("aria-pressed", isActive ? "true" : "false");
      activeClasses.forEach((className) => htmlButton.classList.toggle(className, isActive));
      inactiveClasses.forEach((className) => htmlButton.classList.toggle(className, !isActive));
    });

    cards.forEach((card) => {
      card.querySelectorAll(".amount[data-base-price]").forEach((amountEl) => {
        const htmlEl = amountEl as HTMLElement;
        const basePrice = Number(htmlEl.dataset.basePrice);
        const multiplier = billing === "monthly" ? 1.2 : 1;
        const updatedPrice = basePrice * multiplier;
        htmlEl.textContent = `$${formatPrice(updatedPrice)}`;
      });
    });
  };

  toggleButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const htmlButton = button as HTMLButtonElement;
      applyBilling(htmlButton.dataset.billing || "annual");
    });
  });

  // Initialize: default to self-hosted
  applyDeploymentType("self-hosted");
  // Initialize billing for cloud plans (will be hidden initially)
  applyBilling("annual");
</script>
