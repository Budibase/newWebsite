---
import Button from "@components/Button.astro";
import Card from "@components/cards/Card.astro";
import Icon from "@components/Icon.astro";
import EnterpriseLogoGrid from "../../_components/landing-page/EnterpriseLogoGrid.astro";
import PricingCard from "./PricingCard.astro";
import pricingData from "./pricing.json";
import Plus from "phosphor-astro/Plus.astro";

type FaqItem = {
  question: string;
  paragraphs: string[];
  bullets?: string[];
};

type PlanValue = number | string | null;
type PlanEntry = {
  base_price_per_month: PlanValue;
  included_actions: PlanValue;
  included_ai_credits: PlanValue;
  additional_end_users_per_month: PlanValue;
  additional_creators_users_per_month: PlanValue;
  hosting: string;
  included_creators: PlanValue;
};
type TieredPlan = {
  monthly: PlanEntry[];
  annual: PlanEntry[];
};
type PricingData = {
  pro: TieredPlan;
  premium: TieredPlan;
  business: TieredPlan;
  enterprise: PlanEntry[];
  open_source: PlanEntry;
};

const pricing = pricingData as PricingData;

const toDisplayText = (value: PlanValue): string => {
  if (value === null || value === undefined) {
    return "";
  }

  return String(value);
};

const toNumericValue = (value: PlanValue): number | undefined =>
  typeof value === "number" ? value : undefined;

const toActionsText = (value: PlanValue): string => {
  const text = toDisplayText(value);
  if (!text) {
    return "";
  }

  return /actions$/i.test(text) ? text : `${text} actions`;
};

const toHostingLabel = (value: string): string =>
  value === "Self-hosted" ? "Self-host / on-premise" : value;

const getHostingItems = (...entries: PlanEntry[]): string[] => [
  ...new Set(
    entries.map((entry) => toHostingLabel(entry.hosting)).filter(Boolean),
  ),
];

const getTierOperationTiers = (plan: TieredPlan) =>
  plan.annual.map((annualEntry, index) => ({
    operations: toDisplayText(annualEntry.included_actions),
    annualPrice: toNumericValue(annualEntry.base_price_per_month),
    monthlyPrice: toNumericValue(plan.monthly[index]?.base_price_per_month),
    aiCredits: toDisplayText(annualEntry.included_ai_credits),
  }));

const getAddonPricing = (plan: TieredPlan) => {
  const annualEntry = plan.annual[0];
  const monthlyEntry = plan.monthly[0];
  const endUsersAnnual = toNumericValue(
    annualEntry?.additional_end_users_per_month,
  );
  const endUsersMonthly = toNumericValue(
    monthlyEntry?.additional_end_users_per_month,
  );
  const creatorsAnnual = toNumericValue(
    annualEntry?.additional_creators_users_per_month,
  );
  const creatorsMonthly = toNumericValue(
    monthlyEntry?.additional_creators_users_per_month,
  );

  return {
    endUsers:
      endUsersAnnual !== undefined
        ? { annual: endUsersAnnual, monthly: endUsersMonthly }
        : undefined,
    creators:
      creatorsAnnual !== undefined
        ? { annual: creatorsAnnual, monthly: creatorsMonthly }
        : undefined,
  };
};

const getCreatorsFeature = (entry: PlanEntry): string => {
  const creators = toDisplayText(entry.included_creators);
  if (!creators) {
    return "";
  }

  return `${creators} creator${creators === "1" ? "" : "s"}`;
};

const proAnnualEntry = pricing.pro.annual[0];
const premiumAnnualEntry = pricing.premium.annual[0];
const businessAnnualEntry = pricing.business.annual[0];
const cloudEnterpriseEntry =
  pricing.enterprise.find((entry) => entry.hosting === "Budibase Cloud") ??
  pricing.enterprise[0];
const selfHostedEnterpriseEntry =
  pricing.enterprise.find((entry) => entry.hosting !== "Budibase Cloud") ??
  pricing.enterprise[1];

const openSourcePlanFeatures = [
  "Unlimited apps",
  "Unlimited automations",
  "Unlimited agents",
  "Standard SSO",
  "Unlimited users",
];

const selfHostedEnterprisePlanFeatures = [
  "Enhanced capabilities",
  "Operational controls",
  "Security & compliance",
  "Deployment flexibility",
  "Dedicated support",
];

const cloudCards = [
  {
    title: "Pro",
    description: "Includes:",
    creatorPrice: toNumericValue(proAnnualEntry.base_price_per_month) ?? 0,
    billingPlan: "pro",
    creatorUnit: "/ month",
    creatorLabel: "",
    recommended: false,
    buttonLabel: "Start 14 day free trial",
    buttonVariant: "cta" as const,
    buttonUrl: "https://account.budibase.app/register",
    operationTiers: getTierOperationTiers(pricing.pro),
    defaultTierIndex: 0,
    addonPricing: getAddonPricing(pricing.pro),
    features: [
      getCreatorsFeature(proAnnualEntry),
      "2 end users",
      "1 day logs",
      "1 workspace",
      "Unlimited agents",
      "Synchronous automations",
    ].filter(Boolean),
    hostingItems: getHostingItems(...pricing.pro.annual),
  },
  {
    title: "Premium",
    description: "Everything in Pro, plus:",
    creatorPrice: toNumericValue(premiumAnnualEntry.base_price_per_month) ?? 0,
    billingPlan: "premium",
    creatorUnit: "/ month",
    creatorLabel: "",
    recommended: false,
    buttonLabel: "Start 14 day free trial",
    buttonVariant: "cta" as const,
    buttonUrl: "https://account.budibase.app/register",
    operationTiers: getTierOperationTiers(pricing.premium),
    defaultTierIndex: 0,
    addonPricing: getAddonPricing(pricing.premium),
    features: [
      getCreatorsFeature(premiumAnnualEntry),
      "10 end users",
      "7 days logs",
      "10 workspaces",
      "Custom branding",
      "Backups and restore",
      "SSO",
    ].filter(Boolean),
    hostingItems: getHostingItems(...pricing.premium.annual),
  },
  {
    title: "Business",
    tagLabel: "Best value",
    description: "Everything in Premium, plus:",
    creatorPrice: toNumericValue(businessAnnualEntry.base_price_per_month) ?? 0,
    billingPlan: "business",
    creatorUnit: "/ month",
    creatorLabel: "",
    recommended: false,
    buttonLabel: "Start 14 day free trial",
    buttonVariant: "cta" as const,
    buttonUrl: "https://account.budibase.app/register",
    operationTiers: getTierOperationTiers(pricing.business),
    defaultTierIndex: 0,
    addonPricing: getAddonPricing(pricing.business),
    features: [
      getCreatorsFeature(businessAnnualEntry),
      "30 end users",
      "30 days logs",
      "Unlimited workspaces",
      "Environment variables",
      "Enforced SSO",
      "User groups",
      "Email support",
    ].filter(Boolean),
    hostingItems: getHostingItems(...pricing.business.annual),
  },
  {
    title: "Enterprise",
    description: "Everything in Business, plus:",
    creatorPrice: toDisplayText(cloudEnterpriseEntry.base_price_per_month),
    billingPlan: "enterprise",
    creatorUnit: "",
    creatorLabel: "",
    additionalPriceText: toActionsText(cloudEnterpriseEntry.included_actions),
    additionalPriceTone: "primary" as const,
    recommended: false,
    buttonLabel: "Contact sales",
    buttonVariant: "primary" as const,
    buttonUrl: "/contact",
    addonItems: ["Air-gapped deployment", "Onboarding and training"],
    features: [
      "Active directory/SCIM",
      "365 days logs",
      "Audit logs",
      "Priorty support/SLAs",
      "Micro Frontends (MFEs)",
    ],
    hostingItems: getHostingItems(cloudEnterpriseEntry),
  },
];

const selfHostedCards = [
  {
    title: "Open source",
    description:
      "Access a complete operations platform that you can run on your own infrastructure.",
    buttonLabel: "Get started free",
    buttonHref: "https://docs.budibase.com",
    buttonTarget: "_blank",
    buttonVariant: "cta" as const,
    features: openSourcePlanFeatures,
    tone: "community",
  },
  {
    title: "Enterprise",
    description:
      "Design a custom package with enhanced governance, security, and support requirements.",
    buttonLabel: "Get pricing",
    buttonHref: "/contact",
    buttonVariant: "cta-on-base" as const,
    features: selfHostedEnterprisePlanFeatures,
    tone: "custom",
  },
];

const pricingPageNavItems = [
  { label: "Special packages", href: "#special-packages" },
  { label: "Cloud pricing", href: "#cloud-pricing" },
  { label: "FAQs", href: "#pricing-faqs-heading" },
];

const specialPackageCards = [
  {
    title: "Service partnerships",
    description:
      "Partner with Budibase to deliver internal tools, automation, and AI operations solutions for your customers.",
  },
  {
    title: "Charities",
    description:
      "Access flexible pricing for nonprofit teams building services, workflows, and operational tools with Budibase.",
  },
  {
    title: "Public sector",
    description:
      "Access a specialized package with custom limits, payment arrangements, and open source licensing for public sector teams.",
  },
];

const faqItems: FaqItem[] = [
  {
    question: 'What are "actions"?',
    paragraphs: [
      "Actions represent the total work your agents, apps and automations perform.",
      "If your agent takes an action or your workflow runs a step, that counts as an action.",
      "If a user creates, updates or deletes a row in the Budibase DB or a SQL DB - that counts as one action.",
      "Custom SQL queries and API requests are not included as actions.",
    ],
    bullets: [
      "AI agent tool calls",
      "Automation node executions",
      "Save row",
      "Delete row",
    ],
  },
  {
    question: "Why do you price by actions?",
    paragraphs: [
      "Actions directly reflect the amount of useful work Budibase is doing. This aligns pricing with real business value, not just seats or arbitrary limits.",
    ],
  },
  {
    question: "Are actions soft limits or hard limits?",
    paragraphs: [
      "Actions are hard monthly limits based on your selected plan tier. When you reach your limit, you'll need to move to a higher tier or plan to continue running agents and automations.",
      "This ensures:",
    ],
    bullets: [
      "Predictable infrastructure performance",
      "Clear cost control",
      "Transparent scaling as your action volume grows",
    ],
  },
  {
    question: "Why use hard limits instead of overage billing?",
    paragraphs: [
      "Hard limits keep costs predictable for SMEs. You always know exactly what you're paying each month with no surprise overages.",
    ],
  },
  {
    question: "Can I add more users?",
    paragraphs: [
      "Yes. Pro, Premium, and Business include an End users add-on.",
      "End users are $5/user/mo on yearly billing. Monthly billing follows the same +20% pricing logic shown on the page.",
    ],
  },
  {
    question: "Can I add more creators (builders)?",
    paragraphs: [
      "Yes. Premium and Business include a Creators add-on.",
      "Creators are $50/creator/mo on yearly billing. Monthly billing follows the same +20% pricing logic shown on the page.",
    ],
  },
  {
    question: "Do add-on prices change with yearly vs monthly billing?",
    paragraphs: [
      "Yes. Add-ons follow the same yearly/monthly toggle as plan pricing.",
      "Monthly values are calculated as yearly price +20%.",
    ],
  },
  {
    question: "Does Budibase offer a free open-source plan?",
    paragraphs: [
      "Yes. Budibase offers a fully open-source self-hosted plan that is free to use indefinitely.",
      "You can build and run apps, agents, and automations on your own infrastructure without software licensing fees.",
    ],
  },
  {
    question: "When should I choose cloud instead of self-hosting?",
    paragraphs: [
      "Cloud is best if you want managed infrastructure, built-in scalability, collaboration tools, AI credits, and support.",
      "Self-hosting is ideal if you require full control over your infrastructure and deployment.",
    ],
  },
];
---

<section
  class="pricing-page container max-w-[var(--site-container-max)] mx-auto flex flex-col mt-8 px-2 lg:px-0"
>
  <div class="w-full flex flex-col gap-8">
    <section class="pricing-hero" aria-labelledby="pricing-heading">
      <div class="pricing-hero__copy">
        <p class="hero-metric hero-gradient-text font-medium">Pricing</p>
        <h1
          id="pricing-heading"
          class="hero-title mx-auto mb-5 block w-full text-pretty"
        >
          <span>Open source flexibility. Enterprise control.</span>
          <span>
            Start for free. Scale with the controls and support your
            organization needs.
          </span>
        </h1>
      </div>

      <div id="self-host-pricing" class="pricing-self-host-grid">
        {
          selfHostedCards.map((card) => (
            <article class={`pricing-self-host-card is-${card.tone}`}>
              <div class="pricing-self-host-card__content">
                <div class="pricing-self-host-card__copy">
                  <h2>{card.title}</h2>
                  <p>{card.description}</p>
                </div>
                <Button
                  label={card.buttonLabel}
                  url={card.buttonHref}
                  target={card.buttonTarget}
                  variant={card.buttonVariant}
                  size="medium"
                />
              </div>
              <ul class="pricing-self-host-card__features">
                {card.features.map((feature, index) => (
                  <li class={index === 0 ? "is-first" : ""}>
                    <span
                      class="pricing-self-host-card__feature-icon"
                      aria-hidden="true"
                    >
                      <Icon name="Check" size="14" />
                    </span>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>

      <div id="pricing-logos" class="pricing-logo-grid">
        <EnterpriseLogoGrid placement="hero-compact" />
      </div>

      <nav class="pricing-section-nav" aria-label="Pricing page sections">
        {
          pricingPageNavItems.map((item) => (
            <a href={item.href} class="pricing-section-nav__link">
              {item.label}
            </a>
          ))
        }
      </nav>

      <section
        id="special-packages"
        class="pricing-special-package-section"
        aria-labelledby="special-packages-heading"
      >
        <h2
          id="special-packages-heading"
          class="pricing-special-package-section__heading"
        >
          Special Packages
        </h2>
        <p class="pricing-special-package-section__subtitle">
          Flexible options for partners, nonprofits, and public sector teams.
        </p>
        <div class="pricing-special-package-grid">
          {
            specialPackageCards.map((card) => (
              <Card
                label={card.title}
                description={card.description}
                class="pricing-special-package-card"
                cardContentClass="pricing-special-package-card__content"
                cardTitleClass="pricing-special-package-card__title"
              >
                <div class="pricing-special-package-card__action">
                  <Button
                    label="Contact us"
                    url="/contact"
                    variant="cta"
                    size="medium"
                  />
                </div>
              </Card>
            ))
          }
        </div>
      </section>

      <section
        id="cloud-pricing"
        class="pricing-cloud-section"
        aria-labelledby="cloud-pricing-heading"
      >
        <div class="pricing-cloud-section__inner">
          <h2 id="cloud-pricing-heading" class="pricing-cloud-section__heading">
            Explore pricing for hosting with Budibase Cloud
          </h2>
          <p class="pricing-cloud-section__subtitle">
            We take care of the hosting, updates, and maintenance for you.
          </p>
          <div class="pricing-cloud-grid">
            {
              cloudCards.map(({ hostingItems, ...card }) => (
                <PricingCard {...card} />
              ))
            }
          </div>
        </div>
      </section>
    </section>

    <section
      class="pricing-faq-section mb-12 md:mb-20"
      aria-labelledby="pricing-faqs-heading"
    >
      <h2
        id="pricing-faqs-heading"
        class="text-3xl font-semibold text-stone-900 mb-6 md:mb-8"
      >
        FAQs
      </h2>
      <div
        data-faq-accordion
        class="border-t border-dotted border-stone-300/80"
      >
        {
          faqItems.map((item) => (
            <details
              data-faq-item
              class="group border-b border-dotted border-stone-300/80 "
            >
              <summary class="list-none [&::-webkit-details-marker]:hidden min-h-[64px] py-4 md:py-5 cursor-pointer flex items-center justify-between gap-4 text-left text-stone-900  focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500  focus-visible:ring-offset-2">
                <h3 class="m-0 text-lg md:text-xl text-stone-900 ">
                  {item.question}
                </h3>
                <span class="shrink-0">
                  <Plus
                    class="w-5 h-5 md:w-6 md:h-6 text-stone-900  transition-transform duration-200 ease-out group-open:rotate-45"
                    aria-hidden="true"
                  />
                </span>
              </summary>
              <div class="faq-answer text-base md:text-lg text-stone-600  pb-5 md:pb-6 pr-1 md:pr-12">
                {item.paragraphs.map((paragraph) => (
                  <p class="mb-3">{paragraph}</p>
                ))}
                {item.bullets && item.bullets.length > 0 && (
                  <ul class="mb-3">
                    {item.bullets.map((bullet) => (
                      <li class="mb-1">{bullet}</li>
                    ))}
                  </ul>
                )}
              </div>
            </details>
          ))
        }
      </div>
    </section>
  </div>
</section>

<style>
  .pricing-page {
    --pricing-card-radius: 6px;
    --pricing-card-gap: 0.75rem;
    --pricing-feature-radius: 4px;
    --pricing-community-bg: var(--bb-gray-50);
    --pricing-community-feature-bg: var(--bb-gray-100);
    --pricing-custom-bg: var(--bb-chartreuse-1500);
    --pricing-custom-feature-bg: var(--bb-chartreuse-1300);
  }

  .pricing-hero {
    display: flex;
    width: 100%;
    max-width: 72rem;
    flex-direction: column;
    gap: clamp(1.5rem, 3vw, 1.875rem);
    margin-block: clamp(3rem, 7vw, 5rem);
    margin-inline: auto;
    padding-inline: clamp(0rem, 1.5vw, 1.25rem);
  }

  .pricing-hero__copy {
    width: 100%;
    max-width: 56rem;
    margin-inline: auto;
    overflow: hidden;
  }

  .pricing-hero h1 {
    color: var(--bb-text-base);
  }

  .hero-gradient-text {
    background-image: var(--bb-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent !important;
    -webkit-text-fill-color: transparent !important;
  }

  .hero-metric {
    width: fit-content;
    margin: 0 0 0.25rem;
    font-family: var(--font-geist-mono), var(--font-mono) !important;
    font-size: 0.6875rem;
    font-weight: 500 !important;
  }

  .pricing-hero h1 span {
    display: block;
  }

  .pricing-hero h1 span + span {
    color: var(--bb-text-subtle);
  }

  .pricing-self-host-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    width: 100%;
  }

  .pricing-self-host-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--pricing-card-gap);
    min-height: 260px;
    padding: 0.5rem;
    border: 1px solid var(--bb-border-subtle);
    border-radius: var(--pricing-card-radius);
  }

  .pricing-self-host-card.is-community {
    background: var(--pricing-community-bg);
    border-color: transparent;
  }

  .pricing-self-host-card.is-custom {
    background: var(--pricing-custom-bg);
    border-color: var(--bb-transparent-white-200);
  }

  .pricing-self-host-card__content {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 1.25rem;
    padding: 0.75rem;
  }

  .pricing-self-host-card__copy {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .pricing-self-host-card h2 {
    margin: 0;
    color: var(--bb-text-base);
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .pricing-self-host-card p {
    margin: 0;
    color: var(--bb-text-subtle);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.43;
  }

  .pricing-self-host-card.is-custom h2 {
    color: var(--bb-text-on-base) !important;
  }

  .pricing-self-host-card.is-custom p {
    color: var(--bb-text-on-base-subtle) !important;
  }

  .pricing-self-host-card__features {
    display: flex;
    min-width: 0;
    height: 100%;
    flex-direction: column;
    gap: 0.125rem;
    margin: 0 !important;
    padding: 0;
    list-style: none;
  }

  .pricing-self-host-card__features li {
    display: flex;
    flex: 1 1 0;
    min-height: 2.25rem;
    align-items: center;
    justify-content: flex-start;
    gap: 0.375rem;
    margin: 0 !important;
    padding: 0.5rem 0.75rem;
    border-radius: 0;
    background: var(--pricing-community-feature-bg);
    color: var(--bb-text-base) !important;
    -webkit-text-fill-color: var(--bb-text-base);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.25;
    text-align: left;
  }

  .pricing-self-host-card__feature-icon {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    color: currentColor;
  }

  .pricing-self-host-card__features li:first-child {
    border-top-left-radius: var(--pricing-feature-radius);
    border-top-right-radius: var(--pricing-feature-radius);
  }

  .pricing-self-host-card__features li:last-child {
    border-bottom-right-radius: var(--pricing-feature-radius);
    border-bottom-left-radius: var(--pricing-feature-radius);
  }

  .pricing-self-host-card.is-custom .pricing-self-host-card__features li {
    background: var(--pricing-custom-feature-bg);
    color: var(--bb-text-on-base) !important;
    -webkit-text-fill-color: var(--bb-text-on-base);
  }

  .pricing-section-nav {
    display: flex;
    width: fit-content;
    max-width: 100%;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin: 1rem auto 0;
    padding: 0.625rem 1.25rem;
    border-radius: 50px;
    background: var(--bb-transparent-black-50);
  }

  .pricing-section-nav__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--bb-text-base) !important;
    -webkit-text-fill-color: var(--bb-text-base);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.214;
    text-decoration: none;
    white-space: nowrap;
  }

  .pricing-section-nav__link:hover {
    color: var(--bb-green-1000) !important;
    -webkit-text-fill-color: var(--bb-green-1000);
  }

  .pricing-logo-grid {
    width: 100%;
    margin: 0.5rem auto 0;
  }

  .pricing-cloud-section {
    width: 100vw;
    margin-block: clamp(1.5rem, 4vw, 3rem);
    margin-inline: calc(50% - 50vw);
    padding-block: clamp(2.5rem, 6vw, 5rem);
    padding-inline: clamp(1.25rem, 3vw, 2rem);
    scroll-margin-top: 6rem;
  }

  .pricing-cloud-section__inner {
    width: min(100%, 72rem);
    margin-inline: auto;
    padding-inline: clamp(0rem, 1.5vw, 1.25rem);
  }

  .pricing-cloud-section__heading {
    margin: 0 0 0.5rem;
    color: var(--bb-text-base);
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .pricing-cloud-section__subtitle {
    margin: 0 0 1.5rem;
