---
import Button from "@components/Button.astro";
import Check from "phosphor-astro/check.astro";

type ButtonVariant = "primary" | "secondary" | "cta";
type ButtonSize = "small" | "medium" | "large";
// features is an array of bullet points

interface Props {
  title: string;
  description?: string;
  creatorPrice: string | number;
  userPrice?: string | number;
  creatorUnit?: string;
  userUnit?: string;
  creatorLabel?: string;
  userLabel?: string;
  features?: string[];
  recommended?: boolean;
  buttonLabel: string;
  buttonVariant?: ButtonVariant;
  buttonUrl?: string;
  buttonSize?: ButtonSize;
}

const {
  title,
  description,
  creatorPrice,
  userPrice,
  creatorUnit = "/mo.",
  userUnit = "/mo.",
  creatorLabel = "per creator",
  userLabel = "per end user",
  features = [],
  recommended = false,
  buttonLabel,
  buttonVariant = "primary",
  buttonUrl = "#",
  buttonSize = "medium",
} = Astro.props as Props;

const cardClasses = ["pricing-card", recommended ? "recommended" : ""]
  .filter(Boolean)
  .join(" ");
---

<div class={cardClasses}>
  <header class="header">
    <h3 class="text-stone-900 dark:text-stone-100">{title}</h3>
    {
      recommended && (
        <span
          class="text-stone-100 ml-auto px-2 py-0.5 bg-sky-700 text-sm font-mono rounded-md"
          aria-label="Recommended"
        >
          Recommended
        </span>
      )
    }
  </header>

  <div class="body">
    <div class="prices">
      <p class="price-line">
        <span class="amount"
          >{
            typeof creatorPrice === "number" ? `$${creatorPrice}` : creatorPrice
          }</span
        >
        <span class="inline-flex gap-0.5">
          <span class="text-base text-stone-600 dark:text-stone-400"
            >{creatorLabel}</span
          >
          <span class="text-base text-stone-600 dark:text-stone-400"
            >{creatorUnit}</span
          >
        </span>
      </p>
      {
        userPrice !== undefined && (
          <p class="price-line">
            <span class="amount">
              {typeof userPrice === "number" ? `$${userPrice}` : userPrice}
            </span>
            <span class="inline-flex gap-0.5">
              <span class="text-base text-stone-600 dark:text-stone-400">
                {userLabel}
              </span>
              <span class="text-base text-stone-600 dark:text-stone-400">
                {userUnit}
              </span>
            </span>
          </p>
        )
      }
    </div>
    <div class="mt-4">
      {
        description && (
          <p class=" text-stone-600! dark:text-stone-400!">{description}</p>
        )
      }
    </div>
    {
      features?.length ? (
        <ul class=" gap-1 flex flex-col">
          {features.map((feat) => (
            <li>
              <span class="check">
                <Check class="fill-stone-700 dark:fill-stone-300 w-3" />
              </span>
              <span class="feature-text text-stone-900 dark:text-stone-100">
                {feat}
              </span>
            </li>
          ))}
        </ul>
      ) : null
    }
    <div class="cta mt-20">
      <Button
        label={buttonLabel}
        url={buttonUrl}
        variant={buttonVariant}
        size={buttonSize}
      />
    </div>
  </div>
</div>

<style>
  .pricing-card {
    background: var(--color-theme-bg-secondary);
    border-radius: 8px;
    padding: 20px;
  }

  @media (min-width: 640px) {
    .pricing-card {
      padding: 24px;
    }
  }

  :global(.dark) .pricing-card {
    border-color: var(--color-stone-800);
  }

  .header {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .body {
    margin-top: 20px;
  }

  .prices {
    display: block;
    margin-bottom: 20px;
  }
  .price-line {
    margin: 0;
    color: var(--color-stone-900);
  }
  :global(.dark) .price-line {
    color: var(--color-stone-100);
  }

  .cta {
    margin: 32px 0 16px 0;
  }

  .feature {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
  }
  .check {
    display: inline-flex;
  }
</style>
