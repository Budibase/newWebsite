---
import Button from "@components/Button.astro";
import Tag from "@components/Tag.astro";
import Check from "phosphor-astro/Check.astro";
import Cloud from "phosphor-astro/Cloud.astro";
import HardDrives from "phosphor-astro/HardDrives.astro";
import Plus from "phosphor-astro/Plus.astro";
import Info from "phosphor-astro/Info.astro";

type ButtonVariant = "primary" | "secondary" | "cta";
type ButtonSize = "small" | "medium" | "large";
type AdditionalPriceTone = "muted" | "primary";
type OperationTier = {
  operations: string;
  annualPrice?: number;
  monthlyPrice?: number;
  aiCredits?: string;
};
type AddonDisplayItem = {
  text: string;
  annualAmount?: number;
  monthlyAmount?: number;
  prefix?: string;
  suffix?: string;
};
type AddonPriceValue = {
  annual: number;
  monthly?: number;
};
type AddonPricing = {
  endUsers?: AddonPriceValue;
  creators?: AddonPriceValue;
};
type FeatureTone = "default" | "orange-accent";
type CardTone = "default" | "self-host-open-source" | "self-host-enterprise";
// features can be an array of strings or objects with text and icon
type FeatureItem =
  | string
  | { text: string; icon?: "check" | "plus"; tone?: FeatureTone };

interface Props {
  title: string;
  description?: string;
  creatorPrice: string | number;
  userPrice?: string | number;
  billingPlan?: string;
  creatorUnit?: string;
  userUnit?: string;
  creatorLabel?: string;
  userLabel?: string;
  additionalPriceText?: string;
  additionalPriceTone?: AdditionalPriceTone;
  operationTiers?: OperationTier[];
  defaultTierIndex?: number;
  addonItems?: string[];
  addonPricing?: AddonPricing;
  hostingItems?: string[];
  features?: FeatureItem[];
  recommended?: boolean;
  tagLabel?: string;
  badgeLabel?: string;
  cardTone?: CardTone;
  buttonLabel: string;
  buttonVariant?: ButtonVariant;
  buttonUrl?: string;
  buttonSize?: ButtonSize;
  buttonTarget?: string;
}

const {
  title,
  description,
  creatorPrice,
  userPrice,
  billingPlan,
  creatorUnit = "/mo.",
  userUnit = "/mo.",
  creatorLabel = "per creator",
  userLabel = "per end user",
  additionalPriceText,
  additionalPriceTone = "muted",
  operationTiers = [],
  defaultTierIndex = 0,
  addonItems,
  addonPricing,
  hostingItems = [],
  features = [],
  recommended = false,
  tagLabel,
  badgeLabel,
  cardTone = "default",
  buttonLabel,
  buttonVariant = "primary",
  buttonUrl = "#",
  buttonSize = "medium",
  buttonTarget,
} = Astro.props as Props;

const cardClasses = [
  "pricing-card",
  cardTone !== "default" ? `pricing-card--${cardTone}` : "",
  recommended ? "recommended" : "",
]
  .filter(Boolean)
  .join(" ");
const isSelfHostCard = cardTone !== "default";
const buttonClass = isSelfHostCard ? "pricing-card__button" : "";

const isOperationsFeature = (feature: FeatureItem): feature is string =>
  typeof feature === "string" &&
  (/^Actions:\s*/i.test(feature) ||
    /^(.+?)\s+actions$/i.test(feature) ||
    /^Operations:\s*/i.test(feature) ||
    /^(.+?)\s+operations$/i.test(feature));

const isEndUsersFeature = (feature: FeatureItem): boolean => {
  const featureText = typeof feature === "string" ? feature : feature.text;
  return (
    /^End users:\s*/i.test(featureText) ||
    /^(.+?)\s+end users?\b/i.test(featureText)
  );
};

const isAICreditsFeature = (feature: FeatureItem): boolean => {
  const featureText = typeof feature === "string" ? feature : feature.text;
  return (
    /^Budibase AI credits:\s*/i.test(featureText) ||
    /^(.+?)\s+Budibase AI credits$/i.test(featureText)
  );
};

const toOperationsLabel = (value: string): string => {
  const trimmed = value.trim();
  return /actions$/i.test(trimmed) ? trimmed : `${trimmed} actions`;
};

const normalizedOperationTiers = operationTiers.map((tier) => ({
  ...tier,
  operationsLabel: toOperationsLabel(tier.operations),
}));
const safeDefaultTierIndex = Number.isFinite(defaultTierIndex)
  ? Math.floor(defaultTierIndex)
  : 0;
const selectedTierIndex = normalizedOperationTiers.length
  ? Math.min(
      Math.max(safeDefaultTierIndex, 0),
      normalizedOperationTiers.length - 1,
    )
  : 0;
const selectedOperationTier = normalizedOperationTiers[selectedTierIndex];

const operationsFeature = features.find(isOperationsFeature);
const nonOperationsFeatures = features.filter(
  (feature) => !isOperationsFeature(feature),
);
const aiCreditsFeature = features.find(isAICreditsFeature);
const visibleFeatures = nonOperationsFeatures.filter(
  (feature) => !isEndUsersFeature(feature) && !isAICreditsFeature(feature),
);
const operationsValue =
  operationsFeature?.match(/^Operations:\s*(.+)$/i)?.[1] ||
  operationsFeature?.match(/^(.+?)\s+operations$/i)?.[1] ||
  operationsFeature?.match(/^Actions:\s*(.+)$/i)?.[1] ||
  operationsFeature?.match(/^(.+?)\s+actions$/i)?.[1];
const operationsLabel = operationsValue
  ? `${operationsValue} actions`
  : operationsFeature || undefined;
const fallbackAICreditsValue =
  typeof aiCreditsFeature === "string"
    ? aiCreditsFeature.match(/^Budibase AI credits:\s*(.+)$/i)?.[1] ||
      aiCreditsFeature.match(/^(.+?)\s+Budibase AI credits$/i)?.[1]
    : undefined;
const operationsDropdownOptions = normalizedOperationTiers.length
  ? normalizedOperationTiers
  : operationsLabel
    ? [
        {
          operationsLabel,
          annualPrice: undefined,
          monthlyPrice: undefined,
          aiCredits: undefined,
        },
      ]
    : [];
const initialAICredits =
  selectedOperationTier?.aiCredits || fallbackAICreditsValue;
const selectedAnnualCreatorPrice = selectedOperationTier?.annualPrice;
const selectedMonthlyCreatorPrice = selectedOperationTier?.monthlyPrice;
const initialAnnualPrice =
  typeof selectedAnnualCreatorPrice === "number"
    ? selectedAnnualCreatorPrice
    : typeof creatorPrice === "number"
      ? creatorPrice
      : undefined;
const initialDisplayPrice =
  typeof initialAnnualPrice === "number"
    ? `$${initialAnnualPrice}`
    : typeof creatorPrice === "number"
      ? `$${creatorPrice}`
      : creatorPrice;
const defaultAddonItems =
  billingPlan === "premium" || billingPlan === "business"
    ? ["End users for $5/user/mo", "Creators for $50/creator/mo"]
    : billingPlan === "enterprise"
      ? []
      : ["End users for $5/user/mo"];
const addonItemsFromPricing = addonPricing
  ? ([
      addonPricing.endUsers
        ? {
            text: `End users for $${addonPricing.endUsers.annual}/user/mo`,
            annualAmount: addonPricing.endUsers.annual,
            monthlyAmount: addonPricing.endUsers.monthly,
            prefix: "End users for ",
            suffix: "/user/mo",
          }
        : null,
      addonPricing.creators
        ? {
            text: `Creators for $${addonPricing.creators.annual}/creator/mo`,
            annualAmount: addonPricing.creators.annual,
            monthlyAmount: addonPricing.creators.monthly,
            prefix: "Creators for ",
            suffix: "/creator/mo",
          }
        : null,
    ].filter(Boolean) as AddonDisplayItem[])
  : null;
const addonsToShow = addonItemsFromPricing ?? addonItems ?? defaultAddonItems;
const addonPricePattern = /^(.*)\$(\d+)(.*)$/;
const normalizedAddonItems: AddonDisplayItem[] =
  Array.isArray(addonsToShow) && typeof addonsToShow[0] === "object"
    ? (addonsToShow as AddonDisplayItem[])
    : (addonsToShow as string[]).map((addon) => {
        const priceMatch = addon.match(addonPricePattern);
        if (!priceMatch) {
          return { text: addon };
        }

        const annualAmount = Number(priceMatch[2]);
        if (Number.isNaN(annualAmount)) {
          return { text: addon };
        }

        return {
          text: addon,
          annualAmount,
          prefix: priceMatch[1],
          suffix: priceMatch[3],
        };
      });
const endUsersAddonPricing = addonPricing?.endUsers;
const creatorsAddonPricing = addonPricing?.creators;
const showAddonsSection = normalizedAddonItems.length > 0;
const showHostingSection = hostingItems.length > 0;
---

<div
  class={`${cardClasses} h-full flex flex-col`}
  data-billing-plan={billingPlan}
  data-tier-index={String(selectedTierIndex)}
>
  <header class="header">
    <div class="header-main">
      {badgeLabel && <span class="pricing-card__badge">{badgeLabel}</span>}
      <h3 class="!text-lg text-stone-900">{title}</h3>
      {
        tagLabel && (
          <Tag label={tagLabel} size="small" variant="orange" class="ml-auto" />
        )
      }
      {
        recommended && (
          <span
            class="text-stone-100 ml-auto px-2 py-0.5 bg-sky-700 text-sm font-mono rounded-md"
            aria-label="Recommended"
          >
            Recommended
          </span>
        )
      }
    </div>
    {
      isSelfHostCard && description && (
        <p class="pricing-card__intro">{description}</p>
      )
    }
  </header>

  <div class="body">
    <div class="header-prices">
      <div class="prices">
        <p class="price-line">
          <span
            class="amount !text-2xl text-primary"
            data-annual-price={typeof initialAnnualPrice === "number"
              ? initialAnnualPrice
              : undefined}
            data-monthly-price={typeof selectedMonthlyCreatorPrice === "number"
              ? selectedMonthlyCreatorPrice
              : undefined}>{initialDisplayPrice}</span
          >
          <span class="inline-flex gap-0.5">
            {
              creatorLabel && (
                <span class="text-[14px] text-stone-600 ">{creatorLabel}</span>
              )
            }
            <span class="unit-text text-[14px] text-stone-600">
              {creatorUnit}
            </span>
          </span>
        </p>
        {
          userPrice !== undefined && (
            <p class="price-line">
              <span
                class="amount !text-2xl text-primary"
                data-base-price={
                  typeof userPrice === "number" ? userPrice : undefined
                }
              >
                {typeof userPrice === "number" ? `$${userPrice}` : userPrice}
              </span>
              <span class="inline-flex gap-0.5">
                <span class="text-[14px] text-stone-600 ">{userLabel}</span>
                <span class="unit-text text-[14px] text-stone-600 ">
                  {userUnit}
                </span>
              </span>
            </p>
          )
        }
      </div>
      {
        operationsDropdownOptions.length > 1 && (
          <div class="operations-row operations-select-row text-[14px] text-stone-900  mt-3">
            <select
              class="operations-select"
              aria-label="Actions limit"
              data-operations-select
            >
              {operationsDropdownOptions.map((option, index) => (
                <option
                  value={option.operationsLabel}
                  selected={index === selectedTierIndex}
                  data-tier-index={String(index)}
                  data-tier-annual-price={
                    option.annualPrice !== undefined
                      ? String(option.annualPrice)
                      : undefined
                  }
                  data-tier-monthly-price={
                    option.monthlyPrice !== undefined
                      ? String(option.monthlyPrice)
                      : undefined
                  }
                  data-tier-ai={option.aiCredits}
                  data-tier-operations={option.operationsLabel}
                >
                  {option.operationsLabel}
                </option>
              ))}
            </select>
          </div>
        )
      }
      {
        operationsDropdownOptions.length === 1 && (
          <div class="operations-row mt-3">
            <p class="operations-static operations-static-primary">
              {operationsDropdownOptions[0].operationsLabel}
            </p>
          </div>
        )
      }
      {
        operationsDropdownOptions.length === 0 && additionalPriceText && (
          <div class="operations-row mt-3">
            <p
              class={`operations-static ${
                additionalPriceTone === "primary"
                  ? "operations-static-primary"
                  : "text-stone-600 "
              }`}
            >
              {additionalPriceText}
            </p>
          </div>
        )
      }
    </div>
    <div class="cta">
      <Button
        label={buttonLabel}
        url={buttonUrl}
        variant={buttonVariant}
        size={buttonSize}
        target={buttonTarget}
        class={buttonClass}
      />
    </div>
    <div class="description-features">
      <div>
        {
          description && (
            <p class="!text-[14px] text-stone-600! ">{description}</p>
          )
        }
      </div>
      {
        initialAICredits || visibleFeatures.length ? (
          <ul class=" gap-1 flex flex-col mb-5" aria-label="Plan features">
            {initialAICredits && (
              <li class="text-[14px]" data-tier-ai={initialAICredits}>
                <span class="check">
                  <Check class="fill-stone-700  w-3" aria-hidden="true" />
                </span>
                <span class="feature-text text-stone-900 ">
                  <span data-tier-ai-value>{initialAICredits}</span> Budibase AI
                  credits
                </span>
              </li>
            )}
            {visibleFeatures.map((feat, index) => {
              const featureText = typeof feat === "string" ? feat : feat.text;
              const iconType =
                typeof feat === "string" ? "check" : feat.icon || "check";
              const featureTone =
                typeof feat === "string" ? "default" : feat.tone || "default";
              const endUsersMatch =
                typeof feat === "string"
                  ? feat.match(/^End users:\s*(.+)$/i) ||
                    feat.match(/^(.+?)\s+end users?$/i)
                  : null;
              const endUsersValue = endUsersMatch?.[1] || "";
              const showEndUsersPopover = Boolean(
                endUsersMatch && /\d/.test(endUsersValue),
              );
              const creatorsMatch =
                typeof feat === "string"
                  ? feat.match(/^Creators:\s*(.+)$/i) ||
                    feat.match(/^(.+?)\s+creators?\b/i)
                  : null;
              const creatorsValue = creatorsMatch?.[1] || "";
              const showCreatorsPopover = Boolean(
                creatorsMatch &&
                  /\d/.test(creatorsValue) &&
                  creatorsAddonPricing,
              );
              return (
                <li class="text-[14px]">
                  <span class="check">
                    {iconType === "plus" ? (
                      <Plus
                        class:list={[
                          "w-3",
                          featureTone === "orange-accent"
                            ? "fill-[var(--accent-orange)]"
                            : "fill-stone-700 ",
                        ]}
                        aria-hidden="true"
                      />
                    ) : (
                      <Check
                        class:list={[
                          "w-3",
                          featureTone === "orange-accent"
                            ? "fill-[var(--accent-orange)]"
                            : "fill-stone-700 ",
                        ]}
                        aria-hidden="true"
                      />
                    )}
                  </span>
                  <span
                    class:list={[
                      "feature-text",
                      featureTone === "orange-accent"
                        ? "text-[var(--accent-orange)]"
                        : "text-stone-900 ",
                    ]}
                  >
                    {showEndUsersPopover ? (
                      <span class="end-users-inline">
                        <span>{`${endUsersValue} end users`}</span>
                        <span class="end-users-help">
                          <button
                            type="button"
                            class="end-users-help-button"
                            aria-label="Add end users pricing info"
                          >
                            <Info
                              class="w-4 h-4 fill-stone-700 "
                              aria-hidden="true"
                            />
                          </button>
                          <span
                            role="tooltip"
                            class="end-users-popover p-3 rounded-sm text-sm text-primary"
                            data-overage-kind="end-users"
                            data-overage-annual={endUsersAddonPricing?.annual}
                            data-overage-monthly={endUsersAddonPricing?.monthly}
                          >
                            Add more end users for $
                            {endUsersAddonPricing
                              ? `$${endUsersAddonPricing.annual}`
                              : "$5"}{" "}
                            per end user per month
                          </span>
                        </span>
                      </span>
                    ) : showCreatorsPopover ? (
                      <span class="end-users-inline">
                        <span>{featureText}</span>
                        <span class="end-users-help">
                          <button
                            type="button"
                            class="end-users-help-button"
                            aria-label="Add creators pricing info"
                          >
                            <Info
                              class="w-4 h-4 fill-stone-700 "
                              aria-hidden="true"
                            />
                          </button>
                          <span
                            role="tooltip"
                            class="end-users-popover p-3 rounded-sm text-sm text-primary"
                            data-overage-kind="creators"
                            data-overage-annual={creatorsAddonPricing?.annual}
                            data-overage-monthly={creatorsAddonPricing?.monthly}
                          >
                            Add more creators for $
                            {creatorsAddonPricing
                              ? `$${creatorsAddonPricing.annual}`
                              : "$50"}{" "}
                            per creator per month
                          </span>
                        </span>
                      </span>
                    ) : (
                      featureText
                    )}
                  </span>
                </li>
              );
            })}
          </ul>
        ) : null
      }
    </div>
    {
      showHostingSection && (
        <div class="addons-section">
          <p class="addons-label !text-[14px] text-stone-900 ">Hosting:</p>
          {hostingItems.map((hostingItem) => (
            <p class="addon-line text-[14px]">
              <span class="check">
                {hostingItem === "Budibase Cloud" ? (
                  <Cloud class="w-3 h-3 fill-stone-700 " aria-hidden="true" />
                ) : hostingItem === "Self-host / on-premise" ||
                  hostingItem === "Self-hosted" ? (
                  <HardDrives
                    class="w-3 h-3 fill-stone-700 "
                    aria-hidden="true"
                  />
                ) : (
                  <Check class="w-3 h-3 fill-stone-700 " aria-hidden="true" />
                )}
              </span>
              <span class="feature-text text-stone-900 ">{hostingItem}</span>
            </p>
          ))}
        </div>
      )
    }
    {
      showAddonsSection && (
        <div class="addons-section">
          <p class="addons-label !text-[14px] text-stone-900 ">
            Available add-ons:
          </p>
          {normalizedAddonItems.map((addon) => (
            <p
              class="addon-line text-[14px]"
              data-addon-annual={
                addon.annualAmount !== undefined
                  ? String(addon.annualAmount)
                  : undefined
              }
              data-addon-monthly={
                addon.monthlyAmount !== undefined
                  ? String(addon.monthlyAmount)
                  : undefined
              }
              data-addon-prefix={addon.prefix}
              data-addon-suffix={addon.suffix}
            >
              <span class="check">
                <Plus class="w-3 h-3 fill-stone-700 " aria-hidden="true" />
              </span>
              <span class="feature-text text-stone-900 " data-addon-text>
                {addon.text}
              </span>
            </p>
          ))}
        </div>
      )
    }
  </div>
</div>

<style>
  .pricing-card {
    background: var(--bb-background-base);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 24px 16px;
    min-height: 100%;
  }

  .pricing-card--self-host-open-source,
  .pricing-card--self-host-enterprise {
    overflow: hidden;
    border-radius: 18px;
    padding: 0;
  }

  .pricing-card--self-host-open-source {
    background: var(--bb-green-100);
    border-color: var(--bb-green-300);
    color: var(--bb-green-1000);
  }

  .pricing-card--self-host-enterprise {
    background: var(--bb-cyan-1400);
    border-color: var(--bb-cyan-1000);
    color: var(--bb-cyan-100);
  }

  @media (min-width: 640px) {
    .pricing-card {
      padding: 24px 16px;
    }

    .pricing-card--self-host-open-source,
    .pricing-card--self-host-enterprise {
      padding: 0;
    }
  }

  .header {
    display: block;
  }

  .pricing-card--self-host-open-source .header,
  .pricing-card--self-host-enterprise .header {
    min-height: 260px;
    padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem) 2rem;
    text-align: center;
  }

  .header-main {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .pricing-card--self-host-open-source .header-main,
  .pricing-card--self-host-enterprise .header-main {
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
  }

  .pricing-card--self-host-open-source h3,
  .pricing-card--self-host-enterprise h3 {
    font-size: clamp(2.25rem, 4vw, 3.5rem) !important;
    line-height: 1;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .pricing-card--self-host-open-source h3 {
    color: var(--bb-green-1000) !important;
  }

  .pricing-card--self-host-enterprise h3 {
    color: var(--bb-cyan-100) !important;
  }

  .pricing-card__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 6.75rem;
    border-radius: 999px;
    padding: 0.35rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.08em;
  }

  .pricing-card--self-host-open-source .pricing-card__badge {
    background: var(--bb-green-300);
    color: var(--bb-green-1000);
  }

  .pricing-card--self-host-enterprise .pricing-card__badge {
    background: var(--bb-cyan-1600);
    color: var(--bb-cyan-100);
  }

  .pricing-card__intro {
    max-width: 34rem;
    margin: 1.5rem auto 0;
    font-size: clamp(1.125rem, 2vw, 1.5rem) !important;
    font-weight: 600 !important;
    line-height: 1.25;
  }

  .pricing-card--self-host-open-source .pricing-card__intro {
    color: var(--bb-green-1000) !important;
  }

  .pricing-card--self-host-enterprise .pricing-card__intro {
    color: var(--bb-cyan-100) !important;
  }

  .body {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    min-height: 0;
    height: 100%;
    gap: 20px;
  }

  .pricing-card--self-host-open-source .body,
  .pricing-card--self-host-enterprise .body {
    margin-top: 0;
    gap: 0;
  }

  .header-prices {
    flex-shrink: 0;
    height: fit-content;
  }

  .pricing-card--self-host-open-source .header-prices,
  .pricing-card--self-host-enterprise .header-prices {
    display: none;
  }

  .description-features {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    height: fit-content;
  }

  .pricing-card--self-host-open-source .description-features,
  .pricing-card--self-host-enterprise .description-features {
    padding: 3rem clamp(1.5rem, 4vw, 4rem) 3.5rem;
  }

  .pricing-card--self-host-open-source .description-features > div:first-child,
  .pricing-card--self-host-enterprise .description-features > div:first-child {
    display: none;
  }

  .pricing-card--self-host-open-source .description-features ul,
  .pricing-card--self-host-enterprise .description-features ul {
    margin-bottom: 0 !important;
    gap: 0.6rem;
  }

  .pricing-card--self-host-open-source .description-features li,
  .pricing-card--self-host-enterprise .description-features li {
    align-items: center;
    font-size: 1rem !important;
    line-height: 1.35;
  }

  .prices {
    display: block;
  }
  .price-line {
    margin-bottom: 4px;
    color: var(--bb-gray-900);
  }
  .amount {
    color: var(--text-primary);
  }

  .operations-row {
    display: block;
    width: 100%;
  }

  .operations-select-row {
    position: relative;
  }

  .operations-select-row::after {
    content: "";
    position: absolute;
