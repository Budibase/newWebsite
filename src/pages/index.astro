---
import Layout from "../layouts/MainLayout.astro";
import Hero from "./_components/landing-page/Hero.astro";
import UseCases from "./_components/landing-page/UseCases.astro";
import Resources from "./_components/landing-page/Resources.astro";
import Customers from "./_components/landing-page/Customers.astro";
import CTA from "@components/CTA.astro";
import APIExplorerDemo from "@components/APIExplorerDemo.astro";
---

<Layout
  rawTitle="Budibase is the open-source platform for building AI agents and workflows."
>
  <Hero />
  <Customers />
  <div class="container max-w-5xl mx-auto px-2 lg:px-0 mt-6 md:mt-10">
    <APIExplorerDemo />
  </div>
  <UseCases />
  <Resources />
  <CTA />
</Layout>
