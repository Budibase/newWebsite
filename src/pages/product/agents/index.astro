---
export const prerender = false;

import Layout from "../../../layouts/MainLayout.astro";
import CTA from "@components/CTA.astro";
import Button from "@components/Button.astro";
import TitleBlock from "@components/TitleBlock.astro";
import AgentDemo from "@components/AgentDemo.astro";
import AgentUseCases from "@components/AgentUseCases.astro";
import AgentFeatureCards from "../../_components/landing-page/AgentFeatureCards.astro";
import ContactSalesCTA from "@components/ContactSalesCTA.astro";

const pageTitle = "AI agents that\nrun your operations";
const pageDescription =
  "Build agents that handle requests, answer questions, and take action across your business. Connect your data, trigger automations, and let AI manage the routine work that keeps teams moving.";

const accept = Astro.request.headers.get("accept") ?? "";
Astro.response.headers.set("Vary", "Accept");

if (accept.includes("text/markdown")) {
  return new Response(
    `# Agents that handle everyday requests

Budibase agents help teams handle routine operational work automatically. They can understand requests, gather information, and take action across your systems.

## Core use cases

- Employee self-service: Employees ask questions and get instant answers
- Approval requests: Agents can collect information and run approval workflows
- Support triage: Agents can manage incoming requests and route them to the right team

## Build agents like writing a list

Automate complex work without losing control. Define controlled agent behavior with structured instructions and reusable guidance.

## Choose between 100s of AI models

Run agents with OpenAI, Anthropic, Mistral, or custom model providers.

- Mistral
- Budibase AI
- Anthropic
- Google
- OpenAI

## Deploy where work happens

Run agents inside Automations, Discord, and soon Teams and Slack.

- Slack
- Microsoft Teams
- Discord

## Connect 100s of tools

Give your agent access to over 10,000 operations across 100s of tools.

## Knowledge retrieval (RAG)

Ground responses with retrieval workflows, including pgvector support.

## Data and API access

Access internal data tables and external APIs to execute operational tasks.
`,
    {
      headers: {
        "Content-Type": "text/markdown; charset=utf-8",
        "Vary": "Accept",
      },
    }
  );
}
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="agents-hero">
    <div class="mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0">
      <div class="agents-hero-grid">
        <div class="agents-hero-copy max-w-xl">
          <TitleBlock
            variant="hero"
            titleColorMode="split-primary-secondary"
            titleLines={[
              { text: "AI agents that" },
              { text: "run your operations" },
            ]}
            titleClass="mb-4 w-full leading-[0.9]! tracking-[-0.02em]!"
          />
          <p
            class="hero-description-small mx-auto max-w-xl text-base md:!text-xl !mb-4"
          >
            {pageDescription}
          </p>
        </div>

        <div class="agents-hero-cta">
          <Button
            label="Try for free"
            url="https://account.budibase.app/register"
            variant="primary"
            size="large"
            target="_blank"
          />
          <Button
           label="Contact sales"
           url="/contact/"
           variant="secondary"
           size="large"
           class="px-6 py-3 text-xl md:px-7 md:py-3.5 md:text-xl ml-5"
           target="_blank"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-7xl px-2 pb-12 pt-6 md:px-3 lg:px-0">
    <div class="flex flex-col gap-[var(--section-spacing-y)]">
      <div class="flex flex-col gap-[var(--section-gap-lg)]">
        <AgentDemo />
        <AgentUseCases />
        <AgentFeatureCards />
      </div>
    </div>
  </section>

  <CTA />
</Layout>

<style>
  .agents-hero {
    background: var(--bg-1);
    padding-top: max(calc(var(--site-nav-height) + 1.2rem), 4.8rem);
    padding-bottom: 3rem;
  }

  :global(#site-nav.nav-shell) {
    background-color: var(--bg-1) !important;
  }

  .agents-hero-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    text-align: center;
  }

  .agents-hero-cta {
    display: flex;
    justify-content: center;
  }

  .agents-hero :global(.hero-title-small) {
    font-size: 54px;
    font-weight: 400;
  }

  @media (max-width: 767px) {
    .agents-hero {
      padding-bottom: 2rem;
    }
  }
</style>
