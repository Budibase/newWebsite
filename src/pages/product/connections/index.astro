---

<Layout title={pageTitle} description={pageDescription}>
  <PlatformLayout title={pageTitle} description={pageDescription}>
    <Fragment slot="header">
      <div class="mx-auto w-full max-w-3xl">
        <h1
          class="hero-title mb-2 leading-[0.9]! tracking-[-0.02em]! text-[var(--text-primary)]"
        >
          {pageTitle}
        </h1>
        <p class="mx-auto max-w-xl !mb-4 !text-xl text-secondary">
          {pageDescription}
        </p>

        <section class="mx-auto mt-8 w-full max-w-2xl">
          <div
            class="rounded-[10px] border border-[var(--border-color)] bg-[var(--bg-2)] p-4 md:p-5"
          >
            <label for="connections-search" class="sr-only">
              Search connectors
            </label>
            <div class="relative">
              <input
                id="connections-search"
                type="search"
                placeholder="Search connectors..."
                autocomplete="off"
                data-connector-search
                class="h-11 w-full rounded-[8px] border border-[var(--border-color)] bg-[var(--bg-1)] px-3 pr-11 text-base text-[var(--text-primary)] outline-none placeholder:text-[var(--text-secondary)] focus-visible:ring-4 focus-visible:ring-[rgb(var(--ring)_/_0.5)]"
              />
              <button
                type="button"
                data-connector-search-clear
                aria-label="Clear search"
                hidden
                class="absolute right-2 top-1/2 inline-flex h-7 w-7 -translate-y-1/2 items-center justify-center rounded-md text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)] focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[rgb(var(--ring)_/_0.5)]"
              >
                <svg
                  viewBox="0 0 16 16"
                  aria-hidden="true"
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                >
                  <path d="M4 4l8 8" />
                  <path d="M12 4 4 12" />
                </svg>
              </button>
            </div>
          </div>
        </section>
      </div>
    </Fragment>

    <div class="mb-8 space-y-8" data-connections-results>
      <!-- AI model providers -->
      <section data-connector-section>
        <h2 class="text-lg! text-stone-700!  mb-4">
          AI model providers
        </h2>
        <div
