<script is:inline>
  (() => {
    const initConnectionsSearch = () => {
      const searchInput = document.querySelector("[data-connector-search]");
      const clearButton = document.querySelector(
        "[data-connector-search-clear]",
      );
      const emptyState = document.querySelector("[data-connector-empty]");
      const sections = Array.from(
        document.querySelectorAll("[data-connector-section]"),
      );

      if (
        !(searchInput instanceof HTMLInputElement) ||
        !(emptyState instanceof HTMLElement)
      ) {
        return;
      }

      if (searchInput.dataset.connectorSearchReady === "true") {
        return;
      }
      searchInput.dataset.connectorSearchReady = "true";

      sections.forEach((section) => {
        if (!(section instanceof HTMLElement)) return;
        const cards = Array.from(section.querySelectorAll(".integration-card"));
        cards.forEach((card) => {
          if (!(card instanceof HTMLElement)) return;
          const name =
            card.querySelector("h3")?.textContent?.trim().toLowerCase() ?? "";
          card.dataset.connectorCard = "true";
          card.dataset.connectorName = name;
        });
      });

      const applyFilters = () => {
        const query = searchInput.value.trim().toLowerCase();

        if (clearButton instanceof HTMLButtonElement) {
          clearButton.hidden = query.length === 0;
        }

        let visibleCount = 0;

        sections.forEach((section) => {
          if (!(section instanceof HTMLElement)) return;
          let sectionVisibleCount = 0;

          const cards = Array.from(
            section.querySelectorAll("[data-connector-card]"),
          );
          cards.forEach((card) => {
            if (!(card instanceof HTMLElement)) return;
            const name = card.dataset.connectorName ?? "";
            const isVisible = query.length === 0 || name.includes(query);
            card.hidden = !isVisible;
            if (isVisible) sectionVisibleCount += 1;
          });

          section.hidden = sectionVisibleCount === 0;
          visibleCount += sectionVisibleCount;
        });

        emptyState.hidden = visibleCount > 0;
      };

      searchInput.addEventListener("input", applyFilters);

      if (clearButton instanceof HTMLButtonElement) {
        clearButton.addEventListener("click", () => {
          searchInput.value = "";
          searchInput.focus();
          applyFilters();
        });
      }

      applyFilters();
    };

    initConnectionsSearch();
    document.addEventListener("astro:after-swap", initConnectionsSearch);
  })();
</script>

