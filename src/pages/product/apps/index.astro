---
import Layout from "../../../layouts/MainLayout.astro";
import PlatformLayout from "@components/PlatformLayout.astro";
import { getProductPageMeta } from "../_pageMeta";
import HeroBg from "@assets/images/apps/apps hero.png";
import { Image } from "astro:assets";
import Card from "@components/cards/Card.astro";

const { title: pageTitle, description: pageDescription } = getProductPageMeta(
  Astro.url.pathname,
);
---

<Layout title={pageTitle} description={pageDescription}>
  <PlatformLayout title={pageTitle} description={pageDescription}>
    <div class="mb-8">
      <div class="bg-stone-100 dark:bg-stone-900 rounded-md p-4 mb-4">
        <Image
          src={HeroBg}
          alt="Apps builder"
          class="w-full h-96 object-cover rounded-md"
        />
      </div>

      <section class="mt-16 mb-8">
        <h2 class="text-primary text-center mb-4">
          Give teams intuitive tools for daily operations.
        </h2>
        <div
          class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 md:gap-2"
        >
          <Card
            label="Operational tools for real work"
            description="Build structured internal apps for tasks, approvals, and process management."
            imagePlaceholderColor="var(--orange-950)"
          />
          <Card
            label="Fast to ship, easy to adapt"
            description="Launch production-ready tools quickly and evolve them as processes change."
            imagePlaceholderColor="var(--orange-950)"
          />
          <Card
            label="Built-in governance"
            description="Control access, permissions, and data visibility across every app."
            imagePlaceholderColor="var(--orange-950)"
          />
          <Card
            label="Drag-and-drop UI builder"
            description="Build operational interfaces quickly with a visual app builder."
          />
          <Card
            label="Generate apps from data with 1 click"
            description="Turn Data Tables and external databases into working apps instantly."
          />
          <Card
            label="Custom roles and permissions"
            description="Control who can view, edit, and operate each part of your app."
          />
          <Card
            label="Responsive layouts"
            description="Create app experiences that work across desktop and mobile screens."
          />
          <Card
            label="Reusable components and theming"
            description="Standardize UI patterns with reusable components and shared themes."
          />
          <Card
            label="Embed workflows and operational actions"
            description="Run workflows and operational actions directly inside your app experiences."
          />
        </div>
      </section>
    </div>
  </PlatformLayout>
</Layout>
