---
import Layout from "../../../layouts/MainLayout.astro";
import PlatformLayout from "@components/PlatformLayout.astro";
import { platformNavItemsData } from "../_navItems";
import Circles from "phosphor-astro/Nut.astro";
import Memory from "phosphor-astro/Memory.astro";
import ChatCircle from "phosphor-astro/ChatCircle.astro";
import Path from "phosphor-astro/PathFill.astro";
import Browsers from "phosphor-astro/Browsers.astro";
import Link from "phosphor-astro/Cube.astro";
import Webhooks from "phosphor-astro/WebhooksLogo.astro";
import Database from "phosphor-astro/GridNine.astro";
import Sparkle from "phosphor-astro/Sparkle.astro";
import Cloud from "phosphor-astro/Cloud.astro";
import TrendUp from "phosphor-astro/TrendUp.astro";
import AutomationImage from "@assets/images/platform/AgentInAutomations.png";
import HeroBg from "@assets/images/homepage/valley.png";
import { Image } from "astro:assets";
import Card from "@components/cards/Card.astro";

const iconMap: Record<string, any> = {
	Circles,
	Memory,
	ChatCircle,
	Path,
	Browsers,
	Link,
	Webhooks,
	Database,
	Sparkle,
	Cloud,
	TrendUp,
};

const navItems = platformNavItemsData.map(group => ({
	...group,
	items: group.items.map(item => ({
		...item,
		icon: iconMap[item.iconName],
	})),
}));
const currentNavItem = platformNavItemsData
	.flatMap(group => group.items)
	.find(item => item.link === Astro.url.pathname || `${item.link}/` === Astro.url.pathname);
const pageTitle = currentNavItem?.pageTitle ?? "Product";
const pageDescription =
	currentNavItem?.pageDescription ??
	"The privacy-first platform for building agents, chat, automations & apps.";
---

<Layout title={pageTitle} description={pageDescription}>
	<PlatformLayout
		title={pageTitle}
		description={pageDescription}
		mainContentWidth="narrow"
		{navItems}
	>
		<div class="mb-8">
			<div class="bg-stone-100 dark:bg-stone-900 rounded-md p-4 mb-4">
				<Image
					src={AutomationImage}
					alt="Automations workflows"
					class="w-full h-96 object-cover rounded-md"
				/>
			</div>

			<div
				class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 md:gap-2"
			>
				<Card
					label="Visual builder"
					description="Design workflows visually with drag-and-drop nodes and connections."
				/>
				<Card
					label="100s of connectors"
					description="Integrate with the tools you already use, out of the box."
				/>
				<Card
					label="AI workflows"
					description="Blend deterministic logic with AI reasoning in the same workflow."
				/>
				<Card
					label="Agent integration"
					description="Trigger agents from within automations and allow them to take actions."
				/>
				<Card
					label="Triggers"
					description="Start workflows with webhooks, schedules, database changes, or manual triggers."
				/>
				<Card
					label="Add code (JS / Script support)"
					description="Drop into code when you need full control — without leaving the flow."
				/>
				<Card
					label="Logs"
					description="See exactly what happened, when, and why with detailed execution logs."
				/>
				<Card
					label="Branching / Looping"
					description="Model real-world processes with conditional paths and loops."
				/>
			</div>
		</div>
	</PlatformLayout>
</Layout>
