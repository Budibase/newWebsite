---
import Layout from "../../../layouts/MainLayout.astro";
import CTA from "@components/CTA.astro";
import Button from "@components/Button.astro";
import { getProductPageMeta } from "../_pageMeta";
import AutomationDemo from "@components/AutomationDemo.astro";
import Card from "@components/cards/Card.astro";

const { description: pageMetaDescription } = getProductPageMeta(
  Astro.url.pathname,
);
const pageTitle = "Orchestrate AI agents across your operations.";
const pageDescription =
  "Agents can trigger automations, collaborate inside them, and execute controlled changes - from approvals and support to reporting and system updates - all with full visibility.";
---

<Layout title={pageTitle} description={pageMetaDescription}>
  <section class="automations-hero">
    <div class="mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0">
      <div class="automations-hero-grid">
        <div class="automations-hero-copy max-w-xl">
          <h1
            class="hero-title-small mb-4 w-full leading-[0.9]! tracking-[-0.02em]!"
          >
            <span class="block text-primary">Orchestrate AI agents</span>
            <span class="block text-secondary">across your operations.</span>
          </h1>
        </div>

        <div class="automations-hero-description max-w-xl">
          <p class="m-0 mx-auto max-w-xl text-base text-[var(--text-secondary)] md:text-xl !mb-4 !text-xl text-secondary">
            {pageDescription}
          </p>
        </div>

        <div class="automations-hero-cta">
          <Button
            label="Try for free"
            url="https://account.budibase.app/register"
            variant="primary"
            size="large"
            target="_blank"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-7xl px-2 pb-12 pt-6 md:px-3 lg:px-0">
    <div class="mb-8">
      <div class="mb-4">
        <AutomationDemo />
      </div>

      <section class="mt-16 mb-8">
        <h2 class="text-primary text-center mb-4">
          Run operations faster with fewer manual steps.
        </h2>
        <div
          class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 md:gap-2"
        >
          <Card
            label="Orchestrate operational processes"
            description="Design multi-step workflows that connect systems, approvals, and logic."
            imagePlaceholderColor="var(--purple-900)"
          />
          <Card
            label="Power agent execution"
            description="Give agents structured steps and controlled system access to complete work safely."
            imagePlaceholderColor="var(--purple-900)"
          />
          <Card
            label="Triggered by real events"
            description="Launch workflows from data changes, user actions, schedules, or webhooks."
            imagePlaceholderColor="var(--purple-900)"
          />
          <Card
            label="Visual workflow builder"
            description="Design operational workflows with a visual drag-and-drop builder."
          />
          <Card
            label="Event, webhook, and schedule triggers"
            description="Start workflows from events, incoming webhooks, or scheduled runs."
          />
          <Card
            label="Conditional logic and branching"
            description="Route execution with conditions, branching paths, and dynamic outcomes."
          />
          <Card
            label="Third-party API steps"
            description="Call external APIs as workflow steps to sync and update systems."
          />
          <Card
            label="Agent-triggered workflow steps"
            description="Invoke agents within workflows to handle reasoning-driven actions."
          />
          <Card
            label="Execution logs and run history"
            description="Track every run with detailed logs and execution history."
          />
        </div>
      </section>
    </div>
  </section>

  <CTA />
</Layout>

<style>
  .automations-hero {
    background: var(--bg-1);
    padding-top: max(calc(var(--site-nav-height) + 1.2rem), 4.8rem);
    padding-bottom: 3rem;
  }

  :global(#site-nav.nav-shell) {
    background-color: var(--bg-1) !important;
  }

  .automations-hero-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    text-align: center;
  }

  .automations-hero-cta {
    display: flex;
    justify-content: center;
  }

  .automations-hero :global(.hero-title-small) {
    font-size: 54px;
    font-weight: 400;
  }

  @media (max-width: 767px) {
    .automations-hero {
      padding-bottom: 2rem;
    }

  }
</style>
