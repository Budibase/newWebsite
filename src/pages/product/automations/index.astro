---
import Layout from "../../../layouts/MainLayout.astro";
import CTA from "@components/CTA.astro";
import Button from "@components/Button.astro";
import { getProductPageMeta } from "../_pageMeta";
import AutomationDemo from "@components/AutomationDemo.astro";
import AutomationTriggerOutcomeSection from "@components/AutomationTriggerOutcomeSection.astro";
import Card from "@components/cards/Card.astro";
import TitleBlock from "@components/TitleBlock.astro";
import SectionBlock from "@components/SectionBlock.astro";
import AutomationTestDemo from "@components/AutomationTestDemo.astro";
import AutomationDataFlow from "@components/AutomationDataFlow.astro";
import AutomationLogsDemo from "@components/AutomationLogsDemo.astro";
import AutomationLogicActionsSection from "@components/AutomationLogicActionsSection.astro";
import ContactSalesCTA from "@components/ContactSalesCTA.astro";

const { description: pageMetaDescription } = getProductPageMeta(
  Astro.url.pathname,
);
const pageTitle = "Automate operations with any data, LLM, or API";
const pageDescription =
  "Build advanced logic that can be triggered by AI Agents, in-app actions, system events, WebHooks, and more.";
---

<Layout title={pageTitle} description={pageMetaDescription}>
  <section class="automations-hero">
    <div class="mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0">
      <div class="automations-hero-grid">
        <div class="automations-hero-copy max-w-xl">
          <TitleBlock
            variant="hero"
            titleColorMode="split-primary-secondary"
            titleLines={[
              { text: "Automate workflows" },
              { text: "with any data, LLM, or REST API" },
            ]}
            titleClass="mb-4 w-full leading-[0.9]! tracking-[-0.02em]!"
          />
          <p class="hero-description-small mx-auto max-w-xl text-base md:!text-xl !mb-4">
            {pageDescription}
          </p>
        </div>

        <div class="automations-hero-cta">
          <Button
            label="Try for free"
            url="https://account.budibase.app/register"
            variant="primary"
            size="large"
            target="_blank"
          />
          <Button
            label="Contact sales"
            url="/contact/"
            variant="secondary"
            size="large"
            class="px-6 py-3 text-xl md:px-7 md:py-3.5 md:text-xl ml-5"
            target="_blank"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-7xl px-2 pt-6 md:px-3 lg:px-0">
    <div class="flex flex-col gap-[var(--section-spacing-y)]">
      <div class="flex flex-col gap-[var(--section-gap-lg)]">
        <AutomationDemo />
        <AutomationTriggerOutcomeSection />
      </div>
    </div>
  </section>

  



  <section class="mx-auto w-full max-w-7xl px-2 pb-12 pt-16 md:px-3 lg:px-0">
    <SectionBlock
      align="center"
      maxWidth="3xl"
      titleColorMode="split-secondary-primary"
      titleLines={[
        { text: "Full visibility into" },
        { text: "every decision and action." },
      ]}
      description="Automations don’t just run - they’re fully observable. Test workflows before going live, inspect data at every step, and track every decision agents make."
      descriptionClass="mx-auto max-w-lg text-lg!"
      contentClass="grid grid-cols-1 gap-4 sm:grid-cols-2 md:gap-2 lg:grid-cols-3"
    >
      <Card
        label="Run tests before going live"
        description="Simulate triggers and verify outcomes instantly."
      >
        <div slot="image-overlay" class="automation-test-card-overlay">
          <AutomationTestDemo />
        </div>
      </Card>

      <Card
        label="Inspect data at every step"
        description="See exactly what went in and what came out."
      >
        <div slot="image-overlay" class="automation-data-flow-card-overlay">
          <AutomationDataFlow />
        </div>
      </Card>

      <Card
        label="Automation logs & run history"
        description="Track every execution with full traceability."
      >
        <div slot="image-overlay" class="automation-logs-card-overlay">
          <AutomationLogsDemo />
        </div>
      </Card>
    </SectionBlock>
  </section>
<ContactSalesCTA />
  <section class="mx-auto w-full max-w-7xl px-2 pb-12 pt-6 md:px-3 lg:px-0">
    <div class="flex flex-col gap-[var(--section-spacing-y)]">
      <AutomationLogicActionsSection />
    </div>
  </section>

  <CTA />
</Layout>

<style>
  .automations-hero {
    background: var(--bg-1);
    padding-top: max(calc(var(--site-nav-height) + 1.2rem), 4.8rem);
    padding-bottom: 3rem;
  }

  :global(#site-nav.nav-shell) {
    background-color: var(--bg-1) !important;
  }

  .automations-hero-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    text-align: center;
  }

  .automations-hero-cta {
    display: flex;
    justify-content: center;
  }

  .automations-hero :global(.hero-title-small) {
    font-size: 54px;
    font-weight: 400;
  }

  @media (max-width: 767px) {
    .automations-hero {
      padding-bottom: 2rem;
    }
  }

  .automation-test-card-overlay,
  .automation-data-flow-card-overlay,
  .automation-logs-card-overlay {
    width: 100%;
    height: 350px;
    padding: 28px;
    background-color: var(--bb-blue-800);
    border-radius: 6px;
    pointer-events: auto;
  }
</style>
