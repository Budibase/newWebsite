---
import { BLOG_CATEGORY_ITEMS, type BlogCategory } from "../_feed";

interface Props {
  currentCategory?: BlogCategory;
  title?: string;
}

const { currentCategory = "all", title = "Blog" } = Astro.props as Props;
---

<aside class="categories-sidebar">
  <h1 class="mb-4 h2">{title}</h1>
  <nav aria-label="Blog categories">
    <ul class="nav-list">
      {
        BLOG_CATEGORY_ITEMS.map((category) => (
          <li>
            <a
              href={category.id === "all"
                ? "/blog"
                : `/blog/category/${category.id}`}
              class:list={[
                "nav-link flex h-8 items-center rounded px-2 text-sm text-primary hover:text-primary dark:text-primary dark:hover:text-primary",
                currentCategory === category.id && "active",
              ]}
              aria-current={currentCategory === category.id ? "page" : undefined}
              data-astro-prefetch
              data-astro-transition="none"
            >
              <span>{category.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>

<style>
  .categories-sidebar {
    width: 100%;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .nav-link.active {
    background-color: var(--color-stone-100);
    color: var(--color-blue-700);
  }

  .dark .nav-link.active {
    background-color: var(--color-stone-800);
    color: var(--color-blue-200);
  }

  @media (max-width: 768px) {
    .nav-list {
      flex-direction: row;
      overflow-x: auto;
      gap: 0.5rem;
      padding-bottom: 0.25rem;
    }

    .nav-link {
      white-space: nowrap;
    }
  }
</style>
