---
import Icon from "@components/Icon.astro";

interface Props {
	currentCategory?: string;
	title?: string;
	description?: string;
	showHeader?: boolean;
	links?: Array<{
		label: string;
		description: string;
		href: string;
		target?: string;
		rel?: string;
		prefetch?: boolean;
	}>;
	activeHref?: string;
}

const {
	currentCategory = 'all',
	title = 'Blog',
	description = '',
	showHeader = true,
	links,
	activeHref,
} = Astro.props;
const currentPath = Astro.url.pathname;

const categories = [
	{ id: 'all', label: 'All posts' },
	{ id: 'news', label: 'News' },
	{ id: 'product', label: 'Product' },
	{ id: 'customers', label: 'Customers' },
	{ id: 'research', label: 'Research' },
];

const isLearnLinks = Array.isArray(links) && links.length > 0;

function isLearnActive(link: string): boolean {
	if (activeHref) {
		return activeHref === link;
	}
	return currentPath === link || currentPath === `${link}/`;
}
---

<aside class="categories-sidebar">
	{showHeader && (
		<>
			<h1 class:list={[isLearnLinks ? "mb-2 text-xl!" : "mb-4 h2"]}>{title}</h1>
			{description && <p class="text-stone-500!  mb-4!">{description}</p>}
		</>
	)}
	<nav>
		<ul class:list={["nav-list", isLearnLinks && "learn-list"]}>
			{isLearnLinks
				? links!.map((item) => {
						const showDocsExternalIcon =
							item.label === "Docs" && item.href === "https://docs.budibase.com";

						return (
						<li>
							<a
								href={item.href}
								target={item.target}
								rel={item.rel}
								data-astro-prefetch={item.prefetch ? '' : undefined}
								aria-current={isLearnActive(item.href) ? "page" : undefined}
								class:list={[
									"nav-link flex flex-row gap-3 items-center h-8 px-3 rounded-md text-primary  hover:text-primary  hover:bg-stone-100  [&.active]:text-sky-700  [&.active:hover]:text-sky-600  [&.active]:bg-stone-100  text-sm",
									isLearnActive(item.href) && "active"
								]}
							>
								<span class="inline-flex items-center gap-1.5">
									{item.label}
									{showDocsExternalIcon && (
										<span class="inline-flex text-gray-600 ">
											<Icon name="ArrowUpRight" class="w-3.5 h-3.5 text-current" />
										</span>
									)}
								</span>
							</a>
						</li>
					);
					})
				: categories.map((category) => (
						<li>
							<a
								href={category.id === 'all' ? '/blog' : `/blog/category/${category.id}`}
								class:list={[
									"nav-link flex flex-row items-center h-8 px-2 rounded text-primary  hover:text-primary  [&.active]:text-sky-700  [&.active:hover]:text-sky-600  [&.active]:bg-stone-100  text-sm",
									currentCategory === category.id && "active",
								]}
								data-astro-prefetch
								data-astro-transition="none"
							>
								<span>{category.label}</span>
							</a>
						</li>
					))}
		</ul>
	</nav>
</aside>

<style>
	.categories-sidebar {
		width: 100%;
	}

	.nav-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
	}


	@media (max-width: 768px) {
		.nav-list {
			flex-direction: row;
			overflow-x: auto;
		}

		.nav-link {
			white-space: nowrap;
		}

		.learn-list {
			flex-direction: column;
			overflow-x: visible;
		}
	}
</style>
