---
interface Props {
	currentCategory?: string;
	title?: string;
	description?: string;
}

const { currentCategory = 'all', title = 'Blog', description = '' } = Astro.props;

const categories = [
	{ id: 'all', label: 'All posts' },
	{ id: 'Changelog', label: 'Changelog' },
	{ id: 'tutorials', label: 'Tutorials' },
	{ id: 'ai-agents', label: 'AI Agents' },
	{ id: 'guests', label: 'Guests' },
];
---

<aside class="categories-sidebar">
	<h1 class="mb-4 h2">{title}</h1>
	{description && <p class="text-stone-500! dark:text-stone-400! mb-4!">{description}</p>}
	<nav>
		<ul>
			{
				categories.map((category) => (
					<li>
						<a
							href={category.id === 'all' ? '/blog' : `/blog/category/${category.id}`}
							class:list={[
								"nav-link flex flex-row items-center h-8 px-2 rounded text-stone-600 dark:text-stone-500 hover:text-stone-900 dark:hover:text-stone-100 [&.active]:text-stone-900 [&.active]:dark:text-stone-100 [&.active]:bg-stone-100 dark:[&.active]:bg-stone-800 text-sm",
								currentCategory === category.id && "active"
							]}
							data-astro-prefetch
							data-astro-transition="none"
						>
							<span>{category.label}</span>
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</aside>

<style>
	.categories-sidebar {
		position: sticky;
		top: 2rem;
		width: 280px;
	}

	.nav-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
	}


	@media (max-width: 768px) {
		.categories-sidebar {
			position: static;
		}

		.nav-list {
			flex-direction: row;
			overflow-x: auto;
		}

		.nav-link {
			white-space: nowrap;
		}
	}
</style>
