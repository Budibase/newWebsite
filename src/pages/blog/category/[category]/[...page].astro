---
import type { GetStaticPathsOptions, Page } from "astro";
import Pagination from "../../../../components/Pagination.astro";
import Layout from "../../../../layouts/MainLayout.astro";
import BlogTimelineRow from "../../../blog/_components/BlogTimelineRow.astro";
import BlogFilterPills from "../../../blog/_components/BlogFilterPills.astro";
import BlogTopicPills from "../../../blog/_components/BlogTopicPills.astro";
import {
  BLOG_TOPIC_ITEMS,
  filterBlogFeedByTopic,
  getBlogFeedItems,
  isValidBlogTopic,
  type BlogTopicRoute,
  type BlogFeedItem,
} from "../../../blog/_feed";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const items = await getBlogFeedItems();
  return BLOG_TOPIC_ITEMS.flatMap((category) =>
    paginate(filterBlogFeedByTopic(items, category.id), {
      pageSize: 12,
      params: { category: category.id },
    }),
  );
}

interface Props {
  page: Page<BlogFeedItem>;
}

const { page } = Astro.props as Props;
const rawCategory = Astro.params.category ?? "blog";
const category: BlogTopicRoute = isValidBlogTopic(rawCategory)
  ? rawCategory
  : "blog";

const currentCategoryLabel =
  BLOG_TOPIC_ITEMS.find((item) => item.id === category)?.label ?? "All blog";
const activePill = "blog";
const allPages = [...Array(page.lastPage).keys()].map((num) => {
  return `/blog/category/${category}${num === 0 ? "" : `/${String(num + 1)}`}`;
});
---

<Layout
  title={`Blog / ${currentCategoryLabel}`}
  description="Product updates, customer stories, and workflow guides from Budibase."
  image={{ src: "/og/blog.jpg", alt: "What's new in the Budibase ecosystem" }}
>
  <div
    class="mx-auto mt-[clamp(5.6rem,8vw,7.2rem)] w-full max-w-[62rem] px-4 pb-16 max-md:mt-[max(calc(var(--site-nav-height)+1.1rem),4.8rem)] max-md:px-[0.9rem]"
  >
    <header class="mb-[1.4rem] grid gap-6 max-md:mb-4 max-md:gap-5">
      <h1
        class="hero-title m-0 font-['Fraunces'] text-[clamp(2.8rem,2.3rem+2vw,4.75rem)] leading-[0.9] tracking-[-0.02em] text-[var(--text-primary)]"
      >
        Blog
      </h1>
      <BlogFilterPills context="blog" activePill={activePill} />
      <BlogTopicPills activeTopic={category} />
    </header>

    <main class="min-h-[60vh]">
      {
        page.data.length === 0 ? (
          <section class="rounded-[10px] border border-[var(--border-color)] bg-[var(--bg-2)] p-4">
            <p class="m-0 text-[var(--text-secondary)]">
              No posts available for {currentCategoryLabel.toLowerCase()} yet.
            </p>
          </section>
        ) : (
          <ul class="m-0 flex list-none flex-col p-0">
            {page.data.map((item, index) => (
              <li>
                <BlogTimelineRow
                  item={item}
                  showConnector={index < page.data.length - 1}
                />
              </li>
            ))}
          </ul>
        )
      }

      <div class="mt-4 w-full">
        <Pagination restRoute allPages={allPages} page={page} />
      </div>
    </main>
  </div>
</Layout>
