---
import BookACallButton from "../../components/BookACallButton.astro";
import Layout from "../../layouts/MainLayout.astro";

const pageTitle = "Contact us";
const pageDescription = "Let's explore how Budibase can work for you.";
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="contact-page">
    <div class="contact-shell">
      <div class="contact-grid">
        <div class="contact-copy">
          <h1 class="contact-title">Contact us</h1>
          <p class="contact-lede">
            Let's explore how Budibase can work for you.
          </p>

          <div id="book-a-call" class="py-3">
            <BookACallButton
              label="Book a call with our sales team"
              url="#book-a-call"
              variant="cta"
              size="large"
              class="contact-book-link"
            />
          </div>

          <div class="contact-topics" aria-label="Reasons to speak to sales">
            <article class="contact-topic">
              <div class="contact-topic__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path
                    d="M4.75 6.75A2.75 2.75 0 0 1 7.5 4h9A2.75 2.75 0 0 1 19.25 6.75v6.5A2.75 2.75 0 0 1 16.5 16H10.6l-3.9 3.25V16H7.5a2.75 2.75 0 0 1-2.75-2.75z"
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.8"></path>
                </svg>
              </div>
              <div class="contact-topic__body">
                <h2>Discuss pricing</h2>
                <p>
                  Our sales team will talk you through our pricing and how to
                  get the most value out of Budibase.
                </p>
              </div>
            </article>

            <article class="contact-topic">
              <div class="contact-topic__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <rect
                    x="4.75"
                    y="4.75"
                    width="14.5"
                    height="14.5"
                    rx="2.25"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"></rect>
                  <path
                    d="M12 5.5v13M5.5 12h13"
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-width="1.8"></path>
                </svg>
              </div>
              <div class="contact-topic__body">
                <h2>See Budibase in action</h2>
                <p>
                  Get an overview of Budibase's capabilities, or talk through a
                  specific scenario.
                </p>
              </div>
            </article>

            <article class="contact-topic">
              <div class="contact-topic__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path
                    d="M7 5.5 17 12 7 18.5z"
                    fill="none"
                    stroke="currentColor"
                    stroke-linejoin="round"
                    stroke-width="1.8"></path>
                </svg>
              </div>
              <div class="contact-topic__body">
                <h2>Start a trial</h2>
                <p>
                  If required, our team can offer you a free trial. We'll touch
                  base with you during and at the end of your trial.
                </p>
              </div>
            </article>
          </div>

          <p class="contact-support">
            Looking for support?
            <a href="/support">Visit our support policy</a>
            or
            <a href="https://docs.budibase.com">open the docs</a>
          </p>
        </div>

        <div class="contact-form-column">
          <form
            class="contact-form"
            name="contact-sales"
            method="post"
            data-netlify="true"
            netlify-honeypot="bot-field"
          >
            <p class="contact-form__honeypot">
              <label>
                Don't fill this out if you're human:
                <input name="bot-field" type="text" tabindex="-1" />
              </label>
            </p>

            <label class="contact-field">
              <span>First Name</span>
              <input type="text" name="first_name" autocomplete="given-name" />
            </label>

            <label class="contact-field">
              <span>Last Name</span>
              <input type="text" name="last_name" autocomplete="family-name" />
            </label>

            <label class="contact-field">
              <span>Email Address</span>
              <input type="email" name="email" autocomplete="email" />
            </label>

            <label class="contact-field">
              <span>Company Name</span>
              <input
                type="text"
                name="company_name"
                autocomplete="organization"
              />
            </label>

            <label class="contact-field">
              <span>Message</span>
              <textarea name="message"></textarea>
            </label>

            <button type="submit" class="contact-submit">Submit</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-page {
    background: rgb(var(--bg));
    color: rgb(var(--text));
  }

  .contact-shell {
    width: min(100%, 1240px);
    margin: 0 auto;
    padding: clamp(2rem, 3vw, 2.75rem) 1rem clamp(3.5rem, 6vw, 5rem);
  }

  .contact-grid {
    display: grid;
    gap: clamp(2.75rem, 5vw, 6rem);
    align-items: start;
  }

  .contact-title {
    margin: 0;
    color: rgb(var(--text));
    font-size: clamp(3.5rem, 7vw, 4.6rem);
    line-height: 0.96;
    letter-spacing: -0.05em;
    font-weight: 700;
  }

  .contact-lede {
    margin: 1.75rem 0 0;
    max-width: 28rem;
    color: rgb(var(--text));
    font-size: clamp(1.25rem, 2vw, 1.45rem);
    line-height: 1.35;
  }

  .contact-topics {
    margin-top: 2.25rem;
    border: 1px solid rgb(var(--border) / 0.4);
    border-radius: 1rem;
    background: rgb(var(--surface) / 0.52);
    overflow: hidden;
  }

  .contact-topic {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    padding: 1.7rem 1.65rem;
  }

  .contact-topic + .contact-topic {
    border-top: 1px solid rgb(var(--border) / 0.22);
  }

  .contact-topic__icon {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    color: rgb(var(--text));
  }

  .contact-topic__icon svg {
    width: 1.95rem;
    height: 1.95rem;
  }

  .contact-topic__body h2 {
    margin: 0;
    color: rgb(var(--text));
    font-size: clamp(1.05rem, 1.5vw, 1.15rem);
    line-height: 1.2;
    font-weight: 700;
  }

  .contact-topic__body p {
    margin: 0.6rem 0 0;
    max-width: 31rem;
    color: rgb(var(--text));
    font-size: 1rem;
    line-height: 1.45;
  }

  .contact-support {
    margin: 1.5rem 0 0;
    color: rgb(var(--text));
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.5;
  }

  .contact-support a {
    color: inherit;
    font-weight: 700;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
  }

  .contact-support a:hover,
  .contact-support a:focus-visible {
    text-decoration-thickness: 2px;
  }

  .contact-form-column {
    padding-top: 0.35rem;
  }

  .contact-field input:focus-visible,
  .contact-field textarea:focus-visible,
  .contact-submit:focus-visible {
    outline: 2px solid rgb(var(--ring));
    outline-offset: 3px;
  }

  .contact-form {
    margin-top: 0;
  }

  .contact-form__honeypot {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .contact-field {
    display: grid;
    gap: 0.65rem;
    margin: 0;
  }

  .contact-field + .contact-field {
    margin-top: 1.55rem;
  }

  .contact-field span {
    color: rgb(var(--text));
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .contact-field input,
  .contact-field textarea {
    width: 100%;
    border: 1px solid rgb(var(--border) / 0.92);
    border-radius: 0.55rem;
    background: transparent;
    color: rgb(var(--text));
    font: inherit;
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      background-color 150ms ease;
  }

  .contact-field input {
    min-height: 3.1rem;
    padding: 0 0.95rem;
  }

  .contact-field textarea {
    min-height: 10.6rem;
    resize: vertical;
    padding: 0.9rem 0.95rem;
  }

  .contact-field input:hover,
  .contact-field textarea:hover {
    border-color: rgb(var(--border-strong) / 0.9);
  }

  .contact-field input::placeholder,
  .contact-field textarea::placeholder {
    color: rgb(var(--text-subtle));
  }

  .contact-submit {
    margin-top: 2.2rem;
    border: 0;
    border-radius: 999px;
    background: rgb(var(--text));
    color: rgb(var(--bg));
    min-height: 3.35rem;
    padding: 0 1.45rem;
    font: inherit;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      transform 150ms ease,
      opacity 150ms ease;
  }

  .contact-submit:hover {
    transform: translateY(-1px);
    opacity: 0.94;
  }

  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr);
    }

    .contact-form-column {
      padding-top: 0.9rem;
    }
  }

  @media (max-width: 767px) {
    .contact-shell {
      padding-left: 0.9rem;
      padding-right: 0.9rem;
    }

    .contact-title {
      letter-spacing: -0.04em;
    }

    .contact-topic {
      padding: 1.35rem 1.2rem;
    }

    .contact-form {
      margin-top: 0;
    }
  }
</style>
