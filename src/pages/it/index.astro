---
export const prerender = false;

import Layout from "../../layouts/MainLayout.astro";
import TitleBlock from "@components/TitleBlock.astro";
import Button from "@components/Button.astro";
import ITPlatform from "../_components/landing-page/ITPlatform.astro";
import ITSecurity from "../_components/landing-page/ITSecurity.astro";
import CTA from "@components/CTA.astro";
import ContactSalesCTA from "@components/ContactSalesCTA.astro";
import Customers from "../_components/landing-page/Customers.astro";
import PlatformOverviewMidPage from "../_components/landing-page/PlatformOverviewMidPage.astro";
import ITUseCases from "../_components/landing-page/ITUseCases.astro";
import HostingOptionsMidPage from "../_components/landing-page/HostingOptionsMidPage.astro";
import ChatRequestsMidPage from "../_components/landing-page/ChatRequestsMidPage.astro";

const pageTitle = "AI Workflows for IT Teams | Budibase";
const pageDescription =
  "Budibase is fully optimized for modern IT teams. Transform internal operations without compromising on security, governance, and control.";

const accept = Astro.request.headers.get("accept") ?? "";
Astro.response.headers.set("Vary", "Accept");

if (accept.includes("text/markdown")) {
  return new Response(
    `# The AI workflow platform for IT teams

Budibase is fully optimized for modern IT teams. Transform internal operations without compromising on security, governance, and control.


## Trust Budibase to power mission-critical workflows

IT teams in all kinds of teams trust Budibase to build Agents, Apps, and Automations that they can connect to mission-critical systems and deploy anywhere.

- Open-source, with optional self-hosting and a cloud-based platform
- Connect securely to data sources, LLMs, and REST APIs
- Out-of-the-box audit logging, auth, user management, and more

## One platform for Agents, Apps & Automations

Build AI-powered or human-centered workflows that connect to your data, LLMs, or REST APIs and deploy anywhere.

### Agents

Answer employee questions and handle requests across multiple channels.

### Apps

Create internal tools for teams to manage processes and track work.

### Tables

Connect your databases, spreadsheets, and business systems.

### Automations

Run approvals, routing, notifications, and operational workflows automatically.

## Built for modern IT workflows

Thousands of IT teams choose Budibase to handle approvals, request management, operations, service management, ticketing, and other workflows.

## Handle requests where work really happens

Budibase agents help teams handle routine operational work automatically via existing messaging tools. They can understand requests, gather information, and take action across your systems.

- Employee self-service
- Approval requests
- Support triage

## Deploy in the cloud or your own secure environment

Choose Budibase Cloud for a ready-to-use, secure platform to deploy workflow tools without the infrastructure overhead, or self-host for maximum control.

- Budibase servers are hosted within the EU (Ireland) in data centers certified by SOC 1/2 and ISO 27001
- Mandatory HTTPS connections and data encryption in-transit and at-rest
- Self-hosting via Docker, Kubernetes, and more
- Air-gapped deployments

## Production-ready apps and automations

Budibase gives you everything you need to create secure workflows without excessive engineering overhead.

- Open-Source: Deploy on your own infrastructure with complete data sovereignty
- ISO 27001: Enterprise-grade security certifications to meet your compliance requirements
- Made in Europe
- Pen Tests and Audits: Annual penetration tests and AWS security configuration audits from third-party vendors
- RBAC: Tightly control the data and resources users can access
- SSO: Integrate with auth tools including OpenID Connect
- Audit Logs: Comprehensive audit trails for all user actions and system events
- SCIM & AD: Integrate with existing user management tools
- Environment Variables: Securely handle database credentials and API keys across the platform
`,
    {
      headers: {
        "Content-Type": "text/markdown; charset=utf-8",
        "Vary": "Accept",
      },
    }
  );
}
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="security-hero">
    <div class="mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0">
      <div class="security-hero-grid">
        <div class="security-hero-copy">
          <TitleBlock
            variant="hero"
            titleColorMode="split-primary-secondary"
            titleLines={[
              { text: "The AI workflow platform" },
              { text: "for IT teams" },
            ]}
            titleClass="mb-4 w-full leading-[0.9]! tracking-[-0.02em]!"
          />
          <p class="hero-description-small mx-auto max-w-xl text-base md:!text-xl !mb-4">
            {pageDescription}
          </p>
          <div class="platform-hero__cta">
        <Button
          label="Get started"
          url="https://account.budibase.app/register"
          variant="primary"
          size="large"
          class="px-6 py-3 text-xl md:px-7 md:py-3.5 md:text-xl"
          target="_blank"
        />
        <Button
          label="Contact sales"
          url="/contact/"
          variant="secondary"
          size="large"
          class="px-6 py-3 text-xl md:px-7 md:py-3.5 md:text-xl ml-5"
          target="_blank"
        />
      </div>
        </div>
          
      </div>
    </div>
  </section>

    <div class="mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0">
      <div class="security-hero-grid">
        <ITPlatform />
      </div>
    </div>

    <div class="mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0">
      <div class="security-hero-grid">
        <Customers />
      </div>
    </div>

        <div class="mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0">
      <div class="security-hero-grid">
        <PlatformOverviewMidPage />
      </div>
    </div>
 
    <div class="mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0 mt-16">
      <div class="security-hero-grid">
        <ITUseCases />
      </div>
    </div>

     <div class="mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0 mt-16">
      <div class="security-hero-grid">
        <ChatRequestsMidPage />
      </div>
    </div>

    <div class="mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0 mt-8">
      <ContactSalesCTA />
    </div>

         <div class="mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0 mt-8">
      <div class="security-hero-grid">
        <HostingOptionsMidPage />
      </div>
    </div>

    <div class="mx-auto w-full max-w-7xl px-2 md:px-3 lg:px-0 mt-20">
      <div class="security-hero-grid">
        <ITSecurity />
      </div>
    </div>


    <CTA />

</section>
<style>
  .security-hero {
    background: var(--bg-1);
    padding-top: max(calc(var(--site-nav-height) + 1.2rem), 4.8rem);
    padding-bottom: 1.5rem;
  }

    :global(#site-nav.nav-shell) {
    background-color: var(--bg-1) !important;
  }

  .security-hero-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    text-align: center;
  }

  .security-hero-cta {
    display: flex;
    justify-content: center;
  }

  .security-hero :global(.hero-title-small) {
    font-size: 54px;
    font-weight: 400;
    text-align: center;
  }

  @media (max-width: 767px) {
    .security-hero {
      padding-bottom: 2rem;
    }
  }
    .platform-hero__cta {
    display: flex;
    justify-content: center;
  }
  </style>
