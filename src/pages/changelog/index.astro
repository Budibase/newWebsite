---
import Layout from "../../layouts/MainLayout.astro";
import BlogTimelineRow from "../blog/_components/BlogTimelineRow.astro";
import BlogFilterPills from "../blog/_components/BlogFilterPills.astro";
import { filterBlogFeed, getBlogFeedItems } from "../blog/_feed";

const pageTitle = "Changelog";
const pageDescription = "What shipped and what changed.";
const heading = "Changelog";

const entries = filterBlogFeed(await getBlogFeedItems(), "product");
---

<Layout title={pageTitle} description={pageDescription} enableTransitions>
  <div
    class="mx-auto mt-[clamp(5.6rem,8vw,7.2rem)] w-full max-w-[62rem] px-4 pb-16 max-md:mt-[max(calc(var(--site-nav-height)+1.1rem),4.8rem)] max-md:px-[0.9rem]"
  >
    <header class="mb-[1.45rem] grid gap-6 max-md:mb-4 max-md:gap-5">
      <h1
        class="hero-title m-0 font-['Fraunces'] text-[clamp(2.8rem,2.3rem+2vw,4.75rem)] leading-[0.9] tracking-[-0.02em] text-[var(--text-primary)]"
      >
        {heading}
      </h1>
      <BlogFilterPills context="changelog" activePill="product" />
    </header>

    <main class="min-h-[60vh]">
      {
        entries.length === 0 ? (
          <section class="rounded-[10px] border border-[var(--border-color)] bg-[var(--bg-2)] p-4">
            <p class="m-0 text-[var(--text-secondary)]">
              No changelog entries yet.
            </p>
          </section>
        ) : (
          <ul class="m-0 flex list-none flex-col p-0">
            {entries.map((entry, index) => (
              <li>
                <BlogTimelineRow
                  item={entry}
                  showConnector={index < entries.length - 1}
                />
              </li>
            ))}
          </ul>
        )
      }
    </main>
  </div>
</Layout>
