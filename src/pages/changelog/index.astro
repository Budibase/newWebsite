---
import { getCollection } from "astro:content";
import { format } from "date-fns";
import Layout from "../../layouts/MainLayout.astro";
import Tag from "@components/Tag.astro";

const pageTitle = "Changelog";
const pageDescription = "What shipped and what changed.";

const entries = (
  await getCollection("changelog", ({ data }) => !data.draft)
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function getEntryHref(id: string): string {
  return `/changelog/${id}/`;
}

function getTagClass(tag: string): string {
  switch (tag) {
    case "Added":
      return "changelog-tag--added";
    case "Changed":
      return "changelog-tag--changed";
    case "Deprecated":
      return "changelog-tag--deprecated";
    case "Removed":
      return "changelog-tag--removed";
    case "Fixed":
      return "changelog-tag--fixed";
    case "Security":
      return "changelog-tag--security";
    default:
      return "changelog-tag--default";
  }
}

function getTransitionKey(id: string): string {
  return id.replaceAll("/", "-");
}
---

<Layout title={pageTitle} description={pageDescription} enableTransitions>
  <div class="learn-page-shell">
    <div class="side-rail-main-inner">
      <section class="side-rail-page-header max-w-3xl">
        <h1 class="mb-2 text-5xl!">{pageTitle}</h1>
      </section>

      <main class="changelog-main">
        {
          entries.length === 0 ? (
            <section class="changelog-empty rounded-2xl p-6 md:p-8">
              <p class="text-sm md:text-base text-secondary m-0">
                No changelog entries yet.
              </p>
            </section>
          ) : (
            <section
              class="changelog-table-wrap"
              aria-labelledby="changelog-table-title"
            >
              <h2 id="changelog-table-title" class="sr-only">
                Changelog entries
              </h2>
              <div
                class="changelog-table-scroll"
                role="region"
                aria-label="Changelog table"
              >
                <table class="changelog-table" data-changelog-table>
                  <colgroup>
                    <col class="changelog-col-date" />
                    <col class="changelog-col-title" />
                    <col class="changelog-col-version" />
                    <col class="changelog-col-tags" />
                  </colgroup>
                  <thead>
                    <tr>
                      <th scope="col" aria-sort="descending">
                        <button
                          type="button"
                          class="changelog-sort-btn"
                          data-sort-key="date"
                        >
                          Date
                        </button>
                      </th>
                      <th scope="col" aria-sort="none">
                        <button
                          type="button"
                          class="changelog-sort-btn"
                          data-sort-key="title"
                        >
                          Title
                        </button>
                      </th>
                      <th scope="col" aria-sort="none">
                        <button
                          type="button"
                          class="changelog-sort-btn"
                          data-sort-key="version"
                        >
                          Version
                        </button>
                      </th>
                      <th scope="col">Tags</th>
                    </tr>
                  </thead>
                  <tbody>
                    {entries.map((entry) => {
                      const href = getEntryHref(entry.id);
                      const transitionKey = getTransitionKey(entry.id);
                      return (
                        <tr
                          tabindex="0"
                          role="link"
                          data-changelog-row
                          data-href={href}
                          data-date-ms={String(entry.data.date.getTime())}
                          data-title={entry.data.title.toLocaleLowerCase()}
                          data-version={entry.data.version.toLocaleLowerCase()}
                          aria-label={`Open ${entry.data.title}`}
                        >
                          <td>
                            <time
                              class="changelog-date"
                              datetime={entry.data.date.toISOString()}
                            >
                              {format(entry.data.date, "MMM d, yyyy")}
                            </time>
                          </td>
                          <td>
                            <a
                              href={href}
                              data-astro-prefetch
                              class="changelog-title-link"
                              transition:name={`${transitionKey}-title`}
                            >
                              {entry.data.title}
                            </a>
                          </td>
                          <td>
                            <span class="changelog-version">
                              {entry.data.version}
                            </span>
                          </td>
                          <td>
                            <div class="changelog-tags" aria-label="Tags">
                              {entry.data.tags.map((tag) => (
                                <Tag
                                  label={tag}
                                  variant="secondary"
                                  size="small"
                                  class={`changelog-tag ${getTagClass(tag)}`}
                                />
                              ))}
                            </div>
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </section>
          )
        }
      </main>
    </div>
  </div>

  <script is:inline>
    (() => {
      const interactiveSelector =
        "a, button, input, select, textarea, summary, [role='button']";

      const init = () => {
        const rows = document.querySelectorAll("[data-changelog-row]");
        rows.forEach((row) => {
          if (row.getAttribute("data-row-bound") === "true") return;
          row.setAttribute("data-row-bound", "true");

          const href = row.getAttribute("data-href");
          if (!href) return;

          row.addEventListener("click", (event) => {
            const target = event.target;
            if (
              target instanceof Element &&
              target.closest(interactiveSelector)
            ) {
              return;
            }
            window.location.assign(href);
          });

          row.addEventListener("keydown", (event) => {
            if (event.key !== "Enter") return;
            event.preventDefault();
            window.location.assign(href);
          });
        });

        const table = document.querySelector("[data-changelog-table]");
        if (!(table instanceof HTMLTableElement)) return;

        if (table.getAttribute("data-sort-bound") !== "true") {
          table.setAttribute("data-sort-bound", "true");

          const headers = Array.from(table.querySelectorAll("[data-sort-key]"));
          const body = table.tBodies[0];
          if (!body || headers.length === 0) return;

          let activeKey = "date";
          let activeDirection = "desc";

          const updateAriaSort = () => {
            headers.forEach((header) => {
              if (!(header instanceof HTMLButtonElement)) return;
              const parent = header.closest("th");
              if (!parent) return;
              const key = header.dataset.sortKey;
              if (key !== activeKey) {
                parent.setAttribute("aria-sort", "none");
                return;
              }
              parent.setAttribute(
                "aria-sort",
                activeDirection === "asc" ? "ascending" : "descending",
              );
            });
          };

          const sortRows = (key, direction) => {
            const rowsToSort = Array.from(body.querySelectorAll("tr"));
            rowsToSort.sort((a, b) => {
              if (
                !(a instanceof HTMLTableRowElement) ||
                !(b instanceof HTMLTableRowElement)
              ) {
                return 0;
              }

              if (key === "date") {
                const aValue = Number(a.dataset.dateMs || "0");
                const bValue = Number(b.dataset.dateMs || "0");
                return direction === "asc" ? aValue - bValue : bValue - aValue;
              }

              if (key === "version") {
                const aValue = a.dataset.version || "";
                const bValue = b.dataset.version || "";
                return direction === "asc"
                  ? aValue.localeCompare(bValue, undefined, { numeric: true })
                  : bValue.localeCompare(aValue, undefined, { numeric: true });
              }

              const aValue = a.dataset.title || "";
              const bValue = b.dataset.title || "";
              return direction === "asc"
                ? aValue.localeCompare(bValue, undefined, { numeric: true })
                : bValue.localeCompare(aValue, undefined, { numeric: true });
            });

            rowsToSort.forEach((row) => body.append(row));
          };

          headers.forEach((header) => {
            if (!(header instanceof HTMLButtonElement)) return;
            header.addEventListener("click", () => {
              const key = header.dataset.sortKey;
              if (!key) return;

              if (key === activeKey) {
                activeDirection = activeDirection === "asc" ? "desc" : "asc";
              } else {
                activeKey = key;
                activeDirection = key === "date" ? "desc" : "asc";
              }

              sortRows(activeKey, activeDirection);
              updateAriaSort();
            });
          });

          sortRows(activeKey, activeDirection);
          updateAriaSort();
        }
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init, { once: true });
      } else {
        init();
      }

      document.addEventListener("astro:after-swap", init);
    })();
  </script>
</Layout>

<style>
  :global(::view-transition-group(*)),
  :global(::view-transition-old(*)),
  :global(::view-transition-new(*)) {
    animation-duration: 120ms;
  }

  .learn-page-shell {
    width: 100%;
  }

  .changelog-main {
    flex: 1;
    min-width: 0;
    min-height: 60vh;
  }

  .changelog-empty {
    border: 0.5px solid var(--border-color);
    background: var(--bg-2);
  }

  .changelog-table-wrap {
    border-radius: 6px;
    background: var(--bg-2);
    border: 0;
    overflow: hidden;
  }

  .changelog-table-scroll {
    width: 100%;
    overflow-x: auto;
  }

  .changelog-table {
    width: 100%;
    min-width: 46rem;
    border-collapse: collapse;
    border: 0;
    table-layout: fixed;
  }

  .changelog-table th,
  .changelog-table td {
    border: 0;
    padding: 0.85rem 1rem;
    text-align: left;
    vertical-align: top;
  }

  .changelog-table th {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    background: color-mix(in srgb, var(--bg-3) 70%, transparent);
    font-size: 13px;
    color: var(--text-secondary);
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
  }

  .changelog-sort-btn {
    border: 0;
    background: transparent;
    padding: 0;
    margin: 0;
    font-size: 13px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--text-secondary);
    font-weight: 500;
    cursor: pointer;
  }

  .changelog-sort-btn:hover,
  .changelog-sort-btn:focus-visible {
    color: var(--text-primary);
  }

  .changelog-table tbody td {
    font-size: 14px;
    color: var(--text-primary);
  }

  .changelog-table tbody tr {
    cursor: pointer;
    outline: none;
    transition: background-color 120ms ease;
  }

  .changelog-table tbody tr:hover {
    background: var(--bg-3);
  }

  .changelog-table tbody tr:focus-visible {
    background: var(--bg-3);
    box-shadow: inset 0 0 0 1px rgb(var(--accent-blue) / 0.45);
  }

  .changelog-col-date {
    width: 8.5rem;
  }

  .changelog-col-title {
    width: 50%;
  }

  .changelog-col-version {
    width: 6rem;
  }

  .changelog-col-tags {
    width: 17rem;
  }

  .changelog-table td:first-child {
    color: var(--text-secondary);
  }

  .changelog-title-link {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 400;
    font-size: 14px;
    display: inline-block;
  }

  .changelog-title-link:hover,
  .changelog-title-link:focus-visible {
    color: rgb(var(--primary));
  }

  .changelog-version {
    font-size: 14px;
    color: var(--text-secondary);
    white-space: normal;
    line-height: inherit;
  }

  .changelog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  :global(.changelog-tag) {
    font-size: 13px !important;
    line-height: 1.2;
    border: 0 !important;
  }

  .changelog-date {
    color: var(--text-secondary);
  }

  :global(.changelog-tag.changelog-tag--added) {
    background: color-mix(
      in srgb,
      var(--accent-green) 16%,
      var(--bg-3)
    ) !important;
    color: var(--accent-green) !important;
  }

  :global(.changelog-tag.changelog-tag--changed) {
    background: color-mix(
      in srgb,
      var(--accent-blue) 16%,
      var(--bg-3)
    ) !important;
    color: var(--accent-blue) !important;
  }

  :global(.changelog-tag.changelog-tag--deprecated) {
    background: color-mix(
      in srgb,
      var(--accent-orange) 16%,
      var(--bg-3)
    ) !important;
    color: var(--accent-orange) !important;
  }

  :global(.changelog-tag.changelog-tag--removed) {
    background: color-mix(
      in srgb,
      var(--accent-red) 16%,
      var(--bg-3)
    ) !important;
    color: var(--accent-red) !important;
  }

  :global(.changelog-tag.changelog-tag--fixed) {
    background: color-mix(
      in srgb,
      var(--accent-purple) 16%,
      var(--bg-3)
    ) !important;
    color: var(--accent-purple) !important;
  }

  :global(.changelog-tag.changelog-tag--security) {
    background: color-mix(
      in srgb,
      var(--accent-grey) 20%,
      var(--bg-3)
    ) !important;
    color: var(--text-primary) !important;
  }

  :global(.changelog-tag.changelog-tag--default) {
    background: var(--bg-3) !important;
    color: var(--text-secondary) !important;
  }

  @media (max-width: 768px) {
    .changelog-table th,
    .changelog-table td {
      padding: 0.7rem 0.8rem;
    }
  }
</style>
