---
import Layout from "../../layouts/MainLayout.astro";
import Icon from "@components/Icon.astro";
import { getCollection, render } from "astro:content";
import { docsNavData } from "./_docsNav";

export const prerender = true;

function normalizePath(path: string): string {
  if (path.length > 1 && path.endsWith("/")) {
    return path.slice(0, -1);
  }
  return path;
}

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs
    .map((entry) => {
      const slugParts = entry.id
        .split("/")
        .filter(Boolean)
        .map((part) => part.replace(/\.(md|mdx)$/i, ""))
        .filter((part, index, parts) => !(index === parts.length - 1 && part === "index"));
      if (slugParts.length === 0) return null;
      return {
        params: { slug: slugParts.join("/") },
        props: { entry },
      };
    })
    .filter(Boolean);
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const currentPath = normalizePath(Astro.url.pathname);
const pageDescription = entry.data.description ?? "Budibase documentation.";
const outlineHeadings = headings.filter((heading) => heading.depth === 2);

function isActive(path?: string): boolean {
  if (!path || path === "#") return false;
  return normalizePath(path) === currentPath;
}

function isGroupActive(
  path?: string,
  children?: Array<{ href?: string; children?: Array<{ href?: string }> }>,
): boolean {
  if (isActive(path)) return true;
  if (!children) return false;
  return children.some((child) => isGroupActive(child.href, child.children));
}
---

<Layout title={`${entry.data.title} | Budibase Docs`} description={pageDescription}>
  <div class="side-rail-shell">
    <aside class="side-rail-left chrome-border" aria-label="Docs navigation">
      <div class="side-rail-left-scroll docs-side-rail-scroll">
        <div class="px-3 mb-3 text-sm text-secondary">Docs</div>
        <nav aria-label="Data docs navigation">
          <ul class="docs-nav-root flex flex-col gap-8" data-docs-nav-root>
            {
              docsNavData.map((group) => (
                <li>
                  <div class="docs-nav-group text-sm !text-secondary tracking-wider px-3 py-1">
                    {group.title}
                  </div>
                  <ul class="docs-nav-items">
                    {group.items.map((item) => (
                      <li>
                        {
                          (() => {
                            const children = item.children ?? [];
                            const hasChildren = children.length > 0;
                            const renderAsButton = Boolean(item.toggleOnly && hasChildren);
                            const groupOpen = item.startCollapsed
                              ? false
                              : isGroupActive(item.href, item.children);
                          return (
                              <>
                        {
                          renderAsButton ? (
                            <button
                              type="button"
                              aria-expanded={groupOpen ? "true" : "false"}
                              data-docs-folder-toggle="true"
                              class:list={[
                                "docs-nav-link docs-nav-link-folder w-full border-0 bg-transparent text-sm text-primary dark:text-primary hover:text-primary dark:hover:text-primary [&.active]:text-sky-700 dark:[&.active]:text-sky-200 [&.active:hover]:text-sky-600 dark:[&.active:hover]:text-sky-100 text-left cursor-pointer",
                                isActive(item.href) && "active",
                              ]}
                            >
                              <span>{item.label}</span>
                              <span
                                class:list={[
                                  "inline-flex transition-transform duration-150",
                                  groupOpen && "rotate-90",
                                ]}
                                data-docs-caret
                              >
                                <Icon
                                  name="CaretRight"
                                  class="w-2.5 h-2.5 text-secondary"
                                />
                              </span>
                            </button>
                          ) : (
                            <a
                              href={item.href ?? "#"}
                              aria-current={isActive(item.href) ? "page" : undefined}
                              aria-expanded={hasChildren ? (groupOpen ? "true" : "false") : undefined}
                              data-docs-folder-toggle={hasChildren ? "true" : undefined}
                              class:list={[
                                "docs-nav-link docs-nav-link-folder text-sm text-primary dark:text-primary hover:text-primary dark:hover:text-primary [&.active]:text-sky-700 dark:[&.active]:text-sky-200 [&.active:hover]:text-sky-600 dark:[&.active:hover]:text-sky-100 [&.active]:bg-stone-200 dark:[&.active]:bg-stone-800",
                                isActive(item.href) && "active",
                              ]}
                            >
                              <span>{item.label}</span>
                              {
                                hasChildren && (
                                  <span
                                    class:list={[
                                      "inline-flex transition-transform duration-150",
                                      groupOpen && "rotate-90",
                                    ]}
                                    data-docs-caret
                                  >
                                    <Icon
                                      name="CaretRight"
                                      class="w-2.5 h-2.5 text-secondary"
                                    />
                                  </span>
                                )
                              }
                            </a>
                          )
                        }
                        {
                          hasChildren && (
                            <ul
                              class:list={[
                                "docs-nav-children",
                                groupOpen && "open",
                              ]}
                              data-docs-folder-panel
                            >
                              {children.map((child) => (
                                <li>
                                  <a
                                    href={child.href ?? "#"}
                                    aria-current={isActive(child.href) ? "page" : undefined}
                                    class:list={[
                                      "docs-nav-link docs-nav-link-child text-sm text-primary dark:text-primary hover:text-primary dark:hover:text-primary [&.active]:text-sky-700 dark:[&.active]:text-sky-200 [&.active:hover]:text-sky-600 dark:[&.active:hover]:text-sky-100 [&.active]:bg-stone-200 dark:[&.active]:bg-stone-800",
                                      isActive(child.href) && "active",
                                    ]}
                                  >
                                    {child.label}
                                  </a>
                                </li>
                              ))}
                            </ul>
                          )
                        }
                              </>
                            );
                          })()
                        }
                      </li>
                    ))}
                  </ul>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </aside>

    <div class="side-rail-main">
      <div class="side-rail-main-inner">
        <div class="xl:grid xl:grid-cols-[minmax(0,1fr)_16rem] xl:gap-10 xl:items-start">
          <article
            class="docs-article flex-1 min-w-0 space-y-8 px-4 sm:px-6 lg:px-8 pt-8 pb-8 max-w-3xl [&_h1]:!mt-0"
            data-docs-article
          >
            <Content />
          </article>
          {
            outlineHeadings.length > 0 && (
              <aside
                class="hidden xl:block pt-8 xl:sticky xl:self-start docs-side-rail-scroll"
                style="top: calc(var(--site-nav-height) + 1rem); max-height: calc(100dvh - var(--site-nav-height) - 1rem); overflow-y: auto;"
                aria-label="On this page"
                data-docs-outline-root
              >
                <div>
                  <div class="text-sm !text-primary font-medium px-1 pb-2">
                    On this page
                  </div>
                  <nav aria-label="On this page outline">
                    <ul class="flex flex-col gap-1">
                      {outlineHeadings.map((heading) => (
                        <li>
                          <a
                            href={`#${heading.slug}`}
                            class="block py-1 px-1 text-sm !text-secondary hover:!text-primary transition-colors"
                            data-docs-outline-link
                            data-docs-outline-id={heading.slug}
                          >
                            {heading.text}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </nav>
                </div>
              </aside>
            )
          }
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .docs-nav-root,
  .docs-nav-items,
  .docs-nav-children {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .docs-nav-group {
    margin: 0;
  }

  .docs-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 28px;
    border-radius: 0.375rem;
    padding: 0.25rem 0.75rem;
    text-decoration: none;
  }

  .docs-nav-link-folder {
    padding-right: 0.5rem;
  }

  .docs-nav-link:hover {
    background: var(--bg-3);
  }

  .docs-nav-children {
    margin-top: 0.15rem;
    margin-left: 0.75rem;
    padding-left: 0.35rem;
    border-left: 0.5px solid var(--border-color);
    display: none;
  }

  .docs-nav-children.open {
    display: block;
  }

  .docs-nav-link-child {
    min-height: 28px;
    font-size: 13px;
  }

  .docs-side-rail-scroll {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .docs-side-rail-scroll::-webkit-scrollbar {
    display: none;
  }

  .docs-article :where(h1) {
    margin-top: 0;
  }

  .docs-article :where(h2, h3, h4) {
    scroll-margin-top: calc(var(--site-nav-height) + 24px);
  }
</style>

<script is:inline>
  (() => {
    const initFolderNav = () => {
      const root = document.querySelector("[data-docs-nav-root]");
      if (!root) return;

      if (root._docsFolderCleanup) {
        root._docsFolderCleanup();
      }

      const toggles = Array.from(
        root.querySelectorAll('[data-docs-folder-toggle="true"]'),
      );

      const cleanups = [];

      toggles.forEach((toggle) => {
        const listItem = toggle.closest("li");
        const panel = listItem?.querySelector("[data-docs-folder-panel]");
        const caret = toggle.querySelector("[data-docs-caret]");
        if (!panel) return;

        const setOpen = (open) => {
          panel.classList.toggle("open", open);
          toggle.setAttribute("aria-expanded", String(open));
          if (caret) caret.classList.toggle("rotate-90", open);
        };

        const initialOpen = toggle.getAttribute("aria-expanded") === "true";
        setOpen(initialOpen);

        const onClick = (event) => {
          if (
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey ||
            event.button === 1
          ) {
            return;
          }
          event.preventDefault();
          const isOpen = toggle.getAttribute("aria-expanded") === "true";
          setOpen(!isOpen);
        };

        toggle.addEventListener("click", onClick);
        cleanups.push(() => toggle.removeEventListener("click", onClick));
      });

      root._docsFolderCleanup = () => {
        cleanups.forEach((cleanup) => cleanup());
      };
    };

    const initOutline = () => {
      const root = document.querySelector("[data-docs-outline-root]");
      if (!root) return;

      if (root._docsOutlineCleanup) {
        root._docsOutlineCleanup();
      }

      const links = Array.from(
        root.querySelectorAll("[data-docs-outline-link]"),
      );
      if (links.length === 0) return;

      const sectionIds = links
        .map((link) => link.getAttribute("data-docs-outline-id"))
        .filter(Boolean);
      const sections = sectionIds
        .map((id) => document.getElementById(id))
        .filter(Boolean);
      if (sections.length === 0) return;

      const setActive = (id) => {
        links.forEach((link) => {
          const linkId = link.getAttribute("data-docs-outline-id");
          const isActive = linkId === id;
          link.classList.toggle("!text-primary", isActive);
          link.classList.toggle("!text-secondary", !isActive);
          if (isActive) {
            link.setAttribute("aria-current", "location");
          } else {
            link.removeAttribute("aria-current");
          }
        });
      };

      const onHashChange = () => {
        const hash = decodeURIComponent(window.location.hash.replace("#", ""));
        if (hash && sectionIds.includes(hash)) {
          setActive(hash);
        }
      };

      const onClick = (event) => {
        const target =
          event.target && event.target.closest
            ? event.target.closest("[data-docs-outline-link]")
            : null;
        if (!target || !root.contains(target)) return;
        const id = target.getAttribute("data-docs-outline-id");
        if (id) {
          setActive(id);
        }
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort(
              (a, b) => a.boundingClientRect.top - b.boundingClientRect.top,
            );
          if (visible.length > 0) {
            setActive(visible[0].target.id);
          }
        },
        {
          rootMargin: "0px 0px -70% 0px",
          threshold: 0.2,
        },
      );

      sections.forEach((section) => observer.observe(section));

      const initialHash = decodeURIComponent(window.location.hash.replace("#", ""));
      if (initialHash && sectionIds.includes(initialHash)) {
        setActive(initialHash);
      } else {
        setActive(sections[0].id);
      }

      root.addEventListener("click", onClick);
      window.addEventListener("hashchange", onHashChange);

      root._docsOutlineCleanup = () => {
        observer.disconnect();
        root.removeEventListener("click", onClick);
        window.removeEventListener("hashchange", onHashChange);
      };
    };

    const init = () => {
      initFolderNav();
      initOutline();
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
      init();
    }

    document.addEventListener("astro:after-swap", init);
  })();
</script>
