---
import "../styles/global.css";
import "../styles/fonts.css";
import Nav from "@components/Nav.astro";
import Head from "@components/Head.astro";
import Footer from "@components/Footer.astro";
import { ClientRouter } from "astro:transitions";

const { enableTransitions = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head />
    {enableTransitions && <ClientRouter />}
  </head>

  <body>
    <div>
      <main>
        <div id="hero" class="opacity: 1; transform: none;">
          <div class="text-base">
            <div class="relative flex flex-col min-h-screen h-lvh!">
              <Nav />
              <slot />
              <Footer />
            </div>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

</style>
