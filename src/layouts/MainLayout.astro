---
import "../styles/global.css";
import "../styles/fonts.css";
import Nav from "@components/Nav.astro";
import Head from "@components/Head.astro";
import Footer from "@components/Footer.astro";
import { ClientRouter } from "astro:transitions";

const { enableTransitions = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head {...Astro.props} />
    {enableTransitions && <ClientRouter />}
  </head>

  <body>
    <div>
      <main>
        <div id="hero" class="opacity: 1; transform: none;">
          <div class="text-base">
            <div class="relative flex flex-col min-h-screen">
              <Nav />
              <slot />
              <Footer />
            </div>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>

<script is:inline>
  (() => {
    const root = document.documentElement;

    const setNavHeight = () => {
      const nav = document.getElementById("site-nav");
      if (!nav) return;
      const { height } = nav.getBoundingClientRect();
      root.style.setProperty("--site-nav-height", `${Math.round(height)}px`);
    };

    const onReady = () => {
      setNavHeight();
      if (!window.__siteNavHeightListenerBound) {
        window.addEventListener("resize", setNavHeight, { passive: true });
        window.__siteNavHeightListenerBound = true;
      }
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", onReady, { once: true });
    } else {
      onReady();
    }

    document.addEventListener("astro:after-swap", () => {
      requestAnimationFrame(setNavHeight);
    });
  })();
</script>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

</style>
