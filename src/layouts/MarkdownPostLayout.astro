---
import Layout from './MainLayout.astro';
import { format } from 'date-fns';
import { resolveImageReference } from "../lib/imageReference";

const { frontmatter, enableTransitions = false, transitionKey = '' } = Astro.props;
const publishDate = frontmatter.publishDate instanceof Date
  ? frontmatter.publishDate
  : undefined;
const publishDateIso = publishDate?.toISOString();
const seoImageSrc =
  resolveImageReference(frontmatter.socialImage) ??
  resolveImageReference(frontmatter.coverImage);
const seoImage = seoImageSrc
  ? {
      src: seoImageSrc,
      alt: frontmatter.title,
    }
  : undefined;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: frontmatter.title,
  url: canonicalUrl,
  license: "This work is licensed and owned by Budibase",
  description: frontmatter.description,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
  publisher: {
    "@type": "Organization",
    name: "Budibase",
    url: "https://budibase.com/",
    sameAs: [
      "https://www.wikidata.org/wiki/Q131328403",
      "https://x.com/budibase",
      "https://www.linkedin.com/company/budibase/",
      "https://github.com/budibase/budibase",
    ],
  },
  author: {
    "@type": "Person",
    name: frontmatter.author,
  },
};

if (publishDateIso) {
  blogSchema.datePublished = publishDateIso;
  blogSchema.dateModified = publishDateIso;
}

---

<Layout
  title={frontmatter.title}
  description={frontmatter.description}
  image={seoImage}
  pageType="article"
  enableTransitions={enableTransitions}
  schema={blogSchema}
>
  <div class="max-w-2xl mx-auto w-full px-5 md:px-0">
    <h1 class="mb-4 mt-24" transition:name={`${transitionKey}-title`}>
      {frontmatter.title}
    </h1>
    <div class="post-meta" transition:name={`${transitionKey}-meta`}>
      {publishDate && (
        <time datetime={publishDateIso}>
          {format(publishDate, 'MMM d, yyyy')}
        </time>
      )}
      {frontmatter.author && (
        <span>
          {publishDate ? 'by ' : 'By '}
          {frontmatter.author}
        </span>
      )}
    </div>
  </div>
  <div class="max-w-2xl mx-auto w-full px-5 md:px-0">
    <slot />
  </div>
</Layout>
